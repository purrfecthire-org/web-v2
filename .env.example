# Purrfect Hire V2 — environment variables (copy to .env; never commit .env)
# All PUBLIC_* vars are exposed to the client bundle at build time.

# Base URL of the ATS backend logging API. When set, Layout.astro's client-side
# error reporter POSTs uncaught errors to {PUBLIC_LOG_ENDPOINT}/logs/client.
# Leave unset/empty (the default) to disable the reporter entirely — the site
# then makes zero network calls. The backend is not publicly deployed yet.
# PUBLIC_LOG_ENDPOINT=https://api.purrfecthire.com

# Base URL of the ATS backend API (e.g. https://api.purrfecthire.com, or
# http://localhost:8000 in dev). When set, it drives:
#   • the Offer Acceleration apply form → POST {}/public/oa/applications
#   • the /roles list + /roles/<slug> detail pages, fetched at build time
#     (GET {}/public/roles, GET {}/public/roles/{slug}) and refreshed
#     client-side, plus the apply form → POST {}/public/roles/{slug}/applications
# When the build-time fetch fails (backend unreachable in CI) the roles list
# renders an empty state instead of failing the build.
# Leave unset/empty (the default) to keep the site fully client-side — the OA
# form uses its fallback branch and the roles list shows its empty state.
# PUBLIC_API_ENDPOINT=https://api.purrfecthire.com
