---
// ── LegalLayout ─────────────────────────────────────────────────────────────
// Shared shell for long-form legal documents (privacy policy, future terms).
// Self-contained header (logo → home + language toggle) instead of V6Nav,
// which depends on a hero-scroll observer that legal pages don't have.
// Renders an <article> reading column on the warm-cream canvas and reuses the
// shared Footer. Body copy is passed in via the default <slot />.
import Layout from './Layout.astro';
import Footer from '../components/Footer.astro';
import { getContent } from '../content/index';
import { getRelativeLocaleUrl } from 'astro:i18n';

interface Props {
  title: string;
  description: string;
  lang: 'en' | 'es';
  pageUrl: string;
  /** Human-readable heading shown at the top of the document */
  heading: string;
  /** e.g. "June 15, 2026" — rendered under the heading */
  lastUpdated: string;
  /** Localized "Last updated" label */
  lastUpdatedLabel: string;
}

const { title, description, lang, pageUrl, heading, lastUpdated, lastUpdatedLabel } = Astro.props;

const c = getContent(lang);
const otherLang = lang === 'en' ? 'es' : 'en';
const homeHref = getRelativeLocaleUrl(lang, '/');
// The localized counterpart of this very page (e.g. /privacy-policy ↔ /es/privacy-policy)
const otherLangHref = getRelativeLocaleUrl(otherLang, '/privacy-policy');
---

<Layout title={title} description={description} lang={lang} canonicalUrl={pageUrl}>
  <header class="legal-nav">
    <div class="legal-nav__inner">
      <a href={homeHref} aria-label="Purrfect Hire home">
        <img src="/logos/logo-desktop.png" class="legal-nav__logo" alt="Purrfect Hire" />
      </a>
      <div class="legal-nav__lang">
        {lang === 'en' ? (
          <>
            <span class="legal-nav__lang-active">EN</span>
            <span class="legal-nav__lang-div">|</span>
            <a href={otherLangHref} class="legal-nav__lang-link">ES</a>
          </>
        ) : (
          <>
            <a href={otherLangHref} class="legal-nav__lang-link">EN</a>
            <span class="legal-nav__lang-div">|</span>
            <span class="legal-nav__lang-active">ES</span>
          </>
        )}
      </div>
    </div>
  </header>

  <main class="legal">
    <article class="legal__doc">
      <h1 class="legal__title">{heading}</h1>
      <p class="legal__updated">{lastUpdatedLabel}: {lastUpdated}</p>
      <slot />
    </article>
  </main>

  <Footer content={c.footer} />
</Layout>

<style lang="scss">
  .legal-nav {
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);

    &__inner {
      max-width: 80rem;
      margin-inline: auto;
      padding: 1.25rem 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    &__logo { width: 8rem; }

    &__lang {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.875rem;
    }

    &__lang-active { color: var(--color-text); font-weight: 500; }
    &__lang-div { color: var(--color-border); }
    &__lang-link {
      color: var(--color-muted);
      text-decoration: none;
      transition: color 0.15s ease;
      &:hover { color: var(--color-text); }
    }
  }

  .legal {
    background: var(--color-bg);
    padding-block: 4rem 6rem;
  }

  .legal__doc {
    max-width: 44rem;
    margin-inline: auto;
    padding-inline: 2rem;
    color: var(--color-text);
  }

  .legal__title {
    font-size: clamp(2rem, 5vw, 2.75rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0 0 0.75rem;
  }

  .legal__updated {
    font-size: 0.9375rem;
    color: var(--color-tertiary);
    margin: 0 0 3rem;
  }

  // Styling for the slotted document body (global so it reaches <slot /> content)
  :global(.legal__doc h2) {
    font-size: 1.375rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    margin: 2.75rem 0 0.75rem;
    line-height: 1.25;
  }

  :global(.legal__doc h3) {
    font-size: 1.0625rem;
    font-weight: 600;
    margin: 1.75rem 0 0.5rem;
  }

  :global(.legal__doc p),
  :global(.legal__doc li) {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-muted);
  }

  :global(.legal__doc p) { margin: 0 0 1rem; }

  :global(.legal__doc ul) {
    margin: 0 0 1.25rem;
    padding-left: 1.25rem;
    list-style: disc;
  }

  :global(.legal__doc li) { margin-bottom: 0.4rem; }

  :global(.legal__doc a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  :global(.legal__doc strong) { color: var(--color-text); font-weight: 600; }

  :global(.legal__doc .legal-intro) {
    font-size: 1.0625rem;
    color: var(--color-text);
  }

  @media (max-width: 640px) {
    .legal { padding-block: 2.5rem 4rem; }
    .legal__doc { padding-inline: 1.25rem; }
    .legal-nav__inner { padding-inline: 1.25rem; }
  }
</style>
