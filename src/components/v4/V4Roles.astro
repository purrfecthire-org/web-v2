---
import type { LandingContent } from '../../content/index';

interface Props {
  content: LandingContent['roles'];
}

const { content } = Astro.props;
---

<section id="roles" class="v4-roles">
  <div class="v4-roles__container">

    <div class="v4-roles__header">
      <span class="v4-roles__eyebrow">{content.eyebrow}</span>
      <h2 class="v4-roles__headline">{content.headline}</h2>
      <p class="v4-roles__subheadline">{content.subheadline}</p>
      <p class="v4-roles__context">{content.contextLine}</p>
    </div>

    <div class="v4-roles__grid">
      {content.cards.map((card, i) => (
        <div class={`v4-roles__card v4-roles__card--${i}`}>
          <!-- Top accent line -->
          <div class="v4-roles__card-accent" aria-hidden="true"></div>

          <div class="v4-roles__card-tag">{card.tag}</div>
          <h3 class="v4-roles__card-title">{card.title}</h3>
          <p class="v4-roles__card-stage">{card.stage}</p>

          <div class="v4-roles__card-divider" aria-hidden="true"></div>

          <div class="v4-roles__card-comp">{card.comp}</div>

          <div class="v4-roles__stack">
            {card.stack.map((tech) => (
              <span class="v4-roles__stack-pill">{tech}</span>
            ))}
          </div>

          <a href="#cta" class="v4-roles__card-cta">
            {card.cta}
          </a>
        </div>
      ))}
    </div>

    <div class="v4-roles__footer">
      <p class="v4-roles__footer-text">{content.closingText}</p>
      <a href={`mailto:${content.closingEmail}`} class="v4-roles__footer-email">
        {content.closingEmail}
      </a>
    </div>

  </div>
</section>

<style lang="scss">
  @use '../../styles/breakpoints' as *;

  .v4-roles {
    position: relative;
    z-index: 1;
    padding: 6rem 2rem;

    @include max-sm {
      padding: 4rem 1.25rem;
    }

    &__container {
      max-width: 72rem;
      margin-inline: auto;
    }

    &__header {
      text-align: center;
      margin-bottom: 3.5rem;
    }

    &__eyebrow {
      display: inline-block;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      background: linear-gradient(135deg, #3C2BDC 0%, #7C3AED 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 1rem;
    }

    &__headline {
      font-family: 'Plus Jakarta Sans', Inter, sans-serif;
      font-size: clamp(1.75rem, 3.5vw, 2.5rem);
      font-weight: 700;
      letter-spacing: -0.025em;
      color: #111827;
      margin: 0 0 0.875rem;
      line-height: 1.2;
    }

    &__subheadline {
      font-size: 1.0625rem;
      color: #6B7280;
      margin: 0 0 0.5rem;
    }

    &__context {
      font-size: 13px;
      color: #9CA3AF;
      margin: 0;
      font-style: italic;
    }

    &__grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
      margin-bottom: 3rem;

      @include max-lg {
        grid-template-columns: 1fr;
        max-width: 440px;
        margin-inline: auto;
        margin-bottom: 2.5rem;
      }
    }

    $accent-colors: (#3C2BDC, #7C3AED, #0D0857);

    &__card {
      position: relative;
      display: flex;
      flex-direction: column;
      background: rgba(255, 255, 255, 0.85);
      border: 1.5px solid rgba(229, 231, 235, 0.9);
      border-radius: 20px;
      padding: 32px 28px 28px;
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      overflow: hidden;
      transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;

      &:hover {
        transform: translateY(-5px);
        box-shadow: 0 16px 48px rgba(60, 43, 220, 0.1);
        border-color: rgba(60, 43, 220, 0.25);
      }

      // Hover gradient border effect
      &::after {
        content: '';
        position: absolute;
        inset: 0;
        border-radius: 20px;
        background: linear-gradient(135deg, rgba(60, 43, 220, 0) 0%, rgba(124, 58, 237, 0) 100%);
        opacity: 0;
        transition: opacity 0.25s ease;
        pointer-events: none;
      }

      &:hover::after {
        opacity: 1;
      }
    }

    &__card-accent {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 3px;
      background: linear-gradient(90deg, #3C2BDC 0%, #7C3AED 100%);

      .v4-roles__card--1 & {
        background: linear-gradient(90deg, #7C3AED 0%, #9333EA 100%);
      }

      .v4-roles__card--2 & {
        background: linear-gradient(90deg, #0D0857 0%, #7C3AED 100%);
      }
    }

    &__card-tag {
      font-size: 12px;
      font-weight: 600;
      color: #9CA3AF;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-bottom: 0.875rem;
    }

    &__card-title {
      font-family: 'Plus Jakarta Sans', Inter, sans-serif;
      font-size: 1.375rem;
      font-weight: 700;
      color: #111827;
      margin: 0 0 0.5rem;
      letter-spacing: -0.02em;
    }

    &__card-stage {
      font-size: 0.875rem;
      color: #6B7280;
      margin: 0;
    }

    &__card-divider {
      height: 1px;
      background: rgba(60, 43, 220, 0.08);
      margin: 1.25rem 0;
    }

    &__card-comp {
      font-family: 'Plus Jakarta Sans', Inter, sans-serif;
      font-size: 1rem;
      font-weight: 700;
      color: #111827;
      margin-bottom: 1rem;
    }

    &__stack {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 1.5rem;
    }

    &__stack-pill {
      background: rgba(60, 43, 220, 0.08);
      color: #3C2BDC;
      border: 1px solid rgba(60, 43, 220, 0.15);
      border-radius: 6px;
      padding: 3px 10px;
      font-size: 12px;
      font-weight: 500;
    }

    &__card-cta {
      display: inline-flex;
      align-items: center;
      font-size: 14px;
      font-weight: 600;
      font-family: 'Plus Jakarta Sans', Inter, sans-serif;
      text-decoration: none;
      margin-top: auto;
      background: linear-gradient(135deg, #3C2BDC 0%, #7C3AED 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      transition: opacity 0.15s ease;

      &:hover {
        opacity: 0.7;
      }

      .v4-roles__card--1 & {
        background: linear-gradient(135deg, #7C3AED 0%, #9333EA 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      .v4-roles__card--2 & {
        background: linear-gradient(135deg, #0D0857 0%, #7C3AED 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }
    }

    &__footer {
      text-align: center;
    }

    &__footer-text {
      font-size: 1rem;
      color: #6B7280;
      margin: 0 0 0.5rem;
    }

    &__footer-email {
      font-size: 1rem;
      font-weight: 600;
      font-family: 'Plus Jakarta Sans', Inter, sans-serif;
      background: linear-gradient(135deg, #3C2BDC 0%, #7C3AED 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      text-decoration: none;
      transition: opacity 0.15s;

      &:hover {
        opacity: 0.7;
      }
    }
  }
</style>
