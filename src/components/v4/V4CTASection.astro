---
import type { LandingContent } from '../../content/index';

interface Props {
  content: LandingContent['cta'];
}

const { content } = Astro.props;
---

<section id="cta" class="v4-cta">
  <!-- Floating orbs -->
  <div class="v4-cta__orb v4-cta__orb--1" aria-hidden="true"></div>
  <div class="v4-cta__orb v4-cta__orb--2" aria-hidden="true"></div>
  <div class="v4-cta__orb v4-cta__orb--3" aria-hidden="true"></div>

  <div class="v4-cta__container">
    <div class="v4-cta__content">

      <!-- Eyebrow -->
      <span class="v4-cta__eyebrow">Let's talk</span>

      <h2 class="v4-cta__headline">{content.headline}</h2>
      <p class="v4-cta__subheadline">{content.subheadline}</p>

      <div class="v4-cta__buttons">
        <a href="mailto:hiring@purrfecthire.com?subject=Hiring inquiry" class="v4-cta__btn-primary">
          {content.ctaHire}
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="mailto:hiring@purrfecthire.com?subject=Placement inquiry" class="v4-cta__btn-secondary">
          {content.ctaTalent}
        </a>
      </div>

      <p class="v4-cta__contact">
        or email us directly at
        <a href={`mailto:${content.contactLine}`} class="v4-cta__email">
          {content.contactLine}
        </a>
      </p>

    </div>
  </div>
</section>

<style lang="scss">
  @use '../../styles/breakpoints' as *;

  @keyframes v4-orb-float-1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(30px, -20px) scale(1.05); }
    66% { transform: translate(-20px, 15px) scale(0.97); }
  }

  @keyframes v4-orb-float-2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    40% { transform: translate(-25px, 20px) scale(1.03); }
    70% { transform: translate(15px, -10px) scale(0.98); }
  }

  @keyframes v4-orb-float-3 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    30% { transform: translate(20px, 15px) scale(1.04); }
    60% { transform: translate(-15px, -20px) scale(0.96); }
  }

  .v4-cta {
    position: relative;
    z-index: 1;
    background: linear-gradient(135deg, #0D0857 0%, #0D0857 50%, #0D0857 100%);
    overflow: hidden;
    padding: 7rem 2rem;

    @include max-sm {
      padding: 5rem 1.25rem;
    }

    &__orb {
      position: absolute;
      border-radius: 50%;
      pointer-events: none;
      filter: blur(80px);
      opacity: 0.6;

      &--1 {
        width: 450px;
        height: 450px;
        top: -150px;
        left: -100px;
        background: radial-gradient(circle, rgba(96, 67, 230, 0.4) 0%, transparent 70%);
        animation: v4-orb-float-1 12s ease-in-out infinite;
      }

      &--2 {
        width: 380px;
        height: 380px;
        bottom: -100px;
        right: -80px;
        background: radial-gradient(circle, rgba(124, 58, 237, 0.35) 0%, transparent 70%);
        animation: v4-orb-float-2 15s ease-in-out infinite;
      }

      &--3 {
        width: 300px;
        height: 300px;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        background: radial-gradient(circle, rgba(124, 58, 237, 0.25) 0%, transparent 70%);
        animation: v4-orb-float-3 10s ease-in-out infinite;
      }
    }

    &__container {
      position: relative;
      z-index: 1;
      max-width: 56rem;
      margin-inline: auto;
    }

    &__content {
      text-align: center;
    }

    &__eyebrow {
      display: inline-block;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(159, 143, 255, 0.8);
      margin-bottom: 1.25rem;
    }

    &__headline {
      font-family: 'Plus Jakarta Sans', Inter, sans-serif;
      font-size: clamp(1.75rem, 4vw, 2.75rem);
      font-weight: 800;
      line-height: 1.15;
      letter-spacing: -0.03em;
      color: white;
      margin: 0 0 1rem;
    }

    &__subheadline {
      font-size: 1.0625rem;
      color: rgba(255, 255, 255, 0.6);
      line-height: 1.65;
      max-width: 480px;
      margin: 0 auto 2.5rem;
    }

    &__buttons {
      display: flex;
      gap: 16px;
      justify-content: center;
      flex-wrap: wrap;
      margin-bottom: 1.75rem;

      @include max-sm {
        flex-direction: column;
        align-items: center;
        gap: 12px;
      }
    }

    &__btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: linear-gradient(135deg, #9F8FFF 0%, #A78BFA 100%);
      color: #0D0857;
      border-radius: 999px;
      padding: 15px 30px;
      font-size: 15px;
      font-weight: 700;
      font-family: 'Plus Jakarta Sans', Inter, sans-serif;
      text-decoration: none;
      transition: opacity 0.2s ease, transform 0.15s ease, box-shadow 0.2s ease;
      box-shadow: 0 4px 20px rgba(159, 143, 255, 0.4);

      &:hover {
        opacity: 0.92;
        transform: translateY(-2px);
        box-shadow: 0 8px 32px rgba(159, 143, 255, 0.5);
      }

      svg {
        transition: transform 0.2s ease;
      }

      &:hover svg {
        transform: translateX(3px);
      }
    }

    &__btn-secondary {
      display: inline-flex;
      align-items: center;
      border: 1.5px solid rgba(255, 255, 255, 0.2);
      color: white;
      border-radius: 999px;
      padding: 15px 30px;
      font-size: 15px;
      font-weight: 500;
      font-family: 'Plus Jakarta Sans', Inter, sans-serif;
      text-decoration: none;
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      background: rgba(255, 255, 255, 0.06);
      transition: background 0.2s ease, border-color 0.2s ease, transform 0.15s ease;

      &:hover {
        background: rgba(255, 255, 255, 0.12);
        border-color: rgba(255, 255, 255, 0.35);
        transform: translateY(-2px);
      }
    }

    &__contact {
      font-size: 14px;
      color: rgba(255, 255, 255, 0.4);
      margin: 0;
    }

    &__email {
      color: rgba(159, 143, 255, 0.7);
      text-decoration: none;
      font-weight: 500;
      transition: color 0.15s;

      &:hover {
        color: rgba(159, 143, 255, 1);
      }
    }
  }
</style>
