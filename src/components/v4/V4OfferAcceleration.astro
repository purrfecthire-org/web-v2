---
import type { LandingContent } from '../../content/index';

interface Props {
  content: LandingContent['offerAcceleration'];
}

const { content } = Astro.props;

const blockIcons = [
  // You're the right fit
  `<svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 2a8 8 0 100 16A8 8 0 0010 2zm-1 11.414L5.293 9.707l1.414-1.414L9 10.586l5.293-5.293 1.414 1.414L9 13.414z" fill="currentColor"/></svg>`,
  // 8 sessions
  `<svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 2a8 8 0 100 16A8 8 0 0010 2zm1 8.5l-3 1.5 1-3.5-2.5-2h3l1.5-3 1.5 3h3l-2.5 2 1 3.5-3-1.5z" fill="currentColor"/></svg>`,
  // By the end
  `<svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M3.293 9.293a1 1 0 011.414 0L9 13.586l6.293-6.293a1 1 0 111.414 1.414l-7 7a1 1 0 01-1.414 0l-5-5a1 1 0 010-1.414z" fill="currentColor"/></svg>`,
];

const blockColors = ['indigo', 'teal', 'emerald'];
---

<section class="v4-offer">
  <div class="v4-offer__bg" aria-hidden="true"></div>

  <div class="v4-offer__container">

    <div class="v4-offer__header">
      <span class="v4-offer__eyebrow">{content.eyebrow}</span>
      <h2 class="v4-offer__headline">{content.headline}</h2>
      <p class="v4-offer__subheadline">{content.subheadline}</p>
    </div>

    <div class="v4-offer__blocks">
      {content.blocks.map((block, i) => (
        <div class={`v4-offer__block v4-offer__block--${blockColors[i]}`}>
          <div class="v4-offer__block-header">
            <span class={`v4-offer__block-icon v4-offer__block-icon--${blockColors[i]}`}
              set:html={blockIcons[i]}
            />
            <h3 class="v4-offer__block-title">{block.title}</h3>
          </div>
          <ul class="v4-offer__block-items">
            {block.items.map((item) => (
              <li class="v4-offer__block-item">
                <span class={`v4-offer__check v4-offer__check--${blockColors[i]}`} aria-hidden="true">✓</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="v4-offer__footer">
      <p class="v4-offer__closing">{content.closing}</p>
      <div class="v4-offer__cta-group">
        <a href="#cta" class="v4-offer__cta">{content.cta}</a>
        <span class="v4-offer__cta-sub">{content.ctaSubline}</span>
      </div>
    </div>

  </div>
</section>

<style lang="scss">
  @use '../../styles/breakpoints' as *;

  .v4-offer {
    position: relative;
    z-index: 1;
    padding: 6rem 2rem;
    overflow: hidden;

    @include max-sm {
      padding: 4rem 1.25rem;
    }

    &__bg {
      position: absolute;
      inset: 0;
      background: linear-gradient(180deg, rgba(245, 243, 255, 0.85) 0%, rgba(245, 243, 255, 0.85) 100%);
      pointer-events: none;
    }

    &__container {
      position: relative;
      z-index: 1;
      max-width: 72rem;
      margin-inline: auto;
    }

    &__header {
      text-align: center;
      margin-bottom: 3.5rem;
    }

    &__eyebrow {
      display: inline-block;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      background: linear-gradient(135deg, #3C2BDC 0%, #7C3AED 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 1rem;
    }

    &__headline {
      font-family: 'Plus Jakarta Sans', Inter, sans-serif;
      font-size: clamp(1.75rem, 3.5vw, 2.5rem);
      font-weight: 800;
      letter-spacing: -0.03em;
      color: #111827;
      margin: 0 0 1rem;
      line-height: 1.15;
    }

    &__subheadline {
      font-size: 1.0625rem;
      color: #6B7280;
      max-width: 600px;
      margin: 0 auto;
      line-height: 1.7;
    }

    &__blocks {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
      margin-bottom: 3.5rem;

      @include max-lg {
        grid-template-columns: 1fr;
        max-width: 520px;
        margin-inline: auto;
        margin-bottom: 3rem;
      }
    }

    &__block {
      background: rgba(255, 255, 255, 0.88);
      border-radius: 18px;
      padding: 32px 28px;
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      border: 1px solid rgba(229, 231, 235, 0.8);
      transition: transform 0.2s ease, box-shadow 0.2s ease;

      &:hover {
        transform: translateY(-3px);
      }

      &--indigo:hover {
        box-shadow: 0 8px 32px rgba(60, 43, 220, 0.1);
      }

      &--teal:hover {
        box-shadow: 0 8px 32px rgba(124, 58, 237, 0.1);
      }

      &--emerald:hover {
        box-shadow: 0 8px 32px rgba(13, 8, 87, 0.1);
      }
    }

    &__block-header {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 1.25rem;
    }

    &__block-icon {
      width: 36px;
      height: 36px;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;

      &--indigo {
        background: rgba(60, 43, 220, 0.1);
        color: #3C2BDC;
      }

      &--teal {
        background: rgba(124, 58, 237, 0.1);
        color: #7C3AED;
      }

      &--emerald {
        background: rgba(13, 8, 87, 0.1);
        color: #0D0857;
      }
    }

    &__block-title {
      font-family: 'Plus Jakarta Sans', Inter, sans-serif;
      font-size: 1rem;
      font-weight: 700;
      color: #111827;
      margin: 0;
      line-height: 1.3;
    }

    &__block-items {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0.875rem;
    }

    &__block-item {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      font-size: 0.9125rem;
      color: #4B5563;
      line-height: 1.55;
    }

    &__check {
      font-weight: 700;
      font-size: 0.875rem;
      flex-shrink: 0;
      margin-top: 1px;

      &--indigo { color: #3C2BDC; }
      &--teal { color: #7C3AED; }
      &--emerald { color: #0D0857; }
    }

    &__footer {
      text-align: center;
    }

    &__closing {
      font-size: 1rem;
      color: #6B7280;
      line-height: 1.7;
      max-width: 560px;
      margin: 0 auto 2rem;
    }

    &__cta-group {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.75rem;
    }

    &__cta {
      display: inline-flex;
      align-items: center;
      background: linear-gradient(135deg, #3C2BDC 0%, #7C3AED 100%);
      color: white;
      border-radius: 999px;
      padding: 14px 30px;
      font-size: 15px;
      font-weight: 600;
      font-family: 'Plus Jakarta Sans', Inter, sans-serif;
      text-decoration: none;
      transition: opacity 0.2s ease, transform 0.15s ease, box-shadow 0.2s ease;
      box-shadow: 0 4px 20px rgba(60, 43, 220, 0.3);

      &:hover {
        opacity: 0.9;
        transform: translateY(-2px);
        box-shadow: 0 8px 28px rgba(60, 43, 220, 0.38);
      }
    }

    &__cta-sub {
      font-size: 13px;
      color: #9CA3AF;
    }
  }
</style>
