---
// ── /kate — the living credential (EN + ES) ──────────────────────────────
// The most photographic page of the site: hero, a big-number proof bar, the
// three-chapter arc (Colombia → ADDI → Purrfect Hire), LinkedIn authority,
// and two CTAs separated by audience. Flat 2026 system, `kt-` prefix. Every
// image slot reuses the one approved photo (KATE_PHOTO) until the shoot
// delivers the rest of the shot list — captions still say what each real
// photo will be, so no slot reads as empty in the meantime.
import Layout from '../../layouts/Layout.astro';
import V6Nav from '../v6/V6Nav.astro';
import Footer from '../Footer.astro';
import type { KateContent } from '../../content/kate';
import { KATE_LINKEDIN, KATE_PHOTO } from '../../content/kate';
import { getContent } from '../../content/index';

interface Props {
  c: KateContent;
}

const { c } = Astro.props;
const site = getContent(c.lang);
const siteUrl = 'https://purrfecthire.com';
const pageUrl = `${siteUrl}${c.path}`;

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Kate Forero',
  alternateName: 'Katerine Forero',
  jobTitle: 'Founder',
  url: pageUrl,
  image: `${siteUrl}${KATE_PHOTO}`,
  sameAs: [KATE_LINKEDIN],
  worksFor: {
    '@type': 'Organization',
    name: 'Purrfect Hire',
    url: siteUrl,
  },
  knowsAbout: [
    'Startup hiring',
    'Culture-fit assessment',
    'Career coaching',
    'Offer negotiation',
  ],
  description: c.meta.description,
};
---

<Layout
  title={c.meta.title}
  description={c.meta.description}
  lang={c.lang}
  canonicalUrl={pageUrl}
  ogImage={`${siteUrl}${KATE_PHOTO}`}
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(personSchema)} />

  <V6Nav content={site.nav} lang={c.lang} otherLangPath="/kate" />

  <main class="kt">
    <!-- ── Hero: face + claim + one CTA slot below ─────────────────── -->
    <section class="kt-hero">
      <div class="kt-hero__text">
        <p class="kt-eyebrow">{c.hero.eyebrow}</p>
        <h1 class="kt-hero__headline">{c.hero.headline}</h1>
        <p class="kt-hero__sub">{c.hero.sub}</p>
      </div>
      <!-- Stand-in until the shoot delivers the authority shot -->
      <figure class="kt-hero__media">
        <img src={KATE_PHOTO} alt="Kate Forero" width="1023" height="1537" />
        <figcaption class="kt-hero__caption">{c.hero.placeholderCaption}</figcaption>
      </figure>
    </section>

    <!-- ── Proof bar: big numbers, small labels ────────────────────── -->
    <section class="kt-stats reveal">
      {c.stats.map((s) => (
        <div class="kt-stats__item">
          <span class="kt-stats__value">{s.value}</span>
          <span class="kt-stats__label">{s.label}</span>
        </div>
      ))}
    </section>

    <!-- ── The arc ─────────────────────────────────────────────────── -->
    <section class="kt-arc">
      <h2 class="kt-arc__title reveal">{c.arcTitle}</h2>
      {c.chapters.map((ch, i) => (
        <article class:list={['kt-chapter', 'reveal', { 'kt-chapter--flip': i % 2 === 1 }]}>
          <div class="kt-chapter__text">
            <p class="kt-eyebrow">{ch.tag}</p>
            <h3 class="kt-chapter__title">{ch.title}</h3>
            <p class="kt-chapter__body">{ch.body}</p>
          </div>
          <figure class="kt-chapter__media">
            <img src={ch.image} alt={ch.caption} loading="lazy" width="1023" height="1537" />
            <figcaption class="kt-chapter__caption">{ch.caption}</figcaption>
          </figure>
        </article>
      ))}
    </section>

    <!-- ── LinkedIn authority ──────────────────────────────────────── -->
    <section class="kt-li">
      <div class="kt-li__head reveal">
        <h2 class="kt-li__title">{c.linkedin.title}</h2>
        <p class="kt-li__body">{c.linkedin.body}</p>
      </div>
      <div class="kt-li__posts">
        {c.linkedin.postPlaceholders.map((p) => (
          <div class="kt-placeholder kt-placeholder--post reveal">
            <span class="kt-placeholder__glyph" aria-hidden="true">in</span>
            <p class="kt-placeholder__caption">{p}</p>
          </div>
        ))}
      </div>
      <p class="kt-li__link reveal">
        <a href={KATE_LINKEDIN} target="_blank" rel="noopener">{c.linkedin.profileLabel}</a>
      </p>
    </section>

    <!-- ── Two CTAs, separated by audience ─────────────────────────── -->
    <section class="kt-ctas">
      <h2 class="kt-ctas__title reveal">{c.ctas.title}</h2>
      <div class="kt-ctas__grid">
        {[c.ctas.founders, c.ctas.talent].map((cta, i) => (
          <article class="kt-cta reveal">
            <h3 class="kt-cta__title">{cta.title}</h3>
            <p class="kt-cta__body">{cta.body}</p>
            <a
              href={cta.href}
              class:list={['kt-btn', { 'kt-btn--solid': i === 0 }]}
              target={cta.href.startsWith('http') ? '_blank' : undefined}
              rel={cta.href.startsWith('http') ? 'noopener' : undefined}
            >{cta.label}</a>
          </article>
        ))}
      </div>
    </section>
  </main>

  <Footer content={site.footer} />
</Layout>

<style lang="scss">
  $ease-expo: cubic-bezier(0.16, 1, 0.3, 1);

  .kt {
    --kt-bg: var(--bg, #ffffff);
    --kt-bg-soft: var(--bg-soft, #fcfcfb);
    --kt-text: var(--text, #1c1c1c);
    --kt-ink: var(--ink, #29285f);
    --kt-muted: var(--muted, #6b6b6b);
    --kt-border: var(--line, rgba(0, 0, 0, 0.08));
    --kt-radius: var(--radius, 12px);

    background: var(--kt-bg);
    color: var(--kt-text);
    font-family: 'Schibsted Grotesk', Arial, sans-serif;
    padding-top: 4rem; // clear the fixed nav

    ::selection {
      background: var(--kt-ink);
      color: #fff;
    }
  }

  .kt-eyebrow {
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--kt-ink);
    margin: 0 0 1.25rem;
  }

  // ── Photo placeholders: honest frames describing the coming shot ──
  .kt-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.875rem;
    text-align: center;
    padding: 2rem;
    background: var(--kt-bg-soft);
    border: 1px dashed rgba(41, 40, 95, 0.35);
    border-radius: var(--kt-radius);

    &__glyph {
      font-size: 1.25rem;
      font-weight: 500;
      color: var(--kt-ink);
      opacity: 0.7;
    }

    &__caption {
      margin: 0;
      font-size: 0.8125rem;
      line-height: 1.55;
      color: var(--kt-muted);
      max-width: 26rem;
    }

    &--post {
      min-height: 180px;

      .kt-placeholder__glyph {
        width: 2rem;
        height: 2rem;
        display: grid;
        place-items: center;
        border-radius: 6px;
        background: var(--kt-ink);
        color: #fff;
        font-size: 0.875rem;
        opacity: 1;
      }
    }
  }

  // ── Hero ──────────────────────────────────────────────────
  .kt-hero {
    max-width: 1100px;
    margin: 0 auto;
    padding: clamp(48px, 7vw, 88px) clamp(1.5rem, 5vw, 2rem) clamp(40px, 5vw, 64px);
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(0, 0.8fr);
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;

    @media (max-width: 860px) { grid-template-columns: 1fr; }

    &__headline {
      font-size: clamp(2.5rem, 5.5vw, 3.5rem);
      font-weight: 500;
      line-height: 1.05;
      letter-spacing: -0.02em;
      margin: 0;
      color: var(--kt-ink);
      max-width: 16ch;
    }

    &__sub {
      margin: 1.5rem 0 0;
      font-size: 1.0625rem;
      line-height: 1.65;
      color: var(--kt-muted);
      max-width: 34rem;
    }

    &__media {
      margin: 0;
      aspect-ratio: 4 / 5;
      max-height: 460px;

      img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center top;
        border-radius: var(--kt-radius);
        border: 1px solid var(--kt-border);
        display: block;
      }
    }

    &__caption {
      margin-top: 0.75rem;
      font-size: 0.8125rem;
      line-height: 1.5;
      color: var(--kt-muted);
    }
  }

  // ── Proof bar ─────────────────────────────────────────────
  .kt-stats {
    max-width: 1100px;
    margin: 0 auto;
    padding: clamp(32px, 4vw, 48px) clamp(1.5rem, 5vw, 2rem);
    border-top: 1px solid var(--kt-border);
    border-bottom: 1px solid var(--kt-border);
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;

    @media (max-width: 860px) { grid-template-columns: repeat(2, 1fr); }

    &__item {
      display: flex;
      flex-direction: column;
      gap: 0.375rem;
    }

    &__value {
      font-size: clamp(2.25rem, 4vw, 3rem);
      font-weight: 500;
      letter-spacing: -0.02em;
      line-height: 1;
      color: var(--kt-ink);
    }

    &__label {
      font-size: 0.8125rem;
      color: var(--kt-muted);
    }
  }

  // ── Arc ───────────────────────────────────────────────────
  .kt-arc {
    max-width: 1100px;
    margin: 0 auto;
    padding: clamp(48px, 7vw, 80px) clamp(1.5rem, 5vw, 2rem);

    &__title {
      font-size: clamp(1.75rem, 3vw, 2rem);
      font-weight: 500;
      letter-spacing: -0.02em;
      margin: 0 0 3rem;
      color: var(--kt-ink);
    }
  }

  .kt-chapter {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
    padding: clamp(32px, 4vw, 48px) 0;

    & + & { border-top: 1px solid var(--kt-border); }

    &--flip {
      .kt-chapter__text { order: 2; }
      .kt-chapter__media { order: 1; }
    }

    @media (max-width: 860px) {
      grid-template-columns: 1fr;

      &--flip {
        .kt-chapter__text { order: 1; }
        .kt-chapter__media { order: 2; }
      }
    }

    &__title {
      font-size: clamp(1.375rem, 2.5vw, 1.75rem);
      font-weight: 500;
      letter-spacing: -0.015em;
      line-height: 1.2;
      margin: 0;
      color: var(--kt-text);
    }

    &__body {
      margin: 1rem 0 0;
      font-size: 1rem;
      line-height: 1.65;
      color: var(--kt-muted);
      max-width: 34rem;
    }

    &__media {
      margin: 0;

      img {
        width: 100%;
        height: auto;
        max-height: 420px;
        object-fit: cover;
        object-position: center top;
        border-radius: var(--kt-radius);
        border: 1px solid var(--kt-border);
        display: block;
      }

      .kt-placeholder { aspect-ratio: 3 / 2; }
    }

    &__caption {
      margin-top: 0.75rem;
      font-size: 0.8125rem;
      color: var(--kt-muted);
    }
  }

  // ── LinkedIn ──────────────────────────────────────────────
  .kt-li {
    max-width: 1100px;
    margin: 0 auto;
    padding: clamp(48px, 7vw, 80px) clamp(1.5rem, 5vw, 2rem);
    border-top: 1px solid var(--kt-border);

    &__head { max-width: 46rem; margin-bottom: 2.5rem; }

    &__title {
      font-size: clamp(1.75rem, 3vw, 2rem);
      font-weight: 500;
      letter-spacing: -0.02em;
      margin: 0;
      color: var(--kt-ink);
    }

    &__body {
      margin: 1rem 0 0;
      font-size: 1.0625rem;
      line-height: 1.65;
      color: var(--kt-muted);
    }

    &__posts {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;

      @media (max-width: 720px) { grid-template-columns: 1fr; }
    }

    &__link {
      margin: 2rem 0 0;

      a {
        font-size: 0.9375rem;
        font-weight: 500;
        color: var(--kt-ink);
        text-decoration: none;

        &:hover { text-decoration: underline; }
      }
    }
  }

  // ── Dual CTA ──────────────────────────────────────────────
  .kt-ctas {
    max-width: 1100px;
    margin: 0 auto;
    padding: clamp(48px, 7vw, 80px) clamp(1.5rem, 5vw, 2rem) clamp(64px, 8vw, 100px);
    border-top: 1px solid var(--kt-border);

    &__title {
      font-size: clamp(1.75rem, 3vw, 2rem);
      font-weight: 500;
      letter-spacing: -0.02em;
      margin: 0 0 2.5rem;
      color: var(--kt-ink);
    }

    &__grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;

      @media (max-width: 720px) { grid-template-columns: 1fr; }
    }
  }

  .kt-cta {
    border: 1px solid var(--kt-border);
    border-radius: var(--kt-radius);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
    transition: border-color 0.25s $ease-expo;

    &:hover { border-color: var(--kt-ink); }

    &__title {
      margin: 0;
      font-size: 1.25rem;
      font-weight: 500;
      color: var(--kt-text);
    }

    &__body {
      margin: 0;
      font-size: 0.9375rem;
      line-height: 1.6;
      color: var(--kt-muted);
      flex: 1;
    }
  }

  .kt-btn {
    display: inline-flex;
    align-items: center;
    padding: 12px 26px;
    font-size: 0.875rem;
    font-weight: 500;
    border-radius: var(--kt-radius);
    text-decoration: none;
    color: var(--kt-text);
    border: 1px solid var(--kt-border);
    transition: background 0.25s $ease-expo, border-color 0.25s $ease-expo, color 0.25s $ease-expo;

    &:hover {
      border-color: var(--kt-ink);
      color: var(--kt-ink);
    }

    &--solid {
      background: var(--kt-ink);
      border-color: var(--kt-ink);
      color: #fff;

      &:hover {
        background: #1e1d47;
        border-color: #1e1d47;
        color: #fff;
      }
    }
  }
</style>
