---
// ── Offer Acceleration — v5 (the default program page) ───────────────────
// Direction: v2 "Cinema" converted to LIGHT mode. Same structure, type
// scale, gradients, glows and background grid as v2 — only the palette is
// inverted: warm-paper canvas, white surfaces, dark readable text, brand
// purple (#3C2BDC) kept for accent words. Desktop-first (design test).
// DELETE when a final version is chosen.
import Layout from '../../layouts/Layout.astro';
import { oaContent as c } from '../../content/offerAcceleration';

interface Props {
  /** /offer-acceleration (canonical) is indexable; the /5 test route is not. */
  noindex?: boolean;
}

const { noindex = true } = Astro.props;
---

<Layout title={c.meta.title} description={c.meta.description} lang="es" noindex={noindex}>
  <link
    slot="head"
    href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,300;12..96,500;12..96,700&display=swap"
    rel="stylesheet"
  />

  <main class="oa5">

    <header class="oa5-nav">
      <img src="/logos/logo-desktop.png" alt="Purrfect Hire" class="oa5-nav__logo" />
      <a href={c.apply.url} id="oa5-apply-btn" class="oa5-btn oa5-btn--solid">
        Test gratis
      </a>
    </header>

    <!-- Idle guide arrow → fades in pointing at the "Test gratis" button -->
    <canvas class="oa5-guide" id="oa5-guide" aria-hidden="true"></canvas>

    <!-- ── Hero ─────────────────────────────────────────────────────── -->
    <section class="oa5-hero">
      <div class="oa5-hero__glow" aria-hidden="true"></div>
      <div class="oa5-hero__grid" aria-hidden="true"></div>

      <p class="oa5-eyebrow oa5-hero__eyebrow">{c.hero.eyebrow}</p>

      <h1 class="oa5-hero__headline">
        <span class="oa5-hero__line"><span>Tu perfil tiene</span></span>
        <span class="oa5-hero__line"><span>techo más alto que</span></span>
        <span class="oa5-hero__line oa5-hero__line--accent"><span>tu salario actual.</span></span>
      </h1>

      <p class="oa5-hero__subhead">{c.hero.subhead}</p>

      <div class="oa5-hero__stats">
        {c.hero.stats.map((s) => (
          <div class="oa5-hero__stat">
            <span class="oa5-hero__stat-value">{s.value}</span>
            <span class="oa5-hero__stat-label">{s.label}</span>
          </div>
        ))}
      </div>

      <div class="oa5-hero__scroll" aria-hidden="true">
        <span></span>
      </div>
    </section>

    <!-- ── Ch. 01 — Cost ────────────────────────────────────────────── -->
    <section class="oa5-chapter">
      <div class="oa5-chapter__head oa5-reveal">
        <span class="oa5-chapter__num">01</span>
        <h2 class="oa5-chapter__title">{c.cost.title}</h2>
      </div>

      <div class="oa5-cost">
        <p class="oa5-cost__setup oa5-reveal">{c.cost.body}</p>
        <p class="oa5-cost__big oa5-reveal">
          <span class="oa5-cost__amount">−$12,000</span>
          <span class="oa5-cost__usd">USD que ya no vas a recuperar</span>
        </p>
        <p class="oa5-cost__note oa5-reveal">{c.cost.note}</p>
        <blockquote class="oa5-quote oa5-reveal">{c.cost.quote}</blockquote>
      </div>
    </section>

    <!-- ── Ch. 02 — Cases ───────────────────────────────────────────── -->
    <section class="oa5-chapter" id="casos">
      <div class="oa5-chapter__head oa5-reveal">
        <span class="oa5-chapter__num">02</span>
        <h2 class="oa5-chapter__title">{c.cases.title}</h2>
      </div>

      <div class="oa5-cases">
        {c.cases.items.map((item, i) => (
          <article class={`oa5-case oa5-reveal ${i % 2 === 1 ? 'oa5-case--offset' : ''}`}>
            <div class="oa5-case__metric">{item.metric}</div>
            <div class="oa5-case__unit">{item.unit}</div>
            <h3 class="oa5-case__role">{item.role}</h3>
            <p class="oa5-case__story">{item.story}</p>
            <p class="oa5-case__result">{item.result}</p>
          </article>
        ))}
      </div>
    </section>

    <!-- ── Ch. 03 — Investment ──────────────────────────────────────── -->
    <section class="oa5-chapter">
      <div class="oa5-chapter__head oa5-reveal">
        <span class="oa5-chapter__num">03</span>
        <h2 class="oa5-chapter__title">{c.investment.title}</h2>
      </div>

      <div class="oa5-invest oa5-reveal">
        <p class="oa5-invest__price">{c.investment.price}</p>
        <p class="oa5-invest__note">{c.investment.priceNote}</p>
      </div>

      <div class="oa5-tiers oa5-reveal">
        <div class="oa5-tiers__row oa5-tiers__row--head">
          <span>Seniority</span>
          <span>Hoy</span>
          <span>Salto realista</span>
          <span>Adicional / año</span>
          <span>Recuperas en</span>
        </div>
        {c.investment.tiers.map((t) => (
          <div class="oa5-tiers__row">
            <span class="oa5-tiers__seniority">{t.seniority}</span>
            <span>{t.current}</span>
            <span class="oa5-tiers__jump">{t.jump}</span>
            <span>{t.annual}</span>
            <span>{t.payback}</span>
          </div>
        ))}
        <p class="oa5-tiers__note">{c.investment.tableNote} · {c.investment.payments}</p>
      </div>

      <p class="oa5-statement oa5-reveal">{c.investment.proof}</p>
    </section>

    <!-- ── Ch. 04 — Deliverables ────────────────────────────────────── -->
    <section class="oa5-chapter">
      <div class="oa5-chapter__head oa5-reveal">
        <span class="oa5-chapter__num">04</span>
        <h2 class="oa5-chapter__title">{c.deliverables.title}</h2>
      </div>
      <p class="oa5-chapter__subhead oa5-reveal">{c.deliverables.subhead}</p>

      <ol class="oa5-deliverables">
        {c.deliverables.items.map((d, i) => (
          <li class="oa5-deliverable oa5-reveal">
            <span class="oa5-deliverable__num">{String(i + 1).padStart(2, '0')}</span>
            <div class="oa5-deliverable__text">
              <h3>{d.title}</h3>
              <p>{d.body}</p>
            </div>
          </li>
        ))}
      </ol>
    </section>

    <!-- ── Ch. 05 — How + Who ───────────────────────────────────────── -->
    <section class="oa5-chapter">
      <div class="oa5-chapter__head oa5-reveal">
        <span class="oa5-chapter__num">05</span>
        <h2 class="oa5-chapter__title">{c.how.title}</h2>
      </div>

      <div class="oa5-how oa5-reveal">
        {c.how.facts.map((f) => (
          <div class="oa5-how__fact">
            <span class="oa5-eyebrow">{f.label}</span>
            <span class="oa5-how__value">{f.value}</span>
            <p>{f.detail}</p>
          </div>
        ))}
      </div>

      <p class="oa5-statement oa5-reveal">{c.how.quote}</p>

      <div class="oa5-who oa5-reveal">
        <div class="oa5-who__kate">
          <h3>{c.who.kate.name}</h3>
          <span class="oa5-eyebrow">{c.who.kate.role}</span>
          <p>{c.who.kate.bio}</p>
          <p class="oa5-who__quote">“{c.who.kate.quote}”</p>
        </div>
        <div class="oa5-who__team">
          <h3>{c.who.team.name}</h3>
          <p>{c.who.team.bio}</p>
        </div>
      </div>
    </section>

    <!-- ── Ch. 06 — FAQ ─────────────────────────────────────────────── -->
    <section class="oa5-chapter oa5-chapter--narrow">
      <div class="oa5-chapter__head oa5-reveal">
        <span class="oa5-chapter__num">06</span>
        <h2 class="oa5-chapter__title">{c.faq.title}</h2>
      </div>

      <div class="oa5-faq oa5-reveal">
        {c.faq.items.map((f) => (
          <details class="oa5-faq__item">
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </section>

    <!-- ── Final ────────────────────────────────────────────────────── -->
    <section class="oa5-final">
      <div class="oa5-final__glow" aria-hidden="true"></div>
      <h2 class="oa5-final__title oa5-reveal">
        La diferencia no es talento.<br />
        <em>Es velocidad de decisión.</em>
      </h2>
      <p class="oa5-final__note oa5-reveal">{c.start.note} Tres pasos: completas tu aplicación, agendas con nuestro equipo, reservas tu cupo y arrancamos.</p>
      <div class="oa5-final__ctas oa5-reveal">
        <a href={c.apply.url} class="oa5-btn oa5-btn--solid oa5-btn--lg">
          {c.apply.labelFinal}
        </a>
      </div>
      <p class="oa5-final__footer">© {new Date().getFullYear()} Purrfect Hire · Offer Acceleration</p>
    </section>
  </main>
</Layout>

<style lang="scss">
  $ease-expo: cubic-bezier(0.16, 1, 0.3, 1);
  $ease-quart: cubic-bezier(0.25, 1, 0.5, 1);

  .oa5 {
    // ── Light palette (mirror of v2's dark tokens) ──
    --oa5-bg: #f7f5f0;          // warm paper
    --oa5-surface: #ffffff;     // white cards
    --oa5-text: #14121b;        // near-black ink
    --oa5-muted: rgba(20, 18, 27, 0.62);
    --oa5-faint: rgba(20, 18, 27, 0.42);
    --oa5-border: rgba(20, 18, 27, 0.12);
    --oa5-accent: #3c2bdc;      // brand purple — readable on light
    --oa5-accent-soft: #6354e8; // lighter purple for gradient end
    --oa5-accent-deep: #3c2bdc;

    background: var(--oa5-bg);
    color: var(--oa5-text);
    font-family: 'Inter', Arial, sans-serif;
    overflow-x: hidden;

    ::selection {
      background: var(--oa5-accent-deep);
      color: #fff;
    }
  }

  .oa5-eyebrow {
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--oa5-accent);
  }

  // ── Nav ───────────────────────────────────────────────────
  .oa5-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 3rem;
    background: linear-gradient(rgba(247, 245, 240, 0.9), rgba(247, 245, 240, 0));

    &__logo {
      width: 10rem;
    }
  }

  // ── Idle guide arrow → "Test gratis" button ───────────────
  .oa5-guide {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 60;

    @media (max-width: 767px) { display: none; }
  }

  // ── Buttons ───────────────────────────────────────────────
  .oa5-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 26px;
    font-size: 0.875rem;
    font-weight: 500;
    border-radius: 999px;
    text-decoration: none;
    color: var(--oa5-text);
    border: 1px solid rgba(20, 18, 27, 0.25);
    transition: background 0.25s $ease-quart, border-color 0.25s $ease-quart, color 0.25s $ease-quart, transform 0.25s $ease-quart;

    &:hover {
      border-color: var(--oa5-accent);
      color: var(--oa5-accent);
      transform: translateY(-1px);
    }

    &--solid {
      background: var(--oa5-accent-deep);
      border-color: var(--oa5-accent-deep);
      color: #fff;

      &:hover {
        background: var(--oa5-accent-soft);
        border-color: var(--oa5-accent-soft);
        color: #fff;
      }
    }

    &--lg { padding: 16px 34px; font-size: 0.9375rem; }
  }

  // ── Hero ──────────────────────────────────────────────────
  .oa5-hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 0 7vw;
    overflow: hidden;

    &__glow {
      position: absolute;
      width: 70vw;
      height: 70vw;
      top: -30vw;
      right: -22vw;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(60, 43, 220, 0.20) 0%, rgba(60, 43, 220, 0) 65%);
      animation: oa5-pulse 9s ease-in-out infinite alternate;
      pointer-events: none;
    }

    &__grid {
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(rgba(20, 18, 27, 0.05) 1px, transparent 1px),
        linear-gradient(90deg, rgba(20, 18, 27, 0.05) 1px, transparent 1px);
      background-size: 72px 72px;
      mask-image: radial-gradient(ellipse 70% 60% at 50% 40%, #000 0%, transparent 100%);
      pointer-events: none;
    }

    &__eyebrow {
      position: relative;
      opacity: 0;
      animation: oa5-up 0.9s $ease-expo 0.2s forwards;
      margin-bottom: 2rem;
    }

    &__headline {
      position: relative;
      font-family: 'Bricolage Grotesque', 'Inter', sans-serif;
      font-size: clamp(3.5rem, 7.8vw, 8rem);
      font-weight: 700;
      line-height: 0.98;
      letter-spacing: -0.03em;
      margin: 0;
    }

    &__line {
      display: block;
      overflow: hidden;

      span {
        display: block;
        transform: translateY(110%);
        animation: oa5-line 1.1s $ease-expo forwards;
      }

      &:nth-child(1) span { animation-delay: 0.35s; }
      &:nth-child(2) span { animation-delay: 0.47s; }
      &:nth-child(3) span { animation-delay: 0.59s; }

      &--accent span {
        color: transparent;
        background: linear-gradient(92deg, var(--oa5-accent) 0%, var(--oa5-accent-soft) 100%);
        background-clip: text;
        -webkit-background-clip: text;
      }
    }

    &__subhead {
      position: relative;
      max-width: 32rem;
      margin-top: 2.5rem;
      font-size: 1.0625rem;
      line-height: 1.65;
      color: var(--oa5-muted);
      opacity: 0;
      animation: oa5-up 0.9s $ease-expo 1.1s forwards;
    }

    &__stats {
      position: relative;
      display: flex;
      gap: 3.5rem;
      margin-top: 3.5rem;
      padding-top: 2rem;
      border-top: 1px solid var(--oa5-border);
      opacity: 0;
      animation: oa5-up 0.9s $ease-expo 1.35s forwards;
    }

    &__stat {
      display: flex;
      flex-direction: column;
      gap: 0.375rem;
    }

    &__stat-value {
      font-family: 'Bricolage Grotesque', 'Inter', sans-serif;
      font-size: 2rem;
      font-weight: 500;
      line-height: 1;
    }

    &__stat-label {
      font-size: 0.8125rem;
      color: var(--oa5-faint);
      max-width: 150px;
    }

    &__scroll {
      position: absolute;
      bottom: 2.5rem;
      left: 50%;
      width: 1px;
      height: 56px;
      background: var(--oa5-border);
      overflow: hidden;

      span {
        position: absolute;
        top: -40%;
        left: 0;
        width: 100%;
        height: 40%;
        background: var(--oa5-accent);
        animation: oa5-scrollhint 2.2s $ease-quart 2s infinite;
      }
    }
  }

  // ── Chapters ──────────────────────────────────────────────
  .oa5-chapter {
    position: relative;
    padding: 9rem 7vw;
    border-top: 1px solid var(--oa5-border);

    &--narrow { max-width: 60rem; }

    &__head {
      display: flex;
      align-items: baseline;
      gap: 2rem;
      margin-bottom: 4rem;
    }

    &__num {
      font-family: 'Bricolage Grotesque', 'Inter', sans-serif;
      font-size: 0.9375rem;
      font-weight: 500;
      color: var(--oa5-accent);
      letter-spacing: 0.1em;
    }

    &__title {
      font-family: 'Bricolage Grotesque', 'Inter', sans-serif;
      font-size: clamp(2.25rem, 4vw, 3.75rem);
      font-weight: 500;
      letter-spacing: -0.02em;
      line-height: 1.05;
      margin: 0;
    }

    &__subhead {
      max-width: 36rem;
      color: var(--oa5-muted);
      margin: -2.5rem 0 4rem;
      font-size: 1.0625rem;
      line-height: 1.65;
    }
  }

  // ── Cost ──────────────────────────────────────────────────
  .oa5-cost {
    max-width: 60rem;

    &__setup {
      font-size: 1.25rem;
      line-height: 1.6;
      color: var(--oa5-muted);
      max-width: 38rem;
    }

    &__big {
      margin: 3.5rem 0 0;
      display: flex;
      flex-direction: column;
    }

    &__amount {
      font-family: 'Bricolage Grotesque', 'Inter', sans-serif;
      font-size: clamp(5rem, 12vw, 12rem);
      font-weight: 700;
      letter-spacing: -0.04em;
      line-height: 1;
      color: transparent;
      background: linear-gradient(180deg, var(--oa5-text) 30%, rgba(20, 18, 27, 0.28) 100%);
      background-clip: text;
      -webkit-background-clip: text;
      font-variant-numeric: tabular-nums;
    }

    &__usd {
      font-size: 1.125rem;
      color: var(--oa5-accent);
      margin-top: 1rem;
      font-weight: 500;
    }

    &__note {
      margin-top: 2rem;
      font-size: 0.8125rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--oa5-faint);
    }
  }

  .oa5-quote {
    margin: 4rem 0 0;
    max-width: 40rem;
    padding-left: 1.75rem;
    border-left: 2px solid var(--oa5-accent);
    font-size: 1.375rem;
    line-height: 1.5;
    font-weight: 400;
    color: var(--oa5-text);
  }

  .oa5-statement {
    margin: 5rem auto 0;
    max-width: 52rem;
    font-family: 'Bricolage Grotesque', 'Inter', sans-serif;
    font-size: clamp(1.625rem, 2.6vw, 2.5rem);
    font-weight: 500;
    line-height: 1.25;
    letter-spacing: -0.01em;
    text-align: center;

    em { color: var(--oa5-accent); font-style: normal; }
  }

  // ── Cases ─────────────────────────────────────────────────
  .oa5-cases {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem 2.5rem;
  }

  .oa5-case {
    background: var(--oa5-surface);
    border: 1px solid var(--oa5-border);
    border-radius: 4px;
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    box-shadow: 0 1px 2px rgba(20, 18, 27, 0.04);
    transition: border-color 0.3s $ease-quart, box-shadow 0.3s $ease-quart, transform 0.45s $ease-expo;

    &:hover {
      border-color: rgba(60, 43, 220, 0.45);
      box-shadow: 0 18px 44px rgba(20, 18, 27, 0.08);
      transform: translateY(-4px);
    }

    &--offset { transform: translateY(2.5rem); }
    &--offset:hover { transform: translateY(calc(2.5rem - 4px)); }

    &__metric {
      font-family: 'Bricolage Grotesque', 'Inter', sans-serif;
      font-size: 2.75rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      line-height: 1;
      color: var(--oa5-accent);
      font-variant-numeric: tabular-nums;
    }

    &__unit {
      font-size: 0.8125rem;
      color: var(--oa5-faint);
      letter-spacing: 0.04em;
    }

    &__role {
      margin: 1rem 0 0;
      font-size: 1.125rem;
      font-weight: 500;
    }

    &__story {
      font-size: 0.9375rem;
      line-height: 1.65;
      color: var(--oa5-muted);
    }

    &__result {
      margin-top: auto;
      padding-top: 1rem;
      font-size: 0.9375rem;
      font-weight: 500;
      color: var(--oa5-text);
    }
  }

  // ── Investment ────────────────────────────────────────────
  .oa5-invest {
    margin-bottom: 4rem;

    &__price {
      font-family: 'Bricolage Grotesque', 'Inter', sans-serif;
      font-size: clamp(3rem, 6vw, 5.5rem);
      font-weight: 700;
      letter-spacing: -0.03em;
      line-height: 1;
      margin: 0;
    }

    &__note {
      margin-top: 1.25rem;
      color: var(--oa5-muted);
      font-size: 1.0625rem;
    }
  }

  .oa5-tiers {
    border-top: 1px solid var(--oa5-border);

    &__row {
      display: grid;
      grid-template-columns: 1.2fr 1fr 1fr 1fr 1fr;
      gap: 1.5rem;
      padding: 1.5rem 0;
      border-bottom: 1px solid var(--oa5-border);
      font-size: 0.9375rem;
      color: var(--oa5-muted);
      font-variant-numeric: tabular-nums;
      transition: background 0.2s $ease-quart;

      &:not(&--head):hover { background: rgba(20, 18, 27, 0.025); }

      &--head {
        font-size: 0.6875rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--oa5-faint);
        padding: 1rem 0;
      }
    }

    &__seniority { color: var(--oa5-text); font-weight: 500; }
    &__jump { color: var(--oa5-accent); font-weight: 500; }

    &__note {
      padding-top: 1.25rem;
      font-size: 0.8125rem;
      color: var(--oa5-faint);
    }
  }

  // ── Deliverables ──────────────────────────────────────────
  .oa5-deliverables {
    list-style: none;
    margin: 0;
    padding: 0;
    max-width: 56rem;
  }

  .oa5-deliverable {
    display: grid;
    grid-template-columns: 5rem 1fr;
    gap: 2rem;
    padding: 2.25rem 0;
    border-bottom: 1px solid var(--oa5-border);

    &:first-child { border-top: 1px solid var(--oa5-border); }

    &__num {
      font-family: 'Bricolage Grotesque', 'Inter', sans-serif;
      font-size: 1.75rem;
      font-weight: 300;
      color: var(--oa5-faint);
      line-height: 1.2;
      transition: color 0.3s $ease-quart;
    }

    &:hover &__num { color: var(--oa5-accent); }

    &__text {
      h3 {
        margin: 0 0 0.5rem;
        font-size: 1.25rem;
        font-weight: 500;
      }

      p {
        margin: 0;
        font-size: 0.9375rem;
        line-height: 1.65;
        color: var(--oa5-muted);
        max-width: 38rem;
      }
    }
  }

  // ── How / Who ─────────────────────────────────────────────
  .oa5-how {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.5rem;

    &__fact {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--oa5-border);

      p {
        margin: 0;
        font-size: 0.9375rem;
        line-height: 1.65;
        color: var(--oa5-muted);
      }
    }

    &__value {
      font-family: 'Bricolage Grotesque', 'Inter', sans-serif;
      font-size: 1.625rem;
      font-weight: 500;
    }
  }

  .oa5-who {
    margin-top: 6rem;
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: 2.5rem;

    h3 {
      font-family: 'Bricolage Grotesque', 'Inter', sans-serif;
      font-size: 1.625rem;
      font-weight: 500;
      margin: 0 0 0.375rem;
    }

    p {
      margin: 1rem 0 0;
      font-size: 0.9375rem;
      line-height: 1.7;
      color: var(--oa5-muted);
    }

    &__kate,
    &__team {
      background: var(--oa5-surface);
      border: 1px solid var(--oa5-border);
      border-radius: 4px;
      padding: 2.5rem;
      box-shadow: 0 1px 2px rgba(20, 18, 27, 0.04);
    }

    &__quote {
      color: var(--oa5-accent) !important;
      font-weight: 500;
      font-size: 1.0625rem !important;
    }
  }

  // ── FAQ ───────────────────────────────────────────────────
  .oa5-faq {
    max-width: 46rem;

    &__item {
      border-bottom: 1px solid var(--oa5-border);

      &:first-child { border-top: 1px solid var(--oa5-border); }

      summary {
        padding: 1.5rem 2.5rem 1.5rem 0;
        font-size: 1.0625rem;
        font-weight: 500;
        cursor: pointer;
        list-style: none;
        position: relative;

        &::-webkit-details-marker { display: none; }

        &::after {
          content: '+';
          position: absolute;
          right: 0.25rem;
          top: 50%;
          transform: translateY(-50%);
          color: var(--oa5-accent);
          font-size: 1.375rem;
          font-weight: 300;
          transition: transform 0.25s $ease-expo;
        }
      }

      &[open] summary::after { transform: translateY(-50%) rotate(45deg); }

      p {
        margin: 0 0 1.5rem;
        font-size: 0.9375rem;
        line-height: 1.7;
        color: var(--oa5-muted);
        max-width: 40rem;
      }
    }
  }

  // ── Final ─────────────────────────────────────────────────
  .oa5-final {
    position: relative;
    padding: 11rem 7vw 4rem;
    text-align: center;
    border-top: 1px solid var(--oa5-border);
    overflow: hidden;

    &__glow {
      position: absolute;
      width: 60vw;
      height: 60vw;
      bottom: -40vw;
      left: 50%;
      transform: translateX(-50%);
      border-radius: 50%;
      background: radial-gradient(circle, rgba(60, 43, 220, 0.22) 0%, rgba(60, 43, 220, 0) 65%);
      pointer-events: none;
    }

    &__title {
      position: relative;
      font-family: 'Bricolage Grotesque', 'Inter', sans-serif;
      font-size: clamp(2.75rem, 5.5vw, 5rem);
      font-weight: 700;
      letter-spacing: -0.03em;
      line-height: 1.05;
      margin: 0;

      em {
        font-style: normal;
        color: transparent;
        background: linear-gradient(92deg, var(--oa5-accent) 0%, var(--oa5-accent-soft) 100%);
        background-clip: text;
        -webkit-background-clip: text;
      }
    }

    &__note {
      position: relative;
      max-width: 34rem;
      margin: 2rem auto 0;
      color: var(--oa5-muted);
      font-size: 1rem;
      line-height: 1.65;
    }

    &__ctas {
      position: relative;
      display: flex;
      justify-content: center;
      gap: 1rem;
      margin-top: 3rem;
    }

    &__footer {
      position: relative;
      margin-top: 7rem;
      font-size: 0.8125rem;
      color: var(--oa5-faint);
    }
  }

  // ── Scroll reveals ────────────────────────────────────────
  .oa5-reveal {
    opacity: 0;
    transform: translateY(36px);
    transition: opacity 1s $ease-expo, transform 1s $ease-expo;

    &.is-visible {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .oa5-case--offset.is-visible { transform: translateY(2.5rem); }

  // ── Keyframes ─────────────────────────────────────────────
  @keyframes oa5-line {
    to { transform: translateY(0); }
  }
  @keyframes oa5-up {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes oa5-pulse {
    from { opacity: 0.7; transform: scale(1); }
    to { opacity: 1; transform: scale(1.08); }
  }
  @keyframes oa5-scrollhint {
    0% { top: -40%; }
    100% { top: 110%; }
  }

  @media (prefers-reduced-motion: reduce) {
    .oa5-hero__line span,
    .oa5-hero__eyebrow,
    .oa5-hero__subhead,
    .oa5-hero__stats {
      animation: none;
      opacity: 1;
      transform: none;
    }
    .oa5-hero__glow,
    .oa5-hero__scroll span { animation: none; }
    .oa5-reveal { transition: none; opacity: 1; transform: none; }
    .oa5-case--offset { transform: none; }
  }
</style>

<script>
  const reveals = document.querySelectorAll('.oa5-reveal');
  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add('is-visible');
          io.unobserve(e.target);
        }
      });
    },
    { threshold: 0.12 }
  );
  reveals.forEach((el) => io.observe(el));
</script>

<script>
  // ── "Test gratis" idle guide arrow ──────────────────────────────────
  // Same fading dashed-line design as the v6 hero guide. Fades in pointing
  // at the header button once the user has fully left the hero AND stayed
  // still for 4s. Any scroll fades it out and restarts the 4s count.
  const guideCanvas = document.getElementById('oa5-guide') as HTMLCanvasElement | null;
  const guideBtn = document.getElementById('oa5-apply-btn');
  const guideHero = document.querySelector('.oa5-hero');
  const finePointer = window.matchMedia('(pointer: fine)').matches;
  const noMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (guideCanvas && guideBtn && guideHero && finePointer && !noMotion && window.innerWidth >= 768) {
    const ctx = guideCanvas.getContext('2d')!;
    const IDLE_MS = 4000;

    let heroOut = false;
    let idleTimer: number | undefined;
    let alpha = 0;        // current opacity (eased)
    let targetAlpha = 0;  // desired opacity
    let dash = 0;         // marching-ants offset
    const mouse: { x: number | null; y: number | null } = { x: null, y: null };

    // Origin of the line follows the cursor
    window.addEventListener(
      'mousemove',
      (e) => {
        mouse.x = e.clientX;
        mouse.y = e.clientY;
      },
      { passive: true }
    );

    function resize() {
      const dpr = window.devicePixelRatio || 1;
      guideCanvas!.width = window.innerWidth * dpr;
      guideCanvas!.height = window.innerHeight * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }
    resize();
    window.addEventListener('resize', resize);

    function scheduleShow() {
      window.clearTimeout(idleTimer);
      idleTimer = window.setTimeout(() => {
        if (heroOut) targetAlpha = 1;
      }, IDLE_MS);
    }

    // Detect leaving the hero completely (0% visible)
    new IntersectionObserver(
      ([e]) => {
        heroOut = !e.isIntersecting;
        if (!heroOut) {
          targetAlpha = 0;
          window.clearTimeout(idleTimer);
        } else {
          scheduleShow();
        }
      },
      { threshold: 0 }
    ).observe(guideHero);

    // Any scroll hides the arrow and restarts the idle count
    window.addEventListener(
      'scroll',
      () => {
        targetAlpha = 0;
        scheduleShow();
      },
      { passive: true }
    );

    function drawArrow() {
      const r = guideBtn!.getBoundingClientRect();
      const tx = r.left + r.width / 2;
      const ty = r.bottom + 10;      // target point just under the button

      // Line starts at the cursor (fallback below the button before any move)
      const x0 = mouse.x != null ? mouse.x : tx - 34;
      const y0 = mouse.y != null ? mouse.y : ty + 200;

      // Skip a degenerate arrow when the cursor sits on the button
      const dist = Math.hypot(tx - x0, ty - y0);
      if (dist < 48) return;

      // Pull the arrowhead back a touch from the exact target
      const ang = Math.atan2(ty - y0, tx - x0);
      const x1 = tx - Math.cos(ang) * 4;
      const y1 = ty - Math.sin(ang) * 4;

      // Curved control point — bows the dashed line for a natural sweep
      const midX = (x0 + x1) / 2;
      const midY = (y0 + y1) / 2;
      const offset = Math.min(160, dist * 0.4);
      const t = Math.max(-1, Math.min(1, (y0 - y1) / 200));
      const ctrlX = midX;
      const ctrlY = midY + offset * t;
      const a = 0.8 * alpha;

      ctx.save();
      ctx.strokeStyle = `rgba(60, 43, 220, ${a})`;
      ctx.lineWidth = 2;
      ctx.setLineDash([9, 6]);
      ctx.lineDashOffset = dash;
      ctx.beginPath();
      ctx.moveTo(x0, y0);
      ctx.quadraticCurveTo(ctrlX, ctrlY, x1, y1);
      ctx.stroke();

      // Arrowhead pointing at the button
      const headAng = Math.atan2(y1 - ctrlY, x1 - ctrlX);
      const hl = 12;
      ctx.setLineDash([]);
      ctx.beginPath();
      ctx.moveTo(x1, y1);
      ctx.lineTo(x1 - hl * Math.cos(headAng - Math.PI / 6), y1 - hl * Math.sin(headAng - Math.PI / 6));
      ctx.moveTo(x1, y1);
      ctx.lineTo(x1 - hl * Math.cos(headAng + Math.PI / 6), y1 - hl * Math.sin(headAng + Math.PI / 6));
      ctx.stroke();
      ctx.restore();
    }

    function frame() {
      alpha += (targetAlpha - alpha) * 0.08;
      dash -= 0.4;
      ctx.clearRect(0, 0, window.innerWidth, window.innerHeight);
      if (alpha > 0.01) drawArrow();
      requestAnimationFrame(frame);
    }
    requestAnimationFrame(frame);
  }
</script>
