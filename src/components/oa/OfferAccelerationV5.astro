---
// ── Offer Acceleration — v5 (the default program page) ───────────────────
// Direction: flat navy/white 2026 system. No gradients, no glows, no
// box-shadow, no purple accent — flat surfaces, navy ink (#29285F),
// border-based elevation, Schibsted Grotesk (loaded globally).
import Layout from '../../layouts/Layout.astro';
import { oaContent as c } from '../../content/offerAcceleration';

interface Props {
  /** /offer-acceleration (canonical) is indexable; the /5 test route is not. */
  noindex?: boolean;
}

const { noindex = true } = Astro.props;
---

<Layout title={c.meta.title} description={c.meta.description} lang="es" noindex={noindex}>

  <main class="oa5">

    <header class="oa5-nav">
      <a href="/" class="oa5-nav__logo-link" aria-label="Purrfect Hire — inicio">
        <img src="/logos/logo-desktop.png" alt="Purrfect Hire" class="oa5-nav__logo" />
      </a>
      <nav class="oa5-nav__links">
        <a href="/for-talent" class="oa5-nav__link">Para talento</a>
        <a href="/roles" class="oa5-nav__link">Vacantes abiertas</a>
        <a href="/offer-acceleration" class="oa5-nav__link oa5-nav__link--active">Offer Acceleration</a>
      </nav>
      <a href={c.apply.url} id="oa5-apply-btn" class="oa5-btn oa5-btn--solid">
        {c.apply.label}
      </a>
    </header>

    <!-- ── Hero ─────────────────────────────────────────────────────── -->
    <section class="oa5-hero">
      <p class="oa5-eyebrow oa5-hero__eyebrow">{c.hero.eyebrow}</p>
      <h1 class="oa5-hero__headline">{c.hero.headline}</h1>
      <div class="oa5-hero__body">
        <p>{c.hero.para1}</p>
        <p>{c.hero.para2}</p>
      </div>
      <ul class="oa5-hero__stats">
        {c.hero.stats.map((s) => (
          <li class="oa5-hero__stat">{s}</li>
        ))}
      </ul>
    </section>

    <!-- ── Cost ─────────────────────────────────────────────────────── -->
    <section class="oa5-chapter">
      <div class="oa5-chapter__head oa5-reveal">
        <h2 class="oa5-chapter__title">{c.cost.title}</h2>
      </div>
      <div class="oa5-cost oa5-reveal">
        <p class="oa5-cost__lead">{c.cost.body1}</p>
        <p class="oa5-cost__body">{c.cost.body2}</p>
        <p class="oa5-cost__note">{c.cost.body3}</p>
      </div>
    </section>

    <!-- ── Cases ────────────────────────────────────────────────────── -->
    <section class="oa5-chapter" id="casos">
      <div class="oa5-chapter__head oa5-reveal">
        <h2 class="oa5-chapter__title">{c.cases.title}</h2>
      </div>
      <p class="oa5-chapter__subhead oa5-reveal">{c.cases.intro}</p>

      <div class="oa5-cases">
        {c.cases.items.map((item) => (
          <article class="oa5-case oa5-reveal">
            <h3 class="oa5-case__title">{item.title}</h3>
            <p class="oa5-case__body">{item.body}</p>
          </article>
        ))}
      </div>
    </section>

    <!-- ── How we work ──────────────────────────────────────────────── -->
    <section class="oa5-chapter">
      <div class="oa5-chapter__head oa5-reveal">
        <h2 class="oa5-chapter__title">{c.how.title}</h2>
      </div>
      <p class="oa5-chapter__subhead oa5-reveal">{c.how.intro}</p>

      <ol class="oa5-how">
        {c.how.bullets.map((b, i) => (
          <li class="oa5-how__item oa5-reveal">
            <span class="oa5-how__num">{String(i + 1).padStart(2, '0')}</span>
            <div class="oa5-how__text">
              <h3>{b.title}</h3>
              <p>{b.body}</p>
            </div>
          </li>
        ))}
      </ol>

      <p class="oa5-statement oa5-reveal">{c.how.close}</p>
    </section>

    <!-- ── The half we don't do ─────────────────────────────────────── -->
    <section class="oa5-chapter oa5-chapter--narrow">
      <div class="oa5-chapter__head oa5-reveal">
        <h2 class="oa5-chapter__title">{c.split.title}</h2>
      </div>
      <div class="oa5-split oa5-reveal">
        <p>{c.split.body1}</p>
        <p>{c.split.body2}</p>
        <p>{c.split.body3}</p>
      </div>
    </section>

    <!-- ── Investment ───────────────────────────────────────────────── -->
    <section class="oa5-chapter">
      <div class="oa5-chapter__head oa5-reveal">
        <h2 class="oa5-chapter__title">{c.investment.title}</h2>
      </div>

      <div class="oa5-invest oa5-reveal">
        <p class="oa5-invest__price">{c.investment.price}</p>
        <p class="oa5-invest__note">{c.investment.priceNote}</p>
      </div>

      <div class="oa5-tiers oa5-reveal">
        <div class="oa5-tiers__row oa5-tiers__row--head">
          <span>Seniority</span>
          <span>Hoy</span>
          <span>Salto realista</span>
          <span>Adicional / año</span>
          <span>Recuperas en</span>
        </div>
        {c.investment.tiers.map((t) => (
          <div class="oa5-tiers__row">
            <span class="oa5-tiers__seniority">{t.seniority}</span>
            <span>{t.current}</span>
            <span class="oa5-tiers__jump">{t.jump}</span>
            <span>{t.annual}</span>
            <span>{t.payback}</span>
          </div>
        ))}
      </div>
      <p class="oa5-tiers__note oa5-reveal">{c.investment.tableNote}</p>
    </section>

    <!-- ── Who's behind (dark section) ──────────────────────────────── -->
    <section class="oa5-chapter oa5-chapter--dark">
      <div class="oa5-chapter__head oa5-reveal">
        <h2 class="oa5-chapter__title">{c.who.title}</h2>
      </div>

      <div class="oa5-who oa5-reveal">
        <div class="oa5-who__kate">
          <h3>{c.who.kate.name}</h3>
          <p class="oa5-who__role">{c.who.kate.role}</p>
          <p>{c.who.kate.bio}</p>
          <p class="oa5-who__quote">“{c.who.kate.quote}”</p>
        </div>
        <div class="oa5-who__team">
          <h3>{c.who.team.name}</h3>
          <p>{c.who.team.bio}</p>
        </div>
      </div>
    </section>

    <!-- ── Format ───────────────────────────────────────────────────── -->
    <section class="oa5-chapter oa5-chapter--narrow">
      <div class="oa5-chapter__head oa5-reveal">
        <h2 class="oa5-chapter__title">{c.format.title}</h2>
      </div>
      <p class="oa5-format oa5-reveal">{c.format.body}</p>
    </section>

    <!-- ── FAQ ──────────────────────────────────────────────────────── -->
    <section class="oa5-chapter oa5-chapter--narrow">
      <div class="oa5-chapter__head oa5-reveal">
        <h2 class="oa5-chapter__title">{c.faq.title}</h2>
      </div>

      <div class="oa5-faq oa5-reveal">
        {c.faq.items.map((f) => (
          <details class="oa5-faq__item">
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </section>

    <!-- ── Final ────────────────────────────────────────────────────── -->
    <section class="oa5-final">
      <h2 class="oa5-final__title oa5-reveal">{c.final.title}</h2>
      <p class="oa5-final__note oa5-reveal">{c.final.body}</p>
      <div class="oa5-final__ctas oa5-reveal">
        <a href={c.apply.url} class="oa5-btn oa5-btn--solid oa5-btn--lg">
          {c.final.button}
        </a>
      </div>
      <p class="oa5-final__footer">© {new Date().getFullYear()} Purrfect Hire · Offer Acceleration</p>
    </section>
  </main>
</Layout>

<style lang="scss">
  $ease-expo: cubic-bezier(0.16, 1, 0.3, 1);

  .oa5 {
    // ── Flat navy/white 2026 tokens ──
    --oa5-bg: var(--bg, #ffffff);
    --oa5-bg-soft: var(--bg-soft, #fcfcfb);
    --oa5-surface: var(--bg, #ffffff);
    --oa5-text: var(--text, #1c1c1c);
    --oa5-ink: var(--ink, #29285f);
    --oa5-muted: var(--muted, #6b6b6b);
    --oa5-border: var(--line, rgba(0, 0, 0, 0.08));
    --oa5-dark: var(--dark, #29285f);
    --oa5-on-dark: var(--on-dark, #f3efe6);
    --oa5-radius: var(--radius, 12px);

    background: var(--oa5-bg);
    color: var(--oa5-text);
    font-family: 'Schibsted Grotesk', Arial, sans-serif;
    overflow-x: hidden;

    ::selection {
      background: var(--oa5-ink);
      color: #fff;
    }
  }

  .oa5-eyebrow {
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--oa5-ink);
  }

  // ── Nav ───────────────────────────────────────────────────
  .oa5-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem clamp(1.5rem, 5vw, 3rem);
    background: var(--oa5-bg);
    border-bottom: 1px solid var(--oa5-border);

    &__logo-link {
      display: inline-flex;
      align-items: center;
    }

    &__logo {
      width: 10rem;
    }

    &__links {
      display: flex;
      align-items: center;
      gap: 2rem;

      @media (max-width: 767px) { display: none; }
    }

    &__link {
      font-size: 0.875rem;
      font-weight: 500;
      color: var(--oa5-muted);
      text-decoration: none;
      transition: color 0.2s ease;

      &:hover { color: var(--oa5-ink); }
      &--active { color: var(--oa5-text); }
    }
  }

  // ── Buttons ───────────────────────────────────────────────
  .oa5-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 26px;
    font-size: 0.875rem;
    font-weight: 500;
    border-radius: var(--oa5-radius);
    text-decoration: none;
    color: var(--oa5-text);
    border: 1px solid var(--oa5-border);
    background: var(--oa5-bg);
    transition: background 0.25s $ease-expo, border-color 0.25s $ease-expo, color 0.25s $ease-expo;

    &:hover {
      border-color: var(--oa5-ink);
      color: var(--oa5-ink);
    }

    &--solid {
      background: var(--oa5-ink);
      border-color: var(--oa5-ink);
      color: #fff;

      &:hover {
        background: var(--oa5-text);
        border-color: var(--oa5-text);
        color: #fff;
      }
    }

    &--lg { padding: 16px 34px; font-size: 0.9375rem; }
  }

  // ── Hero ──────────────────────────────────────────────────
  .oa5-hero {
    position: relative;
    max-width: 1100px;
    margin: 0 auto;
    padding: clamp(64px, 9vw, 120px) clamp(1.5rem, 5vw, 2rem) 80px;

    &__eyebrow {
      margin-bottom: 1.75rem;
    }

    &__headline {
      font-family: 'Schibsted Grotesk', sans-serif;
      font-size: clamp(2.5rem, 6vw, 4.75rem);
      font-weight: 700;
      line-height: 1.04;
      letter-spacing: -0.02em;
      margin: 0;
      max-width: 18ch;
      color: var(--oa5-ink);
    }

    &__body {
      max-width: 44rem;
      margin-top: 2rem;
      display: flex;
      flex-direction: column;
      gap: 1.25rem;

      p {
        margin: 0;
        font-size: 1.0625rem;
        line-height: 1.65;
        color: var(--oa5-muted);
      }
    }

    &__stats {
      list-style: none;
      margin: 3rem 0 0;
      padding: 2rem 0 0;
      border-top: 1px solid var(--oa5-border);
      display: flex;
      flex-wrap: wrap;
      gap: 1rem 2.5rem;
    }

    &__stat {
      position: relative;
      font-size: 0.9375rem;
      font-weight: 500;
      color: var(--oa5-text);

      &:not(:last-child)::after {
        content: '·';
        position: absolute;
        right: -1.4rem;
        color: var(--oa5-muted);
      }
    }
  }

  // ── Chapters ──────────────────────────────────────────────
  .oa5-chapter {
    position: relative;
    max-width: 1100px;
    margin: 0 auto;
    padding: clamp(48px, 7vw, 80px) clamp(1.5rem, 5vw, 2rem);
    border-top: 1px solid var(--oa5-border);

    &--narrow { max-width: 760px; }

    &--dark {
      max-width: none;
      background: var(--oa5-dark);
      color: var(--oa5-on-dark);
      border-top: none;

      .oa5-chapter__title { color: var(--oa5-on-dark); }
    }

    &__head {
      margin-bottom: 2.5rem;
    }

    &__title {
      font-family: 'Schibsted Grotesk', sans-serif;
      font-size: clamp(1.875rem, 3.4vw, 3rem);
      font-weight: 700;
      letter-spacing: -0.02em;
      line-height: 1.1;
      margin: 0;
      color: var(--oa5-ink);
      max-width: 22ch;
    }

    &__subhead {
      max-width: 46rem;
      color: var(--oa5-muted);
      margin: -1rem 0 3rem;
      font-size: 1.0625rem;
      line-height: 1.65;
    }
  }

  // dark section inner content needs a centered max-width wrapper
  .oa5-chapter--dark > .oa5-chapter__head,
  .oa5-chapter--dark > .oa5-who {
    max-width: 1100px;
    margin-left: auto;
    margin-right: auto;
  }

  // ── Cost ──────────────────────────────────────────────────
  .oa5-cost {
    max-width: 46rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;

    &__lead {
      margin: 0;
      font-size: 1.375rem;
      line-height: 1.5;
      font-weight: 500;
      color: var(--oa5-text);
    }

    &__body {
      margin: 0;
      font-size: 1.0625rem;
      line-height: 1.65;
      color: var(--oa5-muted);
    }

    &__note {
      margin: 0;
      font-size: 1.0625rem;
      line-height: 1.6;
      font-weight: 500;
      color: var(--oa5-ink);
    }
  }

  .oa5-statement {
    margin: 3.5rem 0 0;
    max-width: 40rem;
    font-family: 'Schibsted Grotesk', sans-serif;
    font-size: clamp(1.375rem, 2.4vw, 2rem);
    font-weight: 500;
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: var(--oa5-ink);
  }

  // ── Cases ─────────────────────────────────────────────────
  .oa5-cases {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;

    @media (max-width: 767px) { grid-template-columns: 1fr; }
  }

  .oa5-case {
    background: var(--oa5-surface);
    border: 1px solid var(--oa5-border);
    border-radius: var(--oa5-radius);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    transition: border-color 0.25s $ease-expo;

    &:hover { border-color: var(--oa5-ink); }

    &__title {
      margin: 0;
      font-size: 1.0625rem;
      font-weight: 700;
      line-height: 1.4;
      color: var(--oa5-ink);
    }

    &__body {
      margin: 0;
      font-size: 0.9375rem;
      line-height: 1.65;
      color: var(--oa5-muted);
    }
  }

  // ── How ───────────────────────────────────────────────────
  .oa5-how {
    list-style: none;
    margin: 0;
    padding: 0;
    max-width: 56rem;
  }

  .oa5-how__item {
    display: grid;
    grid-template-columns: 3.5rem 1fr;
    gap: 1.75rem;
    padding: 1.75rem 0;
    border-bottom: 1px solid var(--oa5-border);

    &:first-child { border-top: 1px solid var(--oa5-border); }

    .oa5-how__num {
      font-family: 'Schibsted Grotesk', sans-serif;
      font-size: 1.25rem;
      font-weight: 500;
      color: var(--oa5-ink);
      line-height: 1.4;
    }

    .oa5-how__text {
      h3 {
        margin: 0 0 0.5rem;
        font-size: 1.125rem;
        font-weight: 700;
        color: var(--oa5-text);
      }

      p {
        margin: 0;
        font-size: 0.9375rem;
        line-height: 1.65;
        color: var(--oa5-muted);
        max-width: 42rem;
      }
    }

    @media (max-width: 480px) {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
  }

  // ── Split ─────────────────────────────────────────────────
  .oa5-split {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;

    p {
      margin: 0;
      font-size: 1.0625rem;
      line-height: 1.7;
      color: var(--oa5-muted);

      &:first-child { color: var(--oa5-text); font-weight: 500; }
    }
  }

  // ── Investment ────────────────────────────────────────────
  .oa5-invest {
    margin-bottom: 3rem;

    &__price {
      font-family: 'Schibsted Grotesk', sans-serif;
      font-size: clamp(2.25rem, 5vw, 3.5rem);
      font-weight: 700;
      letter-spacing: -0.02em;
      line-height: 1.05;
      margin: 0;
      color: var(--oa5-ink);
    }

    &__note {
      margin-top: 1rem;
      color: var(--oa5-muted);
      font-size: 1.0625rem;
    }
  }

  .oa5-tiers {
    border: 1px solid var(--oa5-border);
    border-radius: var(--oa5-radius);
    overflow: hidden;

    &__row {
      display: grid;
      grid-template-columns: 1.2fr 1fr 1fr 1fr 1fr;
      gap: 1.5rem;
      padding: 1.25rem 1.5rem;
      border-bottom: 1px solid var(--oa5-border);
      font-size: 0.9375rem;
      color: var(--oa5-muted);
      font-variant-numeric: tabular-nums;

      &:last-child { border-bottom: none; }

      &--head {
        font-size: 0.6875rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--oa5-muted);
        background: var(--oa5-bg-soft);
      }
    }

    &__seniority { color: var(--oa5-text); font-weight: 500; }
    &__jump { color: var(--oa5-ink); font-weight: 500; }

    &__note {
      margin: 1.25rem 0 0;
      font-size: 0.8125rem;
      color: var(--oa5-muted);
    }

    @media (max-width: 767px) {
      &__row {
        grid-template-columns: 1fr 1fr;
        gap: 0.5rem 1rem;
      }
      &__row--head { display: none; }
      &__seniority { grid-column: 1 / -1; font-size: 1rem; }
    }
  }

  // ── Who (dark) ────────────────────────────────────────────
  .oa5-who {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: 1.5rem;

    @media (max-width: 767px) { grid-template-columns: 1fr; }

    h3 {
      font-family: 'Schibsted Grotesk', sans-serif;
      font-size: 1.375rem;
      font-weight: 700;
      margin: 0 0 0.375rem;
      color: var(--oa5-on-dark);
    }

    p {
      margin: 1rem 0 0;
      font-size: 0.9375rem;
      line-height: 1.7;
      color: rgba(243, 239, 230, 0.78);
    }

    &__role {
      margin-top: 0 !important;
      font-size: 0.8125rem !important;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: rgba(243, 239, 230, 0.6) !important;
    }

    &__kate,
    &__team {
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid rgba(243, 239, 230, 0.16);
      border-radius: var(--oa5-radius);
      padding: 2rem;
    }

    &__quote {
      color: var(--oa5-on-dark) !important;
      font-weight: 500;
      font-size: 1.0625rem !important;
    }
  }

  // ── Format ────────────────────────────────────────────────
  .oa5-format {
    margin: 0;
    max-width: 46rem;
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--oa5-muted);
  }

  // ── FAQ ───────────────────────────────────────────────────
  .oa5-faq {
    max-width: 46rem;

    &__item {
      border-bottom: 1px solid var(--oa5-border);

      &:first-child { border-top: 1px solid var(--oa5-border); }

      summary {
        padding: 1.5rem 2.5rem 1.5rem 0;
        font-size: 1.0625rem;
        font-weight: 500;
        color: var(--oa5-text);
        cursor: pointer;
        list-style: none;
        position: relative;

        &::-webkit-details-marker { display: none; }

        &::after {
          content: '+';
          position: absolute;
          right: 0.25rem;
          top: 50%;
          transform: translateY(-50%);
          color: var(--oa5-ink);
          font-size: 1.375rem;
          font-weight: 400;
          transition: transform 0.25s $ease-expo;
        }
      }

      &[open] summary::after { transform: translateY(-50%) rotate(45deg); }

      p {
        margin: 0 0 1.5rem;
        font-size: 0.9375rem;
        line-height: 1.7;
        color: var(--oa5-muted);
        max-width: 42rem;
      }
    }
  }

  // ── Final ─────────────────────────────────────────────────
  .oa5-final {
    position: relative;
    max-width: 1100px;
    margin: 0 auto;
    padding: clamp(64px, 9vw, 110px) clamp(1.5rem, 5vw, 2rem) 3rem;
    text-align: center;
    border-top: 1px solid var(--oa5-border);

    &__title {
      font-family: 'Schibsted Grotesk', sans-serif;
      font-size: clamp(2rem, 4.5vw, 3.5rem);
      font-weight: 700;
      letter-spacing: -0.02em;
      line-height: 1.1;
      margin: 0 auto;
      max-width: 18ch;
      color: var(--oa5-ink);
    }

    &__note {
      max-width: 34rem;
      margin: 1.5rem auto 0;
      color: var(--oa5-muted);
      font-size: 1rem;
      line-height: 1.65;
    }

    &__ctas {
      display: flex;
      justify-content: center;
      gap: 1rem;
      margin-top: 2.5rem;
    }

    &__footer {
      margin-top: 5rem;
      font-size: 0.8125rem;
      color: var(--oa5-muted);
    }
  }

  // ── Scroll reveals ────────────────────────────────────────
  .oa5-reveal {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.8s $ease-expo, transform 0.8s $ease-expo;

    &.is-visible {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .oa5-reveal { transition: none; opacity: 1; transform: none; }
  }
</style>

<script>
  const reveals = document.querySelectorAll('.oa5-reveal');
  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add('is-visible');
          io.unobserve(e.target);
        }
      });
    },
    { threshold: 0.12 }
  );
  reveals.forEach((el) => io.observe(el));
</script>
