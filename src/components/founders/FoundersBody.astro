---
// ── For Founders — Body ──────────────────────────────────────────────────
// Everything below the hero: the metrics strip, the client logo wall, the
// "why culture fit" answer block (a16z / YC research quotes), the 4-step
// engine, founder testimonials, and the closing CTA. All content is pulled
// from the shared content object so the facts stay consistent with the rest
// of the site. Isolated under the `ff-` prefix.
import type { LandingContent } from '../../content/index';

interface Props {
  content: LandingContent;
}

const { content } = Astro.props;
const { hero, engine, culture, testimonials } = content;

const BOOKING_URL = 'https://calendly.com/purrfecthire/5';

// "How we work" — compact view of the 3 B2B models; full tables on /pricing.
const models = [
  {
    name: 'Success Fee',
    forWho: '1–2 critical hires a year',
    model: 'You pay only when you hire, a percentage of first-year salary. 90-day replacement guarantee.',
    price: 'Exact terms in a 20-min call',
  },
  {
    name: 'All You Can Hire',
    forWho: '4–6+ senior hires a year',
    model: 'Flat monthly fee, up to 6 senior hires in 12 months. Dedicated recruiter, always-on pipeline.',
    price: 'From $9,000/month',
  },
  {
    name: 'Embedded Search',
    forWho: 'The role that defines the company',
    model: 'Dedicated search with retainer + success fee. Kate directly on the search. 120-day guarantee.',
    price: 'Direct conversation',
  },
];

const clients = [
  { name: 'Trébol', logo: '/clients/trebol.png' },
  { name: 'Cheaf', logo: '/clients/cheaf.png' },
  { name: 'Mavi', logo: '/clients/mavi.png' },
  { name: 'Hera', logo: '/clients/hera.png' },
  { name: 'Heron', logo: '/clients/heron.png' },
  { name: 'Optery', logo: '/clients/optery.png' },
];

// Three founder testimonials — the proof, kept short.
const quotes = [testimonials.featured, ...testimonials.grid.slice(0, 2)];
---

<!-- ── Metrics ─────────────────────────────────────────────────────────── -->
<section id="metrics" class="ff-metrics">
  <div class="ff-metrics__container">
    <div class="ff-metrics__strip reveal">
      {hero.stats.map((stat, i) => (
        <>
          {i > 0 && <div class="ff-metrics__divider" />}
          <div class="ff-metrics__item">
            <div class="ff-metrics__value">{stat.suffixLeft}{stat.value}{stat.suffix}</div>
            <p class="ff-metrics__label">{stat.label}</p>
          </div>
        </>
      ))}
    </div>

    <!-- Client wall -->
    <div class="ff-metrics__clients reveal reveal-delay-1">
      <p class="ff-metrics__clients-label eyebrow">Trusted by founders at</p>
      <div class="ff-metrics__clients-row">
        {clients.map((c) => (
          <img src={c.logo} alt={c.name} class="ff-metrics__client-logo" loading="lazy" />
        ))}
      </div>
    </div>
  </div>
</section>

<!-- ── Why culture fit ─────────────────────────────────────────────────── -->
<section id="why" class="ff-why">
  <div class="ff-why__container">

    <div class="ff-why__answer reveal">
      <h2 class="ff-why__q headline2">Why hire for culture fit, not just skills?</h2>
      <p class="ff-why__a body1">
        Because the interview isn't where hires fail. Week four is. 46% of new hires fail
        within 18 months, and 89% of those failures come down to culture and attitude
        misalignment, not a skills gap. In a team of ten, one wrong hire doesn't just
        underperform: they slow everyone down, erode trust, and force your best people to
        cover the gap. We start with fit, so it's the foundation rather than the final check.
      </p>
      <div class="ff-why__quote-row">
        {culture.quotes.map((q) => (
          <figure class="ff-why__research">
            <blockquote class="body2">"{q.text}"</blockquote>
            <figcaption class="eyebrow">{q.attribution}</figcaption>
          </figure>
        ))}
      </div>
    </div>

    <!-- The engine -->
    <div class="ff-why__answer reveal reveal-delay-1">
      <h2 class="ff-why__q headline2">How the engine works</h2>
      <p class="ff-why__a body1">
        It's a closed loop. We go deep on how a startup really operates, that signal trains
        the talent we place, candidates arrive already aligned, and every outcome feeds back
        to sharpen the model. Four steps:
      </p>
      <ol class="ff-why__steps">
        {engine.steps.map((step) => (
          <li class="ff-why__step">
            <span class="ff-why__step-id">{step.id}</span>
            <div class="ff-why__step-text">
              <strong class="ff-why__step-title">{step.title}</strong>
              <span class="ff-why__step-desc">{step.description}</span>
            </div>
          </li>
        ))}
      </ol>
    </div>

    <!-- Founder testimonials -->
    <div class="ff-why__quotes reveal reveal-delay-1">
      {quotes.map((q) => (
        <figure class="ff-why__quote-card">
          <blockquote class="ff-why__quote-text body2">"{q.quote}"</blockquote>
          <figcaption class="ff-why__quote-meta">
            <span class="ff-why__quote-name">{q.name}</span>
            <span class="ff-why__quote-role caption">{q.role}</span>
          </figcaption>
        </figure>
      ))}
    </div>

  </div>
</section>

<!-- ── How we work: the 3 engagement models (full tables on /pricing) ──── -->
<section id="models" class="ff-models">
  <div class="ff-models__container">
    <header class="ff-models__header reveal">
      <h2 class="ff-models__headline headline2">How we work</h2>
      <p class="ff-models__sub body1">
        Three ways to engage, depending on how much you hire. Structure is public;
        exact terms are a 20-minute conversation.
      </p>
    </header>

    <div class="ff-models__grid">
      {models.map((m) => (
        <article class="ff-models__card reveal reveal-delay-1">
          <h3 class="ff-models__card-title">{m.name}</h3>
          <p class="ff-models__card-for caption">{m.forWho}</p>
          <p class="ff-models__card-body">{m.model}</p>
          <p class="ff-models__card-price">{m.price}</p>
        </article>
      ))}
    </div>

    <p class="ff-models__foot reveal reveal-delay-1">
      <a href="/pricing" class="ff-models__link">Compare the three models on the pricing page →</a>
    </p>

    <!-- B2B video slot — described placeholder until it's recorded -->
    <div class="ff-models__video reveal reveal-delay-2" role="img"
      aria-label="Video pending: Kate, founder-to-founder, on how we map your real bar and why our placements stay past year two. 60 seconds.">
      <span class="ff-models__video-glyph" aria-hidden="true">▶</span>
      <p class="ff-models__video-caption">
        Video pending (60 seconds): Kate, founder-to-founder, on how we map your real bar
        before opening the pipeline, and why 80% of our placements are still in the seat
        after two years.
      </p>
    </div>
  </div>
</section>

<!-- ── Closing CTA ─────────────────────────────────────────────────────── -->
<section class="ff-cta">
  <div class="ff-cta__container reveal">
    <h2 class="ff-cta__headline headline2">Tell us how your team actually works.</h2>
    <p class="ff-cta__sub body1">
      The first conversation is fast and honest. No pipeline spam, just a real read on
      whether we can find someone who clears your bar and stays.
    </p>
    <div class="ff-cta__actions">
      <a href={BOOKING_URL} target="_blank" rel="noopener" class="btn ff-cta__btn">Talk to our team →</a>
      <a href="/for-talent" class="ff-cta__link">Looking for a role instead? →</a>
    </div>
  </div>
</section>

<style lang="scss">
  @use '../../styles/breakpoints' as *;

  $accent: #29285F;

  // ── How we work (3 models) ─────────────────────────────────
  .ff-models {
    position: relative;
    z-index: 1;
    padding-block: 5rem;
    scroll-margin-top: 5rem;
    border-top: 1px solid var(--line);

    &__container {
      max-width: 60rem;
      margin-inline: auto;
      padding-inline: 2rem;
      display: flex;
      flex-direction: column;
      gap: 2.5rem;

      @include max-lg { padding-inline: 1.5rem; }
      @include max-sm { padding-inline: 1rem; }
    }

    &__header {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      max-width: 46rem;
    }

    &__headline { color: var(--ink); margin: 0; }
    &__sub { color: var(--color-muted); margin: 0; }

    &__grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;

      @include max-md { grid-template-columns: 1fr; }
    }

    &__card {
      display: flex;
      flex-direction: column;
      gap: 0.625rem;
      padding: 1.75rem;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: var(--bg);
      transition: border-color 0.2s ease;

      &:hover { border-color: $accent; }
    }

    &__card-title { margin: 0; font-size: 1.125rem; font-weight: 700; color: var(--color-text); }
    &__card-for { color: $accent; font-weight: 600; }
    &__card-body { margin: 0; font-size: 0.875rem; line-height: 1.6; color: var(--color-muted); }
    &__card-price {
      margin: auto 0 0;
      padding-top: 0.75rem;
      font-size: 1rem;
      font-weight: 700;
      letter-spacing: -0.01em;
      color: $accent;
    }

    &__foot { margin: 0; }
    &__link {
      font-size: 0.9375rem;
      font-weight: 600;
      color: $accent;
      text-decoration: none;

      &:hover { text-decoration: underline; }
    }

    // B2B video placeholder — honest dashed frame, 16:9
    &__video {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 1rem;
      text-align: center;
      aspect-ratio: 16 / 9;
      max-height: 340px;
      padding: 2rem;
      background: var(--bg-soft);
      border: 1px dashed rgba(41, 40, 95, 0.35);
      border-radius: var(--radius);
    }

    &__video-glyph {
      width: 3.5rem;
      height: 3.5rem;
      display: grid;
      place-items: center;
      border-radius: 50%;
      background: $accent;
      color: #fff;
      font-size: 1.125rem;
      padding-left: 3px;
    }

    &__video-caption {
      margin: 0;
      font-size: 0.8125rem;
      line-height: 1.55;
      color: var(--color-muted);
      max-width: 34rem;
    }
  }

  // ── Metrics ────────────────────────────────────────────────
  .ff-metrics {
    position: relative;
    z-index: 1;
    padding-block: 4rem;
    scroll-margin-top: 5rem;
    background: var(--bg-soft);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);

    &__container {
      max-width: 60rem;
      margin-inline: auto;
      padding-inline: 2rem;
      display: flex;
      flex-direction: column;
      gap: 2.75rem;
      align-items: center;

      @include max-lg { padding-inline: 1.5rem; }
      @include max-sm { padding-inline: 1rem; }
    }

    &__strip {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 3rem;

      @include max-sm { gap: 1.5rem; }
    }

    &__item { display: flex; flex-direction: column; align-items: center; gap: 0.25rem; text-align: center; }
    &__value {
      font-size: 2.75rem;
      font-weight: 700;
      line-height: 1;
      color: $accent;
      letter-spacing: -0.02em;
      @include max-sm { font-size: 1.875rem; }
    }
    &__label { font-size: 0.875rem; color: var(--color-muted); max-width: 120px; }
    &__divider { width: 1px; height: 44px; background: var(--color-border); }

    &__clients { display: flex; flex-direction: column; align-items: center; gap: 1.25rem; width: 100%; }
    &__clients-label { color: var(--color-tertiary); }
    &__clients-row {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: center;
      gap: 2.5rem;
      @include max-sm { gap: 1.5rem; }
    }
    &__client-logo {
      height: 28px; width: auto; max-width: 110px; object-fit: contain;
      filter: grayscale(1);
      opacity: 0.55;
      transition: opacity .2s;
      &:hover { opacity: 1; }
    }
  }

  // ── Why ────────────────────────────────────────────────────
  .ff-why {
    position: relative;
    z-index: 1;
    padding-block: 6rem;

    @include max-md { padding-block: 4rem; }

    &__container {
      max-width: 46rem;
      margin-inline: auto;
      padding-inline: 2rem;
      display: flex;
      flex-direction: column;
      gap: 3.5rem;

      @include max-lg { padding-inline: 1.5rem; }
      @include max-sm { padding-inline: 1rem; }
    }

    &__answer { display: flex; flex-direction: column; gap: 1rem; }
    &__q {
      color: var(--color-text);
      padding-left: 0.875rem;
      border-left: 3px solid $accent;
    }
    &__a { color: var(--color-muted); }

    &__quote-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
      margin-top: 0.5rem;
      @include max-sm { grid-template-columns: 1fr; }
    }
    &__research {
      margin: 0;
      padding: 1.25rem;
      border: 1px solid var(--color-border);
      border-radius: var(--radius);
      background: var(--bg-soft);
      display: flex;
      flex-direction: column;
      gap: 0.625rem;
      blockquote { margin: 0; color: var(--color-text); font-style: italic; }
      figcaption { color: $accent; }
    }

    // Steps
    &__steps {
      list-style: none; margin: 0; padding: 0;
      display: flex; flex-direction: column; gap: 1rem;
    }
    &__step { display: flex; gap: 1rem; align-items: flex-start; }
    &__step-id {
      flex-shrink: 0;
      font-size: 0.875rem;
      font-weight: 600;
      color: $accent;
      background: rgba(41, 40, 95, 0.1);
      width: 2rem; height: 2rem;
      border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
    }
    &__step-text { display: flex; flex-direction: column; gap: 0.25rem; }
    &__step-title { color: var(--color-text); font-weight: 500; line-height: 1.4; }
    &__step-desc { font-size: 0.9375rem; line-height: 1.55; color: var(--color-muted); }

    // Testimonials
    &__quotes {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
      @include max-md { grid-template-columns: 1fr; }
    }
    &__quote-card {
      margin: 0;
      padding: 1.5rem;
      border: 1px solid var(--color-border);
      border-radius: var(--radius);
      background: var(--bg-soft);
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    &__quote-text { color: var(--color-text); font-style: italic; }
    &__quote-meta { display: flex; flex-direction: column; gap: 0.125rem; margin-top: auto; }
    &__quote-name { font-size: 0.875rem; font-weight: 500; color: var(--color-text); }
    &__quote-role { color: var(--color-tertiary); }
  }

  // ── CTA ────────────────────────────────────────────────────
  .ff-cta {
    position: relative;
    z-index: 1;
    padding-block: 6rem;
    background: var(--bg-soft);
    border-top: 1px solid var(--line);

    @include max-md { padding-block: 4rem; }

    &__container {
      max-width: 42rem;
      margin-inline: auto;
      padding-inline: 2rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 1rem;
    }
    &__headline { color: var(--color-text); }
    &__sub { max-width: 34rem; }
    &__actions {
      margin-top: 1rem;
      display: flex;
      align-items: center;
      gap: 1.5rem;
      flex-wrap: wrap;
      justify-content: center;
    }
    &__btn { padding: 14px 28px; }
    &__link {
      font-size: 0.875rem;
      font-weight: 500;
      color: var(--color-text);
      text-decoration: underline;
      text-underline-offset: 3px;
      text-decoration-color: var(--color-border);
      transition: color 0.15s ease;
      &:hover { color: $accent; }
    }
  }
</style>
