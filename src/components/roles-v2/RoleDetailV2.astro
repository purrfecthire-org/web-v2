---
import type { Role } from '../../content/roleSample';

interface Props {
  role: Role;
}

const { role } = Astro.props;
const c = role.company;

const location = [...role.countries, ...(role.states ?? [])];
const internalStages = role.interviewProcess?.filter((s) => s.group === 'internal') ?? [];
const clientStages = role.interviewProcess?.filter((s) => s.group === 'client') ?? [];
const applyHref = role.applyEmail ? `mailto:${role.applyEmail}` : '#apply';
---

<div class="rv2">
  <!-- Slim top bar -->
  <header class="rv2__bar">
    <a href="/" class="rv2__brand">Purrfect&nbsp;Hire</a>
    <nav class="rv2__bar-nav">
      <a href="/#roles" class="rv2__bar-link">All roles</a>
      <a href={applyHref} class="rv2__bar-cta">Apply</a>
    </nav>
  </header>

  <div class="rv2__layout">
    <!-- ── Sticky left rail ─────────────────────────────────────────── -->
    <aside class="rv2__rail">
      <div class="rv2__rail-inner">
        <span class="rv2__company">{role.companyLabel}</span>
        <h1 class="rv2__title">{role.title}</h1>

        <ul class="rv2__facts">
          <li class="rv2__fact">
            <span class="rv2__fact-key">Location</span>
            <span class="rv2__fact-val">{location.join(', ')}</span>
          </li>
          <li class="rv2__fact">
            <span class="rv2__fact-key">Work type</span>
            <span class="rv2__fact-val">{role.modality} · {role.employmentType}</span>
          </li>
          {role.englishLevel && (
            <li class="rv2__fact">
              <span class="rv2__fact-key">English</span>
              <span class="rv2__fact-val rv2__fact-val--accent">{role.englishLevel}</span>
            </li>
          )}
          {c.size && (
            <li class="rv2__fact">
              <span class="rv2__fact-key">Team</span>
              <span class="rv2__fact-val">{c.size}</span>
            </li>
          )}
          {c.founded && (
            <li class="rv2__fact">
              <span class="rv2__fact-key">Founded</span>
              <span class="rv2__fact-val">{c.founded}</span>
            </li>
          )}
          {c.funding && (
            <li class="rv2__fact">
              <span class="rv2__fact-key">Funding</span>
              <span class="rv2__fact-val">{c.funding}</span>
            </li>
          )}
        </ul>

        {c.ycBatch && (
          <span class="rv2__yc">
            <span class="rv2__yc-mark" aria-hidden="true">Y</span>
            Y Combinator · {c.ycBatch}
          </span>
        )}

        <a href={applyHref} class="rv2__apply">
          Apply for this role
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>

        <p class="rv2__rail-note">Company details are shared after your intro call.</p>
      </div>
    </aside>

    <!-- ── Scrollable content ───────────────────────────────────────── -->
    <main class="rv2__content">
      <!-- Company -->
      <section class="rv2__block">
        <span class="rv2__eyebrow">The Company</span>
        <p class="rv2__lede">{c.description}</p>
        {c.industry && <p class="rv2__industry">{c.industry}</p>}

        {c.awards && c.awards.length > 0 && (
          <div class="rv2__awards">
            {c.awards.map((a) => (
              <span class="rv2__award">
                <svg width="13" height="13" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                  <path d="M7 1.5 8.7 5l3.8.5-2.8 2.7.7 3.8L7 10.2 3.6 12l.7-3.8L1.5 5.5 5.3 5 7 1.5Z" fill="currentColor"/>
                </svg>
                {a.label}{a.year ? ` ${a.year}` : ''}{a.source ? ` · ${a.source}` : ''}
              </span>
            ))}
          </div>
        )}

        {c.strengths && c.strengths.length > 0 && (
          <div class="rv2__strengths">
            {c.strengths.map((s) => (
              <span class="rv2__strength">
                <svg width="13" height="13" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                  <path d="M11.5 4 6 9.5 3 6.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {s}
              </span>
            ))}
          </div>
        )}
      </section>

      <div class="rv2__rule" aria-hidden="true"></div>

      <!-- Role -->
      <section class="rv2__block">
        <span class="rv2__eyebrow rv2__eyebrow--role">The Role</span>
        <p class="rv2__lede">{role.roleDescription}</p>

        {role.skills && role.skills.length > 0 && (
          <div class="rv2__skills">
            {role.skills.map((s) => <span class="rv2__skill">{s}</span>)}
          </div>
        )}

        <div class="rv2__reqs">
          <div class="rv2__req-col">
            <h3 class="rv2__req-title">Must have</h3>
            <ul class="rv2__req-list">
              {role.requirements.mandatory.map((r) => (
                <li class="rv2__req rv2__req--must">
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <circle cx="8" cy="8" r="8" fill="currentColor" opacity="0.12"/>
                    <path d="M11.5 5.5 7 10 5 8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  <span>{r}</span>
                </li>
              ))}
            </ul>
          </div>

          {role.requirements.niceToHave && role.requirements.niceToHave.length > 0 && (
            <div class="rv2__req-col">
              <h3 class="rv2__req-title rv2__req-title--nice">Nice to have</h3>
              <ul class="rv2__req-list">
                {role.requirements.niceToHave.map((r) => (
                  <li class="rv2__req rv2__req--nice">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                      <path d="M4 8h8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                    </svg>
                    <span>{r}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>

        {role.englishLevel && (
          <div class="rv2__english">
            <svg width="15" height="15" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.2"/>
              <path d="M1.5 7h11M7 1.5c1.6 1.6 1.6 9.4 0 11M7 1.5c-1.6 1.6-1.6 9.4 0 11" stroke="currentColor" stroke-width="1.1"/>
            </svg>
            Minimum English required: <strong>{role.englishLevel}</strong>
          </div>
        )}
      </section>

      <!-- Interview process (optional) -->
      {role.interviewProcess && role.interviewProcess.length > 0 && (
        <>
          <div class="rv2__rule" aria-hidden="true"></div>
          <section class="rv2__block">
            <span class="rv2__eyebrow">Interview Process</span>

            {internalStages.length > 0 && (
              <div class="rv2__phase">
                <h3 class="rv2__phase-title">Internal process</h3>
                <ol class="rv2__timeline">
                  {internalStages.map((s) => (
                    <li class="rv2__step">
                      <span class="rv2__step-dot" aria-hidden="true"></span>
                      <div class="rv2__step-body">
                        <div class="rv2__step-head">
                          <span class="rv2__step-name">{s.name}</span>
                          {s.duration && <span class="rv2__step-time">{s.duration}</span>}
                        </div>
                        {s.detail && <p class="rv2__step-detail">{s.detail}</p>}
                      </div>
                    </li>
                  ))}
                </ol>
              </div>
            )}

            {clientStages.length > 0 && (
              <div class="rv2__phase">
                <h3 class="rv2__phase-title rv2__phase-title--client">Client stage</h3>
                <ol class="rv2__timeline">
                  {clientStages.map((s) => (
                    <li class="rv2__step rv2__step--client">
                      <span class="rv2__step-dot" aria-hidden="true"></span>
                      <div class="rv2__step-body">
                        <div class="rv2__step-head">
                          <span class="rv2__step-name">{s.name}</span>
                          {s.duration && <span class="rv2__step-time">{s.duration}</span>}
                        </div>
                        {s.detail && <p class="rv2__step-detail">{s.detail}</p>}
                      </div>
                    </li>
                  ))}
                </ol>
              </div>
            )}
          </section>
        </>
      )}

      <!-- Final CTA -->
      <section class="rv2__cta" id="apply">
        <div>
          <h2 class="rv2__cta-title">Think this is you?</h2>
          <p class="rv2__cta-sub">Apply once. We match you with the roles where you fit best.</p>
        </div>
        <a href={applyHref} class="rv2__apply rv2__apply--cta">
          Apply for this role
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </section>
    </main>
  </div>
</div>

<style lang="scss">
  @use '../../styles/breakpoints' as *;

  $indigo: #3C2BDC;
  $cyan: #7C3AED;
  $emerald: #0D0857;
  $ink: #111827;
  $muted: #6B7280;
  $subtle: #9CA3AF;
  $border: rgba(229, 231, 235, 0.9);
  $grad: linear-gradient(135deg, #{$indigo} 0%, #{$cyan} 100%);

  .rv2 {
    position: relative;
    z-index: 1;
    font-family: Inter, sans-serif;
    color: $ink;
    min-height: 100vh;
  }

  // ── Top bar ──────────────────────────────────────────────────────
  .rv2__bar {
    position: sticky;
    top: 0;
    z-index: 30;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px clamp(1.25rem, 4vw, 2.5rem);
    background: rgba(250, 249, 247, 0.8);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid rgba(60, 43, 220, 0.08);
  }

  .rv2__brand {
    font-weight: 800;
    font-size: 1.05rem;
    letter-spacing: -0.02em;
    color: $ink;
    text-decoration: none;
  }

  .rv2__bar-nav { display: flex; align-items: center; gap: 1.25rem; }

  .rv2__bar-link {
    font-size: 14px;
    font-weight: 500;
    color: $muted;
    text-decoration: none;
    transition: color 0.15s ease;
    &:hover { color: $indigo; }
    @include max-sm { display: none; }
  }

  .rv2__bar-cta {
    display: inline-flex;
    align-items: center;
    background: $grad;
    color: #fff;
    border-radius: 999px;
    padding: 9px 20px;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    box-shadow: 0 4px 16px rgba(60, 43, 220, 0.3);
    transition: transform 0.15s ease;
    &:hover { transform: translateY(-1px); }
  }

  // ── Two-column layout ────────────────────────────────────────────
  .rv2__layout {
    max-width: 78rem;
    margin-inline: auto;
    padding: clamp(2rem, 5vw, 3.5rem) clamp(1.25rem, 4vw, 2.5rem) 4rem;
    display: grid;
    grid-template-columns: 340px 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;

    @include max-lg { grid-template-columns: 1fr; gap: 2rem; }
  }

  // ── Left rail ────────────────────────────────────────────────────
  .rv2__rail {
    position: sticky;
    top: 88px;

    @include max-lg { position: static; }
  }

  .rv2__rail-inner {
    background: rgba(255, 255, 255, 0.85);
    border: 1.5px solid $border;
    border-radius: 22px;
    padding: clamp(1.5rem, 3vw, 2rem);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: 0 8px 36px rgba(60, 43, 220, 0.06);
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .rv2__company {
    font-size: 11.5px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: $subtle;
  }

  .rv2__title {
    font-size: clamp(1.6rem, 3vw, 2rem);
    font-weight: 800;
    line-height: 1.12;
    letter-spacing: -0.025em;
    margin: -0.5rem 0 0;
    color: $ink;
  }

  .rv2__facts {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }

  .rv2__fact {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding: 11px 0;
    border-bottom: 1px solid rgba(60, 43, 220, 0.08);
    &:last-child { border-bottom: none; }
  }

  .rv2__fact-key {
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: $subtle;
    flex-shrink: 0;
  }

  .rv2__fact-val {
    font-size: 14px;
    font-weight: 600;
    color: $ink;
    text-align: right;
    &--accent { color: $indigo; }
  }

  .rv2__yc {
    display: inline-flex;
    align-self: flex-start;
    align-items: center;
    gap: 7px;
    background: #FF6B00;
    color: #fff;
    border-radius: 999px;
    padding: 6px 14px 6px 7px;
    font-size: 13px;
    font-weight: 700;
    box-shadow: 0 4px 14px rgba(255, 107, 0, 0.3);
  }

  .rv2__yc-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    border-radius: 5px;
    background: #fff;
    color: #FF6B00;
    font-weight: 800;
    font-size: 14px;
  }

  .rv2__apply {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    background: $grad;
    color: #fff;
    border-radius: 999px;
    padding: 14px 26px;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    box-shadow: 0 4px 20px rgba(60, 43, 220, 0.35);
    transition: transform 0.15s ease, box-shadow 0.2s ease, opacity 0.2s ease;
    svg { transition: transform 0.2s ease; }
    &:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(60, 43, 220, 0.45); opacity: 0.96; }
    &:hover svg { transform: translateX(3px); }
    &--cta { flex-shrink: 0; }
  }

  .rv2__rail-note {
    margin: 0;
    font-size: 12px;
    line-height: 1.5;
    color: $subtle;
    text-align: center;
  }

  // ── Content column ───────────────────────────────────────────────
  .rv2__content {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 2.25rem;
  }

  .rv2__rule {
    height: 1px;
    background: linear-gradient(90deg, rgba(60, 43, 220, 0.18), rgba(60, 43, 220, 0.02));
  }

  .rv2__eyebrow {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    background: $grad;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 1rem;

    &--role {
      background: linear-gradient(135deg, #{$cyan} 0%, #{$emerald} 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
  }

  .rv2__lede {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: #374151;
    margin: 0;
  }

  .rv2__industry {
    margin: 0.75rem 0 0;
    font-size: 14px;
    font-weight: 600;
    color: $cyan;
  }

  .rv2__awards {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 1.5rem;
  }

  .rv2__award {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(60, 43, 220, 0.06);
    border: 1px solid rgba(60, 43, 220, 0.16);
    color: $indigo;
    border-radius: 999px;
    padding: 6px 14px;
    font-size: 12.5px;
    font-weight: 600;
    svg { color: #F59E0B; }
  }

  .rv2__strengths {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 1rem;
  }

  .rv2__strength {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(13, 8, 87, 0.07);
    border: 1px solid rgba(13, 8, 87, 0.18);
    color: #0D0857;
    border-radius: 999px;
    padding: 7px 14px;
    font-size: 13px;
    font-weight: 500;
    svg { color: $emerald; }
  }

  .rv2__skills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 1.5rem;
  }

  .rv2__skill {
    background: rgba(60, 43, 220, 0.08);
    color: $indigo;
    border: 1px solid rgba(60, 43, 220, 0.16);
    border-radius: 7px;
    padding: 5px 12px;
    font-size: 13px;
    font-weight: 600;
  }

  .rv2__reqs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.75rem 2.5rem;
    margin-top: 2rem;
    @include max-md { grid-template-columns: 1fr; gap: 1.75rem; }
  }

  .rv2__req-title {
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: $indigo;
    margin: 0 0 1rem;
    &--nice { color: $subtle; }
  }

  .rv2__req-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .rv2__req {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 0.95rem;
    line-height: 1.5;
    svg { flex-shrink: 0; margin-top: 2px; }
    &--must { color: #1F2937; font-weight: 500; svg { color: $indigo; } }
    &--nice { color: $muted; svg { color: $subtle; } }
  }

  .rv2__english {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 2rem;
    background: rgba(60, 43, 220, 0.06);
    border: 1px solid rgba(60, 43, 220, 0.16);
    border-radius: 12px;
    padding: 12px 16px;
    font-size: 14px;
    color: #374151;
    svg { color: $indigo; flex-shrink: 0; }
    strong { color: $indigo; font-weight: 700; }
  }

  // ── Timeline ─────────────────────────────────────────────────────
  .rv2__phase { & + & { margin-top: 2rem; } }

  .rv2__phase-title {
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: $indigo;
    margin: 0 0 1.25rem;
    &--client { color: $emerald; }
  }

  .rv2__timeline { list-style: none; margin: 0; padding: 0; }

  .rv2__step {
    position: relative;
    padding-left: 28px;
    padding-bottom: 1.5rem;
    &::before {
      content: '';
      position: absolute;
      left: 6px;
      top: 16px;
      bottom: -2px;
      width: 2px;
      background: rgba(60, 43, 220, 0.14);
    }
    &:last-child::before { display: none; }
    &--client::before { background: rgba(13, 8, 87, 0.18); }
  }

  .rv2__step-dot {
    position: absolute;
    left: 0;
    top: 5px;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: #fff;
    border: 3px solid $indigo;
    .rv2__step--client & { border-color: $emerald; }
  }

  .rv2__step-head {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 10px;
  }

  .rv2__step-name { font-size: 1rem; font-weight: 700; color: $ink; }

  .rv2__step-time {
    font-size: 12px;
    font-weight: 600;
    color: $muted;
    background: rgba(17, 24, 39, 0.05);
    border-radius: 999px;
    padding: 2px 10px;
  }

  .rv2__step-detail {
    margin: 5px 0 0;
    font-size: 0.9rem;
    line-height: 1.55;
    color: $muted;
  }

  // ── Final CTA ────────────────────────────────────────────────────
  .rv2__cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
    padding: clamp(1.75rem, 4vw, 2.5rem);
    background: linear-gradient(135deg, rgba(60, 43, 220, 0.08) 0%, rgba(124, 58, 237, 0.08) 100%);
    border: 1.5px solid rgba(60, 43, 220, 0.16);
    border-radius: 22px;
    margin-top: 0.5rem;
  }

  .rv2__cta-title {
    font-size: clamp(1.35rem, 2.5vw, 1.75rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .rv2__cta-sub {
    font-size: 0.95rem;
    color: $muted;
    margin: 0.4rem 0 0;
    max-width: 380px;
  }
</style>
