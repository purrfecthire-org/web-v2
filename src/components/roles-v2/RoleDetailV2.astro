    margin-top: 2rem;
    background: $tint;
    border: 1px solid transparent;
    border-radius: var(--radius);
    padding: 12px 16px;
    font-size: 0.875rem;
    color: $text;
    svg { color: $ink; flex-shrink: 0; }
    strong { color: $ink; font-weight: 700; }
  }

  // ── Apply form ───────────────────────────────────────────────────
  .rv2__apply-block { scroll-margin-top: 5.5rem; }

  .rv2__apply-title {
    font-size: clamp(1.35rem, 2.5vw, 1.75rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    color: $ink;
    margin: 0;
  }

  .rv2__apply-sub { font-size: 0.95rem; color: $muted; margin: 0.4rem 0 1.75rem; }

  .rv2__form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    @include max-md { grid-template-columns: 1fr; }
  }

  .rv2__f {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;

    &--full { grid-column: 1 / -1; }

    label { font-size: 0.875rem; font-weight: 500; color: $text; }

    input, select {
      font-family: 'Schibsted Grotesk', system-ui, sans-serif;
      font-size: 0.9375rem;
      color: $text;
      background: #fff;
      border: 1px solid $line;
      border-radius: 10px;
      padding: 0.75rem 0.9rem;
      width: 100%;
      transition: border-color 0.2s ease, box-shadow 0.2s ease;

      &:focus {
        outline: none;
        border-color: $ink;
        box-shadow: 0 0 0 3px rgba(41, 40, 95, 0.12);
      }
      &.is-invalid {
        border-color: #d14343;
        box-shadow: 0 0 0 3px rgba(209, 67, 67, 0.1);
      }
