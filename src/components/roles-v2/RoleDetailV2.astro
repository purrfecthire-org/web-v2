  .rv2__closed-body { font-size: 1rem; line-height: 1.65; color: $muted; margin: 0; }
  .rv2__closed-body .rv2__result-link { display: inline-block; margin-top: 0.5rem; font-weight: 600; color: $ink; text-decoration: underline; }

  // ── Loading skeleton ─────────────────────────────────────────────────
  // Hidden by default (no-JS fallback = real prerendered content shows
  // immediately). Shimmer bars sized to roughly match the rail + content
  // layout so there's no jump when the real content swaps in.
  .rv2__skeleton {
    &[hidden] { display: none; }
  }

  .rv2__skeleton-layout {
    display: grid;
    grid-template-columns: 340px 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;

    @include max-lg { grid-template-columns: 1fr; gap: 2rem; }
  }

  .rv2__skeleton-rail {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    background: $surface;
    border: 1px solid $line;
    border-top: 4px solid $line;
    border-radius: var(--radius);
    padding: clamp(1.5rem, 3vw, 2rem);
  }

  .rv2__skeleton-content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding-top: 0.5rem;
  }

  .rv2-sk {
    border-radius: 6px;
    background: linear-gradient(90deg, $soft 25%, $line 37%, $soft 63%);
    background-size: 400% 100%;
    animation: rv2-shimmer 1.4s ease infinite;

    &--fact { width: 100%; height: 20px; margin-top: 4px; }
  }

  @keyframes rv2-shimmer {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .rv2-sk { animation: none; background: $soft; }
  }
