  .rv2__result-title { font-size: 1.15rem; font-weight: 600; margin: 0 0 0.5rem; color: $ink; }

  .rv2__result-body { font-size: 0.95rem; line-height: 1.6; color: $muted; margin: 0 0 1rem; }
