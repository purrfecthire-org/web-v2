    input[type='file'] { padding: 0.6rem 0.9rem; }
  }

  .rv2__f-err { font-size: 0.8125rem; color: #d14343; min-height: 1em; }

  // Honeypot — off-screen (NOT display:none so bots still fill it)
  .rv2__hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
    opacity: 0;
  }

  .rv2__form-foot {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
    margin-top: 1.75rem;
  }

  .rv2__form-note { margin: 0; font-size: 0.875rem; color: $muted; }

  .rv2__result {
    margin-top: 1.5rem;
    border: 1px solid $line;
    border-radius: var(--radius);
    padding: 1.75rem 2rem;
    background: $surface;

