---
// ─────────────────────────────────────────────────────────────────────────────
// RoleDetailV2 — public role detail, driven by the backend PublicRoleDetail DTO.
//
// HIDE-ABSENT-FIELDS RULE: every optional field renders NOTHING when null — no
// empty labels, no placeholder boxes. Company identity is never present in the
// DTO; `company_label` is the only company-adjacent string shown.
//
// The JD (`public_description`) is markdown, rendered safely (HTML-escaped, link
// schemes sanitized) via src/lib/markdown.ts.
//
// The apply form POSTs multipart/form-data to {PUBLIC_API_ENDPOINT}{apply_path}.
//
// Chrome (nav + footer) is provided by the page (global v6). This component
// renders only the two-column body and uses the shared brand tokens.
// ─────────────────────────────────────────────────────────────────────────────
import {
  apiBase,
  roleRailHTML,
  roleReadOnlyContentHTML,
  type PublicRoleDetail,
} from '../../lib/roles';

interface Props {
  role: PublicRoleDetail;
}

const { role } = Astro.props;

// Full apply endpoint; empty when no backend configured (form self-disables).
const applyUrl = apiBase() ? `${apiBase()}${role.apply_path}` : '';

// Rail + read-only content are rendered through the SAME functions the client
// refresh script calls after fetchRole() resolves, so build-time and
// client-refreshed markup never drift (identical to roleCardHTML()'s role on
// the list page).
const railHtml = roleRailHTML(role);
const readonlyHtml = roleReadOnlyContentHTML(role);

const englishOptions = ['A1', 'A2', 'B1', 'B2', 'C1', 'C2', 'Native'];
---

<div class="rv2" id="rv2-root" data-slug={role.slug}>
  <!-- Back link to the list -->
  <div class="rv2__crumb">
    <a href="/roles" class="rv2__back">
      <svg width="15" height="15" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path d="M13 8H3M7 4L3 8l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      All open roles
    </a>
  </div>

  <!-- ── Loading skeleton ─────────────────────────────────────────────
       Hidden by default (no-JS / static fallback shows the real content
       below immediately). The client script un-hides this the moment it
       starts the fetch-on-load refresh, then hides it again once the
       fetch settles (success, 404, or network failure). -->
  <div class="rv2__skeleton" id="rv2-skeleton" hidden aria-hidden="true">
    <div class="rv2__skeleton-layout">
      <div class="rv2__skeleton-rail">
        <div class="rv2-sk" style="width:45%;height:11px;"></div>
        <div class="rv2-sk" style="width:85%;height:26px;margin-top:6px;"></div>
        <div class="rv2-sk" style="width:60%;height:26px;"></div>
        <div class="rv2-sk rv2-sk--fact"></div>
        <div class="rv2-sk rv2-sk--fact"></div>
        <div class="rv2-sk rv2-sk--fact"></div>
        <div class="rv2-sk rv2-sk--fact"></div>
        <div class="rv2-sk" style="width:100%;height:46px;border-radius:12px;margin-top:8px;"></div>
      </div>
      <div class="rv2__skeleton-content">
        <div class="rv2-sk" style="width:28%;height:11px;"></div>
        <div class="rv2-sk" style="width:92%;height:16px;"></div>
        <div class="rv2-sk" style="width:75%;height:16px;"></div>
        <div class="rv2-sk" style="width:96%;height:16px;"></div>
        <div class="rv2-sk" style="width:60%;height:16px;"></div>
        <div class="rv2-sk" style="width:88%;height:16px;"></div>
        <div class="rv2-sk" style="width:70%;height:16px;"></div>
      </div>
    </div>
  </div>

  <!-- ── Closed state ─────────────────────────────────────────────────
       Shown only when the client refresh gets a 404 (role was unpublished
       or closed since this page was built). Replaces the WHOLE page body
       — not just the apply form — reusing the same friendly messaging as
       the apply form's own 404 case. -->
  <div class="rv2__closed" id="rv2-closed" hidden>
    <h2 class="rv2__closed-title">This role is no longer open</h2>
    <p class="rv2__closed-body">
      It may have been filled or closed since you opened this page.
      <a class="rv2__result-link" href="/roles">Browse our other open roles →</a>
    </p>
  </div>

  <div class="rv2__layout" id="rv2-layout">
    <!-- ── Sticky left rail ─────────────────────────────────────────── -->
    <aside class="rv2__rail">
      <div class="rv2__rail-inner" id="rv2-rail-inner" set:html={railHtml}></div>
    </aside>

    <!-- ── Scrollable content ───────────────────────────────────────── -->
    <main class="rv2__content">
      <!-- Company + Role sections — rendered from the single-source-of-truth
           renderer (shared build-time + client-refresh). Never includes the
           apply form, which stays static below and is never replaced. -->
      <div id="rv2-readonly" set:html={readonlyHtml}></div>

      <!-- ── Apply form ─────────────────────────────────────────────── -->
      <section class="rv2__block rv2__apply-block" id="apply">
        <span class="rv2__eyebrow">Apply</span>
        <h2 class="rv2__apply-title">Apply for this role</h2>
        <p class="rv2__apply-sub">Apply once. We match you with the roles where you fit best.</p>

        <form class="rv2__form" id="rv2-form" data-apply-url={applyUrl} novalidate>
          <div class="rv2__form-grid">
            <div class="rv2__f">
              <label for="rv2-name">Full name *</label>
              <input type="text" id="rv2-name" name="full_name" autocomplete="name" required />
              <span class="rv2__f-err" data-err-for="rv2-name"></span>
            </div>
            <div class="rv2__f">
              <label for="rv2-email">Email *</label>
              <input type="email" id="rv2-email" name="email" autocomplete="email" required />
              <span class="rv2__f-err" data-err-for="rv2-email"></span>
            </div>
            <div class="rv2__f">
              <label for="rv2-phone">Phone</label>
              <input type="tel" id="rv2-phone" name="phone" autocomplete="tel" />
            </div>
            <div class="rv2__f">
              <label for="rv2-linkedin">LinkedIn</label>
              <input type="text" id="rv2-linkedin" name="linkedin" placeholder="linkedin.com/in/…" />
            </div>
            <div class="rv2__f">
              <label for="rv2-english">English level</label>
              <select id="rv2-english" name="english_level">
                <option value="">Select…</option>
                {englishOptions.map((o) => <option value={o}>{o}</option>)}
              </select>
            </div>
            <div class="rv2__f">
              <label for="rv2-cur">Current salary (USD / mo)</label>
              <input type="number" id="rv2-cur" name="current_salary_usd" min="0" step="50" inputmode="numeric" />
            </div>
            <div class="rv2__f">
              <label for="rv2-des">Desired salary (USD / mo)</label>
              <input type="number" id="rv2-des" name="desired_salary_usd" min="0" step="50" inputmode="numeric" />
            </div>
            <div class="rv2__f rv2__f--full">
              <label for="rv2-cv">CV — PDF, max 3 MB *</label>
              <input type="file" id="rv2-cv" name="cv" accept="application/pdf,.pdf" required />
              <span class="rv2__f-err" data-err-for="rv2-cv"></span>
            </div>
          </div>

          <!-- Honeypot: visually hidden (off-screen, NOT display:none). Humans
               never see or tab into it; bots fill it and get flagged. -->
          <div class="rv2__hp" aria-hidden="true">
            <label for="rv2-website">Website</label>
            <input type="text" id="rv2-website" name="website" tabindex="-1" autocomplete="off" />
          </div>

          <div class="rv2__form-foot">
            <button type="submit" class="rv2__apply rv2__apply--submit" id="rv2-submit">
              Submit application
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <p class="rv2__form-note" id="rv2-formnote"></p>
          </div>
        </form>

        <!-- Success -->
        <div class="rv2__result rv2__result--ok" id="rv2-ok" hidden>
          <h3 class="rv2__result-title">Application received</h3>
          <p class="rv2__result-body">
            Thanks — we've got your application. If there's a fit we'll reach out by email.
          </p>
        </div>

        <!-- Error -->
        <div class="rv2__result rv2__result--err" id="rv2-fail" hidden>
          <h3 class="rv2__result-title" id="rv2-fail-title">Something went wrong</h3>
          <p class="rv2__result-body" id="rv2-fail-body">
            We couldn't submit your application. Please try again in a moment.
          </p>
          <button type="button" class="rv2__apply rv2__apply--submit" id="rv2-retry">Try again</button>
        </div>
      </section>
    </main>
  </div>
</div>

<script>
  // ── Client refresh (primary data path) ──────────────────────────────────
  // On load: show the skeleton, fetch GET /public/roles/{slug}, then render
  // fresh data into #rv2-rail-inner / #rv2-readonly (same renderers used at
  // build time, so markup never drifts — see src/lib/roles.ts).
  //   • success        → swap in fresh content, hide skeleton.
  //   • 404             → role closed since build; hide the whole layout and
  //                       show the "no longer open" message.
  //   • network/other   → keep the prerendered content as-is (progressive
  //                       enhancement fallback), just hide the skeleton.
  // The apply form (further below in the DOM) is never touched by this
  // script, so its own listeners (registered later in this same file) keep
  // working after any swap.
  import { fetchRole, roleRailHTML, roleReadOnlyContentHTML, reportClientError, FetchRoleError } from '../../lib/roles';

  (async () => {
    const root = document.getElementById('rv2-root') as HTMLElement | null;
    const slug = root?.dataset.slug;
    if (!root || !slug) return;

    const skeleton = document.getElementById('rv2-skeleton');
    const layout = document.getElementById('rv2-layout');
    const closed = document.getElementById('rv2-closed');
    const railInner = document.getElementById('rv2-rail-inner');
    const readonly = document.getElementById('rv2-readonly');

    skeleton?.removeAttribute('hidden');
    layout?.setAttribute('hidden', '');

    try {
      const fresh = await fetchRole(slug);
      if (railInner) railInner.innerHTML = roleRailHTML(fresh);
      if (readonly) readonly.innerHTML = roleReadOnlyContentHTML(fresh);
      layout?.removeAttribute('hidden');
    } catch (err) {
      if (err instanceof FetchRoleError && err.status === 404) {
        closed?.removeAttribute('hidden');
        reportClientError('role detail refresh: role no longer open (HTTP 404)', {
          stage: 'role_detail_refresh',
          status: 404,
          slug,
        });
      } else {
        // Network error or misconfiguration — keep the prerendered content.
        layout?.removeAttribute('hidden');
        reportClientError(`role detail refresh failed: ${(err as Error)?.message ?? err}`, {
          stage: 'role_detail_refresh',
          slug,
        });
      }
    } finally {
      skeleton?.setAttribute('hidden', '');
    }
  })();

  const form = document.getElementById('rv2-form') as HTMLFormElement | null;
  if (form) {
    const APPLY_URL = form.dataset.applyUrl || '';
    const MAX_BYTES = 3 * 1024 * 1024; // 3 MB
    const mountTime = Date.now(); // → fill_time_ms

    const submitBtn = document.getElementById('rv2-submit') as HTMLButtonElement;
    const note = document.getElementById('rv2-formnote') as HTMLElement;
    const okCard = document.getElementById('rv2-ok') as HTMLElement;
    const failCard = document.getElementById('rv2-fail') as HTMLElement;
    const failTitle = document.getElementById('rv2-fail-title') as HTMLElement;
    const failBody = document.getElementById('rv2-fail-body') as HTMLElement;
    const retryBtn = document.getElementById('rv2-retry') as HTMLButtonElement;

    const $ = (id: string) => document.getElementById(id) as HTMLInputElement;

    function setErr(id: string, msg: string) {
      const el = document.querySelector(`[data-err-for="${id}"]`);
      if (el) el.textContent = msg;
      $(id)?.classList.toggle('is-invalid', !!msg);
    }

    function clearErrors() {
      ['rv2-name', 'rv2-email', 'rv2-cv'].forEach((id) => setErr(id, ''));
    }

    // Reset the error card back to its generic (retryable) shape.
    function resetFailCard() {
      failTitle.textContent = 'Something went wrong';
      retryBtn.hidden = false;
    }

    function validate(): boolean {
      clearErrors();
      let ok = true;
      const name = $('rv2-name').value.trim();
      const email = $('rv2-email').value.trim();
      const cv = $('rv2-cv').files?.[0];

      if (!name) { setErr('rv2-name', 'Please enter your full name.'); ok = false; }
      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        setErr('rv2-email', 'Please enter a valid email.'); ok = false;
      }
      if (!cv) {
        setErr('rv2-cv', 'Please attach your CV (PDF).'); ok = false;
      } else {
        const isPdf = cv.type === 'application/pdf' || /\.pdf$/i.test(cv.name);
        if (!isPdf) { setErr('rv2-cv', 'CV must be a PDF file.'); ok = false; }
        else if (cv.size > MAX_BYTES) { setErr('rv2-cv', 'CV must be 3 MB or smaller.'); ok = false; }
      }
      return ok;
    }

    async function submit() {
      if (!validate()) return;

      if (!APPLY_URL) {
        // No backend configured — cannot submit.
        resetFailCard();
        retryBtn.hidden = true;
        failBody.textContent = 'Applications are not open yet. Please check back soon.';
        form!.hidden = true;
        failCard.hidden = false;
        return;
      }

      submitBtn.disabled = true;
      note.textContent = 'Submitting…';

      const fd = new FormData();
      fd.append('full_name', $('rv2-name').value.trim());
      fd.append('email', $('rv2-email').value.trim());
      fd.append('phone', $('rv2-phone').value.trim());
      fd.append('linkedin', $('rv2-linkedin').value.trim());
      fd.append('english_level', $('rv2-english').value);
      fd.append('current_salary_usd', $('rv2-cur').value);
      fd.append('desired_salary_usd', $('rv2-des').value);
      fd.append('website', $('rv2-website').value); // honeypot — must be empty
      fd.append('fill_time_ms', String(Date.now() - mountTime));
      const cv = $('rv2-cv').files?.[0];
      if (cv) fd.append('cv', cv, cv.name);

      const requestId = crypto.randomUUID();
      try {
        const res = await fetch(APPLY_URL, {
          method: 'POST',
          headers: { 'X-Request-Id': requestId }, // let the browser set multipart Content-Type
          body: fd,
        });
        const json = await res.json().catch(() => null);
        const respId = res.headers.get('X-Request-Id') || json?.error?.details?.request_id || requestId;

        if (res.ok && json?.data?.status === 'received') {
          form!.hidden = true;
          okCard.hidden = false;
          okCard.scrollIntoView({ behavior: 'smooth', block: 'center' });
          return;
        }

        // The role was unpublished/closed since this page was prerendered — the
        // backend answers 404. Show a friendly, distinct message (no retry).
        if (res.status === 404) {
          failTitle.textContent = 'This role is no longer open';
          failBody.innerHTML =
            'It may have been filled or closed since you opened this page. ' +
            '<a class="rv2__result-link" href="/roles">Browse our other open roles →</a>';
          retryBtn.hidden = true;
          note.textContent = '';
          submitBtn.disabled = false;
          form!.hidden = true;
          failCard.hidden = false;
          okCard.hidden = true;
          reportClientError('role application: role no longer open (HTTP 404)', {
            stage: 'role_application_submit',
            status: 404,
            request_id: requestId,
          });
          return;
        }

        // Generic (retryable) error — surface the support reference.
        resetFailCard();
        failBody.textContent =
          `We couldn't submit your application. Please try again. If it keeps happening, quote reference ${respId}.`;
        note.textContent = '';
        submitBtn.disabled = false;
        form!.hidden = true;
        failCard.hidden = false;
        reportClientError(`role application submit failed (HTTP ${res.status})`, {
          stage: 'role_application_submit',
          status: res.status,
          request_id: requestId,
        });
      } catch (err) {
        note.textContent = '';
        submitBtn.disabled = false;
        resetFailCard();
        failBody.textContent =
          `We couldn't reach the server. Please check your connection and try again. Reference ${requestId}.`;
        form!.hidden = true;
        failCard.hidden = false;
        reportClientError(`role application network error: ${(err as Error)?.message ?? err}`, {
          stage: 'role_application_submit',
          request_id: requestId,
        });
      }
    }

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      submit();
    });
    ['rv2-name', 'rv2-email', 'rv2-cv'].forEach((id) =>
      $(id)?.addEventListener('input', () => setErr(id, ''))
    );
    retryBtn?.addEventListener('click', () => {
      failCard.hidden = true;
      form!.hidden = false;
      form!.scrollIntoView({ behavior: 'smooth', block: 'center' });
    });
  }
</script>

<style lang="scss" is:global>
  /* Styled GLOBALLY (like the .rl__card* rules on the roles list page) because
     the rail + read-only content are injected via set:html (build) / innerHTML
     (client refresh) and never receive Astro's scoped attribute. */
  @use '../../styles/breakpoints' as *;

  // Brand tokens (Kate's 2026 system) — navy ink, white canvas, 12px radius.
  $ink: #29285F;      // single brand color (navy)
  $text: #1C1C1C;
  $muted: #6B6B6B;
  $subtle: #9A9A9A;
  $line: rgba(0, 0, 0, 0.08);
  $surface: #FFFFFF;
  $soft: #FCFCFB;
  $tint: #ECECF3;     // light navy tint for subtle fills

  .rv2 {
    position: relative;
    z-index: 1;
    font-family: 'Schibsted Grotesk', system-ui, sans-serif;
    color: $text;
    max-width: 78rem;
    margin-inline: auto;
    padding: 5.5rem clamp(1.25rem, 4vw, 2.5rem) 4rem;

    @include max-lg { padding-top: 5rem; }
  }

  // ── Back crumb ───────────────────────────────────────────────────
  .rv2__crumb { margin-bottom: 1.5rem; }

  .rv2__back {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 0.875rem;
    font-weight: 500;
    color: $muted;
    text-decoration: none;
    transition: color 0.15s ease;
    svg { transition: transform 0.2s ease; }
    &:hover { color: $ink; }
    &:hover svg { transform: translateX(-3px); }
  }

  // ── Two-column layout ────────────────────────────────────────────
  .rv2__layout {
    display: grid;
    grid-template-columns: 340px 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;

    @include max-lg { grid-template-columns: 1fr; gap: 2rem; }
  }

  // ── Left rail ────────────────────────────────────────────────────
  .rv2__rail {
    position: sticky;
    top: 5.5rem;
    @include max-lg { position: static; }
  }

  .rv2__rail-inner {
    background: $surface;
    border: 1px solid $line;
    border-top: 4px solid $ink;
    border-radius: var(--radius);
    padding: clamp(1.5rem, 3vw, 2rem);
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .rv2__company {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: $subtle;
  }

  .rv2__title {
    font-size: clamp(1.6rem, 3vw, 2rem);
    font-weight: 600;
    line-height: 1.12;
    letter-spacing: -0.025em;
    margin: -0.5rem 0 0;
    color: $ink;
  }

  .rv2__facts { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; }

  .rv2__fact {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding: 11px 0;
    border-bottom: 1px solid $line;
    &:last-child { border-bottom: none; }
  }

  .rv2__fact-key {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: $subtle;
    flex-shrink: 0;
  }

  .rv2__fact-val {
    font-size: 0.875rem;
    font-weight: 600;
    color: $text;
    text-align: right;
    &--accent { color: $ink; }
  }

  .rv2__yc {
    display: inline-flex;
    align-self: flex-start;
    align-items: center;
    gap: 7px;
    background: #FF6B00;
    color: #fff;
    border-radius: 999px;
    padding: 6px 14px 6px 7px;
    font-size: 0.8125rem;
    font-weight: 700;
  }

  .rv2__yc-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    border-radius: 5px;
    background: #fff;
    color: #FF6B00;
    font-weight: 800;
    font-size: 0.875rem;
  }

  .rv2__apply {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    background: $ink;
    color: #fff;
    border: none;
    cursor: pointer;
    font-family: 'Schibsted Grotesk', system-ui, sans-serif;
    border-radius: var(--radius);
    padding: 14px 26px;
    font-size: 0.9375rem;
    font-weight: 500;
    text-decoration: none;
    transition: background-color 0.2s ease;
    svg { transition: transform 0.2s ease; }
    &:hover { background: #1E1D47; }
    &:hover svg { transform: translateX(3px); }
    &:focus-visible { outline: 2px solid $ink; outline-offset: 2px; }
    &:disabled { opacity: 0.55; cursor: default; }
    &--submit { align-self: flex-start; }
  }

  .rv2__rail-note { margin: 0; font-size: 0.75rem; line-height: 1.5; color: $subtle; text-align: center; }

  // ── Content column ───────────────────────────────────────────────
  .rv2__content { min-width: 0; display: flex; flex-direction: column; gap: 2.25rem; }

  .rv2__rule { height: 1px; background: $line; }

  .rv2__eyebrow {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: $ink;
    margin-bottom: 1rem;
    &--role { color: $ink; }
  }

  .rv2__industry { margin: 0; font-size: 0.875rem; font-weight: 600; color: $muted; }

  .rv2__awards { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 1.5rem; }

  .rv2__award {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: $soft;
    border: 1px solid $line;
    color: $text;
    border-radius: 999px;
    padding: 6px 14px;
    font-size: 0.78125rem;
    font-weight: 600;
    svg { color: #F59E0B; }
  }

  .rv2__strengths { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 1rem; }

  .rv2__strength {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: $soft;
    border: 1px solid $line;
    color: $text;
    border-radius: 999px;
    padding: 7px 14px;
    font-size: 0.8125rem;
    font-weight: 500;
    svg { color: $ink; }
  }

  .rv2__skills { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 1.5rem; }

  .rv2__skill {
    background: $tint;
    color: $ink;
    border: 1px solid transparent;
    border-radius: 999px;
    padding: 5px 13px;
    font-size: 0.8125rem;
    font-weight: 500;
  }

  // ── JD prose (rendered markdown) ─────────────────────────────────
  .rv2__prose {
    font-size: 1.0625rem;
