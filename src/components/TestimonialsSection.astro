---
import type { LandingContent } from "../content/index";

interface Props {
  content: LandingContent["testimonials"];
  clientLabel?: string;
  candidateLabel?: string;
  timeLabel?: string;
}

const {
  content,
  clientLabel    = 'Client',
  candidateLabel = 'Candidate',
} = Astro.props;

const featured    = content.items[0];
const middle      = content.items.slice(1, -1);
const featuredEnd = content.items[content.items.length - 1];
---

<section class="testimonials">
  <div class="testimonials__wrapper">

    <!-- Header -->
    <div class="testimonials__header">
      <span class="testimonials__badge label-uppercase">
        {content.badge}
      </span>
      <h2 class="testimonials__headline headline2">
        {content.headline}
      </h2>
    </div>

    <!-- Featured top -->
    <div class="testimonials__card testimonials__card--featured testimonials__card--mb">
      <span class="testimonials__quote-mark" aria-hidden="true">"</span>
      <p class="testimonials__quote testimonials__quote--lg body2">{featured.quote}</p>
      <div class="testimonials__footer">
        <div class="testimonials__author">
          <span class="testimonials__name body2">{featured.flag} {featured.name}</span>
          <span class="testimonials__meta body2">{featured.role}, {featured.company}</span>
        </div>
        <div class="testimonials__pills">
          <span class={`testimonials__pill testimonials__pill--${featured.type} caption`}>
            {featured.type === 'client' ? clientLabel : candidateLabel}
          </span>
          {featured.timeToHire && (
            <span class="testimonials__pill testimonials__pill--time caption">
              <svg width="12" height="12" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M7 1v6l3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.5"/>
              </svg>
              {featured.timeToHire}
            </span>
          )}
        </div>
      </div>
    </div>

    <!-- Middle grid -->
    <div class="testimonials__grid">
      {middle.map((item) => (
        <div class="testimonials__card">
          <span class="testimonials__quote-mark" aria-hidden="true">"</span>
          <p class="testimonials__quote body2">{item.quote}</p>
          <div class="testimonials__footer">
            <div class="testimonials__author">
              <span class="testimonials__name body2">{item.flag} {item.name}</span>
              <span class="testimonials__meta body2">{item.role}, {item.company}</span>
            </div>
            <div class="testimonials__pills">
              <span class={`testimonials__pill testimonials__pill--${item.type} caption`}>
                {item.type === 'client' ? clientLabel : candidateLabel}
              </span>
              {item.timeToHire && (
                <span class="testimonials__pill testimonials__pill--time caption">
                  <svg width="12" height="12" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                    <path d="M7 1v6l3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    <circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.5"/>
                  </svg>
                  {item.timeToHire}
                </span>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Featured bottom -->
    <div class="testimonials__card testimonials__card--featured">
      <span class="testimonials__quote-mark" aria-hidden="true">"</span>
      <p class="testimonials__quote testimonials__quote--lg body2">{featuredEnd.quote}</p>
      <div class="testimonials__footer">
        <div class="testimonials__author">
          <span class="testimonials__name body2">{featuredEnd.flag} {featuredEnd.name}</span>
          <span class="testimonials__meta body2">{featuredEnd.role}, {featuredEnd.company}</span>
        </div>
        <div class="testimonials__pills">
          <span class={`testimonials__pill testimonials__pill--${featuredEnd.type} caption`}>
            {featuredEnd.type === 'client' ? clientLabel : candidateLabel}
          </span>
          {featuredEnd.timeToHire && (
            <span class="testimonials__pill testimonials__pill--time caption">
              <svg width="12" height="12" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M7 1v6l3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.5"/>
              </svg>
              {featuredEnd.timeToHire}
            </span>
          )}
        </div>
      </div>
    </div>

  </div>
</section>

<style lang="scss">
  @use '../styles/breakpoints.scss' as *;

  .testimonials {
    padding: 7rem 0;
    background: var(--color-surface);

    @include max-md {
      padding: 5rem 0;
    }

    &__wrapper {
      max-width: 80rem;
      margin-inline: auto;
      padding-inline: 1rem;

      @include max-sm {
        padding-inline: 1.5rem;
      }
    }

    &__header {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
      align-items: center;
      text-align: center;
      margin-bottom: 3.5rem;
      max-width: 48rem;
      margin-inline: auto;
      margin-bottom: 3.5rem;
    }

    &__badge {
      color: var(--color-warm-charcoal);
    }

    &__headline {
      color: var(--color-text);
    }

    &__grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
      margin-bottom: 1.25rem;

      @include max-lg {
        grid-template-columns: repeat(2, 1fr);
      }

      @include max-sm {
        grid-template-columns: 1fr;
      }
    }

    &__card {
      background: var(--color-bg);
      border: 1px solid var(--color-oat-border);
      border-radius: 24px;
      box-shadow: var(--shadow-base);
      padding: 2rem;
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
      transition: box-shadow 0.15s ease, transform 0.15s ease;

      &:hover {
        box-shadow: var(--shadow-hard);
        transform: translateY(-2px);
      }

      &--featured {
        background: var(--color-surface);
      }

      &--mb {
        margin-bottom: 1.25rem;
      }
    }

    &__quote-mark {
      display: block;
      margin-bottom: -16px;
    }

    &__quote {
      flex: 1;

      &--lg {
        font-size: 1.125rem;
      }
    }

    &__footer {
      display: flex;
      flex-wrap: wrap;
      align-items: flex-end;
      justify-content: space-between;
      gap: 0.75rem;
      padding-top: 1rem;
      border-top: 1px dashed var(--color-oat-border);
      margin-top: auto;
    }

    &__author {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    &__name {
    }

    &__meta {

    }

    &__pills {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      align-items: center;
    }

    &__pill {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      padding: 3px 10px;
      border-radius: 1584px;
      white-space: nowrap;

      &--client {
        background: var(--color-matcha-300);
        color: var(--color-matcha-800);
      }

      &--candidate {
        background: var(--color-ube-300);
        color: var(--color-ube-900);
      }

      &--time {
        background: var(--color-lemon-400);
        color: var(--color-lemon-800);
      }
    }
  }
</style>