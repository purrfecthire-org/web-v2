---
import type { LandingContent } from "../content/index";

interface Props {
  content: LandingContent["testimonials"];
}

const { content } = Astro.props;
---

<section class="testimonials">
  <div class="testimonials__wrapper">

    <!-- Header -->
    <div class="testimonials__header">
      <span class="testimonials__eyebrow eyebrow">
        {content.eyebrow}
      </span>
      <h2 class="testimonials__headline headline2">
        {content.headline}
      </h2>
    </div>

    <!-- Featured testimonial -->
    <div class="testimonials__card testimonials__card--featured">
      <p class="testimonials__quote testimonials__quote--lg body1">
        "{content.featured.quote}"
      </p>
      <div class="testimonials__footer">
        <div class="testimonials__author">
          <span class="testimonials__name">{content.featured.name}</span>
          <span class="testimonials__role">{content.featured.role}</span>
        </div>
        <span class="testimonials__badge">{content.featured.badge}</span>
      </div>
    </div>

    <!-- Grid of 3 -->
    <div class="testimonials__grid">
      {content.grid.map((item) => (
        <div class="testimonials__card">
          <p class="testimonials__quote body2">
            "{item.quote}"
          </p>
          <div class="testimonials__footer">
            <div class="testimonials__author">
              <span class="testimonials__name">{item.name}</span>
              <span class="testimonials__role">{item.role}</span>
            </div>
            <span class="testimonials__badge">{item.badge}</span>
          </div>
        </div>
      ))}
    </div>

    <!-- Candidate testimonial -->
    <div class="testimonials__card testimonials__card--featured">
      <p class="testimonials__quote testimonials__quote--lg body1">
        "{content.candidateTestimonial.quote}"
      </p>
      <div class="testimonials__footer">
        <div class="testimonials__author">
          <span class="testimonials__name">{content.candidateTestimonial.name}</span>
          <span class="testimonials__role">{content.candidateTestimonial.role}</span>
        </div>
        <span class="testimonials__badge testimonials__badge--candidate">
          {content.candidateTestimonial.badge}
        </span>
      </div>
    </div>

  </div>
</section>

<style lang="scss">
  @use '../styles/breakpoints.scss' as *;

  .testimonials {
    padding: 7rem 0;
    background: var(--color-bg);

    @include max-md { padding: 5rem 0; }

    &__wrapper {
      max-width: 80rem;
      margin-inline: auto;
      padding-inline: 2rem;

      @include max-lg { padding-inline: 1.5rem; }
      @include max-sm { padding-inline: 1rem; }
    }

    &__header {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      align-items: center;
      text-align: center;
      max-width: 42rem;
      margin-inline: auto;
      margin-bottom: 3.5rem;
    }

    &__eyebrow {}

    &__headline {
      color: var(--color-text);
    }

    &__grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
      margin-block: 1.25rem;

      @include max-lg { grid-template-columns: repeat(2, 1fr); }
      @include max-sm { grid-template-columns: 1fr; }
    }

    &__card {
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: 12px;
      padding: 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 1.25rem;

      &--featured {
        padding: 2rem;
      }
    }

    &__quote {
      flex: 1;
      font-style: italic;

      &--lg {
        font-size: 1.0625rem;
      }
    }

    &__footer {
      display: flex;
      flex-wrap: wrap;
      align-items: flex-end;
      justify-content: space-between;
      gap: 0.75rem;
      padding-top: 1rem;
      border-top: 1px solid var(--color-border);
      margin-top: auto;
    }

    &__author {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    &__name {
      font-size: 0.875rem;
      font-weight: 500;
      color: var(--color-text);
    }

    &__role {
      font-size: 0.8125rem;
      color: var(--color-muted);
    }

    &__badge {
      display: inline-flex;
      align-items: center;
      padding: 3px 10px;
      border-radius: 999px;
      font-size: 0.6875rem;
      font-weight: 500;
      background: var(--color-accent-light, #E8E6F8);
      color: var(--color-accent);
      white-space: nowrap;

      &--candidate {
        background: #FEF3C7;
        color: #92400E;
      }
    }
  }
</style>
