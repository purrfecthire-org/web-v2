---
// ── For Talent — Body ────────────────────────────────────────────────────
// Below the hero: the two things talent actually wants to see — live open
// roles (proof there's real demand) and the Offer Acceleration program in
// full — plus a placed-candidate testimonial and a closing CTA. Content comes
// from the shared content object. Isolated under the `ft-` prefix.
import type { LandingContent } from '../../content/index';
import { fetchRoles, ftRoleCardHTML, type PublicRoleListItem } from '../../lib/roles';

interface Props {
  content: LandingContent;
}

const { content } = Astro.props;
const { roles, offerAcceleration, testimonials } = content;

const OA_LEARN_MORE = '/offer-acceleration';
const OA_APPLY = '/offer-acceleration/apply';
const ROLES_URL = '/roles';

const ROLES_EMAIL = 'talent@purrfecthire.com';

// Live open roles — same backend fetch as /roles (build-time prerender here,
// client-side refresh below). Resilience: never fail the page build on a
// backend outage — render the empty state instead.
let liveRoles: PublicRoleListItem[] = [];
try {
  liveRoles = await fetchRoles();
} catch (err) {
  console.warn(
    `[TalentBody] build-time roles fetch failed, rendering empty state: ${(err as Error)?.message ?? err}`
  );
}
const rolesHtml = liveRoles.map(ftRoleCardHTML).join('');

const oaFit = offerAcceleration.blocks[0];      // "You're the right fit if:"
const oaSessions = offerAcceleration.blocks[1]; // "Across 8 sessions:"
const oaEnd = offerAcceleration.blocks[2];      // "By the end:"

const candidate = testimonials.candidateTestimonial;
---

<!-- ── Open roles ──────────────────────────────────────────────────────── -->
<section id="roles" class="ft-roles">
  <div class="ft-roles__container">
    <header class="ft-roles__header reveal">
      <span class="ft-roles__tag">Active searches</span>
      <h2 class="ft-roles__headline headline2">Open roles, hiring now.</h2>
      <p class="ft-roles__sub body1">
        Senior roles at YC-, a16z- and Sequoia-backed startups, curated, calibrated, and active right
        now. Company names stay confidential until we make the intro. Apply and you get
        evaluated against the real bar, then introduced when there's a fit.
      </p>
    </header>

    <!-- Loading skeleton — shown the instant the client refresh script
         starts fetching; hidden by default so no-JS visitors see the
         prerendered grid/empty-state below immediately. -->
    <div class="ft-roles__grid ft-roles__skeleton" id="ftr-skeleton" hidden aria-hidden="true">
      {Array.from({ length: 3 }).map(() => (
        <div class="ft-roles__skel-card">
          <div class="ftr-sk" style="width:70%;height:15px;"></div>
          <div class="ftr-sk" style="width:45%;height:11px;margin-top:10px;"></div>
          <div class="ftr-sk" style="width:80%;height:20px;border-radius:999px;margin-top:14px;"></div>
          <div class="ftr-sk" style="width:35%;height:13px;margin-top:16px;"></div>
        </div>
      ))}
    </div>

    <!-- Roles grid — single-source-of-truth card renderer, shared with the
         client refresh script below. -->
    <div
      class="ft-roles__grid"
      id="ftr-grid"
      hidden={liveRoles.length === 0}
      set:html={rolesHtml}
    />

    <!-- Empty state — no open roles (or the build-time fetch failed). The
         "Browse all roles" CTA below stays visible either way. -->
    <div class="ft-roles__empty" id="ftr-empty" hidden={liveRoles.length > 0}>
      <h3 class="ft-roles__empty-title">No open roles right now</h3>
      <p class="ft-roles__empty-sub">
        New searches go live every week. Send us your profile below and we'll reach out the
        moment something fits.
      </p>
    </div>

    <div class="ft-roles__foot reveal reveal-delay-1">
      <a href={ROLES_URL} class="btn ft-roles__foot-btn">Browse all roles →</a>
      <p class="ft-roles__foot-note caption">
        {roles.closingText}{' '}
        <a href={`mailto:${ROLES_EMAIL}`} class="ft-roles__foot-link">{ROLES_EMAIL}</a>
      </p>
    </div>
  </div>
</section>

<!-- ── Offer Acceleration ──────────────────────────────────────────────── -->
<section id="oa" class="ft-oa">
  <div class="ft-oa__container">
    <header class="ft-oa__header reveal">
      <span class="ft-oa__tag">Coaching program</span>
      <h2 class="ft-oa__headline headline2">Offer Acceleration</h2>
      <p class="ft-oa__sub body1">{offerAcceleration.subheadline}</p>
    </header>

    <div class="ft-oa__grid">
      <div class="ft-oa__block reveal reveal-delay-1">
        <h3 class="ft-oa__block-title">{oaFit.title}</h3>
        <ul class="ft-oa__list">
          {oaFit.items.map((item) => <li class="ft-oa__list-item">{item}</li>)}
        </ul>
      </div>

      <div class="ft-oa__block reveal reveal-delay-1">
        <h3 class="ft-oa__block-title">{oaSessions.title}</h3>
        <ul class="ft-oa__list">
          {oaSessions.items.map((item) => <li class="ft-oa__list-item">{item}</li>)}
        </ul>
      </div>

      <div class="ft-oa__block reveal reveal-delay-2">
        <h3 class="ft-oa__block-title">{oaEnd.title}</h3>
        <ul class="ft-oa__list">
          {oaEnd.items.map((item) => <li class="ft-oa__list-item">{item}</li>)}
        </ul>
      </div>
    </div>

    <p class="ft-oa__closing body1 reveal reveal-delay-2">{offerAcceleration.closing}</p>

    <div class="ft-oa__actions reveal reveal-delay-2">
      <a href={OA_APPLY} class="btn ft-oa__btn">{offerAcceleration.cta}</a>
      <a href={OA_LEARN_MORE} class="ft-oa__link">Learn more</a>
      <span class="ft-oa__subline caption">{offerAcceleration.ctaSubline}</span>
    </div>
  </div>
</section>

<!-- ── Candidate testimonial ───────────────────────────────────────────── -->
<section class="ft-quote">
  <figure class="ft-quote__container reveal">
    <blockquote class="ft-quote__text">"{candidate.quote}"</blockquote>
    <figcaption class="ft-quote__meta">
      <span class="ft-quote__name">{candidate.name}</span>
      <span class="ft-quote__role caption">{candidate.role}</span>
      <span class="ft-quote__badge">{candidate.badge}</span>
    </figcaption>
  </figure>
</section>

<script>
  // Client refresh (primary data path) — same fetch-on-load pattern as
  // /roles, sharing the wiring via initRolesRefresh so mid-week publishes
  // show up on this teaser without a rebuild.
  import { ftRoleCardHTML, initRolesRefresh } from '../../lib/roles';

  initRolesRefresh({
    containerId: 'ftr-grid',
    emptyId: 'ftr-empty',
    skeletonId: 'ftr-skeleton',
    render: ftRoleCardHTML,
    stage: 'for_talent_roles_teaser_refresh',
  });
</script>

<style lang="scss" is:global>
  @use '../../styles/breakpoints' as *;

  $talent: #29285F;
  $accent: #29285F;

  // ── Roles ──────────────────────────────────────────────────
  .ft-roles {
    position: relative;
    z-index: 1;
    padding-block: 6rem;
    background: var(--bg-soft);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);

    @include max-md { padding-block: 4rem; }

    &__container {
      max-width: 64rem;
      margin-inline: auto;
      padding-inline: 2rem;
      @include max-lg { padding-inline: 1.5rem; }
      @include max-sm { padding-inline: 1rem; }
    }

    &__header {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1rem;
      text-align: center;
      margin-bottom: 2.5rem;
    }
    &__tag {
      font-size: 0.6875rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #fff;
      background: $talent;
      padding: 5px 14px;
      border-radius: var(--radius);
    }
    &__headline { color: var(--color-text); }
    &__sub { max-width: 42rem; }

    &__grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
      @include max-md { grid-template-columns: 1fr; }
    }

    &__card {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      padding: 1.5rem;
      border: 1px solid var(--color-border);
      border-radius: var(--radius);
      background: var(--bg-soft);
    }
    &__card-head { display: flex; flex-direction: column; gap: 0.25rem; }
    &__card-title { font-size: 1.0625rem; font-weight: 600; color: var(--color-text); }
    &__card-comp { font-size: 0.8125rem; font-weight: 500; color: $accent; }
    &__card-meta { color: var(--color-muted); }
    &__card-stack { display: flex; flex-wrap: wrap; gap: 0.375rem; margin: 0.5rem 0 0.75rem; }
    &__skill {
      font-size: 0.75rem;
      font-weight: 500;
      color: var(--color-muted);
      background: rgba(41, 40, 95, 0.05);
      border: 1px solid var(--color-border);
      border-radius: 6px;
      padding: 2px 8px;
    }
    &__card-cta {
      margin-top: auto;
      font-size: 0.875rem;
      font-weight: 600;
      color: $talent;
      text-decoration: none;
      &:hover { color: $accent; }
    }

    // `[hidden]` alone loses to the `display: grid`/`flex` rules above
    // (author CSS always wins over the UA stylesheet), so every toggled
    // container needs an explicit override.
    &__grid[hidden],
    &__empty[hidden] {
      display: none;
    }

    // Loading skeleton — same grid + box metrics as &__card so there's no
    // layout jump when the client refresh swaps it for real cards.
    &__skel-card {
      display: flex;
      flex-direction: column;
      padding: 1.5rem;
      border: 1px solid var(--color-border);
      border-radius: var(--radius);
      background: var(--bg-soft);
    }

    // Empty state — no open roles (or the fetch failed). The foot CTA below
    // ("Browse all roles" + submit-your-profile note) stays visible either way.
    &__empty {
      padding: clamp(2.5rem, 6vw, 3.5rem) 1.5rem;
      border: 1px solid var(--color-border);
      border-radius: var(--radius);
      background: var(--bg-soft);
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.6rem;
    }
    &__empty-title { font-size: clamp(1.25rem, 2.5vw, 1.5rem); font-weight: 600; letter-spacing: -0.01em; margin: 0; color: var(--color-text); }
    &__empty-sub { font-size: 0.9375rem; line-height: 1.6; color: var(--color-muted); margin: 0; max-width: 30rem; }

    &__foot {
      margin-top: 2.5rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.875rem;
      text-align: center;
    }
    &__foot-btn {
      background: $talent;
      padding: 14px 28px;
      &:hover { background: $accent; }
    }
    &__foot-note { color: var(--color-muted); }
    &__foot-link { color: $accent; text-decoration: underline; text-underline-offset: 2px; }
  }

  .ftr-sk {
    border-radius: 6px;
    background: linear-gradient(90deg, var(--bg) 25%, var(--color-border) 37%, var(--bg) 63%);
    background-size: 400% 100%;
    animation: ftr-shimmer 1.4s ease infinite;
  }

  @keyframes ftr-shimmer {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .ftr-sk { animation: none; background: var(--bg); }
  }

  // ── Offer Acceleration ─────────────────────────────────────
  .ft-oa {
    position: relative;
    z-index: 1;
    padding-block: 6rem;

    @include max-md { padding-block: 4rem; }

    &__container {
      max-width: 60rem;
      margin-inline: auto;
      padding-inline: 2rem;
      @include max-lg { padding-inline: 1.5rem; }
      @include max-sm { padding-inline: 1rem; }
    }

    &__header {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1rem;
      text-align: center;
      margin-bottom: 2.5rem;
    }
    &__tag {
      font-size: 0.6875rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #fff;
      background: $accent;
      padding: 5px 14px;
      border-radius: var(--radius);
    }
    &__headline { color: var(--color-text); }
    &__sub { max-width: 44rem; }

    &__grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
      @include max-md { grid-template-columns: 1fr; }
    }

    &__block {
      display: flex;
      flex-direction: column;
      gap: 0.875rem;
      padding: 1.75rem;
      border: 1px solid var(--color-border);
      border-top: 4px solid $accent;
      border-radius: var(--radius);
      background: var(--bg-soft);
    }
    &__block-title {
      font-size: 0.9375rem;
      font-weight: 600;
      color: var(--color-text);
      margin: 0;
    }
    &__list {
      list-style: none; margin: 0; padding: 0;
      display: flex; flex-direction: column; gap: 0.5rem;
    }
    &__list-item {
      position: relative;
      padding-left: 1.25rem;
      font-size: 0.9375rem;
      line-height: 1.5;
      color: var(--color-muted);
      &::before {
        content: '✓';
        position: absolute;
        left: 0;
        color: $accent;
        font-weight: 600;
      }
    }

    &__closing {
      max-width: 44rem;
      margin: 2.5rem auto 0;
      text-align: center;
      color: var(--color-text);
    }

    &__actions {
      margin-top: 1.75rem;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1.25rem;
      flex-wrap: wrap;
    }
    &__btn { padding: 14px 28px; }
    &__link {
      font-size: 0.875rem;
      font-weight: 500;
      color: var(--color-text);
      text-decoration: underline;
      text-underline-offset: 3px;
      text-decoration-color: var(--color-border);
      &:hover { color: $accent; }
    }
    &__subline { color: var(--color-tertiary); width: 100%; text-align: center; }
  }

  // ── Candidate quote ────────────────────────────────────────
  .ft-quote {
    position: relative;
    z-index: 1;
    padding-block: 5rem 6rem;

    &__container {
      max-width: 44rem;
      margin-inline: auto;
      padding: 2.5rem;
      border: 1px solid var(--color-border);
      border-left: 4px solid $talent;
      border-radius: var(--radius);
      background: var(--bg-soft);
      text-align: center;

      @include max-sm { padding: 1.75rem; }
    }
    &__text {
      font-size: 1.25rem;
      line-height: 1.5;
      font-style: italic;
      color: var(--color-text);
      margin: 0 0 1.25rem;
    }
    &__meta { display: flex; flex-direction: column; gap: 0.25rem; align-items: center; }
    &__name { font-weight: 600; color: var(--color-text); }
    &__role { color: var(--color-tertiary); }
    &__badge {
      margin-top: 0.25rem;
      font-size: 0.6875rem;
      font-weight: 600;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: $talent;
      background: rgba(41, 40, 95, 0.07);
      padding: 4px 12px;
      border-radius: var(--radius);
    }
  }
</style>
