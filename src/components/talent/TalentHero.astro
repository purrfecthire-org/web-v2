---
// ── For Talent — Hero ────────────────────────────────────────────────────
// Isolated design test (navy-accent variant of the V6 language). Talent who
// land here are senior already — the hook is the gap between their skill and
// their offers. The hero names that gap, then forks into the two real ways in:
// the Offer Acceleration program and live open roles. Prefix: `ft-`.
const OA_DETAILS = '/offer-acceleration';
const ROLES_URL = '/roles';

const routes = [
  {
    eyebrow: 'Coaching program',
    title: 'Offer Acceleration',
    body:
      'An 8-session program that gives you the strategy, network, and real startup criteria to stop getting filtered — and start being introduced.',
    href: OA_DETAILS,
    cta: 'See more details →',
    target: OA_DETAILS,
  },
  {
    eyebrow: 'Active searches',
    title: 'Open roles',
    body:
      'Senior roles at YC- and a16z-backed startups, curated and active right now. Apply once, get evaluated against the real bar, and introduced when there is a fit.',
    href: ROLES_URL,
    cta: 'Browse roles →',
    target: '#roles',
  },
];
---

<section id="hero" data-section="hero" class="ft-hero">
  <div class="ft-hero__container">

    <header class="ft-hero__head">
      <!-- <span class="ft-hero__tag">For talent</span>  -->
      <h1 class="ft-hero__headline">
        Why you keep
        <span class="ft-hero__headline-accent">missing offers?</span>
      </h1>
      <p class="ft-hero__sub body1">
        If you're a senior LATAM professional getting filtered out of US roles — or landing
        offers below your level — the problem usually isn't your skill. It's strategy,
        positioning, and getting in front of the right founders. That's exactly what we fix.
      </p>
    </header>

    <!-- Two ways in -->
    <div class="ft-hero__routes">
      {routes.map((r) => (
        <a href={r.target} class="ft-hero__card">
          <span class="ft-hero__card-eyebrow eyebrow">{r.eyebrow}</span>
          <h2 class="ft-hero__card-title">{r.title}</h2>
          <p class="ft-hero__card-body">{r.body}</p>
          <span class="ft-hero__card-link">{r.cta}</span>
        </a>
      ))}
    </div>

  </div>
</section>

<style lang="scss">
  @use '../../styles/breakpoints' as *;

  $talent: #0D0857;
  $accent: #3C2BDC;

  .ft-hero {
    position: relative;
    z-index: 1;
    padding-top: 9rem;
    padding-bottom: 5rem;
    min-height: 100svh;
    display: flex;
    align-items: center;

    @include max-md {
      padding-top: 7rem;
      padding-bottom: 3.5rem;
      min-height: auto;
    }

    &__container {
      width: 100%;
      max-width: 64rem;
      margin-inline: auto;
      padding-inline: 2rem;
      display: flex;
      flex-direction: column;
      gap: 3rem;

      @include max-lg { padding-inline: 1.5rem; }
      @include max-sm { padding-inline: 1rem; gap: 2.25rem; }
    }

    &__head {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
      max-width: 48rem;
      opacity: 0;
      animation: ft-fade-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.1s forwards;
    }

    &__tag {
      align-self: flex-start;
      font-size: 0.6875rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #fff;
      background: $talent;
      padding: 5px 14px;
      border-radius: 999px;
    }

    &__headline {
      font-size: clamp(2.4rem, 5.5vw, 4.25rem);
      font-weight: 800;
      line-height: 1.04;
      letter-spacing: -0.03em;
      color: #111827;
      margin: 0;
    }
    &__headline-accent { display: block; color: $accent; }
    &__sub { max-width: 42rem; }

    // ── Route cards ──────────────────────────────────────────
    &__routes {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
      @include max-md { grid-template-columns: 1fr; }
    }

    &__card {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      padding: 2.25rem;
      border: 1px solid var(--color-border);
      border-top: 4px solid $talent;
      border-radius: 16px;
      background: rgba(255, 255, 255, 0.74);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      text-decoration: none;
      transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;

      opacity: 0;
      animation: ft-fade-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      &:nth-child(1) { animation-delay: 0.35s; }
      &:nth-child(2) { animation-delay: 0.5s; }

      &:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 36px rgba(13, 8, 87, 0.16);
        border-color: $talent;
      }

      @include max-sm { padding: 1.75rem; }
    }

    &__card-eyebrow { color: $talent; font-weight: 600; }
    &__card-title {
      font-size: 1.5rem;
      font-weight: 700;
      line-height: 1.2;
      color: var(--color-text);
      margin: 0;
    }
    &__card-body {
      font-size: 0.9375rem;
      line-height: 1.6;
      color: var(--color-muted);
      margin: 0;
    }
    &__card-link {
      margin-top: auto;
      padding-top: 0.5rem;
      font-size: 0.9375rem;
      font-weight: 600;
      color: $accent;
    }
  }

  @keyframes ft-fade-up {
    to { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .ft-hero__head,
    .ft-hero__card {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>
