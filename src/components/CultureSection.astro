---
import type { LandingContent } from "../content/index";

interface Props {
  content: LandingContent["culture"];
}

const { content } = Astro.props;
---

<section class="culture">
  <div class="culture__container">
    <div class="culture__content">
      <div class="culture__header">
        <h2 class="headline culture__headline">
          {content.headline}
        </h2>
      </div>
      <div class="culture__body-wrapper">
        <div class="culture__body">
          <p class="culture__text">{content.body1}</p>
          <p class="culture__text">{content.body2}</p>
        </div>
      </div>
    </div>
    <img
      src="https://img.freepik.com/foto-gratis/sonriente-mujer-bonita-pone-punos-cara-aislada-pared-naranja_141793-66278.jpg?semt=ais_hybrid&w=740&q=80"
      class="culture__image"
    />
  </div>
</section>

<style lang="scss">
  @use '../styles/breakpoints' as *;

  .culture {
    padding: 7rem 2.5rem;
    background: var(--color-bg);

    @include max-md {
      padding: 5rem 2.5rem;
    }

    &__container {
      display: flex;
      max-width: 80rem;
      margin-inline: auto;
      align-items: center;
      justify-content: center;
      gap: 4rem;
    }

    &__content {
      display: flex;
      flex-direction: column;
    }

    &__header {
      max-width: 36rem;
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
      margin-bottom: 4rem;

      @include max-md {
        margin-bottom: 3rem;
      }
    }

    &__headline {
      color: var(--color-text);

      @include max-lg {
        text-align: center;
      }
    }

    &__body-wrapper {
      display: flex;
      max-width: 36rem;
      align-items: flex-start;
    }

    &__body {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    &__text {
      font-family: var(--font-primary);
      font-size: 1.125rem;
      font-weight: 400;
      line-height: 1.7;
      letter-spacing: -0.36px;
      color: var(--color-muted);
      font-feature-settings: 'ss03', 'ss10', 'ss11', 'ss12';

      @include max-lg {
        text-align: center;
      }
    }

    &__image {
      height: 30rem;
      width: 21.25rem;
      object-fit: cover;
      border-radius: 2rem;
      background-color: #4b5563;
      margin-inline: auto;

      @include max-lg {
        display: none;
      }
    }
  }
</style>