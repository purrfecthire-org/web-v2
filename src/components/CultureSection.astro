---
import type { LandingContent } from "../content/index";

interface Props {
  content: LandingContent["culture"];
}

const { content } = Astro.props;
---

<section
  class="py-20 md:py-28"
  style="background: var(--color-ube-800);"
>
  <div class="max-w-[1280px] mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section header -->
    <div class="flex flex-col gap-6 max-w-3xl mb-12 md:mb-16">

      <!-- Badge -->
      <span
        class="label-uppercase"
        style="color: var(--color-ube-300); display: inline-block; width: fit-content;"
      >
        {content.badge}
      </span>

      <!-- Headline -->
      <h2
        class="headline2"
        style="color: #ffffff;"
      >
        {content.headline}
      </h2>
    </div>

    <!-- Body + Quotes — two column on desktop -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-start">

      <!-- Body text -->
      <div class="flex flex-col gap-6">
        <p
          style="font-family: var(--font-primary); font-size: 1.125rem; font-weight: 400; line-height: 1.7; letter-spacing: -0.36px; color: var(--color-ube-300); font-feature-settings: 'ss03', 'ss10', 'ss11', 'ss12';"
        >
          {content.body1}
        </p>
        <p
          style="font-family: var(--font-primary); font-size: 1.125rem; font-weight: 400; line-height: 1.7; letter-spacing: -0.36px; color: var(--color-ube-300); font-feature-settings: 'ss03', 'ss10', 'ss11', 'ss12';"
        >
          {content.body2}
        </p>
      </div>

      <!-- Quotes -->
      <div class="flex flex-col gap-5">
        {content.quotes.map((quote) => (
          <blockquote
            class="flex flex-col gap-4 p-7"
            style="background: rgba(255,255,255,0.06); border: 1px dashed var(--color-ube-300); border-radius: 24px;"
          >
            <!-- Open-quote glyph -->
            <span
              aria-hidden="true"
              style="font-family: var(--font-display); font-size: 3rem; line-height: 1; color: var(--color-ube-300); opacity: 0.5; margin-bottom: -8px; font-feature-settings: 'ss01', 'ss03', 'ss10', 'ss11', 'ss12';"
            >"</span>

            <p
              style="font-family: var(--font-primary); font-size: 1rem; font-weight: 400; line-height: 1.65; letter-spacing: -0.16px; color: #ffffff; font-feature-settings: 'ss03', 'ss10', 'ss11', 'ss12'; font-style: italic;"
            >
              {quote.text}
            </p>

            <footer>
              <span
                class="label-uppercase"
                style="color: var(--color-ube-300); opacity: 0.8;"
              >
                {quote.author}
              </span>
            </footer>
          </blockquote>
        ))}
      </div>

    </div>
  </div>
</section>
