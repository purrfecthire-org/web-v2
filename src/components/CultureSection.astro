---
import type { LandingContent } from "../content/index";

interface Props {
  content: LandingContent["culture"];
}

const { content } = Astro.props;
---

<section class="culture">
  <div class="culture__container">

    <!-- Header -->
    <div class="culture__header">
      <h2 class="culture__headline headline2">
        {content.headline}
      </h2>
    </div>

    <!-- Body paragraphs -->
    <div class="culture__body">
      {content.body.map((paragraph) => (
        <p class="culture__text body1">{paragraph}</p>
      ))}
    </div>

    <!-- Quotes -->
    <div class="culture__quotes">
      {content.quotes.map((quote) => (
        <div class="culture__quote-card">
          <p class="culture__quote-text body1">
            "{quote.text}"
          </p>
          <span class="culture__quote-attribution eyebrow">
            {quote.attribution}
          </span>
        </div>
      ))}
    </div>

  </div>
</section>

<style lang="scss">
  @use '../styles/breakpoints' as *;

  .culture {
    padding: 7rem 0;
    background: var(--color-bg);

    @include max-md { padding: 5rem 0; }

    &__container {
      max-width: 48rem;
      margin-inline: auto;
      padding-inline: 2rem;

      @include max-sm { padding-inline: 1rem; }
    }

    &__header {
      margin-bottom: 2rem;
    }

    &__headline {
      color: var(--color-text);
    }

    &__body {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      margin-bottom: 3rem;
    }

    &__text {}

    &__quotes {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;

      @include max-sm { grid-template-columns: 1fr; }
    }

    &__quote-card {
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: 12px;
      padding: 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    &__quote-text {
      font-style: italic;
    }

    &__quote-attribution {}
  }
</style>
