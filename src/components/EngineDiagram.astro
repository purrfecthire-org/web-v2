---
import type { LandingContent } from '../content/index';

interface Props {
  content: LandingContent['engine'];
}

const { content } = Astro.props;
---

<!-- ─── DESKTOP: sticky scroll ─────────────────────────────── -->
<section id="engine" class="relative hidden lg:block bg-[#0a0a0f]" aria-label="How it works">

  <!-- Sticky wrapper: fills viewport while scroll triggers pass -->
  <div id="engine-sticky" class="sticky top-0 h-screen flex items-center overflow-hidden">
    <div class="w-full max-w-[1280px] mx-auto px-8 grid grid-cols-2 gap-16 items-center">

      <!-- LEFT: text panel -->
      <div class="flex flex-col gap-8">

        <!-- Badge + headline (static) -->
        <div class="flex flex-col gap-4">
          <span class="inline-flex w-fit items-center px-3 py-1.5 rounded-full border border-white/20 bg-white/5 text-xs font-medium text-white/60 tracking-wide">
            {content.badge}
          </span>
          <h2 class="text-5xl xl:text-6xl font-extrabold tracking-tight text-white leading-[1.05]">
            {content.headline}
          </h2>
          <p class="text-white/40 text-base leading-relaxed max-w-sm">
            {content.subheadline}
          </p>
        </div>

        <!-- Step text (changes on scroll) -->
        <div class="relative h-36">
          {content.steps.map((step, i) => (
            <div
              class="engine-step-text absolute inset-0 flex flex-col gap-3 transition-all duration-500"
              data-step={i}
              style={i === 0 ? 'opacity:1;transform:translateY(0)' : 'opacity:0;transform:translateY(12px);pointer-events:none'}
            >
              <div class="flex items-center gap-3">
                <span class="font-mono text-xs text-white/30 tracking-widest">{step.id}</span>
                <span class="h-px flex-1 max-w-[40px] bg-white/20" />
                <span class="text-xs font-semibold uppercase tracking-widest text-indigo-400">{step.label}</span>
              </div>
              <p class="text-white/70 text-lg leading-relaxed font-light max-w-sm">
                {step.description}
              </p>
            </div>
          ))}
        </div>

        <!-- Step indicators -->
        <div class="flex items-center gap-3">
          {content.steps.map((_, i) => (
            <button
              class="engine-dot transition-all duration-300 rounded-full"
              data-step={i}
              style={i === 0
                ? 'width:24px;height:6px;background:rgb(99,102,241)'
                : 'width:6px;height:6px;background:rgba(255,255,255,0.2)'}
              aria-label={`Step ${i + 1}`}
            />
          ))}
          <span class="ml-2 text-xs text-white/30 font-mono" id="engine-step-counter">01 / 0{content.steps.length}</span>
        </div>
      </div>

      <!-- RIGHT: visual panel (changes on scroll) -->
      <div class="relative h-[460px]">
        {content.steps.map((step, i) => (
          <div
            class="engine-step-visual absolute inset-0 transition-all duration-500"
            data-step={i}
            style={i === 0 ? 'opacity:1;transform:scale(1)' : 'opacity:0;transform:scale(0.97);pointer-events:none'}
          >
            {i === 0 && (
              <!-- Visual 01: Signal extraction -->
              <div class="w-full h-full rounded-2xl border border-white/10 bg-white/[0.03] p-8 flex flex-col gap-6">
                <div class="flex items-center gap-2 mb-2">
                  <span class="w-2 h-2 rounded-full bg-indigo-400 animate-pulse" />
                  <span class="text-xs text-white/40 font-mono">signal_extraction.run()</span>
                </div>
                <div class="flex flex-col gap-3">
                  {['What does a "good" hire look like at your stage?', 'Walk me through your last failed hire.', 'What does your onboarding actually test?'].map((q, qi) => (
                    <div class="flex items-start gap-3 p-3 rounded-xl bg-white/5 border border-white/[0.07]">
                      <span class="w-5 h-5 rounded-full bg-indigo-500/20 border border-indigo-500/30 flex items-center justify-center text-indigo-400 text-[10px] flex-shrink-0 mt-0.5">{qi + 1}</span>
                      <p class="text-sm text-white/70 leading-snug">{q}</p>
                    </div>
                  ))}
                </div>
                <div class="mt-auto p-4 rounded-xl bg-indigo-500/10 border border-indigo-500/20">
                  <p class="text-xs text-indigo-300/80 leading-relaxed">
                    <span class="font-semibold text-indigo-300">Signal captured.</span> Your real bar — not the job description — is now the training spec.
                  </p>
                </div>
              </div>
            )}
            {i === 1 && (
              <!-- Visual 02: Targeted training -->
              <div class="w-full h-full rounded-2xl border border-white/10 bg-white/[0.03] p-8 flex flex-col gap-6">
                <div class="flex items-center gap-2 mb-2">
                  <span class="w-2 h-2 rounded-full bg-violet-400 animate-pulse" />
                  <span class="text-xs text-white/40 font-mono">training_pipeline.start()</span>
                </div>
                <div class="flex flex-col gap-4">
                  {[
                    { label: 'System design calibration', pct: 92 },
                    { label: 'Startup culture signal', pct: 88 },
                    { label: 'Technical depth (your stack)', pct: 95 },
                    { label: 'Execution under ambiguity', pct: 84 },
                  ].map(({ label, pct }) => (
                    <div class="flex flex-col gap-1.5">
                      <div class="flex justify-between text-xs">
                        <span class="text-white/50">{label}</span>
                        <span class="text-violet-400 font-mono font-semibold">{pct}%</span>
                      </div>
                      <div class="h-1.5 rounded-full bg-white/10 overflow-hidden">
                        <div
                          class="h-full rounded-full bg-gradient-to-r from-violet-500 to-indigo-400"
                          style={`width:${pct}%`}
                        />
                      </div>
                    </div>
                  ))}
                </div>
                <div class="mt-auto p-4 rounded-xl bg-violet-500/10 border border-violet-500/20">
                  <p class="text-xs text-violet-300/80 leading-relaxed">
                    <span class="font-semibold text-violet-300">Not generic prep.</span> Every drill maps back to your specific signal.
                  </p>
                </div>
              </div>
            )}
            {i === 2 && (
              <!-- Visual 03: Precision placement -->
              <div class="w-full h-full rounded-2xl border border-white/10 bg-white/[0.03] p-8 flex flex-col gap-5">
                <div class="flex items-center gap-2 mb-2">
                  <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse" />
                  <span class="text-xs text-white/40 font-mono">matches.ready — 3 candidates</span>
                </div>
                {[
                  { name: 'Sofia Reyes', role: 'Sr. Frontend', match: 97, skills: ['React', 'TypeScript'] },
                  { name: 'Marcus Chen', role: 'Full-Stack', match: 94, skills: ['Node.js', 'AWS'] },
                  { name: 'Amara Osei', role: 'Backend', match: 91, skills: ['Go', 'Kubernetes'] },
                ].map((c) => (
                  <div class="flex items-center justify-between gap-4 p-4 rounded-xl bg-white/5 border border-white/[0.07] hover:border-white/20 transition-colors group cursor-default">
                    <div class="flex items-center gap-3">
                      <div class="w-8 h-8 rounded-full bg-gradient-to-br from-indigo-500 to-violet-600 flex items-center justify-center text-xs font-bold text-white flex-shrink-0">
                        {c.name.split(' ').map(n => n[0]).join('')}
                      </div>
                      <div>
                        <p class="text-sm font-medium text-white/90">{c.name}</p>
                        <p class="text-xs text-white/40">{c.role}</p>
                      </div>
                    </div>
                    <div class="flex items-center gap-2">
                      {c.skills.map(s => (
                        <span class="px-2 py-0.5 rounded-md bg-white/5 border border-white/10 text-[11px] text-white/50">{s}</span>
                      ))}
                      <span class="ml-1 text-xs font-bold text-emerald-400">{c.match}%</span>
                    </div>
                  </div>
                ))}
              </div>
            )}
            {i === 3 && (
              <!-- Visual 04: Feedback loop -->
              <div class="w-full h-full rounded-2xl border border-white/10 bg-white/[0.03] p-8 flex flex-col gap-6">
                <div class="flex items-center gap-2 mb-2">
                  <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse" />
                  <span class="text-xs text-white/40 font-mono">feedback.loop — 90d data</span>
                </div>
                <div class="flex flex-col gap-3">
                  {[
                    { event: 'Offer signed', company: 'Meridian AI', delta: '+1 signal', color: 'emerald' },
                    { event: '30-day check-in', company: 'Stride Protocol', delta: 'Strong', color: 'emerald' },
                    { event: 'Pass — culture miss', company: 'Nexus Build', delta: 'Signal updated', color: 'amber' },
                    { event: '90-day retained', company: 'Meridian AI', delta: 'Model trained', color: 'indigo' },
                  ].map(({ event, company, delta, color }) => (
                    <div class="flex items-center justify-between px-4 py-3 rounded-xl bg-white/[0.04] border border-white/[0.06]">
                      <div class="flex items-center gap-3">
                        <span class={`w-1.5 h-1.5 rounded-full flex-shrink-0 bg-${color}-400`} />
                        <div>
                          <p class="text-sm text-white/80">{event}</p>
                          <p class="text-xs text-white/30">{company}</p>
                        </div>
                      </div>
                      <span class={`text-xs font-semibold text-${color}-400`}>{delta}</span>
                    </div>
                  ))}
                </div>
                <div class="mt-auto p-4 rounded-xl bg-emerald-500/10 border border-emerald-500/20">
                  <p class="text-xs text-emerald-300/80 leading-relaxed">
                    <span class="font-semibold text-emerald-300">The system gets smarter.</span> Every outcome — hire, pass, churn — refines the next placement.
                  </p>
                </div>
              </div>
            )}
          </div>
        ))}
      </div>

    </div>
  </div>

  <!-- Scroll triggers: 4 × 100vh, invisible -->
  <div class="relative" style="height: calc(4 * 100vh);" aria-hidden="true">
    {content.steps.map((_, i) => (
      <div class="engine-trigger absolute w-full" data-step={i} style={`top: ${i * 100}vh; height: 100vh;`} />
    ))}
  </div>

</section>

<!-- ─── MOBILE: fade-in cards ─────────────────────────────── -->
<section id="engine" class="lg:hidden bg-[#0a0a0f] py-20 px-4" aria-label="How it works">
  <div class="max-w-lg mx-auto flex flex-col gap-6">

    <!-- Header -->
    <div class="flex flex-col gap-4 mb-4">
      <span class="inline-flex w-fit items-center px-3 py-1.5 rounded-full border border-white/20 bg-white/5 text-xs font-medium text-white/60">
        {content.badge}
      </span>
      <h2 class="text-3xl font-extrabold tracking-tight text-white leading-tight">
        {content.headline}
      </h2>
      <p class="text-white/40 text-sm leading-relaxed">
        {content.subheadline}
      </p>
    </div>

    <!-- Step cards -->
    {content.steps.map((step, i) => (
      <div
        class="mobile-step-card opacity-0 translate-y-6 transition-all duration-500 flex gap-4 p-5 rounded-2xl border border-white/10 bg-white/[0.03]"
        data-index={i}
        style="transition-delay: 0ms"
      >
        <div class="flex-shrink-0 w-10 h-10 rounded-xl bg-indigo-500/20 border border-indigo-500/30 flex items-center justify-center font-mono text-sm font-bold text-indigo-300">
          {step.id}
        </div>
        <div class="flex flex-col gap-1.5 pt-1">
          <h3 class="text-sm font-semibold text-white">{step.label}</h3>
          <p class="text-sm text-white/50 leading-relaxed">{step.description}</p>
        </div>
      </div>
    ))}

    <!-- Flywheel note -->
    <div class="flex items-center gap-2 px-4 py-3 rounded-xl border border-emerald-500/20 bg-emerald-500/5 mt-2">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" class="flex-shrink-0">
        <path d="M2 7c0-2.76 2.24-5 5-5s5 2.24 5 5-2.24 5-5 5" stroke="#10b981" stroke-width="1.3" stroke-linecap="round"/>
        <path d="M2 10V7h3" stroke="#10b981" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span class="text-xs text-emerald-400 font-medium">Step 4 {content.connectorLabel} — the loop never stops.</span>
    </div>
  </div>
</section>

<script>
  // ─── Desktop sticky scroll ────────────────────────────────
  const sticky    = document.getElementById('engine-sticky') as HTMLElement | null;
  const triggers  = document.querySelectorAll<HTMLElement>('.engine-trigger');
  const stepTexts = document.querySelectorAll<HTMLElement>('.engine-step-text');
  const stepVisuals = document.querySelectorAll<HTMLElement>('.engine-step-visual');
  const dots      = document.querySelectorAll<HTMLElement>('.engine-dot');
  const counter   = document.getElementById('engine-step-counter');

  let currentStep = 0;

  function activateStep(idx: number) {
    if (idx === currentStep) return;
    currentStep = idx;

    stepTexts.forEach((el, i) => {
      if (i === idx) {
        el.style.opacity = '1';
        el.style.transform = 'translateY(0)';
        el.style.pointerEvents = 'auto';
      } else {
        el.style.opacity = '0';
        el.style.transform = i < idx ? 'translateY(-12px)' : 'translateY(12px)';
        el.style.pointerEvents = 'none';
      }
    });

    stepVisuals.forEach((el, i) => {
      if (i === idx) {
        el.style.opacity = '1';
        el.style.transform = 'scale(1)';
        el.style.pointerEvents = 'auto';
      } else {
        el.style.opacity = '0';
        el.style.transform = 'scale(0.97)';
        el.style.pointerEvents = 'none';
      }
    });

    dots.forEach((dot, i) => {
      if (i === idx) {
        dot.style.width = '24px';
        dot.style.background = 'rgb(99,102,241)';
      } else {
        dot.style.width = '6px';
        dot.style.background = 'rgba(255,255,255,0.2)';
      }
    });

    if (counter) {
      counter.textContent = `0${idx + 1} / 0${triggers.length}`;
    }
  }

  // Dots are also clickable
  dots.forEach((dot) => {
    dot.addEventListener('click', () => {
      const idx = parseInt(dot.dataset.step ?? '0');
      activateStep(idx);
    });
  });

  if (triggers.length > 0 && sticky) {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const idx = parseInt((entry.target as HTMLElement).dataset.step ?? '0');
            activateStep(idx);
          }
        });
      },
      { threshold: 0.5 }
    );
    triggers.forEach((t) => io.observe(t));
  }

  // ─── Mobile fade-in ───────────────────────────────────────
  const mobileCards = document.querySelectorAll<HTMLElement>('.mobile-step-card');
  if (mobileCards.length > 0) {
    const mio = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            const idx = parseInt(el.dataset.index ?? '0');
            setTimeout(() => {
              el.style.opacity = '1';
              el.style.transform = 'translateY(0)';
            }, idx * 80);
            mio.unobserve(el);
          }
        });
      },
      { threshold: 0.2 }
    );
    mobileCards.forEach((c) => mio.observe(c));
  }
</script>
