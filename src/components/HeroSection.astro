---
import type { LandingContent } from "../content/index";

interface Props {
  content: LandingContent["hero"];
}

const { content } = Astro.props;
---

<section
  class="relative min-h-screen flex flex-col justify-center overflow-hidden pt-24 pb-16 md:pt-32 md:pb-24"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full">
    <div class="flex flex-col gap-10 justify-center items-center">

      <!-- Headline -->
      <h1
        class="opacity-0-init animate-fade-up animate-delay-100 text-center headline1 max-w-5xl"
        style="color: var(--color-text);"
      >
        {content.headline}
        <br />
        <span style="color: var(--color-primary);">
          {content.headlineAccent}
        </span>
      </h1>

      <!-- Subheadline -->
      <p
        class="opacity-0-init animate-fade-up animate-delay-200 text-center max-w-2xl"
        style="font-family: var(--font-primary); font-size: 1.125rem; font-weight: 400; line-height: 1.6; letter-spacing: -0.36px; color: var(--color-muted); font-feature-settings: 'ss03', 'ss10', 'ss11', 'ss12';"
      >
        {content.subheadline}
      </p>

      <!-- Animated Stats -->
      <div
        class="opacity-0-init animate-fade-up animate-delay-300 w-full max-w-3xl"
        id="hero-stats"
      >
        <div
          class="grid grid-cols-1 sm:grid-cols-3 gap-0"
          style=" border-radius: 24px; overflow: hidden;"
        >
          {content.stats.map((stat, i) => (
            <div
              class="stat-item flex flex-col items-center justify-center gap-1 py-8 px-6 text-center"
              style={`${i < content.stats.length - 1 ? 'border-bottom: 1px solid var(--color-oat-border);' : ''}`}
              data-value={stat.value}
              data-suffix={stat.suffix}
            >
              <div
                class="headline2 stat-number"
                style="color: var(--color-text); line-height: 1.0;"
              >
                {stat.suffixLeft}<span class="count">0</span>{stat.suffix}
              </div>
              <p
                class="caption text-center"
                style="color: var(--color-muted); max-width: 160px;"
              >
                {stat.label}
              </p>
            </div>
          ))}
        </div>
      </div>

      <!-- Audience Split CTAs -->
      <div class="opacity-0-init animate-fade-up animate-delay-400 flex flex-col items-center gap-5 w-full">
        <p
          class="label-uppercase"
          style="color: var(--color-warm-charcoal);"
        >
          {content.ctaAudienceLabel}
        </p>
        <div class="flex flex-col sm:flex-row items-center gap-4 w-full sm:w-auto">
          <a
            href="#audience"
            class="btn w-full sm:w-auto justify-center"
            style="padding: 12px 28px; border-radius: 1584px; font-size: 1rem;"
          >
            {content.ctaHire}
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path
                d="M3 8h10M9 4l4 4-4 4"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
          </a>
          <a
            href="#audience"
            class="btn-ghost w-full sm:w-auto justify-center"
            style="padding: 12px 28px; border-radius: 1584px; font-size: 1rem;"
          >
            {content.ctaTalent}
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path
                d="M3 8h10M9 4l4 4-4 4"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
          </a>
        </div>
        <p
          class="caption text-center"
          style="color: var(--color-muted); max-width: 380px;"
        >
          {content.socialProofLabel}
        </p>
      </div>

    </div>
  </div>
</section>

<style>
  /* Responsive stat dividers */
  @media (min-width: 640px) {
    .stat-item {
      border-bottom: none !important;
      border-right: 1px solid var(--color-oat-border);
    }
    .stat-item:last-child {
      border-right: none;
    }
  }
</style>

<script>
  function animateCount(el: Element, target: number, duration: number = 1200) {
    const countEl = el.querySelector('.count');
    if (!countEl) return;

    const start = performance.now();
    const from = 0;

    function easeOut(t: number): number {
      return 1 - Math.pow(1 - t, 3);
    }

    function tick(now: number) {
      const elapsed = now - start;
      const progress = Math.min(elapsed / duration, 1);
      const current = Math.round(from + (target - from) * easeOut(progress));
      if (countEl) {
        countEl.textContent = current.toString();
        if (progress < 1) {
          requestAnimationFrame(tick);
        } else {
          countEl.textContent = target.toString();
        }
      }
    }

    requestAnimationFrame(tick);
  }

  const statsSection = document.getElementById('hero-stats');
  if (statsSection) {
    const items = statsSection.querySelectorAll('.stat-item');
    let triggered = false;

    const observer = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting && !triggered) {
          triggered = true;
          items.forEach((item) => {
            const target = parseInt(item.getAttribute('data-value') || '0', 10);
            animateCount(item, target, 1400);
          });
          observer.disconnect();
        }
      },
      { threshold: 0.4 }
    );

    observer.observe(statsSection);
  }
</script>
