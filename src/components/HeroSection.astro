---
import type { LandingContent } from "../content/index";

interface Props {
  content: LandingContent["hero"];
}

const { content } = Astro.props;
---

<section class="hero">
  <div class="hero__container">
    <div class="hero__content">

      <!-- Headline -->
      <h1 class="hero__headline headline1 opacity-0-init animate-fade-up animate-delay-100">
        {content.headline}
        <br />
        <span class="hero__headline-accent">
          {content.headlineAccent}
        </span>
      </h1>

      <!-- Subheadline -->
      <p class="hero__subheadline subhead subhead-section opacity-0-init animate-fade-up animate-delay-200">
        {content.subheadline}
      </p>

      <!-- Metrics -->
      <div class="hero__metrics opacity-0-init animate-fade-up animate-delay-300" id="hero-stats">
        {content.stats.map((stat, i) => (
          <>
            {i > 0 && <div class="hero__metric-divider" />}
            <div
              class="hero__metric"
              data-value={stat.value}
              data-suffix={stat.suffix}
            >
              <div class="hero__metric-value">
                {stat.suffixLeft}<span class="count">0</span>{stat.suffix}
              </div>
              <p class="hero__metric-label">
                {stat.label}
              </p>
            </div>
          </>
        ))}
      </div>

      <!-- CTAs -->
      <div class="hero__ctas opacity-0-init animate-fade-up animate-delay-400">
        <a href="#cta" class="btn">
          {content.ctaPrimary}
        </a>
        <a href="#engine" class="btn-secondary">
          {content.ctaSecondary}
        </a>
      </div>

      <!-- Trust line -->
      <p class="hero__trust opacity-0-init animate-fade-up animate-delay-400">
        {content.trustLabel}
      </p>

    </div>
  </div>
</section>

<style lang="scss">
  @use '../styles/breakpoints' as *;

  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
    padding-top: 8rem;
    padding-bottom: 6rem;

    @include max-md {
      padding-top: 6rem;
      padding-bottom: 4rem;
    }

    &__container {
      max-width: 80rem;
      margin-inline: auto;
      padding-inline: 2rem;
      width: 100%;

      @include max-lg { padding-inline: 1.5rem; }
      @include max-sm { padding-inline: 1rem; }
    }

    &__content {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 2.5rem;
    }

    &__headline {
      text-align: center;
      max-width: 64rem;
      color: var(--color-text);
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    &__headline-accent {
      color: var(--color-accent);
    }

    &__subheadline {
      text-align: center;
    }

    // ── Metrics ─────────────────────────────────────────────
    &__metrics {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 2.5rem;

      @include max-sm {
        gap: 1.5rem;
      }
    }

    &__metric {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.25rem;
      text-align: center;
    }

    &__metric-value {
      font-size: 2.25rem;
      font-weight: 500;
      line-height: 1;
      color: var(--color-text);

      @include max-sm {
        font-size: 1.75rem;
      }
    }

    &__metric-label {
      font-size: 0.875rem;
      color: var(--color-muted);
      max-width: 120px;
    }

    &__metric-divider {
      width: 1px;
      height: 40px;
      background-color: var(--color-border);
    }

    // ── CTAs ────────────────────────────────────────────────
    &__ctas {
      display: flex;
      align-items: center;
      gap: 1rem;

      @include max-sm {
        flex-direction: column;
        width: 100%;
      }
    }

    &__trust {
      font-size: 0.875rem;
      color: var(--color-muted);
      text-align: center;
    }
  }
</style>

<script>
  function animateCount(el: Element, target: number, duration: number = 1200) {
    const countEl = el.querySelector('.count');
    if (!countEl) return;

    const start = performance.now();

    function easeOut(t: number): number {
      return 1 - Math.pow(1 - t, 3);
    }

    function tick(now: number) {
      const elapsed = now - start;
      const progress = Math.min(elapsed / duration, 1);
      const current = Math.round((target) * easeOut(progress));
      if (countEl) {
        countEl.textContent = current.toString();
        if (progress < 1) requestAnimationFrame(tick);
        else countEl.textContent = target.toString();
      }
    }

    requestAnimationFrame(tick);
  }

  const statsSection = document.getElementById('hero-stats');
  if (statsSection) {
    const items = statsSection.querySelectorAll('.hero__metric');
    let triggered = false;

    const observer = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting && !triggered) {
          triggered = true;
          items.forEach((item) => {
            const target = parseInt(item.getAttribute('data-value') || '0', 10);
            animateCount(item, target, 1400);
          });
          observer.disconnect();
        }
      },
      { threshold: 0.4 }
    );

    observer.observe(statsSection);
  }
</script>
