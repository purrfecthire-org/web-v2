---
import type { LandingContent } from "../content/index";

interface Props {
  content: LandingContent["engine"];
}

const { content } = Astro.props;
---

<section id="engine" class="engine">
  <div class="engine__wrapper">

    <!-- Section header -->
    <div class="engine__header">
      <span class="engine__eyebrow eyebrow">
        {content.eyebrow}
      </span>
      <h2 class="engine__headline headline2">
        {content.headline}
      </h2>
      <p class="engine__subheadline body1">
        {content.subheadline}
      </p>
    </div>

    <!-- Steps -->
    <div class="engine__steps">
      {content.steps.map((step) => (
        <div class="engine__step">
          <div class="engine__step-number-wrapper">
            <span class="engine__step-number">
              {step.id}
            </span>
          </div>

          <div class="engine__step-content">
            <h3 class="engine__step-title headline3">
              {step.title}
            </h3>
            <p class="engine__step-description body2">
              {step.description}
            </p>

            {step.badge && (
              <div class="engine__step-badge-wrapper">
                <span class="engine__step-badge">
                  {step.badge}
                </span>
              </div>
            )}
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style lang="scss">
  @use '../styles/breakpoints.scss' as *;

  .engine {
    padding: 7rem 0;
    background: var(--color-bg);

    @include max-md { padding: 5rem 0; }

    &__wrapper {
      max-width: 80rem;
      margin-inline: auto;
      padding-inline: 2rem;

      @include max-lg { padding-inline: 1.5rem; }
      @include max-sm { padding-inline: 1rem; }
    }

    &__header {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 1rem;
      margin-bottom: 3.5rem;
      max-width: 42rem;
      margin-inline: auto;
    }

    &__eyebrow {}

    &__headline {
      color: var(--color-text);
    }

    &__subheadline {}

    &__steps {
      display: flex;
      flex-direction: column;
    }

    &__step {
      display: flex;
      flex-direction: row;
      gap: 2rem;
      padding: 2rem 0;
      border-bottom: 1px solid var(--color-border);

      &:first-child {
        border-top: 1px solid var(--color-border);
      }

      @include max-sm {
        flex-direction: column;
        gap: 1rem;
        padding: 1.5rem 0;
      }
    }

    &__step-number-wrapper {
      flex-shrink: 0;
    }

    &__step-number {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 4px 8px;
      background-color: #E8E6F8;
      color: #3C2BDC;
      border-radius: 8px;
      font-weight: 500;
      font-size: 0.6875rem;
    }

    &__step-content {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      flex: 1;
    }

    &__step-title {}

    &__step-description {}

    &__step-badge-wrapper {
      margin-top: 0.5rem;
    }

    &__step-badge {
      display: inline-flex;
      align-items: center;
      padding: 4px 12px;
      background: transparent;
      border: 1px solid var(--color-border);
      color: var(--color-muted);
      border-radius: 999px;
      font-size: 0.6875rem;
      font-weight: 500;
    }
  }
</style>
