---
import { getRelativeLocaleUrl } from 'astro:i18n';
import type { LandingContent } from '../content/index';

interface Props {
  content: LandingContent['nav'];
  lang: string;
}

const { content, lang } = Astro.props;
const otherLang = lang === 'en' ? 'es' : 'en';
const otherLangLabel = lang === 'en' ? 'ES' : 'EN';
const otherLangHref = getRelativeLocaleUrl(otherLang, '/');
---

<header id="nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <nav class="flex items-center justify-between h-16">

      <!-- Logo -->
      <img src="/logos/logo-desktop.png" class="w-40" alt="logo" />

      <!-- Desktop links -->
      <div class="hidden md:flex items-center gap-1">
        {content.links.map((link, i) => (
          <>
            {i > 0 && <span class="nav-sep" aria-hidden="true">·</span>}
            <a href={link.href} class="nav-link px-3">
              {link.label}
            </a>
          </>
        ))}
      </div>

      <!-- Right side -->
      <div class="flex items-center gap-3">
        <!-- Lang switcher -->
        <a href={otherLangHref} class="lang-switch">
          {otherLangLabel}
        </a>

        <!-- CTA pill -->
        <a href="#cta" class="btn nav-cta hidden sm:inline-flex">
          {content.cta}
        </a>

        <!-- Mobile hamburger -->
        <button
          id="mobile-menu-btn"
          class="md:hidden p-2 rounded-lg transition-colors"
          style="color: var(--color-text);"
          aria-label="Toggle menu"
        >
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              d="M3 5h14M3 10h14M3 15h14"
            ></path>
          </svg>
        </button>
      </div>
    </nav>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="md:hidden hidden border-b"
    style="background: var(--color-surface); border-color: var(--color-border);"
  >
    <div class="max-w-[1280px] mx-auto px-4 py-4 flex flex-col gap-1">
      {content.links.map((link) => (
        <a href={link.href} class="nav-link py-2">
          {link.label}
        </a>
      ))}
      <a
        href="#cta"
        class="btn nav-cta mt-3 justify-center"
        style="border-radius: 12px;"
      >
        {content.cta}
      </a>
    </div>
  </div>
</header>

<script>
  const nav = document.getElementById('nav');
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      nav?.classList.add('scrolled');
    } else {
      nav?.classList.remove('scrolled');
    }
  }, { passive: true });

  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>

<style>
  header {
    background: transparent;
    transition: background 200ms ease, border-color 200ms ease, box-shadow 200ms ease;
  }

  header.scrolled {
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    box-shadow: var(--shadow-base);
  }

  /* Nav link — 15px weight 500, 4 stylistic sets */
  .nav-link {
    font-family: 'Roobert', 'Space Grotesk', Arial, sans-serif;
    font-size: 0.9375rem; /* 15px */
    font-weight: 500;
    line-height: 1.6;
    letter-spacing: normal;
    font-feature-settings: "ss03", "ss10", "ss11", "ss12";
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .nav-link:hover {
    color: var(--color-text);
  }

  .nav-sep {
    font-family: 'Roobert', 'Space Grotesk', Arial, sans-serif;
    font-size: 0.9375rem;
    color: var(--color-oat-border);
    user-select: none;
    pointer-events: none;
  }

  /* CTA — pill radius override */
  .nav-cta {
    border-radius: 1584px;
    padding: 6px 16px;
    font-size: 0.9375rem;
  }

  /* Lang switcher */
  .lang-switch {
    font-family: 'Roobert', 'Space Grotesk', Arial, sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: 1.08px;
    text-transform: uppercase;
    font-feature-settings: "ss03", "ss10", "ss11", "ss12";
    color: var(--color-muted);
    text-decoration: none;
    padding: 4px 8px;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .lang-switch:hover {
    color: var(--color-text);
    border-color: var(--color-text);
  }
</style>
