---
import { getRelativeLocaleUrl } from 'astro:i18n';
import type { LandingContent } from '../content/index';

interface Props {
  content: LandingContent['nav'];
  lang: string;
}

const { content, lang } = Astro.props;
const otherLang = lang === 'en' ? 'es' : 'en';
const otherLangLabel = lang === 'en' ? 'ES' : 'EN';
const otherLangHref = getRelativeLocaleUrl(otherLang, '/');
---

<header id="nav" class="nav">
  <div class="nav__container">
    <nav class="nav__inner">

      <!-- Logo -->
      <img src="/logos/logo-desktop.png" class="nav__logo" alt="logo" />

      <!-- Desktop links -->
      <div class="nav__links">
        {content.links.map((link, i) => (
          <>
            {i > 0 && <span class="nav__sep" aria-hidden="true">·</span>}
            <a href={link.href} class="nav__link">
              {link.label}
            </a>
          </>
        ))}
      </div>

      <!-- Right side -->
      <div class="nav__actions">
        <a href={otherLangHref} class="nav__lang-switch">
          {otherLangLabel}
        </a>

        <a href="#cta" class="btn nav__cta">
          {content.cta}
        </a>

        <button
          id="mobile-menu-btn"
          class="nav__hamburger"
          aria-label="Toggle menu"
        >
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              d="M3 5h14M3 10h14M3 15h14"
            />
          </svg>
        </button>
      </div>
    </nav>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="nav__mobile-menu">
    <div class="nav__mobile-inner">
      {content.links.map((link) => (
        <a href={link.href} class="nav__link nav__link--mobile">
          {link.label}
        </a>
      ))}
      <a href="#cta" class="btn nav__cta nav__cta--mobile">
        {content.cta}
      </a>
    </div>
  </div>
</header>

<script>
  const nav = document.getElementById('nav');
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      nav?.classList.add('nav--scrolled');
    } else {
      nav?.classList.remove('nav--scrolled');
    }
  }, { passive: true });

  btn?.addEventListener('click', () => {
    menu?.classList.toggle('nav__mobile-menu--open');
  });
</script>

<style lang="scss">
  @use '../styles/breakpoints' as *;

  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background: transparent;
    transition:
      background 200ms ease,
      border-color 200ms ease,
      box-shadow 200ms ease;

    &--scrolled {
      background: var(--color-bg);
      border-bottom: 1px solid var(--color-border);
      box-shadow: var(--shadow-base);
    }

    // ── Container ──────────────────────────────────────────
    &__container {
      max-width: 80rem;
      margin-inline: auto;
      padding-inline: 2rem;

      @include max-lg { padding-inline: 1.5rem; }
      @include max-sm { padding-inline: 1rem; }
    }

    // ── Inner nav row ───────────────────────────────────────
    &__inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 4rem;
    }

    // ── Logo ────────────────────────────────────────────────
    &__logo {
      width: 10rem;
    }

    // ── Desktop links ───────────────────────────────────────
    &__links {
      display: flex;
      align-items: center;
      gap: 0.25rem;

      @include max-md { display: none; }
    }

    &__sep {
      font-family: 'Roobert', 'Space Grotesk', Arial, sans-serif;
      font-size: 0.9375rem;
      color: var(--color-oat-border);
      user-select: none;
      pointer-events: none;
    }

    &__link {
      font-family: 'Roobert', 'Space Grotesk', Arial, sans-serif;
      font-size: 0.9375rem;
      font-weight: 500;
      line-height: 1.6;
      letter-spacing: normal;
      font-feature-settings: "ss03", "ss10", "ss11", "ss12";
      color: var(--color-muted);
      text-decoration: none;
      padding-inline: 0.75rem;
      transition: color 0.15s ease;

      &:hover { color: var(--color-text); }

      &--mobile {
        padding-inline: 0;
        padding-block: 0.5rem;
      }
    }

    // ── Right actions ───────────────────────────────────────
    &__actions {
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    // ── Lang switcher ───────────────────────────────────────
    &__lang-switch {
      font-family: 'Roobert', 'Space Grotesk', Arial, sans-serif;
      font-size: 0.75rem;
      font-weight: 600;
      line-height: 1.2;
      letter-spacing: 1.08px;
      text-transform: uppercase;
      font-feature-settings: "ss03", "ss10", "ss11", "ss12";
      color: var(--color-muted);
      text-decoration: none;
      padding: 4px 8px;
      border: 1px solid var(--color-border);
      border-radius: 8px;
      transition: color 0.15s ease, border-color 0.15s ease;

      &:hover {
        color: var(--color-text);
        border-color: var(--color-text);
      }
    }

    // ── CTA pill ────────────────────────────────────────────
    &__cta {
      display: inline-flex;
      border-radius: 1584px;
      padding: 6px 16px;
      font-size: 0.9375rem;

      @include max-sm { display: none; }

      &--mobile {
        display: flex;
        justify-content: center;
        border-radius: 12px;
        margin-top: 0.75rem;
      }
    }

    // ── Hamburger ───────────────────────────────────────────
    &__hamburger {
      display: none;
      padding: 0.5rem;
      border-radius: 0.5rem;
      color: var(--color-text);
      background: none;
      border: none;
      cursor: pointer;
      transition: color 0.15s ease;

      @include max-md { display: flex; }
    }

    // ── Mobile menu ─────────────────────────────────────────
    &__mobile-menu {
      display: none;
      border-bottom: 1px solid var(--color-border);
      background: var(--color-surface);

      &--open {
        @include max-md { display: block; }
      }
    }

    &__mobile-inner {
      max-width: 1280px;
      margin-inline: auto;
      padding: 1rem;
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }
  }
</style>