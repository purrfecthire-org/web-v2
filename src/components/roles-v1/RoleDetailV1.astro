---
import type { Role } from '../../content/roleSample';

interface Props {
  role: Role;
}

const { role } = Astro.props;
const c = role.company;

const location = [...role.countries, ...(role.states ?? [])];
const internalStages = role.interviewProcess?.filter((s) => s.group === 'internal') ?? [];
const clientStages = role.interviewProcess?.filter((s) => s.group === 'client') ?? [];
---

<div class="rv1">
  <!-- Slim top bar -->
  <header class="rv1__bar">
    <a href="/" class="rv1__brand">Purrfect&nbsp;Hire</a>
    <nav class="rv1__bar-nav">
      <a href="/#roles" class="rv1__bar-link">All roles</a>
      <a href={role.applyEmail ? `mailto:${role.applyEmail}` : '#apply'} class="rv1__bar-cta">Apply</a>
    </nav>
  </header>

  <main class="rv1__main">
    <!-- ── Role header ─────────────────────────────────────────────── -->
    <section class="rv1__header">
      <span class="rv1__company">{role.companyLabel}</span>
      <h1 class="rv1__title">{role.title}</h1>

      <div class="rv1__facts">
        <span class="rv1__fact">
          <svg width="15" height="15" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M7 1.5C4.51 1.5 2.5 3.51 2.5 6c0 3.75 4.5 6.5 4.5 6.5S11.5 9.75 11.5 6c0-2.49-2.01-4.5-4.5-4.5Zm0 6.5a2 2 0 1 1 0-4 2 2 0 0 1 0 4Z" fill="currentColor"/>
          </svg>
          {location.join(' · ')}
        </span>
        <span class="rv1__fact-dot" aria-hidden="true"></span>
        <span class="rv1__fact">{role.modality}</span>
        <span class="rv1__fact-dot" aria-hidden="true"></span>
        <span class="rv1__fact">{role.employmentType}</span>
        {role.englishLevel && (
          <>
            <span class="rv1__fact-dot" aria-hidden="true"></span>
            <span class="rv1__fact rv1__fact--accent">English {role.englishLevel}</span>
          </>
        )}
      </div>

      <a href={role.applyEmail ? `mailto:${role.applyEmail}` : '#apply'} class="rv1__apply">
        Apply for this role
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </section>

    <!-- ── Fall in love with the company ───────────────────────────── -->
    <section class="rv1__card rv1__reveal">
      <span class="rv1__eyebrow">The Company</span>

      {(c.ycBatch || (c.awards && c.awards.length > 0)) && (
        <div class="rv1__badges">
          {c.ycBatch && (
            <span class="rv1__yc">
              <span class="rv1__yc-mark" aria-hidden="true">Y</span>
              Y Combinator · {c.ycBatch}
            </span>
          )}
          {c.awards?.map((a) => (
            <span class="rv1__award">
              {a.label}{a.year ? ` ${a.year}` : ''}{a.source ? ` · ${a.source}` : ''}
            </span>
          ))}
        </div>
      )}

      <p class="rv1__lede">{c.description}</p>
      {c.industry && <p class="rv1__industry">{c.industry}</p>}

      {(c.size || c.founded || c.funding) && (
        <div class="rv1__stats">
          {c.size && (
            <div class="rv1__stat">
              <span class="rv1__stat-value">{c.size}</span>
              <span class="rv1__stat-label">Team size</span>
            </div>
          )}
          {c.founded && (
            <div class="rv1__stat">
              <span class="rv1__stat-value">{c.founded}</span>
              <span class="rv1__stat-label">Founded</span>
            </div>
          )}
          {c.funding && (
            <div class="rv1__stat">
              <span class="rv1__stat-value">{c.funding}</span>
              <span class="rv1__stat-label">Funding</span>
            </div>
          )}
        </div>
      )}

      {c.strengths && c.strengths.length > 0 && (
        <div class="rv1__strengths">
          {c.strengths.map((s) => (
            <span class="rv1__strength">
              <svg width="13" height="13" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M11.5 4 6 9.5 3 6.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              {s}
            </span>
          ))}
        </div>
      )}
    </section>

    <!-- ── The Role ─────────────────────────────────────────────────── -->
    <section class="rv1__card rv1__card--role rv1__reveal">
      <span class="rv1__eyebrow rv1__eyebrow--role">The Role</span>
      <p class="rv1__lede">{role.roleDescription}</p>

      {role.skills && role.skills.length > 0 && (
        <div class="rv1__skills">
          {role.skills.map((s) => <span class="rv1__skill">{s}</span>)}
        </div>
      )}

      <div class="rv1__reqs">
        <div class="rv1__req-col">
          <h3 class="rv1__req-title">Must have</h3>
          <ul class="rv1__req-list">
            {role.requirements.mandatory.map((r) => (
              <li class="rv1__req rv1__req--must">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <circle cx="8" cy="8" r="8" fill="currentColor" opacity="0.12"/>
                  <path d="M11.5 5.5 7 10 5 8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>{r}</span>
              </li>
            ))}
          </ul>
        </div>

        {role.requirements.niceToHave && role.requirements.niceToHave.length > 0 && (
          <div class="rv1__req-col">
            <h3 class="rv1__req-title rv1__req-title--nice">Nice to have</h3>
            <ul class="rv1__req-list">
              {role.requirements.niceToHave.map((r) => (
                <li class="rv1__req rv1__req--nice">
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path d="M4 8h8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                  </svg>
                  <span>{r}</span>
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>

      {role.englishLevel && (
        <div class="rv1__english">
          <svg width="15" height="15" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.2"/>
            <path d="M1.5 7h11M7 1.5c1.6 1.6 1.6 9.4 0 11M7 1.5c-1.6 1.6-1.6 9.4 0 11" stroke="currentColor" stroke-width="1.1"/>
          </svg>
          Minimum English required: <strong>{role.englishLevel}</strong>
        </div>
      )}
    </section>

    <!-- ── Interview process (optional) ─────────────────────────────── -->
    {role.interviewProcess && role.interviewProcess.length > 0 && (
      <section class="rv1__card rv1__reveal">
        <span class="rv1__eyebrow">Interview Process</span>

        {internalStages.length > 0 && (
          <div class="rv1__phase">
            <h3 class="rv1__phase-title">Internal process</h3>
            <ol class="rv1__timeline">
              {internalStages.map((s) => (
                <li class="rv1__step">
                  <span class="rv1__step-dot" aria-hidden="true"></span>
                  <div class="rv1__step-body">
                    <div class="rv1__step-head">
                      <span class="rv1__step-name">{s.name}</span>
                      {s.duration && <span class="rv1__step-time">{s.duration}</span>}
                    </div>
                    {s.detail && <p class="rv1__step-detail">{s.detail}</p>}
                  </div>
                </li>
              ))}
            </ol>
          </div>
        )}

        {clientStages.length > 0 && (
          <div class="rv1__phase">
            <h3 class="rv1__phase-title rv1__phase-title--client">Client stage</h3>
            <ol class="rv1__timeline">
              {clientStages.map((s) => (
                <li class="rv1__step rv1__step--client">
                  <span class="rv1__step-dot" aria-hidden="true"></span>
                  <div class="rv1__step-body">
                    <div class="rv1__step-head">
                      <span class="rv1__step-name">{s.name}</span>
                      {s.duration && <span class="rv1__step-time">{s.duration}</span>}
                    </div>
                    {s.detail && <p class="rv1__step-detail">{s.detail}</p>}
                  </div>
                </li>
              ))}
            </ol>
          </div>
        )}
      </section>
    )}

    <!-- ── Final CTA ────────────────────────────────────────────────── -->
    <section class="rv1__cta" id="apply">
      <h2 class="rv1__cta-title">Think this is you?</h2>
      <p class="rv1__cta-sub">Apply once. We match you with the roles where you fit best.</p>
      <a href={role.applyEmail ? `mailto:${role.applyEmail}` : '#'} class="rv1__apply">
        Apply for this role
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </section>
  </main>

  <footer class="rv1__footer">
    <span>Purrfect Hire</span>
    <span class="rv1__footer-note">Company details are shared after your intro call.</span>
  </footer>
</div>

<script>
  const els = document.querySelectorAll('.rv1__reveal');
  const io = new IntersectionObserver((entries) => {
    entries.forEach((e) => {
      if (e.isIntersecting) {
        e.target.classList.add('is-visible');
        io.unobserve(e.target);
      }
    });
  }, { threshold: 0.12 });
  els.forEach((el) => io.observe(el));
</script>

<style lang="scss">
  @use '../../styles/breakpoints' as *;

  $indigo: #3C2BDC;
  $cyan: #7C3AED;
  $emerald: #0D0857;
  $ink: #111827;
  $muted: #6B7280;
  $subtle: #9CA3AF;
  $grad: linear-gradient(135deg, #{$indigo} 0%, #{$cyan} 100%);

  .rv1 {
    position: relative;
    z-index: 1;
    font-family: Inter, sans-serif;
    color: $ink;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  // ── Top bar ──────────────────────────────────────────────────────
  .rv1__bar {
    position: sticky;
    top: 0;
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px clamp(1.25rem, 4vw, 2.5rem);
    background: rgba(250, 249, 247, 0.78);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid rgba(60, 43, 220, 0.08);
  }

  .rv1__brand {
    font-weight: 800;
    font-size: 1.05rem;
    letter-spacing: -0.02em;
    color: $ink;
    text-decoration: none;
  }

  .rv1__bar-nav {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .rv1__bar-link {
    font-size: 14px;
    font-weight: 500;
    color: $muted;
    text-decoration: none;
    transition: color 0.15s ease;
    &:hover { color: $indigo; }

    @include max-sm { display: none; }
  }

  .rv1__bar-cta {
    display: inline-flex;
    align-items: center;
    background: $grad;
    color: #fff;
    border-radius: 999px;
    padding: 9px 20px;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    box-shadow: 0 4px 16px rgba(60, 43, 220, 0.3);
    transition: transform 0.15s ease, box-shadow 0.2s ease;
    &:hover { transform: translateY(-1px); box-shadow: 0 6px 22px rgba(60, 43, 220, 0.4); }
  }

  // ── Layout ───────────────────────────────────────────────────────
  .rv1__main {
    flex: 1;
    width: 100%;
    max-width: 56rem;
    margin-inline: auto;
    padding: clamp(2.5rem, 6vw, 4.5rem) clamp(1.25rem, 4vw, 2rem) 4rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  // ── Role header ──────────────────────────────────────────────────
  .rv1__header {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.1rem;
    margin-bottom: 1rem;
  }

  .rv1__company {
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: $subtle;
  }

  .rv1__title {
    font-size: clamp(2.1rem, 5vw, 3.5rem);
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -0.03em;
    margin: 0;
    background: linear-gradient(135deg, #{$indigo} 0%, #{$cyan} 50%, #{$emerald} 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .rv1__facts {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    color: $muted;
    font-size: 14px;
    font-weight: 500;
  }

  .rv1__fact {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    svg { color: $indigo; opacity: 0.8; }
    &--accent { color: $indigo; font-weight: 600; }
  }

  .rv1__fact-dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: $subtle;
  }

  .rv1__apply {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: $grad;
    color: #fff;
    border-radius: 999px;
    padding: 14px 28px;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    box-shadow: 0 4px 20px rgba(60, 43, 220, 0.35);
    transition: transform 0.15s ease, box-shadow 0.2s ease, opacity 0.2s ease;
    svg { transition: transform 0.2s ease; }
    &:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(60, 43, 220, 0.45); opacity: 0.96; }
    &:hover svg { transform: translateX(3px); }
  }

  // ── Glass cards ──────────────────────────────────────────────────
  .rv1__card {
    background: rgba(255, 255, 255, 0.82);
    border: 1.5px solid rgba(229, 231, 235, 0.9);
    border-radius: 22px;
    padding: clamp(1.5rem, 4vw, 2.5rem);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: 0 8px 36px rgba(60, 43, 220, 0.06);

    &--role {
      border-color: rgba(124, 58, 237, 0.22);
      background:
        linear-gradient(180deg, rgba(124, 58, 237, 0.04) 0%, rgba(255, 255, 255, 0) 140px),
        rgba(255, 255, 255, 0.85);
    }
  }

  .rv1__eyebrow {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    background: $grad;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 1rem;

    &--role {
      background: linear-gradient(135deg, #{$cyan} 0%, #{$emerald} 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
  }

  .rv1__lede {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: #374151;
    margin: 0;
  }

  .rv1__industry {
    margin: 0.75rem 0 0;
    font-size: 14px;
    font-weight: 600;
    color: $cyan;
  }

  // ── Badges (YC + awards) ─────────────────────────────────────────
  .rv1__badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .rv1__yc {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    background: #FF6B00;
    color: #fff;
    border-radius: 999px;
    padding: 6px 14px 6px 7px;
    font-size: 13px;
    font-weight: 700;
    box-shadow: 0 4px 14px rgba(255, 107, 0, 0.32);
  }

  .rv1__yc-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    border-radius: 5px;
    background: #fff;
    color: #FF6B00;
    font-weight: 800;
    font-size: 14px;
  }

  .rv1__award {
    display: inline-flex;
    align-items: center;
    background: rgba(60, 43, 220, 0.07);
    border: 1px solid rgba(60, 43, 220, 0.16);
    color: $indigo;
    border-radius: 999px;
    padding: 6px 14px;
    font-size: 12.5px;
    font-weight: 600;
  }

  // ── Company stats ────────────────────────────────────────────────
  .rv1__stats {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 1.75rem;
  }

  .rv1__stat {
    flex: 1 1 130px;
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid rgba(60, 43, 220, 0.12);
    border-radius: 14px;
    padding: 16px 18px;
  }

  .rv1__stat-value {
    display: block;
    font-size: 1.25rem;
    font-weight: 700;
    color: $ink;
    letter-spacing: -0.01em;
  }

  .rv1__stat-label {
    display: block;
    margin-top: 4px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: $subtle;
  }

  // ── Strengths ────────────────────────────────────────────────────
  .rv1__strengths {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 1.75rem;
  }

  .rv1__strength {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(13, 8, 87, 0.07);
    border: 1px solid rgba(13, 8, 87, 0.18);
    color: #0D0857;
    border-radius: 999px;
    padding: 7px 14px;
    font-size: 13px;
    font-weight: 500;
    svg { color: $emerald; }
  }

  // ── Skills ───────────────────────────────────────────────────────
  .rv1__skills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 1.5rem;
  }

  .rv1__skill {
    background: rgba(60, 43, 220, 0.08);
    color: $indigo;
    border: 1px solid rgba(60, 43, 220, 0.16);
    border-radius: 7px;
    padding: 5px 12px;
    font-size: 13px;
    font-weight: 600;
  }

  // ── Requirements ─────────────────────────────────────────────────
  .rv1__reqs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.75rem 2.5rem;
    margin-top: 2rem;

    @include max-md { grid-template-columns: 1fr; gap: 1.75rem; }
  }

  .rv1__req-title {
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: $indigo;
    margin: 0 0 1rem;

    &--nice { color: $subtle; }
  }

  .rv1__req-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .rv1__req {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 0.95rem;
    line-height: 1.5;

    svg { flex-shrink: 0; margin-top: 2px; }

    &--must { color: #1F2937; font-weight: 500; svg { color: $indigo; } }
    &--nice { color: $muted; svg { color: $subtle; } }
  }

  // ── English requirement strip ────────────────────────────────────
  .rv1__english {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 2rem;
    background: rgba(60, 43, 220, 0.06);
    border: 1px solid rgba(60, 43, 220, 0.16);
    border-radius: 12px;
    padding: 12px 16px;
    font-size: 14px;
    color: #374151;
    svg { color: $indigo; flex-shrink: 0; }
    strong { color: $indigo; font-weight: 700; }
  }

  // ── Interview timeline ───────────────────────────────────────────
  .rv1__phase {
    & + & { margin-top: 2rem; }
  }

  .rv1__phase-title {
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: $indigo;
    margin: 0 0 1.25rem;

    &--client { color: $emerald; }
  }

  .rv1__timeline {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .rv1__step {
    position: relative;
    padding-left: 28px;
    padding-bottom: 1.5rem;

    &::before {
      content: '';
      position: absolute;
      left: 6px;
      top: 16px;
      bottom: -2px;
      width: 2px;
      background: rgba(60, 43, 220, 0.14);
    }
    &:last-child::before { display: none; }
    &--client::before { background: rgba(13, 8, 87, 0.18); }
  }

  .rv1__step-dot {
    position: absolute;
    left: 0;
    top: 5px;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: #fff;
    border: 3px solid $indigo;

    .rv1__step--client & { border-color: $emerald; }
  }

  .rv1__step-head {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 10px;
  }

  .rv1__step-name {
    font-size: 1rem;
    font-weight: 700;
    color: $ink;
  }

  .rv1__step-time {
    font-size: 12px;
    font-weight: 600;
    color: $muted;
    background: rgba(17, 24, 39, 0.05);
    border-radius: 999px;
    padding: 2px 10px;
  }

  .rv1__step-detail {
    margin: 5px 0 0;
    font-size: 0.9rem;
    line-height: 1.55;
    color: $muted;
  }

  // ── Final CTA ────────────────────────────────────────────────────
  .rv1__cta {
    text-align: center;
    padding: clamp(2.5rem, 6vw, 4rem) 1.5rem;
    background: linear-gradient(135deg, rgba(60, 43, 220, 0.08) 0%, rgba(124, 58, 237, 0.08) 100%);
    border: 1.5px solid rgba(60, 43, 220, 0.16);
    border-radius: 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .rv1__cta-title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    margin: 0;
