---
// ── Home router (the default landing) ────────────────────────────────────
// Shared by `/` (en) and `/es/` (es). Jul 2026: the long two-lane scroll was
// replaced by a 3-screen router — claim → shared proof → bifurcation — that
// forces a founder/talent self-selection in one click. All founder/talent
// depth now lives on /for-founders and /for-talent; this page only validates
// ("is this firm serious?") and routes. Copy is content-driven via
// content.homeRouter + reused hero/testimonials, so it renders bilingually.
import Layout from '../../layouts/Layout.astro';
import V6Nav from './V6Nav.astro';
import HomeHero from '../home/HomeHero.astro';
import HomeProof from '../home/HomeProof.astro';
import HomeFork from '../home/HomeFork.astro';
import Footer from '../Footer.astro';
import { getContent, type Lang } from '../../content/index';

interface Props {
  lang?: Lang;
}

const { lang = 'en' } = Astro.props;
const c = getContent(lang);
const siteUrl = 'https://purrfecthire.com';

// Unified global nav — c.nav.links already points at the dedicated
// destinations (for-founders / for-talent / pricing / roles), localized.
const v6Nav = c.nav;

// FAQ JSON-LD is intentionally NOT emitted here anymore: the founder/talent
// FAQs moved to their subpages, so their schema belongs there (schema must
// match on-page content). The home keeps only entity + site schema.
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Purrfect Hire',
  url: siteUrl,
  logo: `${siteUrl}/logos/ph_imagotipo.png`,
  description: c.meta.description,
  sameAs: ['https://www.linkedin.com/company/purrfect-hire'],
  areaServed: 'Latin America',
  knowsAbout: ['Technical recruiting', 'Startup hiring', 'Culture-fit assessment', 'YC, a16z and Sequoia startups'],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Purrfect Hire',
  url: siteUrl,
  publisher: { '@type': 'Organization', name: 'Purrfect Hire' },
};
---

<Layout
  title={c.meta.title}
  description={c.meta.description}
  lang={lang}
>
  <!-- Structured data for search + AI engines (entity + site) -->
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  </Fragment>

  <V6Nav content={v6Nav} lang={lang}>
    <a slot="extra-cta" href={c.homeRouter.nav.ctaHref} class="v6-home__nav-cta">
      {c.homeRouter.nav.cta}
    </a>
  </V6Nav>

  <main>
    <HomeHero hero={c.hero} router={c.homeRouter.hero} />
    <HomeProof content={c} />
    <HomeFork fork={c.homeRouter.fork} />
  </main>

  <Footer content={c.footer} />
</Layout>

<style is:global>
  html {
    scroll-behavior: smooth;
    background: var(--bg);
  }

  /* Router nav is solid from the top (hero is white, not a dark chart), so the
     nav CTA reads immediately — no intro choreography to wait on. */
  .v6-home__nav-cta {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
    font-weight: 500;
    line-height: 1;
    color: #ffffff;
    background: var(--ink);
    border-radius: var(--radius);
    text-decoration: none;
    transition: background-color 0.2s ease;
  }

  .v6-home__nav-cta:hover {
    background: #1E1D47;
  }
</style>
