---
import { getRelativeLocaleUrl } from 'astro:i18n';
import type { LandingContent } from '../../content/index';

interface Props {
  content: LandingContent['nav'];
  lang: string;
  /** Path the language toggle targets in the other locale (defaults to home). */
  otherLangPath?: string;
  /** Set false for pages with no counterpart in the other locale. */
  showLangToggle?: boolean;
}

const { content, lang, otherLangPath = '/', showLangToggle = true } = Astro.props;
const otherLang = lang === 'en' ? 'es' : 'en';
const otherLangHref = getRelativeLocaleUrl(otherLang, otherLangPath);
---

<header id="nav" class="v6-nav">
  <div class="v6-nav__container">
    <nav class="v6-nav__inner">

      <!-- Logo (always visible) — links home -->
      <a href="/" class="v6-nav__logo-link" aria-label="Purrfect Hire — home">
        <img src="/logos/logo-desktop.png" class="v6-nav__logo" alt="Purrfect Hire" />
      </a>

      <!-- Desktop links -->
      <div class="v6-nav__links">
        {content.links.map((link, i) => (
          <>
            {i > 0 && <span class="v6-nav__sep" aria-hidden="true">·</span>}
            {link.children ? (
              <div class="v6-nav__dropdown">
                <a href={link.href} class="v6-nav__link v6-nav__link--dropdown">
                  {link.label}
                  <svg class="v6-nav__chevron" width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true">
                    <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </a>
                <div class="v6-nav__dropdown-panel">
                  <div class="v6-nav__dropdown-panel-inner">
                    {link.children.map((child) => (
                      <a href={child.href} class="v6-nav__dropdown-item">
                        <span class="v6-nav__dropdown-item-label">{child.label}</span>
                        <span class="v6-nav__dropdown-item-desc">{child.description}</span>
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            ) : (
              <a href={link.href} class="v6-nav__link">
                {link.label}
              </a>
            )}
          </>
        ))}
      </div>

      <!-- Right side: extra CTA slot + language toggle -->
      <div class="v6-nav__actions">
        <slot name="extra-cta" />

        {showLangToggle && (
          <div class="v6-nav__lang-toggle">
            {lang === 'en' ? (
              <>
                <span class="v6-nav__lang v6-nav__lang--active">EN</span>
                <span class="v6-nav__lang-divider">|</span>
                <a href={otherLangHref} class="v6-nav__lang v6-nav__lang--inactive">ES</a>
              </>
            ) : (
              <>
                <a href={otherLangHref} class="v6-nav__lang v6-nav__lang--inactive">EN</a>
                <span class="v6-nav__lang-divider">|</span>
                <span class="v6-nav__lang v6-nav__lang--active">ES</span>
              </>
            )}
          </div>
        )}

        <button
          id="mobile-menu-btn"
          class="v6-nav__hamburger"
          aria-label="Toggle menu"
        >
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              d="M3 5h14M3 10h14M3 15h14"
            />
          </svg>
        </button>
      </div>
    </nav>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="v6-nav__mobile-menu">
    <div class="v6-nav__mobile-inner">
      {content.links.map((link) => (
        link.children ? (
          <div class="v6-nav__mobile-group">
            <a href={link.href} class="v6-nav__link v6-nav__link--mobile v6-nav__link--mobile-parent">
              {link.label}
            </a>
            <div class="v6-nav__mobile-submenu">
              {link.children.map((child) => (
                <a href={child.href} class="v6-nav__link v6-nav__link--mobile v6-nav__link--mobile-child">
                  {child.label}
                </a>
              ))}
            </div>
          </div>
        ) : (
          <a href={link.href} class="v6-nav__link v6-nav__link--mobile">
            {link.label}
          </a>
        )
      ))}
    </div>
  </div>
</header>

<script>
  const nav = document.getElementById('nav');
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      nav?.classList.add('v6-nav--scrolled');
    } else {
      nav?.classList.remove('v6-nav--scrolled');
    }
  }, { passive: true });

  btn?.addEventListener('click', () => {
    menu?.classList.toggle('v6-nav__mobile-menu--open');
  });
</script>

<style lang="scss">
  @use '../../styles/breakpoints' as *;

  .v6-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background: transparent;
    transition:
      background 200ms ease,
      border-color 200ms ease;

    &--scrolled {
      background: rgba(250, 249, 247, 0.72);
      backdrop-filter: blur(14px) saturate(1.4);
      -webkit-backdrop-filter: blur(14px) saturate(1.4);
      border-bottom: 1px solid rgba(229, 229, 225, 0.6);
    }

    &__container {
      max-width: 80rem;
      margin-inline: auto;
      padding-inline: 2rem;
      @include max-lg { padding-inline: 1rem; }
    }

    &__inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 4rem;
    }

    &__logo {
      width: 10rem;
    }

    &__links {
      display: flex;
      align-items: center;
      gap: 0.25rem;
      @include max-lg { display: none; }
    }

    &__sep {
      font-size: 0.9375rem;
      color: var(--color-border);
      user-select: none;
      pointer-events: none;
    }

    &__link {
      font-size: 0.9375rem;
      font-weight: 500;
      color: var(--color-muted);
      text-decoration: none;
      padding-inline: 0.75rem;
      transition: color 0.15s ease;

      &:hover { color: var(--color-text); }

      &--mobile {
        padding-inline: 0;
        padding-block: 0.5rem;
      }

      &--mobile-parent {
        font-weight: 500;
      }

      &--mobile-child {
        font-weight: 400;
        color: var(--color-muted);
        padding-block: 0.375rem;
      }

      &--dropdown {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        white-space: nowrap;
      }
    }

    &__chevron {
      color: var(--color-tertiary);
      transition: transform 0.2s ease;
    }

    &__dropdown {
      position: relative;
      display: inline-flex;
      align-items: center;

      &:hover .v6-nav__dropdown-panel,
      &:focus-within .v6-nav__dropdown-panel {
        opacity: 1;
        pointer-events: auto;
        transform: translateX(-50%);
        transition:
          opacity 150ms ease,
          transform 150ms ease,
          pointer-events 0s;
      }

      &:hover .v6-nav__chevron,
      &:focus-within .v6-nav__chevron {
        transform: rotate(180deg);
      }
    }

    // Invisible hit-box: sits flush against the trigger (no gap) so the
    // pointer never crosses dead space between the link and the visible
    // card — the `padding-top` here IS the hoverable bridge. Closing is
    // delayed so a slow diagonal mouse move doesn't drop out of hover.
    &__dropdown-panel {
      position: absolute;
      top: 100%;
      left: 50%;
      padding-top: 0.625rem;
      opacity: 0;
      pointer-events: none;
      transform: translateX(-50%) translateY(-4px);
      transition:
        opacity 180ms ease 220ms,
        transform 180ms ease 220ms,
        pointer-events 0s 400ms;
    }

    &__dropdown-panel-inner {
      min-width: 15rem;
      padding: 0.375rem;
      display: flex;
      flex-direction: column;
      gap: 0.125rem;
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: 0.75rem;
    }

    &__dropdown-item {
      display: flex;
      flex-direction: column;
      gap: 0.125rem;
      padding: 0.625rem 0.75rem;
      border-radius: 0.5rem;
      text-decoration: none;
      transition: background 0.15s ease;

      &:hover,
      &:focus-visible {
        background: var(--color-bg-soft);
      }
    }

    &__dropdown-item-label {
      font-size: 0.875rem;
      font-weight: 500;
      color: var(--color-text);
    }

    &__dropdown-item-desc {
      font-size: 0.75rem;
      color: var(--color-muted);
    }

    &__mobile-group {
      display: flex;
      flex-direction: column;
    }

    &__mobile-submenu {
      display: flex;
      flex-direction: column;
      padding-left: 1rem;
    }

    &__actions {
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    &__lang-toggle {
      display: flex;
      align-items: center;
      gap: 0.375rem;
    }

    &__lang {
      font-size: 0.875rem;
      text-decoration: none;

      &--active {
        font-weight: 500;
        color: var(--color-text);
      }

      &--inactive {
        font-weight: 400;
        color: var(--color-tertiary);
        transition: color 0.15s ease;

        &:hover {
          color: var(--color-text);
        }
      }
    }

    &__lang-divider {
      font-size: 0.875rem;
      color: var(--color-tertiary);
      user-select: none;
    }

    &__hamburger {
      display: none;
      padding: 0.5rem;
      border-radius: 0.5rem;
      color: var(--color-text);
      background: none;
      border: none;
      cursor: pointer;

      @include max-lg { display: flex; }
    }

    &__mobile-menu {
      display: none;
      border-bottom: 1px solid var(--color-border);
      background: var(--color-surface);

      &--open {
        @include max-lg { display: block; }
      }
    }

    &__mobile-inner {
      max-width: 1280px;
      margin-inline: auto;
      padding: 1rem;
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }
  }
</style>
