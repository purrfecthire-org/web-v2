---
import type { LandingContent } from "../../content/index";

interface Props {
  content: LandingContent["hero"];
}

const { content } = Astro.props;

// 12-month timeline geometry (viewBox units)
const CHART_LEFT = 80;
const CHART_RIGHT = 1360;
const BASELINE = 720;
// Month 6 (the "quits" exit) is pulled out to ~60% of the canvas width so the
// red marker reads clearly. Only months 1/6/12 carry ticks, so the uneven
// spacing between milestones is invisible.
const month1X = CHART_LEFT;
const exitX = 864; // ~60% of the 1440 viewBox
const month12X = CHART_RIGHT;
const ticks = [month1X, exitX, month12X];

// ── Line-bundle vertical origins (TUNE THESE to line up with the headline) ──
// These two numbers are the ONLY knobs for change-3 alignment. They are y
// values in the SVG viewBox (0–800 tall), and because the chart is stretched
// with preserveAspectRatio="none", a value of Y lands at (Y / 800) of the
// section height on screen.
//   • SKILLS_START  → height where the GRAY/RED (downward) lines begin.
//     Set it level with the FIRST phrase "Skills get people hired."
//   • CULTURE_START → height where the PURPLE (upward) lines begin.
//     Set it level with the SECOND phrase "Culture fit makes them stay."
// Increase a value to push that origin DOWN, decrease to move it UP.
const SKILLS_START = 348;
const CULTURE_START = 465;
const CULTURE_TOP = 150;

// Skills bundle: starts at the first phrase's height, decays and funnels into
// the red exit at month 6.
const skillsPaths = Array.from({ length: 8 }, (_, i) => ({
  d: `M ${CHART_LEFT} ${SKILLS_START + i * 8}
      C 320 ${SKILLS_START + 40 + i * 8}, 600 ${SKILLS_START + 200 + i * 5}, 730 ${SKILLS_START + 310 + i * 3}
      C 800 ${SKILLS_START + 360 + i}, 840 715, ${exitX} ${BASELINE}`,
  width: 0.7 + i * 0.12,
  opacity: 0.12 + i * 0.045,
  flowDuration: 14 + i * 1.4,
  flowDelay: 5.0 + i * 0.3,
}));

// Culture bundle: starts at the second phrase's height (just below the first)
// and fans upward across the full 12 months.
const culturePaths = Array.from({ length: 10 }, (_, i) => ({
  d: `M ${CHART_LEFT} ${CULTURE_START - i * 3}
      C 420 ${CULTURE_START - 35 - i * 4}, 780 ${CULTURE_START - 120 - i * 7}, 980 ${CULTURE_START - 165 - i * 8}
      C 1150 ${CULTURE_START - 210 - i * 9}, 1270 ${CULTURE_START - 240 - i * 10}, ${CHART_RIGHT} ${CULTURE_TOP - i * 11}`,
  width: 0.6 + i * 0.16,
  opacity: 0.08 + i * 0.05,
  flowDuration: 16 + i * 1.2,
  flowDelay: 5.0 + i * 0.25,
}));

---

<section class="v6-hero">

  <!-- Animated retention-timeline background — flowing path bundles -->
  <div class="v6-hero__chart" aria-hidden="true">
    <svg
      class="v6-chart"
      viewBox="0 0 1440 800"
      preserveAspectRatio="none"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
    >
      <defs>
        <linearGradient id="v6-area" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="#29285F" stop-opacity="0.10" />
          <stop offset="60%" stop-color="#29285F" stop-opacity="0.04" />
          <stop offset="100%" stop-color="#29285F" stop-opacity="0" />
        </linearGradient>
        <!-- Skills lines fade from gray into alarm red as they reach the exit -->
        <linearGradient
          id="v6-skills-stroke"
          gradientUnits="userSpaceOnUse"
          x1={CHART_LEFT} y1="0" x2={exitX} y2="0"
        >
          <stop offset="0%" stop-color="#5C5C5C" />
          <stop offset="65%" stop-color="#5C5C5C" />
          <stop offset="100%" stop-color="#D14343" />
        </linearGradient>
      </defs>

      <!-- Baseline + month ticks — enters with phase 1 -->
      <g class="v6-chart__axis">
        <line
          x1={CHART_LEFT} y1={BASELINE}
          x2={CHART_RIGHT} y2={BASELINE}
          stroke="#0F0F0F" stroke-opacity="0.12"
        />
        {ticks.map((x) => (
          <line
            x1={x} y1={BASELINE}
            x2={x} y2={BASELINE + 8}
            stroke="#0F0F0F" stroke-opacity="0.14"
          />
        ))}
        <text class="v6-chart__month" x={month1X} y={BASELINE + 32} text-anchor="middle">
          {content.chart.monthStart}
        </text>
        <text class="v6-chart__month" x={exitX} y={BASELINE + 32} text-anchor="middle">
          {content.chart.monthMid}
        </text>
        <text class="v6-chart__month" x={month12X} y={BASELINE + 32} text-anchor="middle">
          {content.chart.monthEnd}
        </text>
      </g>

      <!-- Gradient area under the main culture curve — phase 2 -->
      <g class="v6-chart__area-wrap">
        <path
          class="v6-chart__area"
          d={`M ${CHART_LEFT} ${CULTURE_START}
              C 420 ${CULTURE_START - 35}, 780 ${CULTURE_START - 120}, 980 ${CULTURE_START - 165}
              C 1150 ${CULTURE_START - 210}, 1270 ${CULTURE_START - 240}, ${CHART_RIGHT} ${CULTURE_TOP}
              L ${CHART_RIGHT} ${BASELINE} L ${CHART_LEFT} ${BASELINE} Z`}
          fill="url(#v6-area)"
        />
      </g>

      <!-- Skills bundle: decaying gray lines that turn red and funnel into the exit -->
      <g class="v6-chart__reveal v6-chart__reveal--skills">
        {skillsPaths.map((p) => (
          <path
            class="v6-chart__flow-line"
            d={p.d}
            pathLength="100"
            stroke="url(#v6-skills-stroke)"
            stroke-width={p.width}
            stroke-opacity={p.opacity}
            stroke-linecap="round"
            style={`animation-duration: ${p.flowDuration}s; animation-delay: ${p.flowDelay}s;`}
          />
        ))}
      </g>
      <g class="v6-chart__skills-end">
        <circle class="v6-chart__exit-ring" cx={exitX} cy={BASELINE} r="6" stroke="#D14343" stroke-width="1.5" />
        <circle class="v6-chart__exit-dot" cx={exitX} cy={BASELINE} r="4.5" />
        <text class="v6-chart__label v6-chart__label--skills" x="630" y="598">
          {content.chart.skillsLabel}
        </text>
        <text class="v6-chart__label v6-chart__label--exit" x={exitX + 18} y={BASELINE - 16}>
          {content.chart.exitLabel}
        </text>
      </g>

      <!-- Culture bundle: purple lines fanning upward, flowing the full 12 months -->
      <g class="v6-chart__reveal v6-chart__reveal--culture">
        {culturePaths.map((p) => (
          <path
            class="v6-chart__flow-line"
            d={p.d}
            pathLength="100"
            stroke="#29285F"
            stroke-width={p.width}
            stroke-opacity={p.opacity}
            stroke-linecap="round"
            style={`animation-duration: ${p.flowDuration}s; animation-delay: ${p.flowDelay}s;`}
          />
        ))}
      </g>
      <g class="v6-chart__culture-end">
        <text class="v6-chart__label v6-chart__label--culture" x="1330" y="210" text-anchor="end">
          {content.chart.cultureLabel}
        </text>
      </g>
    </svg>

    <!-- Soft vignette so the headline stays readable over the chart -->
    <div class="v6-hero__chart-vignette"></div>
  </div>

  <!-- Mouse-to-button guide arrow (desktop only, after the intro) -->
  <canvas class="v6-hero__arrow-canvas" id="v6-arrow-canvas" aria-hidden="true"></canvas>

  <div class="v6-hero__container">
    <div class="v6-hero__content">

      <!-- Headline: each phrase fades in as a whole (ease-in), synced with its line -->
      <h1 class="v6-hero__headline headline1">
        <span class="v6-hero__phrase v6-hero__phrase--skills">{content.headline}</span>
        <span class="v6-hero__phrase v6-hero__phrase--culture">{content.headlineAccent}</span>
      </h1>

      <!-- Metrics — phase 3 -->
      <div class="v6-hero__metrics v6-phase-3" id="v6-hero-stats">
        {content.stats.map((stat, i) => (
          <>
            {i > 0 && <div class="v6-hero__metric-divider" />}
            <div
              class="v6-hero__metric"
              data-value={stat.value}
              data-suffix={stat.suffix}
            >
              <div class="v6-hero__metric-value">
                {stat.suffixLeft}<span class="count">0</span>{stat.suffix}
              </div>
              <p class="v6-hero__metric-label">
                {stat.label}
              </p>
            </div>
          </>
        ))}
      </div>

      <!-- CTAs — phase 4: dual buttons, each proximity-reactive on desktop -->
      <div class="v6-hero__ctas v6-phase-4">
        <a href="/for-founders" id="v6-cta-founders" class="v6-hero__cta v6-hero__cta--founders">
          {content.ctaFounders}
        </a>
        <a href="/for-talent" id="v6-cta-talent" class="v6-hero__cta v6-hero__cta--talent">
          {content.ctaTalent}
        </a>
      </div>

    </div>
  </div>
</section>

<style lang="scss">
  @use '../../styles/breakpoints' as *;

  // ── Intro choreography timeline ────────────────────────────
  // 0.0s → 0.8s  phase 1: "Skills get people hired." fades in + axis + skills bundle
  // 1.5s → 2.2s  phase 2: "Culture fit makes them stay." fades in + culture bundle
  // 2.5s         phase 3: metrics / KPIs fade in (counts run alongside)
  // 3.2s         phase 4: the rest of the content (CTAs + nav)
  // 5.0s+        ambient: continuous line flow, pulses, float
  $t-phase-1: 0s;
  $t-phase-2: 1.5s;
  $t-phase-3: 2.5s;
  $t-phase-4: 3.2s;
  $t-ambient: 5.0s;

  $ease-expo: cubic-bezier(0.16, 1, 0.3, 1);
  $ease-quart: cubic-bezier(0.25, 1, 0.5, 1);
  $ease-soft: cubic-bezier(0.45, 0, 0.55, 1);
  // Spring-like overshoot for the letter reveal
  $ease-spring: cubic-bezier(0.34, 1.3, 0.64, 1);

  .v6-hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    overflow: hidden;
    padding-top: 42vh;
    padding-bottom: 6rem;

    @include max-md {
      justify-content: center;
      padding-top: 6rem;
      padding-bottom: 4rem;
    }

    // ── Chart background ────────────────────────────────────
    &__chart {
      position: absolute;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      animation: v6-float 16s $ease-soft $t-ambient infinite alternate;

      @include max-md {
        opacity: 0.6;

        // preserveAspectRatio="none" distorts text at narrow widths
        :global(.v6-chart__month),
        :global(.v6-chart__label) {
          display: none;
        }
      }
    }

    &__chart-vignette {
      position: absolute;
      inset: 0;
      background: rgba(255, 255, 255, 0.55);
    }

    &__container {
      position: relative;
      z-index: 1;
      width: 100%;
      padding-inline: 2rem;

      @include max-lg { padding-inline: 1.5rem; }
      @include max-sm { padding-inline: 1rem; }
    }

    &__content {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 2.5rem;
      padding-left: 8vw;

      @include max-md {
        align-items: center;
        padding-left: 0;
      }
    }

    &__headline {
      text-align: left;
      max-width: 96rem;
      display: flex;
      flex-direction: column;
      gap: 10px;

      @include max-md {
        text-align: center;
      }
    }

    // Phrase typography mirrors V4's hero headline (size + weight).
    &__phrase {
      display: block;
      font-size: clamp(2.6rem, 6vw, 5.25rem);
      font-weight: 800;
      line-height: 1.05;
      letter-spacing: -0.03em;
      // Fade the whole phrase in (ease-in) — no per-letter stagger.
      opacity: 0;
    }

    // First phrase: solid black (matches V4's headline color). 0s → 0.8s.
    &__phrase--skills {
      color: #111827;
      animation: v6-fade-in 0.8s ease-in $t-phase-1 forwards;
    }

    // Second phrase: solid navy accent, no gradient. 1.5s to 2.2s.
    &__phrase--culture {
      color: var(--color-accent);
      animation: v6-fade-in 0.7s ease-in $t-phase-2 forwards;
    }

    // ── Metrics ─────────────────────────────────────────────
    &__metrics {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 2.5rem;

      @include max-sm {
        gap: 1.5rem;
      }
    }

    &__metric {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.25rem;
      text-align: center;
    }

    &__metric-value {
      font-size: 2.25rem;
      font-weight: 500;
      line-height: 1;
      color: var(--color-text);

      @include max-sm {
        font-size: 1.75rem;
      }
    }

    &__metric-label {
      font-size: 0.875rem;
      color: var(--color-muted);
      max-width: 120px;
    }

    &__metric-divider {
      width: 1px;
      height: 40px;
      background-color: var(--color-border);
    }

    // ── CTAs ────────────────────────────────────────────────
    &__ctas {
      display: flex;
      align-items: center;
      gap: 1rem;

      @include max-sm {
        flex-direction: column;
        width: 100%;
      }
    }

    &__cta {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 12px 24px;
      font-family: 'Schibsted Grotesk', system-ui, sans-serif;
      font-size: 0.875rem;
      font-weight: 500;
      line-height: 1.5;
      border: 1.5px solid #0F0F0F;
      border-radius: var(--radius);
      cursor: pointer;
      text-decoration: none;
      background-color: transparent;
      color: #0F0F0F;

      &--founders {
        &:hover,
        &:focus-visible {
          background-color: #0F0F0F !important;
          color: #ffffff !important;
        }
      }

      &--talent {
        &:hover,
        &:focus-visible {
          background-color: #29285F !important;
          color: #ffffff !important;
          border-color: #29285F !important;
        }
      }
    }

    &__arrow-canvas {
      position: fixed;
      inset: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      z-index: 40;

      @include max-md {
        display: none;
      }
    }

    &__trust {
      font-size: 0.875rem;
      color: var(--color-muted);
      text-align: center;
    }
  }

  // ── Phase entrance classes ───────────────────────────────
  .v6-phase-3 {
    opacity: 0;
    transform: translateY(20px);
    animation: v6-fade-up 0.9s $ease-expo $t-phase-3 forwards;
  }

  .v6-phase-4 {
    opacity: 0;
    transform: translateY(20px);
    animation: v6-fade-up 0.9s $ease-expo $t-phase-4 forwards;
  }

  // ── Chart internals ───────────────────────────────────────
  .v6-chart {
    width: 100%;
    height: 100%;
    display: block;

    &__month {
      font-size: 13px;
      fill: var(--color-muted);
      fill-opacity: 0.75;
      letter-spacing: 0.04em;
    }

    &__label {
      font-size: 14px;
      letter-spacing: 0.02em;

      &--skills {
        fill: var(--color-muted);
      }

      &--exit {
        fill: #D14343;
        font-size: 12.5px;
        font-weight: 500;
      }

      &--culture {
        fill: var(--color-accent);
        font-weight: 500;
      }
    }

    // Axis enters with phase 1
    &__axis {
      opacity: 0;
      animation: v6-fade-in 0.8s $ease-quart $t-phase-1 forwards;
    }

    // Left-to-right draw reveal (clip-path keeps dash patterns intact)
    &__reveal {
      clip-path: inset(-5% 105% -5% -2%);

      &--skills {
        animation: v6-draw 0.8s $ease-quart $t-phase-1 forwards;
      }

      &--culture {
        animation: v6-draw 0.7s $ease-expo $t-phase-2 forwards;
      }
    }

    // Bundle lines: continuous traveling-dash flow after the intro.
    // Duration/delay are set per path inline; the dash pattern only
    // exists inside the animation, so the intro draws solid lines.
    &__flow-line {
      animation-name: v6-flow;
      animation-timing-function: linear;
      animation-iteration-count: infinite;
    }

    &__area-wrap {
      opacity: 0;
      animation: v6-fade-in 1.2s $ease-expo ($t-phase-2 + 0.4s) forwards;
    }

    &__area {
      animation: v6-breathe 7s $ease-soft $t-ambient infinite alternate;
    }

    &__skills-end {
      opacity: 0;
      animation: v6-fade-in 0.7s $ease-expo ($t-phase-1 + 0.9s) forwards;
    }

    &__culture-end {
      opacity: 0;
      animation: v6-fade-in 0.7s $ease-expo ($t-phase-2 + 1s) forwards;
    }

    // Red exit marker — the cost of skills-only hiring
    &__exit-dot {
      fill: #D14343;
      fill-opacity: 0.7;
      animation: v6-dim 3.2s $ease-soft $t-ambient infinite alternate;
    }

    &__exit-ring {
      transform-box: fill-box;
      transform-origin: center;
      animation: v6-pulse 2.6s $ease-expo $t-ambient infinite;
      opacity: 0;
    }
  }

  @keyframes v6-fade-up {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes v6-draw {
    to { clip-path: inset(-5% -2% -5% -2%); }
  }

  @keyframes v6-fade-in {
    to { opacity: 1; }
  }

  @keyframes v6-flow {
    from {
      stroke-dasharray: 80 20;
      stroke-dashoffset: 0;
    }
    to {
      stroke-dasharray: 80 20;
      stroke-dashoffset: -100;
    }
  }

  @keyframes v6-breathe {
    from { opacity: 0.65; }
    to { opacity: 1; }
  }

  @keyframes v6-dim {
    from { fill-opacity: 0.7; }
    to { fill-opacity: 0.3; }
  }

  @keyframes v6-pulse {
    0% { transform: scale(1); opacity: 0.55; }
    70% { transform: scale(3.2); opacity: 0; }
    100% { transform: scale(3.2); opacity: 0; }
  }

  @keyframes v6-float {
    from { transform: translateY(0); }
    to { transform: translateY(-12px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .v6-hero__chart {
      animation: none;
    }

    .v6-hero__phrase {
      animation: none;
      opacity: 1;
    }

    .v6-phase-3,
    .v6-phase-4 {
      animation: none;
      opacity: 1;
      transform: none;
    }

    .v6-chart__reveal {
      animation: none;
      clip-path: none;
    }

    .v6-chart__flow-line {
      animation: none !important;
    }

    .v6-chart__axis,
    .v6-chart__area-wrap,
    .v6-chart__skills-end,
    .v6-chart__culture-end {
      animation: none;
      opacity: 1;
    }

    .v6-chart__area,
    .v6-chart__exit-dot,
    .v6-chart__exit-ring {
      animation: none;
    }
  }
</style>

<script>
  // Metric count-up, synced to phase 3 of the intro choreography (2.5s)
  const PHASE_3_DELAY = 2500;

  function animateCount(el: Element, target: number, duration: number = 1200) {
    const countEl = el.querySelector('.count');
    if (!countEl) return;

    const start = performance.now();

    function easeOut(t: number): number {
      return 1 - Math.pow(1 - t, 3);
    }

    function tick(now: number) {
      const elapsed = now - start;
      const progress = Math.min(elapsed / duration, 1);
      const current = Math.round((target) * easeOut(progress));
      if (countEl) {
        countEl.textContent = current.toString();
        if (progress < 1) requestAnimationFrame(tick);
        else countEl.textContent = target.toString();
      }
    }

    requestAnimationFrame(tick);
  }

  const statsSection = document.getElementById('v6-hero-stats');
  if (statsSection) {
    const items = statsSection.querySelectorAll('.v6-hero__metric');
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const delay = reducedMotion ? 0 : PHASE_3_DELAY;

    window.setTimeout(() => {
      items.forEach((item) => {
        const target = parseInt(item.getAttribute('data-value') || '0', 10);
        animateCount(item, target, 1000);
      });
    }, delay);
  }

  // ── Dual CTA proximity + mouse-to-midpoint guide arrow (desktop only) ──
  const ARROW_DELAY = 6900;
  // Each CTA flips to its solid/primary colour the instant the cursor's edge
  // distance drops below this many pixels — an on/off switch, not a distance fade.
  const PROX_THRESHOLD = 200;

  const ctaFounders = document.getElementById('v6-cta-founders') as HTMLElement | null;
  const ctaTalent = document.getElementById('v6-cta-talent') as HTMLElement | null;
  const canvas = document.getElementById('v6-arrow-canvas') as HTMLCanvasElement | null;
  const finePointer = window.matchMedia('(pointer: fine)').matches;
  const noMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (ctaFounders && ctaTalent && canvas && finePointer) {
    const ctx = canvas.getContext('2d');
    const mouse: { x: number | null; y: number | null } = { x: null, y: null };
    let arrowEnabled = false;
    let arrowStart = 0;
    let dismissed = false;

    const resize = () => {
      const dpr = window.devicePixelRatio || 1;
      canvas.width = window.innerWidth * dpr;
      canvas.height = window.innerHeight * dpr;
      ctx?.setTransform(dpr, 0, 0, dpr, 0, 0);
    };
    resize();
    window.addEventListener('resize', resize);

    window.addEventListener('mousemove', (e) => {
      mouse.x = e.clientX;
      mouse.y = e.clientY;
    });

    // Solid/primary state — applied instantly, with no interpolation.
    function setActive(el: HTMLElement, fillColor: string) {
      el.style.backgroundColor = fillColor;
      el.style.color = '#ffffff';
      // Talent's accent also recolours its border; founders keeps its black outline.
      if (fillColor !== '#0F0F0F') el.style.borderColor = fillColor;
    }

    function resetProximity(el: HTMLElement) {
      el.style.backgroundColor = '';
      el.style.color = '';
      el.style.borderColor = '';
    }

    const dismiss = () => {
      dismissed = true;
      resetProximity(ctaFounders);
      resetProximity(ctaTalent);
      ctx?.clearRect(0, 0, window.innerWidth, window.innerHeight);
    };
    ctaFounders.addEventListener('click', dismiss);
    ctaTalent.addEventListener('click', dismiss);

    if (!noMotion) {
      window.setTimeout(() => {
        arrowEnabled = true;
        arrowStart = performance.now();
      }, ARROW_DELAY);
    }

    function edgeDist(el: HTMLElement, mx: number, my: number): number {
      const r = el.getBoundingClientRect();
      const dx = Math.max(r.left - mx, 0, mx - r.right);
      const dy = Math.max(r.top - my, 0, my - r.bottom);
      return Math.hypot(dx, dy);
    }

    function drawArrow(tx: number, ty: number, x0: number, y0: number, ramp: number) {
      if (!ctx) return;

      const a = Math.atan2(ty - y0, tx - x0);
      const x1 = tx - Math.cos(a) * 12;
      const y1 = ty - Math.sin(a) * 12;

      const midX = (x0 + x1) / 2;
      const midY = (y0 + y1) / 2;
      const offset = Math.min(200, Math.hypot(x1 - x0, y1 - y0) * 0.5);
      const t = Math.max(-1, Math.min(1, (y0 - y1) / 200));
      const controlX = midX;
      const controlY = midY + offset * t;

      const r = Math.hypot(x1 - x0, y1 - y0);
      const opacity = Math.max(0, Math.min(1, (r - 30) / 500)) * ramp;
      if (opacity <= 0) return;

      ctx.strokeStyle = `rgba(15, 15, 15, ${opacity})`;
      ctx.lineWidth = 2;

      ctx.save();
      ctx.beginPath();
      ctx.moveTo(x0, y0);
      ctx.quadraticCurveTo(controlX, controlY, x1, y1);
      ctx.setLineDash([10, 5]);
      ctx.stroke();
      ctx.restore();

      const angle = Math.atan2(y1 - controlY, x1 - controlX);
      const headLength = 10 * (ctx.lineWidth / 1.5);
      ctx.beginPath();
      ctx.moveTo(x1, y1);
      ctx.lineTo(
        x1 - headLength * Math.cos(angle - Math.PI / 6),
        y1 - headLength * Math.sin(angle - Math.PI / 6)
      );
      ctx.moveTo(x1, y1);
      ctx.lineTo(
        x1 - headLength * Math.cos(angle + Math.PI / 6),
        y1 - headLength * Math.sin(angle + Math.PI / 6)
      );
      ctx.stroke();
    }

    function frame(now: number) {
      const active = !dismissed && window.innerWidth >= 768;

      if (active) {
        if (mouse.x !== null && mouse.y !== null) {
          // Binary per-button toggle — each reacts to its own distance, so the
          // founders button can be solid while talent stays outlined (and vice
          // versa), or both flip when the cursor is near both.
          const dF = edgeDist(ctaFounders!, mouse.x, mouse.y);
          const dT = edgeDist(ctaTalent!, mouse.x, mouse.y);
          if (dF < PROX_THRESHOLD) setActive(ctaFounders!, '#0F0F0F');
          else resetProximity(ctaFounders!);
          if (dT < PROX_THRESHOLD) setActive(ctaTalent!, '#29285F');
          else resetProximity(ctaTalent!);
        }

        if (ctx) {
          ctx.clearRect(0, 0, window.innerWidth, window.innerHeight);
          const rF = ctaFounders!.getBoundingClientRect();
          const rT = ctaTalent!.getBoundingClientRect();
          const onScreen = rF.bottom > 0 && rT.top < window.innerHeight;
          if (arrowEnabled && onScreen && mouse.x !== null && mouse.y !== null) {
            const ramp = Math.min(1, (now - arrowStart) / 600);
            const targetX = (rF.left + rT.right) / 2;
            const targetY = rF.top + rF.height * 0.85;
            drawArrow(targetX, targetY, mouse.x, mouse.y, ramp);
          }
        }
      } else {
        resetProximity(ctaFounders!);
        resetProximity(ctaTalent!);
        ctx?.clearRect(0, 0, window.innerWidth, window.innerHeight);
      }

      requestAnimationFrame(frame);
    }

    requestAnimationFrame(frame);
  }
</script>
