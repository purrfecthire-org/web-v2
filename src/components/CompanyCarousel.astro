---
interface Props {
  label?: string;
}

const companies = [
  // Tecnología y DevTools (CDNs muy fiables)
  { 
    name: 'GitHub', 
    logo: 'https://cdn.simpleicons.org/github/000000/000000?viewbox=0,0,120,40' 
  },
  { 
    name: 'Microsoft', 
    logo: 'https://upload.wikimedia.org/wikipedia/commons/9/96/Microsoft_logo_%282012%29.svg' 
  },
  { 
    name: 'Google', 
    logo: 'https://upload.wikimedia.org/wikipedia/commons/2/2f/Google_2015_logo.svg' 
  },
  { 
    name: 'Amazon', 
    logo: 'https://upload.wikimedia.org/wikipedia/commons/a/a9/Amazon_logo.svg' 
  },
  { 
    name: 'Netflix', 
    logo: 'https://upload.wikimedia.org/wikipedia/commons/0/08/Netflix_2015_logo.svg' 
  },
  { 
    name: 'Airbnb', 
    logo: 'https://upload.wikimedia.org/wikipedia/commons/6/69/Airbnb_Logo_Bélo.svg' 
  },
  { 
    name: 'Spotify', 
    logo: 'https://upload.wikimedia.org/wikipedia/commons/2/26/Spotify_logo_with_text.svg' 
  },
  { 
    name: 'Slack', 
    logo: 'https://upload.wikimedia.org/wikipedia/commons/d/d5/Slack_icon_2019.svg' // Incluye icono + texto en formato apilado, pero muy legible
  },
  { 
    name: 'Tesla', 
    logo: 'https://upload.wikimedia.org/wikipedia/commons/b/bd/Tesla_Motors.svg' 
  },
  { 
    name: 'Figma', 
    logo: 'https://upload.wikimedia.org/wikipedia/commons/3/33/Figma-logo.svg' 
  },
  
  // FinTech y Pagos
  { 
    name: 'PayPal', 
    logo: 'https://upload.wikimedia.org/wikipedia/commons/b/b5/PayPal.svg' 
  },
  { 
    name: 'Stripe', 
    logo: 'https://upload.wikimedia.org/wikipedia/commons/b/ba/Stripe_Logo%2C_revised_2016.svg' 
  },
  { 
    name: 'Mastercard', 
    logo: 'https://upload.wikimedia.org/wikipedia/commons/2/2a/Mastercard-logo.svg' 
  },
];
const doubled = [...companies, ...companies];
---

<section
  class="py-10"
  style="background: var(--color-surface);"
  aria-label="Partner companies"
>

  <div
    class="relative overflow-hidden"
    style="mask-image: linear-gradient(to right, transparent 0%, black 10%, black 90%, transparent 100%); -webkit-mask-image: linear-gradient(to right, transparent 0%, black 10%, black 90%, transparent 100%);"
    aria-hidden="true"
  >
    <div
      class="flex items-center gap-12"
      style="animation: marquee 35s linear infinite; width: max-content;"
    >
      {doubled.map((company) => (
        <div class="flex-shrink-0 flex flex-col items-center justify-center gap-2 w-28 transition-all duration-300 group">
          <div class="h-10 flex items-center justify-center">
            <img
              src={company.logo}
              alt={company.name}
              width="100"
              height="40"
              loading="lazy"
              class="max-w-full max-h-full object-contain"
              onerror="this.style.display='none';this.nextElementSibling.style.display='block'"
            />
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  @keyframes marquee {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @media (prefers-reduced-motion: reduce) {
    [style*="animation: marquee"] {
      animation: none !important;
      flex-wrap: wrap;
      justify-content: center;
      width: auto !important;
    }
  }
</style>
