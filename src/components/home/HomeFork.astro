---
// ── Home router · Screen 3: the bifurcation ──────────────────────────────
// The forced decision, so it gets the page's one dark section for maximum
// weight. Each card: identity, one promise, one anchor, ONE primary button.
// The small "escape" link under each button serves the third visitor — the
// one who already decided: founders → contact sales, talent → apply to OA.
// Open roles is intentionally NOT repeated here (it lives in the nav).
import type { LandingContent } from '../../content/index';

interface Props {
  fork: LandingContent['homeRouter']['fork'];
}

const { fork } = Astro.props;
const cards = [fork.founders, fork.talent];
---

<section class="home-fork">
  <div class="home-fork__inner">

    <header class="home-fork__head reveal">
      <p class="home-fork__eyebrow eyebrow">{fork.eyebrow}</p>
      <h2 class="home-fork__headline headline2">{fork.headline}</h2>
      <p class="home-fork__sub">{fork.sub}</p>
    </header>

    <div class="home-fork__cards reveal reveal-delay-1">
      {cards.map((card) => (
        <article class="home-fork__card">
          <p class="home-fork__card-label eyebrow">{card.label}</p>
          <h3 class="home-fork__card-title">{card.title}</h3>
          <p class="home-fork__card-promise">{card.promise}</p>
          <p class="home-fork__card-anchor">{card.anchor}</p>
          <div class="home-fork__card-actions">
            <a href={card.ctaHref} class="btn home-fork__card-cta">{card.cta}</a>
            <p class="home-fork__card-escape">
              {card.escapePre}{' '}
              <a href={card.escapeHref}>{card.escapeLink}</a>
            </p>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>

<style lang="scss">
  @use '../../styles/breakpoints' as *;

  .home-fork {
    background: var(--color-dark);
    color: var(--color-on-dark);
    padding-block: 6.5rem;

    @include max-md { padding-block: 5rem; }

    &__inner {
      max-width: 60rem;
      margin-inline: auto;
      padding-inline: 1.5rem;
      text-align: center;
    }

    &__eyebrow { color: rgba(243, 239, 230, 0.6); }

    &__headline {
      margin-top: 0.85rem;
      color: var(--color-on-dark);
    }

    &__sub {
      margin-top: 0.85rem;
      font-size: 1.0625rem;
      color: rgba(243, 239, 230, 0.75);
    }

    &__cards {
      margin-top: 3.25rem;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.25rem;
      text-align: left;

      @include max-md { grid-template-columns: 1fr; }
    }

    &__card {
      display: flex;
      flex-direction: column;
      background: var(--color-surface);
      color: var(--color-text);
      border-radius: var(--radius);
      padding: 2.25rem 2rem;
    }

    &__card-label { color: var(--color-muted); }

    &__card-title {
      margin-top: 0.6rem;
      font-size: 1.75rem;
      font-weight: 500;
      line-height: 1.1;
      letter-spacing: -0.01em;
      color: var(--color-ink);
    }

    &__card-promise {
      margin-top: 0.6rem;
      font-size: 0.9875rem;
      line-height: 1.55;
      color: var(--color-muted);
    }

    &__card-anchor {
      margin-top: 1.1rem;
      padding-left: 0.75rem;
      border-left: 2px solid var(--color-ink);
      font-size: 0.9375rem;
      line-height: 1.4;
      color: var(--color-ink);
    }

    &__card-actions {
      margin-top: auto;
      padding-top: 1.75rem;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 0.9rem;
    }

    &__card-escape {
      font-size: 0.875rem;
      color: var(--color-muted);

      a {
        color: var(--color-ink);
        font-weight: 500;
        text-decoration: none;
        border-bottom: 1px solid var(--color-border);
        transition: border-color 0.15s ease;

        &:hover { border-bottom-color: var(--color-ink); }
      }
    }
  }
</style>
