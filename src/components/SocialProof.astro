---
import type { LandingContent } from '../content/index';
import SectionWrapper from './SectionWrapper.astro';
import TestimonialCard from './TestimonialCard.astro';

interface Props {
  content: LandingContent['socialProof'];
}

const { content } = Astro.props;
---

<SectionWrapper id="proof" class="bg-[var(--color-surface-2)]" tight>
  <!-- Badge + headline -->
  <div class="text-center mb-10">
    <span
      class="inline-flex items-center px-3 py-1.5 rounded-full border border-[var(--color-border)] bg-[var(--color-surface)] text-xs font-medium text-[var(--color-muted)] mb-4"
    >
      {content.badge}
    </span>
    <h2
      class="text-2xl sm:text-3xl font-extrabold tracking-tight text-[var(--color-text)]"
    >
      {content.headline}
    </h2>
  </div>

  <!-- Testimonials -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-5 max-w-3xl mx-auto">
    {
      content.testimonials.map((t) => (
        <TestimonialCard
          quote={t.quote}
          author={t.author}
          role={t.role}
          company={t.company}
        />
      ))
    }
  </div>
</SectionWrapper>
