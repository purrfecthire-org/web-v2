---
import type { LandingContent } from '../../content/index';

interface Props {
  content: LandingContent['testimonials'];
}

const { content } = Astro.props;

function getInitials(name: string): string {
  return name.split(' ').map(n => n[0]).join('').slice(0, 2).toUpperCase();
}
---

<section class="v3-testimonials">
  <div class="v3-testimonials__container">

    <div class="v3-testimonials__header">
      <span class="v3-testimonials__eyebrow">{content.eyebrow}</span>
      <h2 class="v3-testimonials__headline">{content.headline}</h2>
    </div>

    <!-- Featured testimonial -->
    <div class="v3-testimonials__featured">
      <div class="v3-testimonials__featured-inner">
        <div class="v3-testimonials__featured-quote-mark" aria-hidden="true">"</div>

        <blockquote class="v3-testimonials__featured-quote">
          {content.featured.quote}
        </blockquote>

        <div class="v3-testimonials__person">
          <div class="v3-testimonials__avatar">
            {getInitials(content.featured.name)}
          </div>
          <div class="v3-testimonials__person-info">
            <div class="v3-testimonials__person-name">{content.featured.name}</div>
            <div class="v3-testimonials__person-role">{content.featured.role}</div>
          </div>
          <span class="v3-testimonials__badge v3-testimonials__badge--indigo">{content.featured.badge}</span>
        </div>
      </div>
    </div>

    <!-- Grid of 3 -->
    <div class="v3-testimonials__grid">
      {content.grid.map((item) => (
        <div class="v3-testimonials__card">
          <div class="v3-testimonials__card-quote-mark" aria-hidden="true">"</div>
          <p class="v3-testimonials__card-text">{item.quote}</p>
          <div class="v3-testimonials__person v3-testimonials__person--card">
            <div class="v3-testimonials__avatar v3-testimonials__avatar--sm">
              {getInitials(item.name)}
            </div>
            <div>
              <div class="v3-testimonials__person-name">{item.name}</div>
              <div class="v3-testimonials__person-role">{item.role}</div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Candidate testimonial -->
    <div class="v3-testimonials__candidate">
      <div class="v3-testimonials__candidate-inner">
        <div class="v3-testimonials__candidate-left">
          <span class="v3-testimonials__badge v3-testimonials__badge--emerald">
            {content.candidateTestimonial.badge}
          </span>
          <blockquote class="v3-testimonials__candidate-quote">
            "{content.candidateTestimonial.quote}"
          </blockquote>
        </div>
        <div class="v3-testimonials__person v3-testimonials__person--candidate">
          <div class="v3-testimonials__avatar v3-testimonials__avatar--emerald">
            {getInitials(content.candidateTestimonial.name)}
          </div>
          <div>
            <div class="v3-testimonials__person-name">{content.candidateTestimonial.name}</div>
            <div class="v3-testimonials__person-role">{content.candidateTestimonial.role}</div>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<style lang="scss">
  @use '../../styles/breakpoints' as *;

  .v3-testimonials {
    position: relative;
    z-index: 1;
    padding: 6rem 2rem;

    @include max-sm {
      padding: 4rem 1.25rem;
    }

    &__container {
      max-width: 72rem;
      margin-inline: auto;
    }

    &__header {
      text-align: center;
      margin-bottom: 3.5rem;
    }

    &__eyebrow {
      display: inline-block;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      background: linear-gradient(135deg, #4F46E5 0%, #0891B2 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 1rem;
    }

    &__headline {
      font-family: 'Plus Jakarta Sans', Inter, sans-serif;
      font-size: clamp(1.5rem, 3vw, 2.25rem);
      font-weight: 700;
      letter-spacing: -0.025em;
      color: #111827;
      margin: 0;
      max-width: 52rem;
      margin-inline: auto;
      line-height: 1.25;
    }

    // Featured card with gradient border
    &__featured {
      background: linear-gradient(white, white) padding-box,
                  linear-gradient(135deg, #4F46E5, #0891B2) border-box;
      border: 2px solid transparent;
      border-radius: 24px;
      margin-bottom: 24px;
      overflow: hidden;
      transition: box-shadow 0.25s ease;

      &:hover {
        box-shadow: 0 12px 48px rgba(79, 70, 229, 0.14);
      }
    }

    &__featured-inner {
      padding: 48px;
      position: relative;
      background: rgba(255, 255, 255, 0.95);

      @include max-md {
        padding: 36px 32px;
      }

      @include max-sm {
        padding: 28px 24px;
      }
    }

    &__featured-quote-mark {
      position: absolute;
      top: 24px;
      right: 32px;
      font-family: Georgia, serif;
      font-size: 7rem;
      line-height: 1;
      background: linear-gradient(135deg, rgba(79, 70, 229, 0.12), rgba(8, 145, 178, 0.08));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      pointer-events: none;
      user-select: none;
    }

    &__featured-quote {
      font-size: 1.25rem;
      font-style: italic;
      color: #111827;
      line-height: 1.65;
      margin: 0 0 2rem;
      max-width: 720px;

      @include max-sm {
        font-size: 1.0625rem;
      }
    }

    &__person {
      display: flex;
      align-items: center;
      gap: 14px;

      &--card {
        margin-top: auto;
      }

      &--candidate {
        flex-shrink: 0;

        @include max-md {
          flex-direction: row;
        }
      }
    }

    &__avatar {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      background: linear-gradient(135deg, #4F46E5, #0891B2);
      color: white;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Plus Jakarta Sans', Inter, sans-serif;
      font-size: 15px;
      font-weight: 700;
      flex-shrink: 0;

      &--sm {
        width: 38px;
        height: 38px;
        font-size: 13px;
      }

      &--emerald {
        background: linear-gradient(135deg, #059669, #0891B2);
      }
    }

    &__person-name {
      font-family: 'Plus Jakarta Sans', Inter, sans-serif;
      font-weight: 600;
      font-size: 0.9375rem;
      color: #111827;
    }

    &__person-role {
      font-size: 13px;
      color: #9CA3AF;
      margin-top: 2px;
    }

    &__badge {
      display: inline-block;
      border-radius: 999px;
      padding: 4px 12px;
      font-size: 12px;
      font-weight: 600;
      margin-left: auto;

      &--indigo {
        background: rgba(79, 70, 229, 0.08);
        color: #4F46E5;
        border: 1px solid rgba(79, 70, 229, 0.18);
      }

      &--emerald {
        background: rgba(5, 150, 105, 0.08);
        color: #059669;
        border: 1px solid rgba(5, 150, 105, 0.2);
      }
    }

    // Grid of 3
    &__grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
      margin-bottom: 24px;

      @include max-lg {
        grid-template-columns: 1fr;
        max-width: 480px;
        margin-inline: auto;
        margin-bottom: 20px;
      }
    }

    &__card {
      display: flex;
      flex-direction: column;
      background: rgba(255, 255, 255, 0.8);
      border: 1px solid rgba(79, 70, 229, 0.1);
      border-radius: 18px;
      padding: 28px;
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      position: relative;
      overflow: hidden;
      transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;

      &:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 28px rgba(79, 70, 229, 0.08);
        border-color: rgba(79, 70, 229, 0.2);
      }
    }

    &__card-quote-mark {
      position: absolute;
      top: 10px;
      right: 16px;
      font-family: Georgia, serif;
      font-size: 4rem;
      line-height: 1;
      color: rgba(79, 70, 229, 0.08);
      pointer-events: none;
      user-select: none;
    }

    &__card-text {
      font-size: 0.9375rem;
      font-style: italic;
      color: #374151;
      line-height: 1.65;
      margin: 0 0 1.5rem;
      flex: 1;
    }

    // Candidate section
    &__candidate {
      background: linear-gradient(135deg, rgba(5, 150, 105, 0.06) 0%, rgba(8, 145, 178, 0.06) 100%);
      border: 1.5px solid rgba(5, 150, 105, 0.18);
      border-radius: 20px;
      overflow: hidden;
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
    }

    &__candidate-inner {
      padding: 36px 40px;
      display: flex;
      align-items: center;
      gap: 3rem;

      @include max-md {
        flex-direction: column;
        gap: 1.5rem;
        padding: 28px 24px;
        align-items: flex-start;
      }
    }

    &__candidate-left {
      flex: 1;
    }

    &__candidate-quote {
      font-size: 1.0625rem;
      font-style: italic;
      color: #111827;
      line-height: 1.65;
      margin: 0.75rem 0 0;
    }
  }
</style>
