---
import type { LandingContent } from '../../content/index';

interface Props {
  content: LandingContent['nav'];
  lang: string;
}

const { content, lang } = Astro.props;
---

<header id="v3-nav" class="v3-nav">
  <div class="v3-nav__container">
    <nav class="v3-nav__inner">

      <!-- Logo -->
      <a href="#" class="v3-nav__logo" aria-label="Purrfect Hire">
        <span class="v3-nav__logo-mark" aria-hidden="true">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
            <circle cx="14" cy="14" r="14" fill="url(#v3-logo-grad)" opacity="0.12"/>
            <circle cx="14" cy="14" r="5" fill="url(#v3-logo-grad)"/>
            <defs>
              <linearGradient id="v3-logo-grad" x1="0" y1="0" x2="28" y2="28" gradientUnits="userSpaceOnUse">
                <stop offset="0%" stop-color="#4F46E5"/>
                <stop offset="100%" stop-color="#0891B2"/>
              </linearGradient>
            </defs>
          </svg>
        </span>
        <span class="v3-nav__logo-text">{content.logo}</span>
      </a>

      <!-- Desktop links -->
      <div class="v3-nav__links">
        {content.links.map((link) => (
          <a href={link.href} class="v3-nav__link">
            {link.label}
          </a>
        ))}
      </div>

      <!-- Right side -->
      <div class="v3-nav__actions">
        <a href="#cta" class="v3-nav__cta">
          {content.cta}
        </a>
        <button id="v3-mobile-menu-btn" class="v3-nav__hamburger" aria-label="Toggle menu">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path stroke="currentColor" stroke-width="1.5" stroke-linecap="round" d="M3 5h14M3 10h14M3 15h14" />
          </svg>
        </button>
      </div>
    </nav>
  </div>

  <!-- Mobile menu -->
  <div id="v3-mobile-menu" class="v3-nav__mobile-menu">
    <div class="v3-nav__mobile-inner">
      {content.links.map((link) => (
        <a href={link.href} class="v3-nav__link v3-nav__link--mobile">
          {link.label}
        </a>
      ))}
      <a href="#cta" class="v3-nav__cta v3-nav__cta--mobile">
        {content.cta}
      </a>
    </div>
  </div>
</header>

<script>
  const nav = document.getElementById('v3-nav');
  const btn = document.getElementById('v3-mobile-menu-btn');
  const menu = document.getElementById('v3-mobile-menu');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      nav?.classList.add('v3-nav--scrolled');
    } else {
      nav?.classList.remove('v3-nav--scrolled');
    }
  }, { passive: true });

  btn?.addEventListener('click', () => {
    menu?.classList.toggle('v3-nav__mobile-menu--open');
  });
</script>

<style lang="scss">
  @use '../../styles/breakpoints' as *;

  .v3-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(248, 247, 255, 0.85);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(79, 70, 229, 0.08);
    transition: box-shadow 250ms ease;

    &--scrolled {
      box-shadow: 0 2px 20px rgba(79, 70, 229, 0.08);
    }

    &__container {
      max-width: 80rem;
      margin-inline: auto;
      padding-inline: 2rem;
      @include max-lg { padding-inline: 1.25rem; }
    }

    &__inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 4rem;
    }

    &__logo {
      display: flex;
      align-items: center;
      gap: 8px;
      text-decoration: none;
    }

    &__logo-mark {
      display: flex;
      align-items: center;
      flex-shrink: 0;
    }

    &__logo-text {
      font-family: 'Plus Jakarta Sans', Inter, sans-serif;
      font-size: 1.0625rem;
      font-weight: 700;
      color: #111827;
      letter-spacing: -0.02em;
    }

    &__links {
      display: flex;
      align-items: center;
      gap: 0.25rem;
      @include max-lg { display: none; }
    }

    &__link {
      font-size: 0.9rem;
      font-weight: 500;
      color: #6B7280;
      text-decoration: none;
      padding: 6px 14px;
      border-radius: 8px;
      transition: color 0.15s ease, background 0.15s ease;

      &:hover {
        color: #4F46E5;
        background: rgba(79, 70, 229, 0.06);
      }

      &--mobile {
        padding: 0.625rem 0;
        border-radius: 0;
        background: none;
        display: block;
        font-size: 1rem;
        border-bottom: 1px solid rgba(79, 70, 229, 0.06);

        &:hover {
          background: none;
          padding-left: 4px;
        }
      }
    }

    &__actions {
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    &__cta {
      display: inline-flex;
      align-items: center;
      background: linear-gradient(135deg, #4F46E5 0%, #0891B2 100%);
      color: white;
      border-radius: 999px;
      padding: 10px 22px;
      font-size: 14px;
      font-weight: 600;
      font-family: 'Plus Jakarta Sans', Inter, sans-serif;
      text-decoration: none;
      transition: opacity 0.2s ease, transform 0.15s ease;

      &:hover {
        opacity: 0.9;
        transform: translateY(-1px);
      }

      @include max-lg { display: none; }

      &--mobile {
        display: flex;
        justify-content: center;
        margin-top: 1rem;
        border-radius: 999px;
      }
    }

    &__hamburger {
      display: none;
      padding: 0.5rem;
      border-radius: 0.5rem;
      color: #4F46E5;
      background: rgba(79, 70, 229, 0.08);
      border: none;
      cursor: pointer;
      transition: background 0.15s;

      &:hover {
        background: rgba(79, 70, 229, 0.14);
      }

      @include max-lg { display: flex; }
    }

    &__mobile-menu {
      display: none;
      border-bottom: 1px solid rgba(79, 70, 229, 0.08);
      background: rgba(248, 247, 255, 0.98);
      backdrop-filter: blur(16px);

      &--open {
        @include max-lg { display: block; }
      }
    }

    &__mobile-inner {
      max-width: 80rem;
      margin-inline: auto;
      padding: 0.75rem 1.25rem 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 0.125rem;
    }
  }
</style>
