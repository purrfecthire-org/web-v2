---
import type { LandingContent } from '../../content/index';

interface Props {
  content: LandingContent['audienceSplit'];
}

const { content } = Astro.props;
---

<section id="audience" class="v3-audience">
  <div class="v3-audience__container">

    <div class="v3-audience__header">
      <h2 class="v3-audience__headline">{content.headline}</h2>
      <p class="v3-audience__subheadline">{content.subheadline}</p>
    </div>

    <div class="v3-audience__grid">

      <!-- Founders card -->
      <div class="v3-audience__card v3-audience__card--founders">
        <div class="v3-audience__card-glow v3-audience__card-glow--founders" aria-hidden="true"></div>

        <span class="v3-audience__tag v3-audience__tag--indigo">{content.founders.eyebrow}</span>

        <h3 class="v3-audience__card-headline">{content.founders.headline}</h3>
        <p class="v3-audience__card-body">{content.founders.body}</p>

        <ul class="v3-audience__bullets">
          {content.founders.bullets.map((bullet) => (
            <li class="v3-audience__bullet">
              <span class="v3-audience__bullet-dot v3-audience__bullet-dot--indigo" aria-hidden="true"></span>
              <div>
                <span class="v3-audience__bullet-label">{bullet.label}:</span>
                <span class="v3-audience__bullet-text"> {bullet.text}</span>
              </div>
            </li>
          ))}
        </ul>

        <a href="#cta" class="v3-audience__cta v3-audience__cta--indigo">
          {content.founders.cta}
        </a>
      </div>

      <!-- Talent card -->
      <div class="v3-audience__card v3-audience__card--talent">
        <div class="v3-audience__card-glow v3-audience__card-glow--emerald" aria-hidden="true"></div>

        <span class="v3-audience__tag v3-audience__tag--emerald">{content.talent.eyebrow}</span>

        <h3 class="v3-audience__card-headline">{content.talent.headline}</h3>
        <p class="v3-audience__card-body">{content.talent.body}</p>

        <ul class="v3-audience__bullets">
          {content.talent.bullets.map((bullet) => (
            <li class="v3-audience__bullet">
              <span class="v3-audience__bullet-dot v3-audience__bullet-dot--emerald" aria-hidden="true"></span>
              <div>
                <span class="v3-audience__bullet-label">{bullet.label}:</span>
                <span class="v3-audience__bullet-text"> {bullet.text}</span>
              </div>
            </li>
          ))}
        </ul>

        <a href="#cta" class="v3-audience__cta v3-audience__cta--emerald">
          {content.talent.cta}
        </a>
      </div>

    </div>
  </div>
</section>

<style lang="scss">
  @use '../../styles/breakpoints' as *;

  .v3-audience {
    position: relative;
    z-index: 1;
    padding: 6rem 2rem;

    @include max-sm {
      padding: 4rem 1.25rem;
    }

    &__container {
      max-width: 72rem;
      margin-inline: auto;
    }

    &__header {
      text-align: center;
      margin-bottom: 3.5rem;
    }

    &__headline {
      font-family: 'Plus Jakarta Sans', Inter, sans-serif;
      font-size: clamp(1.75rem, 3.5vw, 2.5rem);
      font-weight: 700;
      letter-spacing: -0.025em;
      color: #111827;
      margin: 0 0 1rem;
    }

    &__subheadline {
      font-size: 1.0625rem;
      color: #6B7280;
      max-width: 560px;
      margin: 0 auto;
      line-height: 1.65;
    }

    &__grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px;

      @include max-md {
        grid-template-columns: 1fr;
        gap: 20px;
      }
    }

    &__card {
      position: relative;
      border-radius: 20px;
      padding: 40px;
      overflow: hidden;
      transition: transform 0.25s ease, box-shadow 0.25s ease;

      &:hover {
        transform: translateY(-4px);
      }

      &--founders {
        background: linear-gradient(135deg, rgba(79, 70, 229, 0.08) 0%, rgba(79, 70, 229, 0.03) 100%);
        border: 1.5px solid rgba(79, 70, 229, 0.2);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);

        &:hover {
          box-shadow: 0 12px 40px rgba(79, 70, 229, 0.14);
        }
      }

      &--talent {
        background: linear-gradient(135deg, rgba(5, 150, 105, 0.08) 0%, rgba(8, 145, 178, 0.05) 100%);
        border: 1.5px solid rgba(5, 150, 105, 0.2);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);

        &:hover {
          box-shadow: 0 12px 40px rgba(5, 150, 105, 0.12);
        }
      }

      @include max-sm {
        padding: 28px 24px;
      }
    }

    &__card-glow {
      position: absolute;
      top: -60px;
      right: -60px;
      width: 200px;
      height: 200px;
      border-radius: 50%;
      pointer-events: none;

      &--founders {
        background: radial-gradient(circle, rgba(79, 70, 229, 0.15) 0%, transparent 70%);
        filter: blur(40px);
      }

      &--emerald {
        background: radial-gradient(circle, rgba(5, 150, 105, 0.15) 0%, transparent 70%);
        filter: blur(40px);
      }
    }

    &__tag {
      display: inline-block;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      border-radius: 999px;
      padding: 5px 14px;
      margin-bottom: 1.5rem;

      &--indigo {
        background: rgba(79, 70, 229, 0.1);
        color: #4F46E5;
        border: 1px solid rgba(79, 70, 229, 0.2);
      }

      &--emerald {
        background: rgba(5, 150, 105, 0.1);
        color: #059669;
        border: 1px solid rgba(5, 150, 105, 0.2);
      }
    }

    &__card-headline {
      font-family: 'Plus Jakarta Sans', Inter, sans-serif;
      font-size: 1.625rem;
      font-weight: 700;
      color: #111827;
      margin: 0 0 0.875rem;
      letter-spacing: -0.02em;
      line-height: 1.25;

      @include max-sm {
        font-size: 1.375rem;
      }
    }

    &__card-body {
      font-size: 1rem;
      color: #6B7280;
      line-height: 1.65;
      margin: 0 0 1.75rem;
    }

    &__bullets {
      list-style: none;
      padding: 0;
      margin: 0 0 2rem;
      display: flex;
      flex-direction: column;
      gap: 0.875rem;
    }

    &__bullet {
      display: flex;
      align-items: flex-start;
      gap: 12px;
    }

    &__bullet-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      flex-shrink: 0;
      margin-top: 6px;

      &--indigo {
        background: linear-gradient(135deg, #4F46E5, #818CF8);
      }

      &--emerald {
        background: linear-gradient(135deg, #059669, #34D399);
      }
    }

    &__bullet-label {
      font-weight: 600;
      color: #374151;
      font-size: 0.9375rem;
    }

    &__bullet-text {
      color: #6B7280;
      font-size: 0.9375rem;
    }

    &__cta {
      font-size: 0.9375rem;
      font-weight: 600;
      font-family: 'Plus Jakarta Sans', Inter, sans-serif;
      text-decoration: none;
      transition: opacity 0.15s ease, letter-spacing 0.15s ease;
      display: inline-block;

      &--indigo {
        color: #4F46E5;
        text-decoration: underline;
        text-underline-offset: 3px;
        text-decoration-color: rgba(79, 70, 229, 0.3);

        &:hover {
          text-decoration-color: #4F46E5;
          opacity: 0.8;
        }
      }

      &--emerald {
        color: #059669;
        text-decoration: underline;
        text-underline-offset: 3px;
        text-decoration-color: rgba(5, 150, 105, 0.3);

        &:hover {
          text-decoration-color: #059669;
          opacity: 0.8;
        }
      }
    }
  }
</style>
