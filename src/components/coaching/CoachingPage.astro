---
// ── Coaching landing pages (career-sessions / career-momentum, EN + ES) ──
// Shared renderer for the individual-coaching offerings. Flat navy/white
// 2026 system: no gradients, no shadows, border-based elevation, Schibsted
// Grotesk, one dark section max (none here). Scroll reveals use the shared
// `.reveal` class from global.scss (single IntersectionObserver in Layout).
//
// Jul 2026 architecture: pages live under the global V6 nav, the hero holds
// the one primary CTA per viewport (WhatsApp with the price in the label),
// career-sessions shows Kate's photo (approved 4:5 use) plus the honest
// scarcity line, session types collapse to a one-line accordion, and a
// described placeholder holds the 60-sec Kate video slot until it exists.
import Layout from '../../layouts/Layout.astro';
import V6Nav from '../v6/V6Nav.astro';
import Footer from '../Footer.astro';
import type { CoachingContent } from '../../content/coaching';
import { coachingContact } from '../../content/coaching';
import { getContent } from '../../content/index';

interface Props {
  c: CoachingContent;
}

const { c } = Astro.props;
const site = getContent(c.lang);
const siteUrl = 'https://purrfecthire.com';
const pageUrl = `${siteUrl}${c.path}`;
// Locale-less path for the nav language toggle (e.g. '/career-sessions').
const basePath = c.path.replace(/^\/es/, '');

// Service + Offer + FAQPage structured data so search engines and AI
// answer engines can extract the offering, its price, and the Q&A directly.
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Service',
      '@id': `${pageUrl}#service`,
      name: c.jsonLd.serviceName,
      description: c.jsonLd.serviceDescription,
      serviceType: 'Career coaching',
      url: pageUrl,
      inLanguage: ['es', 'en'],
      provider: {
        '@type': 'Organization',
        name: 'Purrfect Hire',
        url: siteUrl,
        email: coachingContact.email,
        sameAs: ['https://www.linkedin.com/company/purrfect-hire'],
      },
      areaServed: ['Latin America', 'United States', 'Europe'],
      offers: {
        '@type': 'Offer',
        price: c.jsonLd.price,
        priceCurrency: 'USD',
        description: `$${c.jsonLd.price} USD ${c.jsonLd.priceUnit}`,
        availability: 'https://schema.org/InStock',
      },
    },
    {
      '@type': 'FAQPage',
      '@id': `${pageUrl}#faq`,
      mainEntity: c.faq.items.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    },
  ],
};
---

<Layout
  title={c.meta.title}
  description={c.meta.description}
  lang={c.lang}
  canonicalUrl={pageUrl}
  ogImage={`${siteUrl}/sessions/kate.jpeg`}
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <V6Nav content={site.nav} lang={c.lang} otherLangPath={basePath} />

  <main class="cx">
    <!-- ── Hero: face + claim + one CTA ─────────────────────────────── -->
    <section class:list={['cx-hero', { 'cx-hero--photo': !!c.hero.photo }]}>
      <div class="cx-hero__main">
        <p class="cx-eyebrow cx-hero__eyebrow">{c.hero.eyebrow}</p>
        <h1 class="cx-hero__headline">{c.hero.headline}</h1>
        <div class="cx-hero__body">
          <p>{c.hero.para1}</p>
          <p>{c.hero.para2}</p>
        </div>
        <div class="cx-hero__cta">
          <a href={c.whatsappUrl} class="cx-btn cx-btn--solid cx-btn--lg" target="_blank" rel="noopener">
            {c.navCta}
          </a>
        </div>
        <ul class="cx-hero__stats">
          {c.hero.stats.map((s) => <li class="cx-hero__stat">{s}</li>)}
        </ul>
        {c.hero.scarcity && <p class="cx-hero__scarcity">{c.hero.scarcity}</p>}
      </div>
      {c.hero.photo && (
        <figure class="cx-hero__media">
          <img src={c.hero.photo.src} alt={c.hero.photo.alt} width="1023" height="1537" />
        </figure>
      )}
    </section>

    <!-- ── For who ──────────────────────────────────────────────────── -->
    <section class="cx-chapter cx-chapter--narrow">
      <div class="cx-chapter__head reveal">
        <h2 class="cx-chapter__title">{c.forWho.title}</h2>
      </div>
      <p class="cx-chapter__subhead reveal">{c.forWho.intro}</p>
      <ul class="cx-forwho reveal">
        {c.forWho.items.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <!-- ── Video (60-sec Kate) — placeholder until recorded ─────────── -->
    {c.video && (
      <section class="cx-chapter cx-chapter--narrow">
        <div class="cx-chapter__head reveal">
          <h2 class="cx-chapter__title">{c.video.title}</h2>
        </div>
        <div class="cx-video reveal" role="img" aria-label={c.video.caption}>
          <span class="cx-video__glyph" aria-hidden="true">▶</span>
          <p class="cx-video__caption">{c.video.caption}</p>
        </div>
      </section>
    )}

    <!-- ── What's included / session types (one-line accordion) ─────── -->
    <section class="cx-chapter cx-chapter--narrow">
      <div class="cx-chapter__head reveal">
        <h2 class="cx-chapter__title">{c.cards.title}</h2>
      </div>
      <p class="cx-chapter__subhead reveal">{c.cards.intro}</p>
      <div class="cx-faq reveal">
        {c.cards.items.map((item) => (
          <details class="cx-faq__item">
            <summary>{item.title}</summary>
            <p>{item.body}</p>
          </details>
        ))}
      </div>
    </section>

    <!-- ── How it works ─────────────────────────────────────────────── -->
    <section class="cx-chapter">
      <div class="cx-chapter__head reveal">
        <h2 class="cx-chapter__title">{c.how.title}</h2>
      </div>
      <p class="cx-chapter__subhead reveal">{c.how.intro}</p>
      <ol class="cx-how">
        {c.how.steps.map((s, i) => (
          <li class="cx-how__item reveal">
            <span class="cx-how__num">{String(i + 1).padStart(2, '0')}</span>
            <div class="cx-how__text">
              <h3>{s.title}</h3>
              <p>{s.body}</p>
            </div>
          </li>
        ))}
      </ol>
      <p class="cx-statement reveal">{c.how.close}</p>
    </section>

    <!-- ── Price ────────────────────────────────────────────────────── -->
    <section class="cx-chapter">
      <div class="cx-chapter__head reveal">
        <h2 class="cx-chapter__title">{c.price.title}</h2>
      </div>
      <div class="cx-price reveal">
        <p class="cx-price__amount">{c.price.amount}</p>
        <p class="cx-price__note">{c.price.note}</p>
        <ul class="cx-price__bullets">
          {c.price.bullets.map((b) => <li>{b}</li>)}
        </ul>
      </div>
    </section>

    <!-- ── FAQ ──────────────────────────────────────────────────────── -->
    <section class="cx-chapter cx-chapter--narrow">
      <div class="cx-chapter__head reveal">
        <h2 class="cx-chapter__title">{c.faq.title}</h2>
      </div>
      <div class="cx-faq reveal">
        {c.faq.items.map((f) => (
          <details class="cx-faq__item">
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </section>

    <!-- ── Final CTA ────────────────────────────────────────────────── -->
    <section class="cx-final">
      <h2 class="cx-final__title reveal">{c.final.title}</h2>
      <p class="cx-final__note reveal">{c.final.body}</p>
      <div class="cx-final__ctas reveal">
        <a href={c.whatsappUrl} class="cx-btn cx-btn--solid cx-btn--lg" target="_blank" rel="noopener">
          {c.final.buttonWhatsapp}
        </a>
        <a href={coachingContact.emailUrl} class="cx-btn cx-btn--lg">
          {c.final.buttonEmail}
        </a>
      </div>
    </section>
  </main>

  <Footer content={site.footer} />
</Layout>

<style lang="scss">
  $ease-expo: cubic-bezier(0.16, 1, 0.3, 1);

  .cx {
    --cx-bg: var(--bg, #ffffff);
    --cx-bg-soft: var(--bg-soft, #fcfcfb);
    --cx-text: var(--text, #1c1c1c);
    --cx-ink: var(--ink, #29285f);
    --cx-muted: var(--muted, #6b6b6b);
    --cx-border: var(--line, rgba(0, 0, 0, 0.08));
    --cx-radius: var(--radius, 12px);

    background: var(--cx-bg);
    color: var(--cx-text);
    font-family: 'Schibsted Grotesk', Arial, sans-serif;
    overflow-x: hidden;
    padding-top: 4rem; // clear the fixed V6 nav

    ::selection {
      background: var(--cx-ink);
      color: #fff;
    }
  }

  .cx-eyebrow {
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--cx-ink);
  }

  // ── Buttons ───────────────────────────────────────────────
  .cx-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 26px;
    font-size: 0.875rem;
    font-weight: 500;
    border-radius: var(--cx-radius);
    text-decoration: none;
    color: var(--cx-text);
    border: 1px solid var(--cx-border);
    background: var(--cx-bg);
    transition: background 0.25s $ease-expo, border-color 0.25s $ease-expo, color 0.25s $ease-expo;

    &:hover {
      border-color: var(--cx-ink);
      color: var(--cx-ink);
    }

    &--solid {
      background: var(--cx-ink);
      border-color: var(--cx-ink);
      color: #fff;

      &:hover {
        background: #1e1d47;
        border-color: #1e1d47;
        color: #fff;
      }
    }

    &--lg { padding: 16px 34px; font-size: 0.9375rem; }
  }

  // ── Hero ──────────────────────────────────────────────────
  .cx-hero {
    max-width: 1100px;
    margin: 0 auto;
    padding: clamp(64px, 9vw, 120px) clamp(1.5rem, 5vw, 2rem) 80px;

    &--photo {
      display: grid;
      grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.85fr);
      gap: clamp(2rem, 5vw, 4rem);
      align-items: center;

      @media (max-width: 860px) { grid-template-columns: 1fr; }
    }

    &__eyebrow { margin-bottom: 1.75rem; }

    &__headline {
      font-size: clamp(2.25rem, 5vw, 3.75rem);
      font-weight: 500;
      line-height: 1.06;
      letter-spacing: -0.02em;
      margin: 0;
      max-width: 20ch;
      color: var(--cx-ink);
    }

    &__body {
      max-width: 44rem;
      margin-top: 2rem;
      display: flex;
      flex-direction: column;
      gap: 1.25rem;

      p {
        margin: 0;
        font-size: 1.0625rem;
        line-height: 1.65;
        color: var(--cx-muted);
      }
    }

    &__cta { margin-top: 2.25rem; }

    &__stats {
      list-style: none;
      margin: 2.5rem 0 0;
      padding: 2rem 0 0;
      border-top: 1px solid var(--cx-border);
      display: flex;
      flex-wrap: wrap;
      gap: 1rem 2.5rem;
    }

    &__stat {
      position: relative;
      font-size: 0.9375rem;
      font-weight: 500;
      color: var(--cx-text);

      &:not(:last-child)::after {
        content: '·';
        position: absolute;
        right: -1.4rem;
        color: var(--cx-muted);
      }
    }

    &__scarcity {
      margin: 1.25rem 0 0;
      font-size: 0.8125rem;
      line-height: 1.5;
      color: var(--cx-muted);
      max-width: 34rem;
    }

    // Approved use: career-sessions hero, 4:5 crop, hands and desk respected.
    &__media {
      margin: 0;

      img {
        width: 100%;
        aspect-ratio: 4 / 5;
        max-height: 480px;
        object-fit: cover;
        object-position: center top;
        border-radius: var(--cx-radius);
        border: 1px solid var(--cx-border);
        display: block;
      }
    }
  }

  // ── Chapters ──────────────────────────────────────────────
  .cx-chapter {
    max-width: 1100px;
    margin: 0 auto;
    padding: clamp(48px, 7vw, 80px) clamp(1.5rem, 5vw, 2rem);
    border-top: 1px solid var(--cx-border);

    &--narrow { max-width: 760px; }

    &__head { margin-bottom: 2.5rem; }

    &__title {
      font-size: clamp(1.75rem, 3vw, 2rem);
      font-weight: 500;
      letter-spacing: -0.02em;
      line-height: 1.1;
      margin: 0;
      color: var(--cx-ink);
      max-width: 22ch;
    }

    &__subhead {
      max-width: 46rem;
      color: var(--cx-muted);
      margin: -1rem 0 3rem;
      font-size: 1.0625rem;
      line-height: 1.65;
    }
  }

  // ── For who ───────────────────────────────────────────────
  .cx-forwho {
    list-style: none;
    margin: 0;
    padding: 0;

    li {
      position: relative;
      padding: 1.25rem 0 1.25rem 2rem;
      border-bottom: 1px solid var(--cx-border);
      font-size: 1.0625rem;
      line-height: 1.6;
      color: var(--cx-text);

      &:first-child { border-top: 1px solid var(--cx-border); }

      &::before {
        content: '→';
        position: absolute;
        left: 0;
        color: var(--cx-ink);
        font-weight: 500;
      }
    }
  }

  // ── Video placeholder ─────────────────────────────────────
  .cx-video {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    text-align: center;
    aspect-ratio: 16 / 9;
    padding: 2rem;
    background: var(--cx-bg-soft);
    border: 1px dashed rgba(41, 40, 95, 0.35);
    border-radius: var(--cx-radius);

    &__glyph {
      width: 3.5rem;
      height: 3.5rem;
      display: grid;
      place-items: center;
      border-radius: 50%;
      background: var(--cx-ink);
      color: #fff;
      font-size: 1.125rem;
      padding-left: 3px;
    }

    &__caption {
      margin: 0;
      font-size: 0.8125rem;
      line-height: 1.55;
      color: var(--cx-muted);
      max-width: 30rem;
    }
  }

  // ── How ───────────────────────────────────────────────────
  .cx-how {
    list-style: none;
    margin: 0;
    padding: 0;
    max-width: 56rem;
  }

  .cx-how__item {
    display: grid;
    grid-template-columns: 3.5rem 1fr;
    gap: 1.75rem;
    padding: 1.75rem 0;
    border-bottom: 1px solid var(--cx-border);

    &:first-child { border-top: 1px solid var(--cx-border); }

    .cx-how__num {
      font-size: 1.25rem;
      font-weight: 500;
      color: var(--cx-ink);
      line-height: 1.4;
    }

    .cx-how__text {
      h3 {
        margin: 0 0 0.5rem;
        font-size: 1.125rem;
        font-weight: 500;
        color: var(--cx-text);
      }

      p {
        margin: 0;
        font-size: 0.9375rem;
        line-height: 1.65;
        color: var(--cx-muted);
        max-width: 42rem;
      }
    }

    @media (max-width: 480px) {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
  }

  .cx-statement {
    margin: 3.5rem 0 0;
    max-width: 40rem;
    font-size: clamp(1.25rem, 2.2vw, 1.75rem);
    font-weight: 500;
    line-height: 1.35;
    letter-spacing: -0.01em;
    color: var(--cx-ink);
  }

  // ── Price ─────────────────────────────────────────────────
  .cx-price {
    &__amount {
      font-size: clamp(2.25rem, 5vw, 3.5rem);
      font-weight: 500;
      letter-spacing: -0.02em;
      line-height: 1.05;
      margin: 0;
      color: var(--cx-ink);
    }

    &__note {
      margin: 1rem 0 0;
      max-width: 40rem;
      color: var(--cx-muted);
      font-size: 1.0625rem;
      line-height: 1.6;
    }

    &__bullets {
      list-style: none;
      margin: 2rem 0 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 0;
      max-width: 40rem;

      li {
        position: relative;
        padding: 1rem 0 1rem 1.75rem;
        border-bottom: 1px solid var(--cx-border);
        font-size: 0.9375rem;
        color: var(--cx-text);

        &:first-child { border-top: 1px solid var(--cx-border); }

        &::before {
          content: '·';
          position: absolute;
          left: 0.5rem;
          color: var(--cx-ink);
          font-weight: 700;
        }
      }
    }
  }

  // ── FAQ / accordion (also used for session types) ─────────
  .cx-faq {
    max-width: 46rem;

    &__item {
      border-bottom: 1px solid var(--cx-border);

      &:first-child { border-top: 1px solid var(--cx-border); }

      summary {
        padding: 1.5rem 2.5rem 1.5rem 0;
        font-size: 1.0625rem;
        font-weight: 500;
        color: var(--cx-text);
        cursor: pointer;
        list-style: none;
        position: relative;

        &::-webkit-details-marker { display: none; }

        &::after {
          content: '+';
          position: absolute;
          right: 0.25rem;
          top: 50%;
          transform: translateY(-50%);
          color: var(--cx-ink);
          font-size: 1.375rem;
          font-weight: 400;
          transition: transform 0.25s $ease-expo;
        }
      }

      &[open] summary::after { transform: translateY(-50%) rotate(45deg); }

      p {
        margin: 0 0 1.5rem;
        font-size: 0.9375rem;
        line-height: 1.7;
        color: var(--cx-muted);
        max-width: 42rem;
      }
    }
  }

  // ── Final ─────────────────────────────────────────────────
  .cx-final {
    max-width: 1100px;
    margin: 0 auto;
    padding: clamp(64px, 9vw, 110px) clamp(1.5rem, 5vw, 2rem) clamp(64px, 8vw, 90px);
    text-align: center;
    border-top: 1px solid var(--cx-border);

    &__title {
      font-size: clamp(2rem, 4.5vw, 3.25rem);
      font-weight: 500;
      letter-spacing: -0.02em;
      line-height: 1.1;
      margin: 0 auto;
      max-width: 22ch;
      color: var(--cx-ink);
    }

    &__note {
      max-width: 34rem;
      margin: 1.5rem auto 0;
      color: var(--cx-muted);
      font-size: 1rem;
      line-height: 1.65;
    }

    &__ctas {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 1rem;
      margin-top: 2.5rem;
    }
  }
</style>
