---
import type { LandingContent } from "../../content/index";

interface Props {
  content: LandingContent["hero"];
}

const { content } = Astro.props;

// 12-month timeline geometry (viewBox units)
const CHART_LEFT = 80;
const CHART_RIGHT = 1360;
const BASELINE = 720;
const MONTHS = 12;
const monthX = (m: number) =>
  CHART_LEFT + ((CHART_RIGHT - CHART_LEFT) / (MONTHS - 1)) * (m - 1);
const ticks = Array.from({ length: MONTHS }, (_, i) => monthX(i + 1));
const exitX = monthX(6);
---

<section class="v5-hero">

  <!-- Animated retention-timeline background -->
  <div class="v5-hero__chart" aria-hidden="true">
    <svg
      class="v5-chart"
      viewBox="0 0 1440 800"
      preserveAspectRatio="none"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
    >
      <defs>
        <linearGradient id="v5-area" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="#3C2BDC" stop-opacity="0.14" />
          <stop offset="60%" stop-color="#3C2BDC" stop-opacity="0.05" />
          <stop offset="100%" stop-color="#3C2BDC" stop-opacity="0" />
        </linearGradient>
        <linearGradient id="v5-culture-stroke" x1="0" y1="0" x2="1" y2="0">
          <stop offset="0%" stop-color="#3C2BDC" stop-opacity="0.35" />
          <stop offset="100%" stop-color="#3C2BDC" stop-opacity="0.9" />
        </linearGradient>
        <linearGradient id="v5-sweep" x1="0" y1="0" x2="1" y2="0">
          <stop offset="0%" stop-color="#3C2BDC" stop-opacity="0" />
          <stop offset="50%" stop-color="#3C2BDC" stop-opacity="0.08" />
          <stop offset="100%" stop-color="#3C2BDC" stop-opacity="0" />
        </linearGradient>
      </defs>

      <!-- Baseline + month ticks — enters with phase 1 -->
      <g class="v5-chart__axis">
        <line
          x1={CHART_LEFT} y1={BASELINE}
          x2={CHART_RIGHT} y2={BASELINE}
          stroke="#0F0F0F" stroke-opacity="0.12"
        />
        {ticks.map((x) => (
          <line
            x1={x} y1={BASELINE}
            x2={x} y2={BASELINE + 8}
            stroke="#0F0F0F" stroke-opacity="0.14"
          />
        ))}
        <text class="v5-chart__month" x={monthX(1)} y={BASELINE + 32} text-anchor="middle">
          {content.chart.monthStart}
        </text>
        <text class="v5-chart__month" x={monthX(6)} y={BASELINE + 32} text-anchor="middle">
          {content.chart.monthMid}
        </text>
        <text class="v5-chart__month" x={monthX(12)} y={BASELINE + 32} text-anchor="middle">
          {content.chart.monthEnd}
        </text>
      </g>

      <!-- Gradient area under the culture-fit curve — phase 2 -->
      <g class="v5-chart__area-wrap">
        <path
          class="v5-chart__area"
          d={`M ${CHART_LEFT} 560
              C 400 555, 700 510, 950 430
              C 1130 372, 1270 300, ${CHART_RIGHT} 240
              L ${CHART_RIGHT} ${BASELINE} L ${CHART_LEFT} ${BASELINE} Z`}
          fill="url(#v5-area)"
        />
      </g>

      <!-- Skills-only line: draws with the first headline phrase -->
      <g class="v5-chart__reveal v5-chart__reveal--skills">
        <path
          class="v5-chart__line v5-chart__line--skills"
          d={`M ${CHART_LEFT} 530
              C 220 545, 360 590, 480 645
              C 570 686, 630 708, ${exitX} ${BASELINE}`}
          stroke="#5C5C5C" stroke-width="2" stroke-dasharray="7 9"
          stroke-linecap="round"
        />
      </g>
      <g class="v5-chart__skills-end">
        <circle class="v5-chart__exit-dot" cx={exitX} cy={BASELINE} r="4.5" />
        <text class="v5-chart__label v5-chart__label--skills" x="250" y="610">
          {content.chart.skillsLabel}
        </text>
        <text class="v5-chart__label v5-chart__label--exit" x={exitX + 18} y={BASELINE - 16}>
          {content.chart.exitLabel}
        </text>
      </g>

      <!-- Culture-fit line: draws with the second headline phrase -->
      <g class="v5-chart__reveal v5-chart__reveal--culture">
        <path
          class="v5-chart__line v5-chart__line--culture"
          d={`M ${CHART_LEFT} 560
              C 400 555, 700 510, 950 430
              C 1130 372, 1270 300, ${CHART_RIGHT} 240`}
          stroke="url(#v5-culture-stroke)" stroke-width="3"
          stroke-linecap="round"
        />
      </g>
      <g class="v5-chart__culture-end">
        <circle class="v5-chart__pulse-ring" cx={CHART_RIGHT} cy="240" r="6" stroke="#3C2BDC" stroke-width="1.5" />
        <circle class="v5-chart__end-dot" cx={CHART_RIGHT} cy="240" r="5" fill="#3C2BDC" />
        <text class="v5-chart__label v5-chart__label--culture" x="1330" y="330" text-anchor="end">
          {content.chart.cultureLabel}
        </text>
      </g>

      <!-- Slow ambient sweep — starts after the intro -->
      <g class="v5-chart__sweep-wrap">
        <rect
          class="v5-chart__sweep"
          x={CHART_LEFT - 160} y="200" width="160" height={BASELINE - 200}
          fill="url(#v5-sweep)"
        />
      </g>
    </svg>

    <!-- Soft vignette so the headline stays readable over the chart -->
    <div class="v5-hero__chart-vignette"></div>
  </div>

  <div class="v5-hero__container">
    <div class="v5-hero__content">

      <!-- Headline: each phrase enters with its line -->
      <h1 class="v5-hero__headline headline1">
        <span class="v5-hero__phrase v5-hero__phrase--skills">
          {content.headline}
        </span>
        <span class="v5-hero__phrase v5-hero__phrase--culture v5-hero__headline-accent">
          {content.headlineAccent}
        </span>
      </h1>

      <!-- Subheadline — phase 4 -->
      <p class="v5-hero__subheadline subhead subhead-section v5-phase-4">
        {content.subheadline}
      </p>

      <!-- Metrics — phase 3 -->
      <div class="v5-hero__metrics v5-phase-3" id="v5-hero-stats">
        {content.stats.map((stat, i) => (
          <>
            {i > 0 && <div class="v5-hero__metric-divider" />}
            <div
              class="v5-hero__metric"
              data-value={stat.value}
              data-suffix={stat.suffix}
            >
              <div class="v5-hero__metric-value">
                {stat.suffixLeft}<span class="count">0</span>{stat.suffix}
              </div>
              <p class="v5-hero__metric-label">
                {stat.label}
              </p>
            </div>
          </>
        ))}
      </div>

      <!-- CTAs — phase 4 -->
      <div class="v5-hero__ctas v5-phase-4">
        <a href="#cta" class="btn">
          {content.ctaPrimary}
        </a>
        <a href="#engine" class="btn-secondary">
          {content.ctaSecondary}
        </a>
      </div>

      <!-- Trust line — phase 4 -->
      <p class="v5-hero__trust v5-phase-4">
        {content.trustLabel}
      </p>

    </div>
  </div>
</section>

<style lang="scss">
  @use '../../styles/breakpoints' as *;

  // ── Intro choreography timeline ─────────────────────────────
  // 0.2s  phase 1: "Skills get people hired." + axis + skills line draw
  // 1.3s  phase 2: "Culture fit makes them stay." + culture line draw
  // 2.3s  phase 3: metrics fade in (counts run alongside)
  // 3.1s  phase 4: subheadline, CTAs, trust line (nav fades from the page)
  // 3.6s+ ambient loops (sweep, pulse, breathing area, float)
  $t-phase-1: 0.2s;
  $t-phase-2: 1.3s;
  $t-phase-3: 2.3s;
  $t-phase-4: 3.1s;
  $t-ambient: 3.6s;

  $ease-expo: cubic-bezier(0.16, 1, 0.3, 1);
  $ease-quart: cubic-bezier(0.25, 1, 0.5, 1);
  $ease-soft: cubic-bezier(0.45, 0, 0.55, 1);

  .v5-hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
    padding-top: 8rem;
    padding-bottom: 6rem;

    @include max-md {
      padding-top: 6rem;
      padding-bottom: 4rem;
    }

    // ── Chart background ────────────────────────────────────
    &__chart {
      position: absolute;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      animation: v5-float 16s $ease-soft $t-ambient infinite alternate;

      @include max-md {
        opacity: 0.6;

        // preserveAspectRatio="none" distorts text at narrow widths
        :global(.v5-chart__month),
        :global(.v5-chart__label) {
          display: none;
        }
      }
    }

    &__chart-vignette {
      position: absolute;
      inset: 0;
      background: radial-gradient(
        ellipse 62% 55% at 50% 46%,
        rgba(250, 249, 247, 0.92) 0%,
        rgba(250, 249, 247, 0.55) 55%,
        rgba(250, 249, 247, 0) 100%
      );
    }

    &__container {
      position: relative;
      z-index: 1;
      max-width: 80rem;
      margin-inline: auto;
      padding-inline: 2rem;
      width: 100%;

      @include max-lg { padding-inline: 1.5rem; }
      @include max-sm { padding-inline: 1rem; }
    }

    &__content {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 2.5rem;
    }

    &__headline {
      text-align: center;
      max-width: 64rem;
      color: var(--color-text);
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    // Each headline phrase enters with its chart line
    &__phrase {
      display: block;
      opacity: 0;
      transform: translateY(24px);

      &--skills {
        animation: v5-fade-up 0.9s $ease-expo $t-phase-1 forwards;
      }

      &--culture {
        animation: v5-fade-up 0.9s $ease-expo $t-phase-2 forwards;
      }
    }

    &__headline-accent {
      color: var(--color-accent);
    }

    &__subheadline {
      text-align: center;
    }

    // ── Metrics ─────────────────────────────────────────────
    &__metrics {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 2.5rem;

      @include max-sm {
        gap: 1.5rem;
      }
    }

    &__metric {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.25rem;
      text-align: center;
    }

    &__metric-value {
      font-size: 2.25rem;
      font-weight: 500;
      line-height: 1;
      color: var(--color-text);

      @include max-sm {
        font-size: 1.75rem;
      }
    }

    &__metric-label {
      font-size: 0.875rem;
      color: var(--color-muted);
      max-width: 120px;
    }

    &__metric-divider {
      width: 1px;
      height: 40px;
      background-color: var(--color-border);
    }

    // ── CTAs ────────────────────────────────────────────────
    &__ctas {
      display: flex;
      align-items: center;
      gap: 1rem;

      @include max-sm {
        flex-direction: column;
        width: 100%;
      }
    }

    &__trust {
      font-size: 0.875rem;
      color: var(--color-muted);
      text-align: center;
    }
  }

  // ── Phase entrance classes ───────────────────────────────
  .v5-phase-3 {
    opacity: 0;
    transform: translateY(20px);
    animation: v5-fade-up 0.9s $ease-expo $t-phase-3 forwards;
  }

  .v5-phase-4 {
    opacity: 0;
    transform: translateY(20px);
    animation: v5-fade-up 0.9s $ease-expo $t-phase-4 forwards;
  }

  // ── Chart internals ───────────────────────────────────────
  .v5-chart {
    width: 100%;
    height: 100%;
    display: block;

    &__month {
      font-size: 13px;
      fill: var(--color-muted);
      fill-opacity: 0.75;
      letter-spacing: 0.04em;
    }

    &__label {
      font-size: 14px;
      letter-spacing: 0.02em;

      &--skills {
        fill: var(--color-muted);
      }

      &--exit {
        fill: #D14343;
        font-size: 12.5px;
        font-weight: 500;
      }

      &--culture {
        fill: var(--color-accent);
        font-weight: 500;
      }
    }

    // Axis enters with phase 1
    &__axis {
      opacity: 0;
      animation: v5-fade-in 0.8s $ease-quart $t-phase-1 forwards;
    }

    // Left-to-right draw reveal (clip-path keeps the dash pattern intact)
    &__reveal {
      clip-path: inset(-5% 105% -5% -2%);

      &--skills {
        animation: v5-draw 1.1s $ease-quart $t-phase-1 forwards;
      }

      &--culture {
        animation: v5-draw 1.2s $ease-expo $t-phase-2 forwards;
      }
    }

    &__line--skills {
      stroke-opacity: 0.5;
    }

    &__area-wrap {
      opacity: 0;
      animation: v5-fade-in 1.2s $ease-expo ($t-phase-2 + 0.4s) forwards;
    }

    &__area {
      animation: v5-breathe 7s $ease-soft $t-ambient infinite alternate;
    }

    &__skills-end {
      opacity: 0;
      animation: v5-fade-in 0.7s $ease-expo ($t-phase-1 + 0.9s) forwards;
    }

    &__culture-end {
      opacity: 0;
      animation: v5-fade-in 0.7s $ease-expo ($t-phase-2 + 1s) forwards;
    }

    // Red exit marker — emphasizes the cost of skills-only hiring
    &__exit-dot {
      fill: #D14343;
      fill-opacity: 0.7;
      animation: v5-dim 3.2s $ease-soft $t-ambient infinite alternate;
    }

    &__pulse-ring {
      transform-box: fill-box;
      transform-origin: center;
      animation: v5-pulse 2.6s $ease-expo $t-ambient infinite;
      opacity: 0;
    }

    &__sweep-wrap {
      opacity: 0;
      animation: v5-fade-in 2s linear $t-ambient forwards;
    }

    &__sweep {
      animation: v5-sweep 11s $ease-soft $t-ambient infinite;
    }
  }

  @keyframes v5-fade-up {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes v5-draw {
    to { clip-path: inset(-5% -2% -5% -2%); }
  }

  @keyframes v5-fade-in {
    to { opacity: 1; }
  }

  @keyframes v5-breathe {
    from { opacity: 0.65; }
    to { opacity: 1; }
  }

  @keyframes v5-dim {
    from { fill-opacity: 0.7; }
    to { fill-opacity: 0.3; }
  }

  @keyframes v5-pulse {
    0% { transform: scale(1); opacity: 0.55; }
    70% { transform: scale(3.2); opacity: 0; }
    100% { transform: scale(3.2); opacity: 0; }
  }

  @keyframes v5-sweep {
    from { transform: translateX(0); }
    to { transform: translateX(1600px); }
  }

  @keyframes v5-float {
    from { transform: translateY(0); }
    to { transform: translateY(-12px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .v5-hero__chart {
      animation: none;
    }

    .v5-hero__phrase,
    .v5-phase-3,
    .v5-phase-4 {
      animation: none;
      opacity: 1;
      transform: none;
    }

    .v5-chart__reveal {
      animation: none;
      clip-path: none;
    }

    .v5-chart__axis,
    .v5-chart__area-wrap,
    .v5-chart__skills-end,
    .v5-chart__culture-end {
      animation: none;
      opacity: 1;
    }

    .v5-chart__area,
    .v5-chart__exit-dot,
    .v5-chart__sweep,
    .v5-chart__pulse-ring {
      animation: none;
    }

    .v5-chart__sweep-wrap {
      animation: none;
      opacity: 0;
    }
  }
</style>

<script>
  // Metric count-up, synced to phase 3 of the intro choreography
  const PHASE_3_DELAY = 2300;

  function animateCount(el: Element, target: number, duration: number = 1200) {
    const countEl = el.querySelector('.count');
    if (!countEl) return;

    const start = performance.now();

    function easeOut(t: number): number {
      return 1 - Math.pow(1 - t, 3);
    }

    function tick(now: number) {
      const elapsed = now - start;
      const progress = Math.min(elapsed / duration, 1);
      const current = Math.round((target) * easeOut(progress));
      if (countEl) {
        countEl.textContent = current.toString();
        if (progress < 1) requestAnimationFrame(tick);
        else countEl.textContent = target.toString();
      }
    }

    requestAnimationFrame(tick);
  }

  const statsSection = document.getElementById('v5-hero-stats');
  if (statsSection) {
    const items = statsSection.querySelectorAll('.v5-hero__metric');
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const delay = reducedMotion ? 0 : PHASE_3_DELAY;

    window.setTimeout(() => {
      items.forEach((item) => {
        const target = parseInt(item.getAttribute('data-value') || '0', 10);
        animateCount(item, target, 1000);
      });
    }, delay);
  }
</script>
