---
interface Props {
  id?: string;
  class?: string;
  tight?: boolean;
}

const { id, class: className = '', tight = false } = Astro.props;
---

<section
  id={id}
  class={`w-full ${tight ? 'py-16 md:py-20' : 'py-20 md:py-28'} ${className}`}
>
  <div class="max-w-[1280px] mx-auto px-4 sm:px-6 lg:px-8">
    <slot />
  </div>
</section>
