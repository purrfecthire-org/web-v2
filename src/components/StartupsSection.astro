---
import type { LandingContent } from '../content/index';
import SectionWrapper from './SectionWrapper.astro';
import FeatureCard from './FeatureCard.astro';

interface Props {
  content: LandingContent['startups'];
}

const { content } = Astro.props;
---

<SectionWrapper id="startups">
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-start">
    <!-- Left: statements -->
    <div class="flex flex-col gap-6">
      <span
        class="inline-flex items-center w-fit px-3 py-1.5 rounded-full border border-[var(--color-border)] bg-[var(--color-surface)] text-xs font-medium text-[var(--color-muted)]"
      >
        {content.badge}
      </span>

      <h2
        class="text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight text-[var(--color-text)] leading-tight"
      >
        {content.headline}
      </h2>

      <p class="text-base text-[var(--color-muted)] leading-relaxed max-w-md">
        {content.subheadline}
      </p>

      <!-- Strike-through statements -->
      <ul class="flex flex-col gap-3 mt-2">
        {
          content.statements.map((stmt) => (
            <li class="flex items-start gap-3">
              <span
                class="flex-shrink-0 mt-1 w-4 h-4 rounded-full bg-red-50 border border-red-200 flex items-center justify-center"
                aria-hidden="true"
              >
                <svg width="8" height="8" viewBox="0 0 8 8" fill="none">
                  <path
                    d="M1.5 1.5l5 5M6.5 1.5l-5 5"
                    stroke="#ef4444"
                    stroke-width="1.2"
                    stroke-linecap="round"
                  />
                </svg>
              </span>
              <span class="text-sm text-[var(--color-muted)] line-through leading-relaxed">
                {stmt}
              </span>
            </li>
          ))
        }
      </ul>

      <a
        href="#cta"
        class="mt-2 w-fit inline-flex items-center gap-2 px-5 py-3 rounded-xl bg-[var(--color-primary)] text-white font-semibold text-sm hover:bg-[var(--color-primary-hover)] transition-all duration-150 shadow-md hover:shadow-lg hover:-translate-y-0.5"
      >
        {content.cta}
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path
            d="M3 8h10M9 4l4 4-4 4"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </a>
    </div>

    <!-- Right: benefits grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {
        content.benefits.map((benefit) => (
          <FeatureCard
            title={benefit.title}
            description={benefit.description}
          />
        ))
      }
    </div>
  </div>
</SectionWrapper>
