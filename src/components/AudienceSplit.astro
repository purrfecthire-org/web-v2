---
import type { LandingContent } from "../content/index";

interface Props {
  content: LandingContent["audienceSplit"];
}

const { content } = Astro.props;
---

<section id="audience" class="audience">
  <div class="audience__container">
    <!-- Section header -->
    <div class="audience__header reveal">
      <h2 class="audience__headline headline2">
        {content.headline}
      </h2>
      <p class="audience__subheadline body1">
        {content.subheadline}
      </p>
    </div>

    <!-- Two cards -->
    <div class="audience__grid">
      <!-- Founders card -->
      <div class="audience__card reveal reveal-delay-1">
        <span class="audience__eyebrow eyebrow">
          {content.founders.eyebrow}
        </span>

        <h3 class="headline3">
          {content.founders.headline}
        </h3>

        <p class="audience__card-body body1">
          {content.founders.body}
        </p>

        <div class="audience__bullets">
          {content.founders.bullets.map((bullet) => (
            <div class="audience__bullet">
              <span class="audience__bullet-label">{bullet.label}:</span>
              <span class="audience__bullet-text">{bullet.text}</span>
            </div>
          ))}
        </div>

        <div class="audience__cta">
          <a href="#cta" class="btn">
            {content.founders.cta}
          </a>
        </div>
      </div>

      <!-- Talent card -->
      <div class="audience__card reveal reveal-delay-2">
        <span class="audience__eyebrow eyebrow">
          {content.talent.eyebrow}
        </span>

        <h3 class="headline3">
          {content.talent.headline}
        </h3>

        <p class="audience__card-body body1">
          {content.talent.body}
        </p>

        <div class="audience__bullets">
          {content.talent.bullets.map((bullet) => (
            <div class="audience__bullet">
              <span class="audience__bullet-label">{bullet.label}:</span>
              <span class="audience__bullet-text">{bullet.text}</span>
            </div>
          ))}
        </div>

        <div class="audience__cta">
          <a href="#cta" class="btn">
            {content.talent.cta}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  @use "../styles/breakpoints" as *;

  .reveal {
    opacity: 0;
    transform: translateY(40px);
    transition:
      opacity 0.7s ease,
      transform 0.7s ease;
    will-change: opacity, transform;
  }

  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .reveal-delay-1 { transition-delay: 0.15s; }
  .reveal-delay-2 { transition-delay: 0.3s; }

  .audience {
    background: var(--color-bg);
    padding-block: 7rem;

    @include max-md { padding-block: 5rem; }

    &__container {
      max-width: 80rem;
      margin-inline: auto;
      padding-inline: 2rem;

      @include max-lg { padding-inline: 1.5rem; }
      @include max-sm { padding-inline: 1rem; }
    }

    &__header {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1rem;
      text-align: center;
      margin-bottom: 3.5rem;
    }

    &__headline {
      max-width: 42rem;
      color: var(--color-text);
    }

    &__subheadline {
      max-width: 42rem;
    }

    &__grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;

      @include max-md { grid-template-columns: 1fr; }
    }

    &__card {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
      padding: 2rem;
      border: 1px solid var(--color-border);
      border-radius: 12px;
      background: var(--color-surface);

      @include max-sm { padding: 1.5rem; }
    }

    &__eyebrow {
      align-self: flex-start;
    }

    &__card-body {}

    &__bullets {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    &__bullet {
      font-size: 0.9375rem;
      line-height: 1.5;
      color: var(--color-muted);
    }

    &__bullet-label {
      font-weight: 500;
      color: var(--color-text);
    }

    &__bullet-text {}

    &__cta {
      margin-top: auto;
    }
  }
</style>

<script>
  const elements = document.querySelectorAll('.reveal');

  const observer = new IntersectionObserver((entries, obs) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        obs.unobserve(entry.target);
      }
    });
  }, { threshold: 0.2 });

  elements.forEach(el => observer.observe(el));
</script>
