---
interface Props {
  quote: string;
  author: string;
  role: string;
  company: string;
}

const { quote, author, role, company } = Astro.props;
const initials = author
  .split(' ')
  .map((n) => n[0])
  .join('');
---

<div
  class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6 flex flex-col gap-5 hover:shadow-md transition-shadow duration-200"
>
  <!-- Quote marks -->
  <svg
    width="24"
    height="18"
    viewBox="0 0 24 18"
    fill="none"
    class="text-[var(--color-accent)] opacity-60"
  >
    <path
      d="M0 18V11.25C0 7.5 1.5 4.375 4.5 1.875L6.75 0l2.25 1.875C6.75 4.375 5.25 7.5 5.25 11.25V18H0zm13.5 0V11.25C13.5 7.5 15 4.375 18 1.875L20.25 0 22.5 1.875C20.25 4.375 18.75 7.5 18.75 11.25V18H13.5z"
      fill="currentColor"></path>
  </svg>

  <p class="text-sm text-[var(--color-text)] leading-relaxed flex-1">
    {quote}
  </p>

  <div class="flex items-center gap-3">
    <div
      class="w-9 h-9 rounded-full bg-gradient-to-br from-[var(--color-primary)] to-[var(--color-secondary)] flex items-center justify-center text-xs font-semibold text-white flex-shrink-0"
    >
      {initials}
    </div>
    <div>
      <p class="text-sm font-semibold text-[var(--color-text)]">{author}</p>
      <p class="text-xs text-[var(--color-muted)]">{role}, {company}</p>
    </div>
  </div>
</div>
