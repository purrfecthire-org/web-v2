---
import type { LandingContent } from '../../content/index';

interface Props {
  content: LandingContent['testimonials'];
}

const { content } = Astro.props;

function getInitial(name: string): string {
  return name.charAt(0).toUpperCase();
}
---

<section class="v1-testimonials" id="testimonials">
  <div class="v1-testimonials__container">

    <div class="v1-testimonials__header">
      <span class="v1-testimonials__eyebrow">{content.eyebrow}</span>
      <h2 class="v1-testimonials__headline">{content.headline}</h2>
    </div>

    <!-- Featured testimonial -->
    <div class="v1-testimonials__featured">
      <span class="v1-testimonials__featured-mark" aria-hidden="true">"</span>
      <blockquote class="v1-testimonials__featured-quote">
        {content.featured.quote}
      </blockquote>
      <div class="v1-testimonials__featured-meta">
        <div class="v1-testimonials__avatar">
          {getInitial(content.featured.name)}
        </div>
        <div class="v1-testimonials__featured-info">
          <span class="v1-testimonials__featured-name">{content.featured.name}</span>
          <span class="v1-testimonials__featured-role">{content.featured.role}</span>
        </div>
        <span class="v1-testimonials__badge">{content.featured.badge}</span>
      </div>
    </div>

    <!-- Grid of 3 -->
    <div class="v1-testimonials__grid">
      {content.grid.map((item) => (
        <div class="v1-testimonials__card">
          <span class="v1-testimonials__card-mark" aria-hidden="true">"</span>
          <blockquote class="v1-testimonials__card-quote">{item.quote}</blockquote>
          <div class="v1-testimonials__card-meta">
            <div class="v1-testimonials__avatar v1-testimonials__avatar--sm">
              {getInitial(item.name)}
            </div>
            <div class="v1-testimonials__card-info">
              <span class="v1-testimonials__card-name">{item.name}</span>
              <span class="v1-testimonials__card-role">{item.role}</span>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Candidate testimonial -->
    <div class="v1-testimonials__candidate">
      <div class="v1-testimonials__candidate-tag">
        <span class="v1-testimonials__candidate-dot" aria-hidden="true"></span>
        Candidate Voice
      </div>
      <span class="v1-testimonials__featured-mark v1-testimonials__featured-mark--candidate" aria-hidden="true">"</span>
      <blockquote class="v1-testimonials__candidate-quote">
        {content.candidateTestimonial.quote}
      </blockquote>
      <div class="v1-testimonials__featured-meta">
        <div class="v1-testimonials__avatar v1-testimonials__avatar--candidate">
          {getInitial(content.candidateTestimonial.name)}
        </div>
        <div class="v1-testimonials__featured-info">
          <span class="v1-testimonials__featured-name">{content.candidateTestimonial.name}</span>
          <span class="v1-testimonials__featured-role">{content.candidateTestimonial.role}</span>
        </div>
        <span class="v1-testimonials__badge v1-testimonials__badge--candidate">{content.candidateTestimonial.badge}</span>
      </div>
    </div>

  </div>
</section>

<style lang="scss">
  @use '../../styles/breakpoints' as *;

  .v1-testimonials {
    background: #09090b;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    padding-block: 6rem;

    @include max-md {
      padding-block: 4rem;
    }

    &__container {
      max-width: 80rem;
      margin-inline: auto;
      padding-inline: 2rem;
      display: flex;
      flex-direction: column;
      gap: 2.5rem;

      @include max-lg {
        padding-inline: 1.25rem;
      }
    }

    &__header {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1rem;
      text-align: center;
    }

    &__eyebrow {
      font-size: 0.6875rem;
      font-weight: 600;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: #7c3aed;
    }

    &__headline {
      font-size: clamp(1.5rem, 3vw, 2.25rem);
      font-weight: 500;
      letter-spacing: -0.025em;
      color: #fafafa;
      margin: 0;
      line-height: 1.2;
      max-width: 640px;
    }

    &__featured {
      position: relative;
      background: #18181b;
      border: 1px solid rgba(124, 58, 237, 0.3);
      border-radius: 20px;
      padding: 40px;
      display: flex;
      flex-direction: column;
      gap: 1.75rem;
      overflow: hidden;

      @include max-sm {
        padding: 24px;
        gap: 1.25rem;
      }
    }

    &__featured-mark {
      position: absolute;
      top: 12px;
      left: 24px;
      font-size: 6rem;
      line-height: 0.5;
      font-family: Georgia, serif;
      color: rgba(124, 58, 237, 0.25);
      user-select: none;
      pointer-events: none;

      &--candidate {
        color: rgba(124, 58, 237, 0.2);
      }
    }

    &__featured-quote {
      font-style: italic;
      font-size: 1.25rem;
      color: #fafafa;
      line-height: 1.65;
      margin: 0;
      padding-top: 2rem;

      @include max-sm {
        font-size: 1.0625rem;
      }
    }

    &__featured-meta {
      display: flex;
      align-items: center;
      gap: 1rem;
      flex-wrap: wrap;
    }

    &__avatar {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: linear-gradient(135deg, #7c3aed, #4c1d95);
      color: #ffffff;
      font-size: 1rem;
      font-weight: 600;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;

      &--sm {
        width: 32px;
        height: 32px;
        font-size: 0.875rem;
      }

      &--candidate {
        background: linear-gradient(135deg, #6d28d9, #3b0764);
      }
    }

    &__featured-info {
      display: flex;
      flex-direction: column;
      gap: 0.15rem;
      flex: 1;
    }

    &__featured-name {
      font-size: 0.9375rem;
      font-weight: 500;
      color: #fafafa;
    }

    &__featured-role {
      font-size: 0.8125rem;
      color: #a1a1aa;
    }

    &__badge {
      font-size: 0.625rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #a78bfa;
      background: rgba(124, 58, 237, 0.1);
      border: 1px solid rgba(124, 58, 237, 0.25);
      border-radius: 999px;
      padding: 3px 10px;
      white-space: nowrap;

      &--candidate {
        color: #c4b5fd;
        background: rgba(109, 40, 217, 0.1);
        border-color: rgba(109, 40, 217, 0.3);
      }
    }

    &__grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;

      @include max-md {
        grid-template-columns: 1fr;
      }
    }

    &__card {
      position: relative;
      background: #18181b;
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 16px;
      padding: 28px;
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
      overflow: hidden;
      transition: border-color 0.2s ease;

      &:hover {
        border-color: rgba(124, 58, 237, 0.2);
      }
    }

    &__card-mark {
      position: absolute;
      top: 8px;
      left: 16px;
      font-size: 4rem;
      line-height: 0.5;
      font-family: Georgia, serif;
      color: rgba(124, 58, 237, 0.2);
      user-select: none;
      pointer-events: none;
    }

    &__card-quote {
      font-style: italic;
      font-size: 0.9375rem;
      color: #fafafa;
      line-height: 1.65;
      margin: 0;
      padding-top: 1.5rem;
      flex: 1;
    }

    &__card-meta {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding-top: 0.5rem;
      border-top: 1px solid rgba(255, 255, 255, 0.06);
    }

    &__card-info {
      display: flex;
      flex-direction: column;
      gap: 0.1rem;
    }

    &__card-name {
      font-size: 0.875rem;
      font-weight: 500;
      color: #fafafa;
    }

    &__card-role {
      font-size: 0.75rem;
      color: #a1a1aa;
    }

    &__candidate {
      position: relative;
      background: linear-gradient(135deg, rgba(124, 58, 237, 0.06) 0%, rgba(18, 18, 27, 0.9) 100%);
      border: 1px solid rgba(124, 58, 237, 0.3);
      border-radius: 20px;
      padding: 40px;
      display: flex;
      flex-direction: column;
      gap: 1.75rem;
      overflow: hidden;

      @include max-sm {
        padding: 24px;
        gap: 1.25rem;
      }
    }

    &__candidate-tag {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.6875rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #a78bfa;
    }

    &__candidate-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: #7c3aed;
      box-shadow: 0 0 6px rgba(124, 58, 237, 0.7);
    }

    &__candidate-quote {
      font-style: italic;
      font-size: 1.125rem;
      color: #fafafa;
      line-height: 1.65;
      margin: 0;
      padding-top: 1rem;

      @include max-sm {
        font-size: 1rem;
      }
    }
  }
</style>
