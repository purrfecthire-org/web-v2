---
import type { LandingContent } from '../../content/index';

interface Props {
  content: LandingContent['nav'];
  lang: string;
}

const { content, lang } = Astro.props;
---

<header id="v1-nav" class="v1-nav">
  <div class="v1-nav__container">
    <nav class="v1-nav__inner">

      <!-- Logo -->
      <a href="#" class="v1-nav__logo">
        <span class="v1-nav__logo-dot"></span>
        {content.logo}
      </a>

      <!-- Desktop links -->
      <div class="v1-nav__links">
        {content.links.map((link) => (
          <a href={link.href} class="v1-nav__link">
            {link.label}
          </a>
        ))}
      </div>

      <!-- Right side -->
      <div class="v1-nav__actions">
        <a href="#cta" class="v1-nav__cta">
          {content.cta}
        </a>

        <button
          id="v1-mobile-menu-btn"
          class="v1-nav__hamburger"
          aria-label="Toggle menu"
        >
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              d="M3 5h14M3 10h14M3 15h14"
            />
          </svg>
        </button>
      </div>
    </nav>
  </div>

  <!-- Mobile menu -->
  <div id="v1-mobile-menu" class="v1-nav__mobile-menu">
    <div class="v1-nav__mobile-inner">
      {content.links.map((link) => (
        <a href={link.href} class="v1-nav__link v1-nav__link--mobile">
          {link.label}
        </a>
      ))}
      <a href="#cta" class="v1-nav__cta v1-nav__cta--mobile">
        {content.cta}
      </a>
    </div>
  </div>
</header>

<script>
  const nav = document.getElementById('v1-nav');
  const btn = document.getElementById('v1-mobile-menu-btn');
  const menu = document.getElementById('v1-mobile-menu');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      nav?.classList.add('v1-nav--scrolled');
    } else {
      nav?.classList.remove('v1-nav--scrolled');
    }
  }, { passive: true });

  btn?.addEventListener('click', () => {
    menu?.classList.toggle('v1-nav__mobile-menu--open');
  });
</script>

<style lang="scss">
  @use '../../styles/breakpoints' as *;

  .v1-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background: rgba(9, 9, 11, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    transition: background 200ms ease, border-color 200ms ease;

    &--scrolled {
      background: rgba(9, 9, 11, 0.95);
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    &__container {
      max-width: 80rem;
      margin-inline: auto;
      padding-inline: 2rem;

      @include max-lg {
        padding-inline: 1rem;
      }
    }

    &__inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 4rem;
    }

    &__logo {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 1.0625rem;
      font-weight: 500;
      color: #fafafa;
      text-decoration: none;
      letter-spacing: -0.01em;
      transition: opacity 0.15s ease;

      &:hover {
        opacity: 0.85;
      }
    }

    &__logo-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: #7c3aed;
      box-shadow: 0 0 8px rgba(124, 58, 237, 0.6);
      flex-shrink: 0;
    }

    &__links {
      display: flex;
      align-items: center;
      gap: 0.25rem;

      @include max-lg {
        display: none;
      }
    }

    &__link {
      font-size: 0.9375rem;
      font-weight: 400;
      color: #a1a1aa;
      text-decoration: none;
      padding-inline: 0.875rem;
      padding-block: 0.4rem;
      border-radius: 6px;
      transition: color 0.15s ease, background 0.15s ease;

      &:hover {
        color: #fafafa;
        background: rgba(255, 255, 255, 0.05);
      }

      &--mobile {
        padding-inline: 0;
        padding-block: 0.625rem;
        border-radius: 0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);

        &:hover {
          background: transparent;
          color: #fafafa;
        }
      }
    }

    &__actions {
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    &__cta {
      display: inline-flex;
      align-items: center;
      background: #7c3aed;
      color: #ffffff;
      border-radius: 999px;
      padding: 8px 18px;
      font-size: 0.875rem;
      font-weight: 500;
      text-decoration: none;
      transition: background 0.2s ease, box-shadow 0.2s ease;
      letter-spacing: -0.01em;

      &:hover {
        background: #6d28d9;
        box-shadow: 0 0 20px rgba(124, 58, 237, 0.35);
      }

      @include max-lg {
        display: none;
      }

      &--mobile {
        display: flex;
        justify-content: center;
        border-radius: 999px;
        margin-top: 1rem;
        padding: 12px 18px;
      }
    }

    &__hamburger {
      display: none;
      padding: 0.5rem;
      border-radius: 0.5rem;
      color: #a1a1aa;
      background: none;
      border: 1px solid rgba(255, 255, 255, 0.08);
      cursor: pointer;
      transition: color 0.15s ease, border-color 0.15s ease;

      &:hover {
        color: #fafafa;
        border-color: rgba(255, 255, 255, 0.15);
      }

      @include max-lg {
        display: flex;
      }
    }

    &__mobile-menu {
      display: none;
      border-top: 1px solid rgba(255, 255, 255, 0.06);
      background: rgba(9, 9, 11, 0.97);
      backdrop-filter: blur(20px);

      &--open {
        @include max-lg {
          display: block;
        }
      }
    }

    &__mobile-inner {
      max-width: 80rem;
      margin-inline: auto;
      padding: 1rem;
      display: flex;
      flex-direction: column;
      gap: 0;
    }
  }
</style>
