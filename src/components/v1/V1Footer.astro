---
import type { LandingContent } from '../../content/index';

interface Props {
  content: LandingContent['footer'];
}

const { content } = Astro.props;
---

<footer class="v1-footer">
  <div class="v1-footer__container">

    <div class="v1-footer__left">
      <a href="#" class="v1-footer__logo">
        <span class="v1-footer__logo-dot" aria-hidden="true"></span>
        Purrfect Hire
      </a>
      <p class="v1-footer__tagline">Culture-first hiring for the 1% of startups that get it.</p>
    </div>

    <nav class="v1-footer__links" aria-label="Footer navigation">
      {content.links.map((link) => (
        <a href={link.href} class="v1-footer__link">
          {link.label}
        </a>
      ))}
    </nav>

    <div class="v1-footer__right">
      <p class="v1-footer__legal">{content.legal}</p>
    </div>

  </div>
</footer>

<style lang="scss">
  @use '../../styles/breakpoints' as *;

  .v1-footer {
    background: #09090b;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    padding-block: 2.5rem;

    &__container {
      max-width: 80rem;
      margin-inline: auto;
      padding-inline: 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 2rem;
      flex-wrap: wrap;

      @include max-lg {
        padding-inline: 1.25rem;
      }

      @include max-md {
        flex-direction: column;
        align-items: flex-start;
        gap: 1.5rem;
      }
    }

    &__left {
      display: flex;
      flex-direction: column;
      gap: 0.375rem;
    }

    &__logo {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.9375rem;
      font-weight: 500;
      color: #fafafa;
      text-decoration: none;
      transition: opacity 0.15s ease;

      &:hover {
        opacity: 0.75;
      }
    }

    &__logo-dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: #7c3aed;
    }

    &__tagline {
      font-size: 0.8125rem;
      color: #52525b;
      margin: 0;
    }

    &__links {
      display: flex;
      align-items: center;
      gap: 1.75rem;
      flex-wrap: wrap;

      @include max-md {
        gap: 1.25rem;
      }
    }

    &__link {
      font-size: 0.875rem;
      color: #a1a1aa;
      text-decoration: none;
      transition: color 0.15s ease;

      &:hover {
        color: #fafafa;
      }
    }

    &__right {
      display: flex;
      align-items: center;
    }

    &__legal {
      font-size: 0.8125rem;
      color: #52525b;
      margin: 0;
    }
  }
</style>
