---
import type { LandingContent } from '../../content/index';

interface Props {
  content: LandingContent['engine'];
}

const { content } = Astro.props;
---

<section class="v1-engine" id="engine">
  <div class="v1-engine__container">

    <div class="v1-engine__header">
      <span class="v1-engine__eyebrow">{content.eyebrow}</span>
      <h2 class="v1-engine__headline">{content.headline}</h2>
      <p class="v1-engine__subheadline">{content.subheadline}</p>
    </div>

    <div class="v1-engine__timeline">
      {content.steps.map((step, i) => (
        <div class="v1-engine__step">
          <!-- Connecting line (except last) -->
          {i < content.steps.length - 1 && (
            <div class="v1-engine__connector" aria-hidden="true">
              <div class="v1-engine__connector-line"></div>
            </div>
          )}

          <div class="v1-engine__step-left">
            <div class="v1-engine__step-id">{step.id}</div>
            {i < content.steps.length - 1 && (
              <div class="v1-engine__step-vline" aria-hidden="true"></div>
            )}
          </div>

          <div class="v1-engine__step-content">
            <div class="v1-engine__step-top">
              <h3 class="v1-engine__step-title">{step.title}</h3>
              {step.badge && (
                <span class="v1-engine__badge">{step.badge}</span>
              )}
            </div>
            <p class="v1-engine__step-desc">{step.description}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style lang="scss">
  @use '../../styles/breakpoints' as *;

  .v1-engine {
    background: #09090b;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    padding-block: 6rem;

    @include max-md {
      padding-block: 4rem;
    }

    &__container {
      max-width: 80rem;
      margin-inline: auto;
      padding-inline: 2rem;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: start;

      @include max-lg {
        grid-template-columns: 1fr;
        gap: 3rem;
        padding-inline: 1.25rem;
      }
    }

    &__header {
      position: sticky;
      top: 6rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;

      @include max-lg {
        position: static;
      }
    }

    &__eyebrow {
      font-size: 0.6875rem;
      font-weight: 600;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: #7c3aed;
    }

    &__headline {
      font-size: clamp(1.75rem, 3vw, 2.5rem);
      font-weight: 500;
      letter-spacing: -0.025em;
      color: #fafafa;
      margin: 0;
      line-height: 1.2;
    }

    &__subheadline {
      color: #a1a1aa;
      font-size: 1.0625rem;
      line-height: 1.65;
      margin: 0;
    }

    &__timeline {
      display: flex;
      flex-direction: column;
    }

    &__step {
      display: flex;
      gap: 1.25rem;
      position: relative;
    }

    &__step-left {
      display: flex;
      flex-direction: column;
      align-items: center;
      flex-shrink: 0;
    }

    &__step-id {
      background: rgba(124, 58, 237, 0.15);
      color: #a78bfa;
      font-size: 0.6875rem;
      font-weight: 600;
      padding: 5px 10px;
      border-radius: 6px;
      letter-spacing: 0.05em;
      flex-shrink: 0;
      white-space: nowrap;
    }

    &__step-vline {
      width: 1px;
      flex: 1;
      min-height: 2.5rem;
      background: linear-gradient(180deg, rgba(124, 58, 237, 0.3) 0%, rgba(255, 255, 255, 0.06) 100%);
      margin-top: 0.5rem;
      margin-bottom: 0.5rem;
    }

    &__step-content {
      padding-bottom: 2.5rem;
      display: flex;
      flex-direction: column;
      gap: 0.625rem;

      .v1-engine__step:last-child & {
        padding-bottom: 0;
      }
    }

    &__step-top {
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
      flex-wrap: wrap;
    }

    &__step-title {
      font-size: 1.125rem;
      font-weight: 500;
      color: #fafafa;
      margin: 0;
      line-height: 1.35;
      letter-spacing: -0.01em;
      flex: 1;
    }

    &__badge {
      display: inline-flex;
      align-items: center;
      border: 1px solid rgba(124, 58, 237, 0.4);
      color: #a78bfa;
      background: rgba(124, 58, 237, 0.1);
      border-radius: 999px;
      font-size: 0.6875rem;
      font-weight: 500;
      padding: 4px 12px;
      white-space: nowrap;
      letter-spacing: 0.01em;
    }

    &__step-desc {
      margin: 0;
      color: #a1a1aa;
      font-size: 0.9375rem;
      line-height: 1.65;
    }

    &__connector {
      display: none;
    }
  }
</style>
