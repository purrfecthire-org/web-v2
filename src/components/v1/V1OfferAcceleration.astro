---
import type { LandingContent } from '../../content/index';

interface Props {
  content: LandingContent['offerAcceleration'];
}

const { content } = Astro.props;
---

<section class="v1-offer" id="offer">
  <!-- Background accent -->
  <div class="v1-offer__bg-orb" aria-hidden="true"></div>

  <div class="v1-offer__container">

    <div class="v1-offer__header">
      <span class="v1-offer__eyebrow">{content.eyebrow}</span>
      <h2 class="v1-offer__headline">{content.headline}</h2>
      <p class="v1-offer__subheadline">{content.subheadline}</p>
    </div>

    <div class="v1-offer__blocks">
      {content.blocks.map((block, i) => (
        <div class="v1-offer__block">
          <div class="v1-offer__block-number">{String(i + 1).padStart(2, '0')}</div>
          <h3 class="v1-offer__block-title">{block.title}</h3>
          <ul class="v1-offer__items">
            {block.items.map((item) => (
              <li class="v1-offer__item">
                <span class="v1-offer__check" aria-hidden="true">✓</span>
                <span class="v1-offer__item-text">{item}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="v1-offer__closing-row">
      <p class="v1-offer__closing">{content.closing}</p>
    </div>

    <div class="v1-offer__cta-row">
      <a href="#cta" class="v1-offer__btn">{content.cta}</a>
      <span class="v1-offer__cta-subline">{content.ctaSubline}</span>
    </div>

  </div>
</section>

<style lang="scss">
  @use '../../styles/breakpoints' as *;

  .v1-offer {
    position: relative;
    background: linear-gradient(180deg, #09090b 0%, #0d0b1a 100%);
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    padding-block: 6rem;
    overflow: hidden;

    @include max-md {
      padding-block: 4rem;
    }

    &__bg-orb {
      position: absolute;
      top: -200px;
      left: 50%;
      transform: translateX(-50%);
      width: 800px;
      height: 400px;
      background: radial-gradient(
        ellipse at center top,
        rgba(124, 58, 237, 0.12) 0%,
        transparent 70%
      );
      pointer-events: none;
    }

    &__container {
      position: relative;
      z-index: 1;
      max-width: 80rem;
      margin-inline: auto;
      padding-inline: 2rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 3rem;

      @include max-lg {
        padding-inline: 1.25rem;
      }
    }

    &__header {
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1rem;
      max-width: 700px;
    }

    &__eyebrow {
      font-size: 0.6875rem;
      font-weight: 600;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: #7c3aed;
    }

    &__headline {
      font-size: clamp(1.75rem, 3.5vw, 2.5rem);
      font-weight: 500;
      letter-spacing: -0.025em;
      color: #fafafa;
      margin: 0;
      line-height: 1.15;
    }

    &__subheadline {
      color: #a1a1aa;
      font-size: 1.0625rem;
      line-height: 1.7;
      margin: 0;
      text-align: center;
    }

    &__blocks {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
      width: 100%;

      @include max-lg {
        grid-template-columns: 1fr;
        max-width: 520px;
      }
    }

    &__block {
      background: #18181b;
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 16px;
      padding: 28px;
      display: flex;
      flex-direction: column;
      gap: 1rem;
      transition: border-color 0.2s ease;

      &:hover {
        border-color: rgba(124, 58, 237, 0.25);
      }
    }

    &__block-number {
      font-size: 0.75rem;
      font-weight: 600;
      color: #7c3aed;
      letter-spacing: 0.08em;
    }

    &__block-title {
      font-size: 1.0625rem;
      font-weight: 500;
      color: #fafafa;
      margin: 0;
      line-height: 1.35;
      letter-spacing: -0.01em;
    }

    &__items {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      flex: 1;
    }

    &__item {
      display: flex;
      align-items: flex-start;
      gap: 0.625rem;
    }

    &__check {
      font-size: 0.75rem;
      font-weight: 700;
      color: #7c3aed;
      flex-shrink: 0;
      margin-top: 3px;
    }

    &__item-text {
      font-size: 0.9rem;
      color: #a1a1aa;
      line-height: 1.6;
    }

    &__closing-row {
      max-width: 640px;
      text-align: center;
      padding: 1.5rem 2rem;
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 12px;
      background: rgba(255, 255, 255, 0.02);
    }

    &__closing {
      margin: 0;
      color: #a1a1aa;
      font-size: 0.9375rem;
      line-height: 1.65;
      font-style: italic;
    }

    &__cta-row {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
    }

    &__btn {
      display: inline-flex;
      align-items: center;
      border: 1px solid #7c3aed;
      color: #a78bfa;
      background: transparent;
      border-radius: 999px;
      padding: 14px 28px;
      font-size: 0.9375rem;
      font-weight: 500;
      text-decoration: none;
      letter-spacing: -0.01em;
      transition: all 0.2s ease;

      &:hover {
        background: #7c3aed;
        color: #ffffff;
        box-shadow: 0 0 24px rgba(124, 58, 237, 0.4);
        transform: translateY(-1px);
      }
    }

    &__cta-subline {
      font-size: 0.8125rem;
      color: #52525b;
    }
  }
</style>
