---
import type { LandingContent } from '../../content/index';

interface Props {
  content: LandingContent['why2026'];
}

const { content } = Astro.props;
---

<section class="v1-why" id="why2026">
  <div class="v1-why__container">
    <div class="v1-why__inner">

      <div class="v1-why__label-row">
        <span class="v1-why__eyebrow">{content.eyebrow}</span>
        <div class="v1-why__divider-line" aria-hidden="true"></div>
      </div>

      <h2 class="v1-why__headline">{content.headline}</h2>

      <div class="v1-why__body-block">
        {content.body.map((paragraph) => (
          <p class="v1-why__paragraph">{paragraph}</p>
        ))}
      </div>

      <p class="v1-why__closing">"{content.closing}"</p>

      <!-- Competitor strip -->
      <div class="v1-why__competitor-row">
        <div class="v1-why__competitor v1-why__competitor--out">
          <span class="v1-why__competitor-name">Prism</span>
          <span class="v1-why__competitor-desc">Finds profiles</span>
        </div>
        <div class="v1-why__competitor v1-why__competitor--out">
          <span class="v1-why__competitor-name">Contra</span>
          <span class="v1-why__competitor-desc">Fills contracts</span>
        </div>
        <div class="v1-why__competitor v1-why__competitor--out">
          <span class="v1-why__competitor-name">Metaview</span>
          <span class="v1-why__competitor-desc">Transcribes interviews</span>
        </div>
        <div class="v1-why__competitor v1-why__competitor--us">
          <span class="v1-why__competitor-name">Purrfect Hire</span>
          <span class="v1-why__competitor-desc">Knows who stays</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  @use '../../styles/breakpoints' as *;

  .v1-why {
    background: #09090b;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    padding-block: 6rem;

    @include max-md {
      padding-block: 4rem;
    }

    &__container {
      max-width: 80rem;
      margin-inline: auto;
      padding-inline: 2rem;

      @include max-lg {
        padding-inline: 1.25rem;
      }
    }

    &__inner {
      max-width: 680px;
    }

    &__label-row {
      display: flex;
      align-items: center;
      gap: 1.25rem;
      margin-bottom: 1.5rem;
    }

    &__eyebrow {
      font-size: 0.6875rem;
      font-weight: 600;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: #7c3aed;
      white-space: nowrap;
    }

    &__divider-line {
      flex: 1;
      height: 1px;
      background: linear-gradient(90deg, rgba(124, 58, 237, 0.4) 0%, transparent 100%);
    }

    &__headline {
      font-size: clamp(1.75rem, 3vw, 2.5rem);
      font-weight: 500;
      line-height: 1.2;
      letter-spacing: -0.02em;
      color: #fafafa;
      margin: 0 0 2rem 0;
      max-width: 640px;
    }

    &__body-block {
      border-left: 3px solid #7c3aed;
      padding-left: 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
      margin-bottom: 2.5rem;
    }

    &__paragraph {
      margin: 0;
      color: #a1a1aa;
      font-size: 1.0625rem;
      line-height: 1.7;
    }

    &__closing {
      margin: 0 0 3rem 0;
      font-style: italic;
      color: #fafafa;
      font-size: 1.1rem;
      line-height: 1.6;
    }

    &__competitor-row {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
    }

    &__competitor {
      display: flex;
      flex-direction: column;
      gap: 0.2rem;
      padding: 0.875rem 1.25rem;
      border-radius: 12px;
      border: 1px solid rgba(255, 255, 255, 0.07);
      min-width: 130px;

      &--out {
        background: rgba(255, 255, 255, 0.02);
        opacity: 0.5;
      }

      &--us {
        background: rgba(124, 58, 237, 0.1);
        border-color: rgba(124, 58, 237, 0.3);
        opacity: 1;
      }
    }

    &__competitor-name {
      font-size: 0.875rem;
      font-weight: 500;
      color: #fafafa;

      .v1-why__competitor--out & {
        color: #a1a1aa;
      }
    }

    &__competitor-desc {
      font-size: 0.75rem;
      color: #52525b;

      .v1-why__competitor--us & {
        color: #a78bfa;
      }
    }
  }
</style>
