---
import type { LandingContent } from '../../content/index';

interface Props {
  content: LandingContent['cta'];
}

const { content } = Astro.props;
---

<section class="v1-cta" id="cta">
  <!-- Background orb -->
  <div class="v1-cta__orb" aria-hidden="true"></div>
  <!-- Noise/grain overlay -->
  <div class="v1-cta__grain" aria-hidden="true"></div>

  <div class="v1-cta__container">
    <div class="v1-cta__inner">

      <div class="v1-cta__eyebrow">
        <span class="v1-cta__eyebrow-dot" aria-hidden="true"></span>
        Ready to start
      </div>

      <h2 class="v1-cta__headline">{content.headline}</h2>
      <p class="v1-cta__subheadline">{content.subheadline}</p>

      <div class="v1-cta__buttons">
        <a href={`mailto:${content.contactLine}?subject=I need to hire`} class="v1-cta__btn v1-cta__btn--primary">
          {content.ctaHire}
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <path d="M3.75 9h10.5M9.75 4.5l4.5 4.5-4.5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href={`mailto:${content.contactLine}?subject=I want to get placed`} class="v1-cta__btn v1-cta__btn--secondary">
          {content.ctaTalent}
        </a>
      </div>

      <p class="v1-cta__contact">
        Or reach us directly at{' '}
        <a href={`mailto:${content.contactLine}`} class="v1-cta__contact-email">
          {content.contactLine}
        </a>
      </p>

    </div>
  </div>
</section>

<style lang="scss">
  @use '../../styles/breakpoints' as *;

  .v1-cta {
    position: relative;
    background: linear-gradient(135deg, #1a0a2e 0%, #0f0a1a 50%, #09090b 100%);
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    padding-block: 7rem;
    overflow: hidden;

    @include max-md {
      padding-block: 5rem;
    }

    &__orb {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 700px;
      height: 400px;
      background: radial-gradient(
        ellipse at center,
        rgba(124, 58, 237, 0.2) 0%,
        rgba(76, 29, 149, 0.1) 40%,
        transparent 70%
      );
      pointer-events: none;
    }

    &__grain {
      position: absolute;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
      background-repeat: repeat;
      background-size: 150px 150px;
      pointer-events: none;
      opacity: 0.4;
    }

    &__container {
      position: relative;
      z-index: 1;
      max-width: 80rem;
      margin-inline: auto;
      padding-inline: 2rem;

      @include max-lg {
        padding-inline: 1.25rem;
      }
    }

    &__inner {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 1.75rem;
    }

    &__eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.6875rem;
      font-weight: 600;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: #a78bfa;
    }

    &__eyebrow-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: #7c3aed;
      box-shadow: 0 0 8px rgba(124, 58, 237, 0.7);
    }

    &__headline {
      font-size: clamp(1.75rem, 4vw, 2.75rem);
      font-weight: 500;
      letter-spacing: -0.025em;
      color: #fafafa;
      margin: 0;
      line-height: 1.15;
      max-width: 600px;
    }

    &__subheadline {
      max-width: 480px;
      color: #a1a1aa;
      font-size: 1.0625rem;
      line-height: 1.65;
      margin: 0;
    }

    &__buttons {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      flex-wrap: wrap;
      justify-content: center;
    }

    &__btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      border-radius: 999px;
      font-size: 1rem;
      font-weight: 500;
      text-decoration: none;
      transition: all 0.2s ease;
      letter-spacing: -0.01em;

      &--primary {
        background: #7c3aed;
        color: #ffffff;
        padding: 14px 32px;

        &:hover {
          background: #6d28d9;
          box-shadow: 0 0 40px rgba(124, 58, 237, 0.45);
          transform: translateY(-2px);
        }
      }

      &--secondary {
        background: transparent;
        border: 1px solid rgba(255, 255, 255, 0.15);
        color: #fafafa;
        padding: 14px 32px;

        &:hover {
          border-color: rgba(255, 255, 255, 0.35);
          background: rgba(255, 255, 255, 0.05);
          transform: translateY(-2px);
        }
      }
    }

    &__contact {
      font-size: 0.875rem;
      color: #52525b;
      margin: 0;
    }

    &__contact-email {
      color: #7c3aed;
      text-decoration: none;
      transition: color 0.15s ease;

      &:hover {
        color: #a78bfa;
      }
    }
  }
</style>
