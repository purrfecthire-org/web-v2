---
import type { LandingContent } from '../../content/index';

interface Props {
  content: LandingContent['culture'];
}

const { content } = Astro.props;
---

<section class="v1-culture" id="culture">
  <div class="v1-culture__container">

    <div class="v1-culture__left">
      <h2 class="v1-culture__headline">{content.headline}</h2>
      <div class="v1-culture__body">
        {content.body.map((paragraph) => (
          <p class="v1-culture__paragraph">{paragraph}</p>
        ))}
      </div>

      <div class="v1-culture__stat-block">
        <div class="v1-culture__stat">
          <span class="v1-culture__stat-value">46%</span>
          <span class="v1-culture__stat-label">of new hires fail within 18 months</span>
        </div>
        <div class="v1-culture__stat">
          <span class="v1-culture__stat-value">89%</span>
          <span class="v1-culture__stat-label">of those failures: culture & attitude — not skills</span>
        </div>
      </div>
    </div>

    <div class="v1-culture__right">
      {content.quotes.map((quote) => (
        <div class="v1-culture__quote-card">
          <span class="v1-culture__quote-mark" aria-hidden="true">"</span>
          <blockquote class="v1-culture__quote-text">{quote.text}</blockquote>
          <cite class="v1-culture__quote-attribution">{quote.attribution}</cite>
        </div>
      ))}
    </div>

  </div>
</section>

<style lang="scss">
  @use '../../styles/breakpoints' as *;

  .v1-culture {
    background: #09090b;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    padding-block: 6rem;

    @include max-md {
      padding-block: 4rem;
    }

    &__container {
      max-width: 80rem;
      margin-inline: auto;
      padding-inline: 2rem;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: start;

      @include max-lg {
        grid-template-columns: 1fr;
        gap: 3rem;
        padding-inline: 1.25rem;
      }
    }

    &__left {
      display: flex;
      flex-direction: column;
      gap: 2rem;
    }

    &__headline {
      font-size: clamp(1.5rem, 2.8vw, 2.25rem);
      font-weight: 500;
      letter-spacing: -0.025em;
      color: #fafafa;
      margin: 0;
      line-height: 1.2;
    }

    &__body {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }

    &__paragraph {
      margin: 0;
      color: #a1a1aa;
      font-size: 1.0625rem;
      line-height: 1.7;
    }

    &__stat-block {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
      padding: 1.5rem;
      background: rgba(124, 58, 237, 0.05);
      border: 1px solid rgba(124, 58, 237, 0.15);
      border-radius: 12px;
    }

    &__stat {
      display: flex;
      flex-direction: column;
      gap: 0.2rem;
    }

    &__stat-value {
      font-size: 2rem;
      font-weight: 500;
      letter-spacing: -0.03em;
      color: #a78bfa;
      line-height: 1;
    }

    &__stat-label {
      font-size: 0.875rem;
      color: #a1a1aa;
      line-height: 1.5;
    }

    &__right {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }

    &__quote-card {
      position: relative;
      background: #18181b;
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 16px;
      padding: 32px;
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
      overflow: hidden;
      transition: border-color 0.2s ease;

      &:hover {
        border-color: rgba(124, 58, 237, 0.2);
      }
    }

    &__quote-mark {
      position: absolute;
      top: 12px;
      left: 20px;
      font-size: 5rem;
      line-height: 0.5;
      font-family: Georgia, serif;
      color: rgba(124, 58, 237, 0.3);
      user-select: none;
      pointer-events: none;
    }

    &__quote-text {
      font-style: italic;
      font-size: 1.0625rem;
      color: #fafafa;
      line-height: 1.65;
      margin: 0;
      padding-top: 1.5rem;
    }

    &__quote-attribution {
      font-style: normal;
      font-size: 0.6875rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #7c3aed;
    }
  }
</style>
