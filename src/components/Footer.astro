---
import type { LandingContent } from '../content/index';

interface Props {
  content: LandingContent['footer'];
}

const { content } = Astro.props;
---

<footer class="footer">
  <div class="footer__container">
    <div class="footer__inner">

      <!-- Logo -->
      <a href="/" aria-label="Purrfect Hire home">
        <img src="/logos/logo-desktop.png" class="footer__logo" alt="Purrfect Hire" />
      </a>

      <!-- Links + legal -->
      <div class="footer__links">
        {content.links.map((link, i) => (
          <>
            {i > 0 && <span class="footer__sep" aria-hidden="true">·</span>}
            <a
              href={link.href}
              class="footer__link"
              target={link.href.startsWith('http') ? '_blank' : undefined}
              rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
            >
              {link.label}
            </a>
          </>
        ))}
        <span class="footer__sep" aria-hidden="true">·</span>
        <span class="footer__legal">{content.legal}</span>
      </div>

    </div>
  </div>
</footer>

<style lang="scss">
  .footer {
    background: var(--color-bg);
    border-top: 1px solid var(--color-border);

    &__container {
      max-width: 80rem;
      margin-inline: auto;
      padding: 1.75rem 2rem;
    }

    &__inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1.25rem;
      flex-wrap: wrap;
    }

    &__logo {
      width: 8rem;
    }

    &__links {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.25rem;
    }

    &__link {
      font-size: 0.875rem;
      font-weight: 400;
      color: var(--color-muted);
      text-decoration: none;
      padding: 2px 4px;
      transition: color 0.15s ease;

      &:hover {
        color: var(--color-text);
      }
    }

    &__sep {
      font-size: 0.875rem;
      color: var(--color-border);
      user-select: none;
      pointer-events: none;
    }

    &__legal {
      font-size: 0.875rem;
      color: var(--color-tertiary);
    }
  }
</style>
