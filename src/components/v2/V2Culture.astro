---
import type { LandingContent } from '../../content/index';

interface Props {
  content: LandingContent['culture'];
}

const { content } = Astro.props;

// Extract stats from the body text
const stat1 = '46%';
const stat2 = '89%';
---

<section class="v2-culture" id="culture">
  <div class="v2-culture__container">
    <h2 class="v2-culture__headline">{content.headline}</h2>

    <!-- Stat callout -->
    <div class="v2-culture__stats">
      <div class="v2-culture__stat">
        <div class="v2-culture__stat-value">{stat1}</div>
        <div class="v2-culture__stat-label">of new hires fail within 18 months</div>
      </div>
      <div class="v2-culture__stat-divider" aria-hidden="true"></div>
      <div class="v2-culture__stat">
        <div class="v2-culture__stat-value">{stat2}</div>
        <div class="v2-culture__stat-label">of those failures: culture & attitude mismatch — not skills</div>
      </div>
    </div>

    <!-- Body paragraphs -->
    <div class="v2-culture__body">
      {content.body.map((para) => (
        <p class="v2-culture__para">{para}</p>
      ))}
    </div>

    <!-- Quote cards -->
    <div class="v2-culture__quotes">
      {content.quotes.map((quote) => (
        <div class="v2-culture__quote-card">
          <div class="v2-culture__quote-mark" aria-hidden="true">&ldquo;</div>
          <p class="v2-culture__quote-text">{quote.text}</p>
          <p class="v2-culture__quote-attr">{quote.attribution}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style lang="scss">
  @use '../../styles/breakpoints' as *;

  .v2-culture {
    background: var(--v2-navy);
    padding-block: 100px;

    @include max-md { padding-block: 72px; }
    @include max-sm { padding-block: 56px; }

    &__container {
      max-width: 80rem;
      margin-inline: auto;
      padding-inline: 2rem;

      @include max-lg { padding-inline: 1.5rem; }
      @include max-sm { padding-inline: 1rem; }
    }

    &__headline {
      font-family: 'DM Serif Display', Georgia, serif;
      font-size: clamp(1.875rem, 3.5vw, 2.5rem);
      line-height: 1.2;
      color: #F5F0E8;
      max-width: 680px;
      margin: 0 0 3.5rem;

      @include max-md { margin-bottom: 2.5rem; }
    }

    // ── Stats ────────────────────────────────────────────────
    &__stats {
      display: flex;
      align-items: center;
      gap: 3rem;
      margin-bottom: 3.5rem;
      flex-wrap: wrap;

      @include max-sm { gap: 2rem; margin-bottom: 2.5rem; }
    }

    &__stat {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    &__stat-value {
      font-family: 'DM Serif Display', Georgia, serif;
      font-size: 3.5rem;
      line-height: 1;
      color: var(--v2-accent);

      @include max-sm { font-size: 2.75rem; }
    }

    &__stat-label {
      font-size: 0.875rem;
      line-height: 1.5;
      color: rgba(245, 240, 232, 0.6);
      max-width: 200px;
    }

    &__stat-divider {
      width: 1px;
      height: 64px;
      background: rgba(245, 240, 232, 0.15);
      flex-shrink: 0;

      @include max-sm { display: none; }
    }

    // ── Body ─────────────────────────────────────────────────
    &__body {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
      max-width: 680px;
      margin-bottom: 4rem;

      @include max-md { margin-bottom: 3rem; }
    }

    &__para {
      font-size: 1.0625rem;
      line-height: 1.7;
      color: rgba(245, 240, 232, 0.7);
      margin: 0;
    }

    // ── Quotes ───────────────────────────────────────────────
    &__quotes {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.25rem;

      @include max-md {
        grid-template-columns: 1fr;
      }
    }

    &__quote-card {
      background: rgba(255, 255, 255, 0.06);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 16px;
      padding: 32px;
      display: flex;
      flex-direction: column;
      gap: 1rem;

      @include max-sm { padding: 24px; }
    }

    &__quote-mark {
      color: rgba(194, 65, 12, 0.4);
      font-size: 5rem;
      font-family: Georgia, serif;
      line-height: 0.7;
      user-select: none;
    }

    &__quote-text {
      font-family: 'DM Serif Display', Georgia, serif;
      font-style: italic;
      font-size: 1.125rem;
      line-height: 1.55;
      color: #F5F0E8;
      margin: 0;
      flex: 1;
    }

    &__quote-attr {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--v2-accent);
      margin: 0;
    }
  }
</style>
