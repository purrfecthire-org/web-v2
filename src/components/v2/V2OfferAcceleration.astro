---
import type { LandingContent } from '../../content/index';

interface Props {
  content: LandingContent['offerAcceleration'];
}

const { content } = Astro.props;
---

<section class="v2-offer" id="offer">
  <div class="v2-offer__container">
    <div class="v2-offer__header">
      <p class="v2-offer__eyebrow">{content.eyebrow}</p>
      <h2 class="v2-offer__headline">{content.headline}</h2>
      <p class="v2-offer__subheadline">{content.subheadline}</p>
    </div>

    <div class="v2-offer__blocks">
      {content.blocks.map((block, i) => (
        <div class="v2-offer__block">
          <div class="v2-offer__block-num" aria-hidden="true">0{i + 1}</div>
          <h3 class="v2-offer__block-title">{block.title}</h3>
          <ul class="v2-offer__block-list">
            {block.items.map((item) => (
              <li class="v2-offer__block-item">
                <span class="v2-offer__check" aria-hidden="true">✓</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="v2-offer__footer">
      <p class="v2-offer__closing">{content.closing}</p>
      <a href="#cta" class="v2-offer__cta">{content.cta}</a>
      <p class="v2-offer__cta-subline">{content.ctaSubline}</p>
    </div>
  </div>
</section>

<style lang="scss">
  @use '../../styles/breakpoints' as *;

  .v2-offer {
    background: var(--v2-warm);
    padding-block: 100px;

    @include max-md { padding-block: 72px; }
    @include max-sm { padding-block: 56px; }

    &__container {
      max-width: 80rem;
      margin-inline: auto;
      padding-inline: 2rem;

      @include max-lg { padding-inline: 1.5rem; }
      @include max-sm { padding-inline: 1rem; }
    }

    &__header {
      text-align: center;
      max-width: 680px;
      margin-inline: auto;
      margin-bottom: 4rem;

      @include max-md { margin-bottom: 2.5rem; }
    }

    &__eyebrow {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--v2-accent);
      margin: 0 0 1rem;
    }

    &__headline {
      font-family: 'DM Serif Display', Georgia, serif;
      font-size: clamp(2rem, 3.5vw, 2.75rem);
      line-height: 1.15;
      color: var(--v2-navy);
      margin: 0 0 1.25rem;
    }

    &__subheadline {
      font-size: 1.0625rem;
      line-height: 1.65;
      color: var(--v2-muted);
      margin: 0;
    }

    &__blocks {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
      margin-bottom: 4rem;

      @include max-lg {
        grid-template-columns: 1fr;
        gap: 1.25rem;
      }
    }

    &__block {
      background: var(--v2-surface);
      border: 1.5px solid var(--v2-border);
      border-radius: 16px;
      padding: 32px 28px;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    &__block-num {
      font-family: 'DM Serif Display', Georgia, serif;
      font-size: 2rem;
      color: var(--v2-accent);
      opacity: 0.35;
      line-height: 1;
      user-select: none;
    }

    &__block-title {
      font-family: 'DM Serif Display', Georgia, serif;
      font-size: 1.25rem;
      line-height: 1.25;
      color: var(--v2-navy);
      margin: 0;
    }

    &__block-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      flex: 1;
    }

    &__block-item {
      display: flex;
      align-items: flex-start;
      gap: 0.625rem;
      font-size: 0.9375rem;
      line-height: 1.55;
      color: var(--v2-text);
    }

    &__check {
      color: var(--v2-accent);
      font-weight: 700;
      flex-shrink: 0;
      margin-top: 0.05rem;
    }

    &__footer {
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1.25rem;
    }

    &__closing {
      font-size: 1rem;
      line-height: 1.65;
      color: var(--v2-muted);
      max-width: 640px;
      margin: 0;
      font-style: italic;
    }

    &__cta {
      display: inline-flex;
      align-items: center;
      background: var(--v2-accent);
      color: #fff;
      border-radius: 999px;
      padding: 14px 28px;
      font-size: 0.9375rem;
      font-weight: 500;
      text-decoration: none;
      transition: background 0.2s ease, transform 0.15s ease;

      &:hover {
        background: var(--v2-accent-warm);
        transform: translateY(-1px);
      }
    }

    &__cta-subline {
      font-size: 13px;
      color: var(--v2-subtle);
      margin: 0;
    }
  }
</style>
