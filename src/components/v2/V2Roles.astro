---
import type { LandingContent } from '../../content/index';

interface Props {
  content: LandingContent['roles'];
}

const { content } = Astro.props;
---

<section class="v2-roles" id="roles">
  <div class="v2-roles__container">
    <div class="v2-roles__header">
      <p class="v2-roles__eyebrow">{content.eyebrow}</p>
      <h2 class="v2-roles__headline">{content.headline}</h2>
      <p class="v2-roles__subheadline">{content.subheadline}</p>
      <p class="v2-roles__context">{content.contextLine}</p>
    </div>

    <div class="v2-roles__grid">
      {content.cards.map((card) => (
        <div class="v2-roles__card">
          <p class="v2-roles__card-tag">{card.tag}</p>
          <h3 class="v2-roles__card-title">{card.title}</h3>
          <div class="v2-roles__card-meta">
            <span class="v2-roles__card-stage">{card.stage}</span>
            <span class="v2-roles__card-dot" aria-hidden="true">·</span>
            <span class="v2-roles__card-comp">{card.comp}</span>
          </div>
          <div class="v2-roles__stack">
            {card.stack.map((tech) => (
              <span class="v2-roles__pill">{tech}</span>
            ))}
          </div>
          <a href="#cta" class="v2-roles__cta">{card.cta}</a>
        </div>
      ))}
    </div>

    <div class="v2-roles__footer">
      <p class="v2-roles__closing">{content.closingText}</p>
      <a href={`mailto:${content.closingEmail}`} class="v2-roles__email">{content.closingEmail}</a>
    </div>
  </div>
</section>

<style lang="scss">
  @use '../../styles/breakpoints' as *;

  .v2-roles {
    background: var(--v2-warm);
    padding-block: 100px;

    @include max-md { padding-block: 72px; }
    @include max-sm { padding-block: 56px; }

    &__container {
      max-width: 80rem;
      margin-inline: auto;
      padding-inline: 2rem;

      @include max-lg { padding-inline: 1.5rem; }
      @include max-sm { padding-inline: 1rem; }
    }

    &__header {
      text-align: center;
      max-width: 600px;
      margin-inline: auto;
      margin-bottom: 3.5rem;

      @include max-md { margin-bottom: 2.5rem; }
    }

    &__eyebrow {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--v2-accent);
      margin: 0 0 1rem;
    }

    &__headline {
      font-family: 'DM Serif Display', Georgia, serif;
      font-size: clamp(1.875rem, 3.5vw, 2.5rem);
      line-height: 1.2;
      color: var(--v2-navy);
      margin: 0 0 0.875rem;
    }

    &__subheadline {
      font-size: 1.0625rem;
      color: var(--v2-muted);
      margin: 0 0 0.5rem;
    }

    &__context {
      font-size: 0.875rem;
      color: var(--v2-subtle);
      font-style: italic;
      margin: 0;
    }

    &__grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
      margin-bottom: 3rem;

      @include max-lg { grid-template-columns: 1fr; }
    }

    &__card {
      background: var(--v2-surface);
      border: 1.5px solid var(--v2-border);
      border-radius: 16px;
      padding: 28px;
      display: flex;
      flex-direction: column;
      gap: 0.875rem;
      transition: border-color 0.2s ease, box-shadow 0.2s ease;

      &:hover {
        border-color: var(--v2-border-dark);
        box-shadow: 0 6px 28px rgba(15, 23, 42, 0.08);
      }

      @include max-sm { padding: 20px; }
    }

    &__card-tag {
      font-size: 0.8125rem;
      color: var(--v2-muted);
      margin: 0;
    }

    &__card-title {
      font-family: 'DM Serif Display', Georgia, serif;
      font-size: 1.25rem;
      line-height: 1.2;
      color: var(--v2-navy);
      margin: 0;
    }

    &__card-meta {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      flex-wrap: wrap;
    }

    &__card-stage,
    &__card-comp {
      font-size: 0.875rem;
      color: var(--v2-muted);
    }

    &__card-dot {
      color: var(--v2-border-dark);
      font-size: 0.75rem;
    }

    &__stack {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      flex: 1;
    }

    &__pill {
      background: var(--v2-warm);
      color: var(--v2-muted);
      border: 1px solid var(--v2-border);
      border-radius: 6px;
      padding: 3px 10px;
      font-size: 12px;
      font-weight: 500;
    }

    &__cta {
      display: inline-flex;
      align-items: center;
      color: var(--v2-accent);
      font-size: 0.9375rem;
      font-weight: 500;
      text-decoration: none;
      border-bottom: 1.5px solid currentColor;
      padding-bottom: 1px;
      align-self: flex-start;
      transition: opacity 0.15s ease;

      &:hover { opacity: 0.7; }
    }

    &__footer {
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
    }

    &__closing {
      font-size: 1rem;
      color: var(--v2-muted);
      margin: 0;
    }

    &__email {
      font-size: 1rem;
      font-weight: 500;
      color: var(--v2-accent);
      text-decoration: none;
      border-bottom: 1px solid currentColor;
      padding-bottom: 1px;
      transition: opacity 0.15s ease;

      &:hover { opacity: 0.7; }
    }
  }
</style>
