---
import type { LandingContent } from '../../content/index';

interface Props {
  content: LandingContent['footer'];
}

const { content } = Astro.props;
---

<footer class="v2-footer">
  <div class="v2-footer__container">
    <div class="v2-footer__inner">

      <!-- Logo -->
      <a href="#" class="v2-footer__logo" aria-label="Purrfect Hire">
        <span class="v2-footer__logo-text">Purrfect</span><span class="v2-footer__logo-dot">.</span><span class="v2-footer__logo-rest"> Hire</span>
      </a>

      <!-- Links -->
      <nav class="v2-footer__links" aria-label="Footer navigation">
        {content.links.map((link) => (
          <a href={link.href} class="v2-footer__link" target={link.href.startsWith('http') ? '_blank' : undefined} rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}>
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Legal -->
      <p class="v2-footer__legal">{content.legal}</p>
    </div>
  </div>
</footer>

<style lang="scss">
  @use '../../styles/breakpoints' as *;

  .v2-footer {
    background: var(--v2-bg);
    border-top: 1px solid var(--v2-border);
    padding-block: 2rem;

    &__container {
      max-width: 80rem;
      margin-inline: auto;
      padding-inline: 2rem;

      @include max-sm { padding-inline: 1rem; }
    }

    &__inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1.5rem;
      flex-wrap: wrap;

      @include max-md {
        flex-direction: column;
        align-items: flex-start;
        gap: 1rem;
      }
    }

    &__logo {
      display: flex;
      align-items: baseline;
      text-decoration: none;
      font-size: 1rem;
      font-weight: 700;
      color: var(--v2-navy);
    }

    &__logo-text {
      color: var(--v2-navy);
    }

    &__logo-dot {
      color: var(--v2-accent);
      font-size: 1.125rem;
    }

    &__logo-rest {
      color: var(--v2-navy);
      font-weight: 600;
    }

    &__links {
      display: flex;
      align-items: center;
      gap: 1.5rem;

      @include max-sm {
        gap: 1rem;
        flex-wrap: wrap;
      }
    }

    &__link {
      font-size: 0.875rem;
      color: var(--v2-muted);
      text-decoration: none;
      transition: color 0.15s ease;

      &:hover { color: var(--v2-text); }
    }

    &__legal {
      font-size: 0.8125rem;
      color: var(--v2-subtle);
      margin: 0;
    }
  }
</style>
