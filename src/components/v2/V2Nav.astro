---
import type { LandingContent } from '../../content/index';

interface Props {
  content: LandingContent['nav'];
  lang: string;
}

const { content, lang } = Astro.props;
---

<header id="v2-nav" class="v2-nav">
  <div class="v2-nav__container">
    <nav class="v2-nav__inner">

      <!-- Logo -->
      <a href="#" class="v2-nav__logo" aria-label="Purrfect Hire">
        <span class="v2-nav__logo-text">{content.logo.split(' ')[0]}</span><span class="v2-nav__logo-dot">.</span><span class="v2-nav__logo-text v2-nav__logo-text--rest"> {content.logo.split(' ').slice(1).join(' ')}</span>
      </a>

      <!-- Desktop links -->
      <div class="v2-nav__links">
        {content.links.map((link, i) => (
          <>
            {i > 0 && <span class="v2-nav__sep" aria-hidden="true">·</span>}
            <a href={link.href} class="v2-nav__link">
              {link.label}
            </a>
          </>
        ))}
      </div>

      <!-- Right side -->
      <div class="v2-nav__actions">
        <a href="#cta" class="v2-nav__cta">
          {content.cta}
        </a>
        <button id="v2-mobile-menu-btn" class="v2-nav__hamburger" aria-label="Toggle menu">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path stroke="currentColor" stroke-width="1.5" stroke-linecap="round" d="M3 5h14M3 10h14M3 15h14" />
          </svg>
        </button>
      </div>
    </nav>
  </div>

  <!-- Mobile menu -->
  <div id="v2-mobile-menu" class="v2-nav__mobile-menu">
    <div class="v2-nav__mobile-inner">
      {content.links.map((link) => (
        <a href={link.href} class="v2-nav__link v2-nav__link--mobile">
          {link.label}
        </a>
      ))}
      <a href="#cta" class="v2-nav__cta v2-nav__cta--mobile">
        {content.cta}
      </a>
    </div>
  </div>
</header>

<script>
  const nav = document.getElementById('v2-nav');
  const btn = document.getElementById('v2-mobile-menu-btn');
  const menu = document.getElementById('v2-mobile-menu');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      nav?.classList.add('v2-nav--scrolled');
    } else {
      nav?.classList.remove('v2-nav--scrolled');
    }
  }, { passive: true });

  btn?.addEventListener('click', () => {
    menu?.classList.toggle('v2-nav__mobile-menu--open');
  });
</script>

<style lang="scss">
  @use '../../styles/breakpoints' as *;

  .v2-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background: rgba(253, 250, 246, 0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--v2-border);
    transition: box-shadow 200ms ease;

    &--scrolled {
      box-shadow: 0 1px 16px rgba(15, 23, 42, 0.06);
    }

    &__container {
      max-width: 80rem;
      margin-inline: auto;
      padding-inline: 2rem;
      @include max-lg { padding-inline: 1rem; }
    }

    &__inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 4rem;
    }

    &__logo {
      display: flex;
      align-items: baseline;
      text-decoration: none;
      font-size: 1.0625rem;
      font-weight: 700;
      color: var(--v2-navy);
      letter-spacing: -0.02em;
    }

    &__logo-text {
      color: var(--v2-navy);

      &--rest {
        font-weight: 600;
      }
    }

    &__logo-dot {
      color: var(--v2-accent);
      font-size: 1.25rem;
      line-height: 1;
      margin-left: 1px;
    }

    &__links {
      display: flex;
      align-items: center;
      gap: 0.25rem;
      @include max-lg { display: none; }
    }

    &__sep {
      font-size: 0.9375rem;
      color: var(--v2-border-dark);
      user-select: none;
      pointer-events: none;
    }

    &__link {
      font-size: 0.9375rem;
      font-weight: 400;
      color: var(--v2-muted);
      text-decoration: none;
      padding-inline: 0.75rem;
      transition: color 0.15s ease;

      &:hover { color: var(--v2-text); }

      &--mobile {
        padding-inline: 0;
        padding-block: 0.5rem;
        display: block;
      }
    }

    &__actions {
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    &__cta {
      display: inline-flex;
      align-items: center;
      background: var(--v2-navy);
      color: #ffffff;
      border-radius: 999px;
      padding: 10px 22px;
      font-size: 14px;
      font-weight: 500;
      text-decoration: none;
      transition: background 0.2s ease;

      &:hover {
        background: var(--v2-accent);
      }

      @include max-lg { display: none; }

      &--mobile {
        display: flex;
        justify-content: center;
        margin-top: 0.75rem;
        border-radius: 999px;
      }
    }

    &__hamburger {
      display: none;
      padding: 0.5rem;
      border-radius: 0.5rem;
      color: var(--v2-navy);
      background: none;
      border: none;
      cursor: pointer;

      @include max-lg { display: flex; }
    }

    &__mobile-menu {
      display: none;
      border-bottom: 1px solid var(--v2-border);
      background: #FDFAF6;

      &--open {
        @include max-lg { display: block; }
      }
    }

    &__mobile-inner {
      max-width: 80rem;
      margin-inline: auto;
      padding: 1rem 1.5rem 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }
  }
</style>
