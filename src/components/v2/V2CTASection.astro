---
import type { LandingContent } from '../../content/index';

interface Props {
  content: LandingContent['cta'];
}

const { content } = Astro.props;
---

<section class="v2-cta" id="cta">
  <div class="v2-cta__container">
    <div class="v2-cta__inner">
      <h2 class="v2-cta__headline">{content.headline}</h2>
      <p class="v2-cta__subheadline">{content.subheadline}</p>

      <div class="v2-cta__buttons">
        <a href="mailto:hiring@purrfecthire.com" class="v2-cta__btn-primary">
          {content.ctaHire}
        </a>
        <a href="mailto:hiring@purrfecthire.com" class="v2-cta__btn-secondary">
          {content.ctaTalent}
        </a>
      </div>

      <p class="v2-cta__contact">
        Or reach us directly:
        <a href={`mailto:${content.contactLine}`} class="v2-cta__email">{content.contactLine}</a>
      </p>
    </div>
  </div>
</section>

<style lang="scss">
  @use '../../styles/breakpoints' as *;

  .v2-cta {
    background: var(--v2-navy);
    padding-block: 100px;

    @include max-md { padding-block: 72px; }
    @include max-sm { padding-block: 56px; }

    &__container {
      max-width: 80rem;
      margin-inline: auto;
      padding-inline: 2rem;

      @include max-sm { padding-inline: 1rem; }
    }

    &__inner {
      max-width: 600px;
      margin-inline: auto;
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1.75rem;
    }

    &__headline {
      font-family: 'DM Serif Display', Georgia, serif;
      font-size: clamp(2rem, 4vw, 2.75rem);
      line-height: 1.15;
      color: #F5F0E8;
      margin: 0;
    }

    &__subheadline {
      font-size: 1.0625rem;
      line-height: 1.65;
      color: rgba(245, 240, 232, 0.6);
      margin: 0;
      max-width: 480px;
    }

    &__buttons {
      display: flex;
      align-items: center;
      gap: 1rem;
      flex-wrap: wrap;
      justify-content: center;
    }

    &__btn-primary {
      display: inline-flex;
      align-items: center;
      background: var(--v2-accent);
      color: #fff;
      border-radius: 999px;
      padding: 14px 28px;
      font-size: 0.9375rem;
      font-weight: 500;
      text-decoration: none;
      transition: background 0.2s ease, transform 0.15s ease;

      &:hover {
        background: var(--v2-accent-warm);
        transform: translateY(-1px);
      }
    }

    &__btn-secondary {
      display: inline-flex;
      align-items: center;
      border: 1.5px solid rgba(245, 240, 232, 0.3);
      color: #F5F0E8;
      border-radius: 999px;
      padding: 14px 28px;
      font-size: 0.9375rem;
      font-weight: 500;
      text-decoration: none;
      transition: background 0.2s ease, border-color 0.2s ease;

      &:hover {
        background: rgba(245, 240, 232, 0.08);
        border-color: rgba(245, 240, 232, 0.5);
      }
    }

    &__contact {
      font-size: 0.9375rem;
      color: rgba(245, 240, 232, 0.5);
      margin: 0;
    }

    &__email {
      color: rgba(245, 240, 232, 0.75);
      text-decoration: none;
      border-bottom: 1px solid rgba(245, 240, 232, 0.3);
      padding-bottom: 1px;
      margin-left: 0.375rem;
      transition: color 0.15s ease;

      &:hover {
        color: #F5F0E8;
      }
    }
  }
</style>
