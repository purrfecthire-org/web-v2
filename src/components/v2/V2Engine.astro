---
import type { LandingContent } from '../../content/index';

interface Props {
  content: LandingContent['engine'];
}

const { content } = Astro.props;
---

<section class="v2-engine" id="engine">
  <div class="v2-engine__container">
    <div class="v2-engine__header">
      <p class="v2-engine__eyebrow">{content.eyebrow}</p>
      <h2 class="v2-engine__headline">{content.headline}</h2>
      <p class="v2-engine__subheadline">{content.subheadline}</p>
    </div>

    <div class="v2-engine__grid">
      {content.steps.map((step) => (
        <div class="v2-engine__step">
          <div class="v2-engine__step-num" aria-hidden="true">{step.id}</div>
          <div class="v2-engine__step-body">
            <h3 class="v2-engine__step-title">{step.title}</h3>
            <p class="v2-engine__step-desc">{step.description}</p>
            {step.badge && (
              <span class="v2-engine__step-badge">{step.badge}</span>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style lang="scss">
  @use '../../styles/breakpoints' as *;

  .v2-engine {
    background: var(--v2-bg);
    padding-block: 100px;

    @include max-md { padding-block: 72px; }
    @include max-sm { padding-block: 56px; }

    &__container {
      max-width: 80rem;
      margin-inline: auto;
      padding-inline: 2rem;

      @include max-lg { padding-inline: 1.5rem; }
      @include max-sm { padding-inline: 1rem; }
    }

    &__header {
      text-align: center;
      max-width: 640px;
      margin-inline: auto;
      margin-bottom: 4rem;

      @include max-md { margin-bottom: 2.5rem; }
    }

    &__eyebrow {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--v2-accent);
      margin: 0 0 1rem;
    }

    &__headline {
      font-family: 'DM Serif Display', Georgia, serif;
      font-size: clamp(1.875rem, 3.5vw, 2.5rem);
      line-height: 1.2;
      color: var(--v2-navy);
      margin: 0 0 1rem;
    }

    &__subheadline {
      font-size: 1.0625rem;
      color: var(--v2-muted);
      line-height: 1.6;
      margin: 0;
    }

    &__grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;

      @include max-md {
        grid-template-columns: 1fr;
      }
    }

    &__step {
      display: flex;
      align-items: flex-start;
      gap: 1.25rem;
      padding: 32px;
      background: var(--v2-surface);
      border: 1.5px solid var(--v2-border);
      border-radius: 16px;
      transition: border-color 0.2s ease, box-shadow 0.2s ease;

      &:hover {
        border-color: var(--v2-border-dark);
        box-shadow: 0 4px 24px rgba(15, 23, 42, 0.06);
      }

      @include max-sm { padding: 24px; }
    }

    &__step-num {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: var(--v2-warm);
      border: 1.5px solid var(--v2-border);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'DM Serif Display', Georgia, serif;
      font-size: 1.125rem;
      color: var(--v2-navy);
      flex-shrink: 0;
    }

    &__step-body {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 0.625rem;
    }

    &__step-title {
      font-family: 'DM Serif Display', Georgia, serif;
      font-size: 1.125rem;
      line-height: 1.3;
      color: var(--v2-navy);
      margin: 0;
    }

    &__step-desc {
      font-size: 0.9375rem;
      line-height: 1.6;
      color: var(--v2-muted);
      margin: 0;
    }

    &__step-badge {
      display: inline-flex;
      align-self: flex-start;
      border: 1.5px solid var(--v2-accent);
      color: var(--v2-accent);
      border-radius: 999px;
      padding: 4px 12px;
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.02em;
      margin-top: 0.25rem;
    }
  }
</style>
