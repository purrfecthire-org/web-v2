---
import type { LandingContent } from "../content/index";

interface Props {
  content: LandingContent["cta"];
}

const { content } = Astro.props;
---

<section id="cta" class="cta">
  <div class="cta__container">
    <div class="cta__inner">

      <!-- Headline -->
      <h2 class="cta__headline headline2">
        {content.headline}
      </h2>

      <!-- Subheadline -->
      <p class="cta__subheadline body1">
        {content.subheadline}
      </p>

      <!-- CTAs -->
      <div class="cta__buttons">
        <a href="mailto:hiring@purrfecthire.com" class="btn">
          {content.ctaHire}
        </a>
        <a href="mailto:hiring@purrfecthire.com" class="btn-secondary">
          {content.ctaTalent}
        </a>
      </div>

      <!-- Contact line -->
      <p class="cta__contact caption">
        {content.contactLine}
      </p>

    </div>
  </div>
</section>

<style lang="scss">
  @use '../styles/breakpoints' as *;

  .cta {
    background: var(--color-bg);
    border-top: 1px solid var(--color-border);
    padding-block: 9rem;

    @include max-md { padding-block: 6rem; }

    &__container {
      max-width: 80rem;
      margin-inline: auto;
      padding-inline: 2rem;

      @include max-lg { padding-inline: 1.5rem; }
      @include max-sm { padding-inline: 1rem; }
    }

    &__inner {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 2rem;
      max-width: 36rem;
      margin-inline: auto;
    }

    &__headline {
      color: var(--color-text);
    }

    &__subheadline {
      max-width: 520px;
    }

    &__buttons {
      display: flex;
      align-items: center;
      gap: 1rem;

      @include max-sm {
        flex-direction: column;
        width: 100%;
      }
    }

    &__contact {
      color: var(--color-muted);
    }
  }
</style>
