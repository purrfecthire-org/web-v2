---
import type { LandingContent } from "../content/index";

interface Props {
  content: LandingContent["cta"];
}

const { content } = Astro.props;
---

<section
  id="cta"
  class="py-24 md:py-36"
  style="background: var(--color-bg); border-top: 1px solid var(--color-oat-border);"
>
  <div class="max-w-[1280px] mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col items-center text-center gap-10 max-w-3xl mx-auto">

      <!-- Headline -->
      <h2 class="headline2" style="color: var(--color-text);">
        {content.headline}
        <br />
        <span style="color: var(--color-ube-800);">{content.headlineAccent}</span>
      </h2>

      <!-- Subheadline -->
      <p
        style="font-family: var(--font-primary); font-size: 1.125rem; font-weight: 400; line-height: 1.6; letter-spacing: -0.36px; color: var(--color-muted); font-feature-settings: 'ss03', 'ss10', 'ss11', 'ss12'; max-width: 520px;"
      >
        {content.subheadline}
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row items-center gap-4 w-full sm:w-auto">
        <a
          href="#audience"
          class="btn w-full sm:w-auto justify-center"
          style="padding: 14px 32px; border-radius: 1584px; font-size: 1rem;"
        >
          {content.ctaHire}
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a
          href="#audience"
          class="btn-ghost w-full sm:w-auto justify-center"
          style="padding: 14px 32px; border-radius: 1584px; font-size: 1rem;"
        >
          {content.ctaTalent}
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>

      <!-- Contact emails -->
      <p class="contact-line">
        <span class="contact-label">{content.contactCompaniesLabel}:</span>
        <a
          href={`mailto:${content.contactCompaniesEmail}`}
          class="contact-email"
        >{content.contactCompaniesEmail}</a>
        <span class="contact-sep" aria-hidden="true">·</span>
        <span class="contact-label">{content.contactCandidatesLabel}:</span>
        <a
          href={`mailto:${content.contactCandidatesEmail}`}
          class="contact-email"
        >{content.contactCandidatesEmail}</a>
      </p>

    </div>
  </div>
</section>

<style>
  .contact-line {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 6px;
    font-family: var(--font-primary);
    font-size: 0.875rem;
    font-weight: 400;
    line-height: 1.5;
    color: var(--color-muted);
    font-feature-settings: "ss03", "ss10", "ss11", "ss12";
  }
  .contact-label {
    font-weight: 500;
    color: var(--color-warm-charcoal);
  }
  .contact-email {
    color: var(--color-text);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--color-oat-border);
    transition: text-decoration-color 0.15s ease, color 0.15s ease;
  }
  .contact-email:hover {
    color: var(--color-ube-800);
    text-decoration-color: var(--color-ube-800);
  }
  .contact-sep {
    color: var(--color-oat-border);
  }
</style>
