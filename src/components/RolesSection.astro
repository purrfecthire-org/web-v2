---
const roles = [
  {
    title: "Senior Full-Stack Engineer",
    area: "Engineering",
    modality: "Remote",
    contract: "Full-time",
    salary: "$120k – $160k",
    tags: ["React", "Node.js", "TypeScript", "PostgreSQL"],
  },
  {
    title: "Product Designer",
    area: "Design",
    modality: "Hybrid",
    contract: "Full-time",
    salary: "$90k – $120k",
    tags: ["Figma", "Design Systems", "User Research"],
  },
  {
    title: "Growth Marketing Lead",
    area: "Marketing",
    modality: "Remote",
    contract: "Full-time",
    salary: "$95k – $130k",
    tags: ["SEO", "Paid Ads", "Analytics", "B2B"],
  },
  {
    title: "Backend Engineer",
    area: "Engineering",
    modality: "Remote",
    contract: "Full-time",
    salary: "$110k – $150k",
    tags: ["Python", "AWS", "Microservices"],
  },
  {
    title: "Talent Operations Specialist",
    area: "People",
    modality: "On-site",
    contract: "Full-time",
    salary: "$70k – $90k",
    tags: ["ATS", "Sourcing", "Onboarding"],
  },
  {
    title: "Founding Account Executive",
    area: "Sales",
    modality: "Remote",
    contract: "Full-time",
    salary: "$80k – $110k + commission",
    tags: ["B2B SaaS", "Outbound", "Startups"],
  },
];

const modalityColors: Record<string, string> = {
  Remote:  "roles__modality--matcha",
  Hybrid:  "roles__modality--lemon",
  "On-site": "roles__modality--ube",
};
---

<section id="roles" class="roles">
  <div class="roles__container">

    <!-- Header -->
    <div class="roles__header">
      <span class="roles__eyebrow label-uppercase">Open roles</span>
      <h2 class="roles__headline headline2">
        Find your next <br />
        <span class="roles__headline-accent">great hire</span>
      </h2>
      <p class="roles__subheadline body1">
        Curated roles at high-growth startups — vetted, calibrated, and ready to fill.
      </p>
    </div>

    <!-- Grid -->
    <div class="roles__grid">
      {roles.map((role) => (
        <article class="roles__card">

          <!-- Top: area + modality -->
          <div class="roles__card-meta">
            <span class="roles__area label-uppercase">{role.area}</span>
            <span class={`roles__modality label-uppercase ${modalityColors[role.modality] ?? ''}`}>
              {role.modality}
            </span>
          </div>

          <!-- Title -->
          <h3 class="roles__card-title headline3">{role.title}</h3>

          <!-- Contract + Salary -->
          <div class="roles__card-details">
            <span class="roles__detail body2">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M7 1v6l3.5 2" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                <circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.4"/>
              </svg>
              {role.contract}
            </span>
            <span class="roles__detail body2">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <rect x="1" y="3" width="12" height="9" rx="1.5" stroke="currentColor" stroke-width="1.4"/>
                <path d="M1 6h12" stroke="currentColor" stroke-width="1.4"/>
                <path d="M4 9.5h2M8 9.5h2" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
              </svg>
              {role.salary}
            </span>
          </div>

          <!-- Tags -->
          <div class="roles__tags">
            {role.tags.map((tag) => (
              <span class="roles__tag caption">{tag}</span>
            ))}
          </div>

          <!-- CTA -->
          <a href="#cta" class="btn roles__btn">
            Apply now
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>

        </article>
      ))}
    </div>

    <!-- Footer note -->
    <p class="roles__footer caption">
      Don't see a fit?
      <a href="mailto:talent@purrfecthire.com" class="roles__footer-link">Send us your profile</a>
      — we place proactively.
    </p>

  </div>
</section>

<style lang="scss">
  @use '../styles/breakpoints' as *;

  .roles {
    background: var(--color-bg);
    border-top: 1px solid var(--color-oat-border);
    padding-block: 7rem;

    @include max-md { padding-block: 5rem; }

    // ── Container ──────────────────────────────────────────
    &__container {
      max-width: 80rem;
      margin-inline: auto;
      padding-inline: 2rem;

      @include max-lg { padding-inline: 1.5rem; }
      @include max-sm { padding-inline: 1rem; }
    }

    // ── Header ─────────────────────────────────────────────
    &__header {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 1rem;
      margin-bottom: 3.5rem;
    }

    &__eyebrow {
      color: var(--color-warm-charcoal);
    }

    &__headline {
      color: var(--color-text);
      max-width: 36rem;
    }

    &__headline-accent {
      color: var(--color-primary);
    }

    &__subheadline {
      max-width: 40rem;
    }

    // ── Grid ───────────────────────────────────────────────
    &__grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;

      @include max-lg { grid-template-columns: repeat(2, 1fr); }
      @include max-sm { grid-template-columns: 1fr; }
    }

    // ── Card ───────────────────────────────────────────────
    &__card {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
      padding: 1.75rem;
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: 20px;
      transition: border-color 0.15s ease, box-shadow 0.15s ease;

      &:hover {
        border-color: var(--color-oat-border);
        box-shadow: var(--shadow-base);
      }

      @include max-sm { padding: 1.5rem; }
    }

    // ── Card meta row ───────────────────────────────────────
    &__card-meta {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.5rem;
    }

    &__area {
      color: var(--color-warm-charcoal);
    }

    &__modality {
      padding: 3px 10px;
      border-radius: 999px;

      &--matcha {
        color: var(--color-matcha-800);
        background: rgba(132, 231, 165, 0.15);
        border: 1px solid rgba(132, 231, 165, 0.35);
      }

      &--lemon {
        color: var(--color-lemon-800);
        background: rgba(248, 204, 101, 0.15);
        border: 1px solid rgba(248, 204, 101, 0.35);
      }

      &--ube {
        color: var(--color-ube-800);
        background: rgba(193, 176, 255, 0.15);
        border: 1px solid rgba(193, 176, 255, 0.35);
      }
    }

    // ── Card title ──────────────────────────────────────────
    &__card-title {
    }

    // ── Details row ─────────────────────────────────────────
    &__card-details {
      display: flex;
      flex-direction: column;
      gap: 0.375rem;
    }

    &__detail {
      display: flex;
      align-items: center;
      gap: 0.375rem;

      svg { flex-shrink: 0; }
    }

    // ── Tags ────────────────────────────────────────────────
    &__tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.375rem;
      margin-top: auto; // empuja tags + btn hacia abajo
    }

    &__tag {
      color: var(--color-warm-charcoal);
      background: var(--color-surface-2);
      border: 1px solid var(--color-oat-border);
      border-radius: 6px;
      padding: 3px 8px;
    }

    // ── Card CTA ────────────────────────────────────────────
    &__btn {
      border-radius: 1584px;
      padding: 8px 18px;
      align-self: flex-start;
      margin-top: 0.25rem;
    }

    // ── Footer note ─────────────────────────────────────────
    &__footer {
      text-align: center;
      margin-top: 3rem;
    }

    &__footer-link {
      text-decoration: underline;
      text-underline-offset: 3px;
      text-decoration-color: var(--color-oat-border);
      transition: color 0.15s ease, text-decoration-color 0.15s ease;

      &:hover {
        color: var(--color-ube-800);
        text-decoration-color: var(--color-ube-800);
      }
    }
  }
</style>