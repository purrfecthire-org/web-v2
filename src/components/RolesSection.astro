---
import type { LandingContent } from "../content/index";

interface Props {
  content: LandingContent["roles"];
}

const { content } = Astro.props;
---

<section id="roles" class="roles">
  <div class="roles__container">

    <!-- Header -->
    <div class="roles__header">
      <span class="eyebrow">{content.eyebrow}</span>
      <h2 class="roles__headline headline2">
        {content.headline}
      </h2>
      <p class="roles__subheadline body1">
        {content.subheadline}
      </p>
      <p class="roles__context caption">
        {content.contextLine}
      </p>
    </div>

    <!-- Grid -->
    <div class="roles__grid">
      {content.cards.map((role) => (
        <article class="roles__card">
          <span class="roles__tag eyebrow">{role.tag}</span>
          <h3 class="roles__card-title headline3">{role.title}</h3>
          <p class="roles__stage caption">{role.stage}</p>
          <p class="roles__comp caption">{role.comp}</p>

          <div class="roles__stack">
            {role.stack.map((skill) => (
              <span class="roles__skill">{skill}</span>
            ))}
          </div>

          <a href="#cta" class="btn roles__btn">
            {role.cta}
          </a>
        </article>
      ))}
    </div>

    <!-- Footer -->
    <p class="roles__footer body2">
      {content.closingText} →{' '}
      <a href={`mailto:${content.closingEmail}`} class="roles__footer-link">
        {content.closingEmail}
      </a>
    </p>

  </div>
</section>

<style lang="scss">
  @use '../styles/breakpoints' as *;

  .roles {
    background: var(--color-bg);
    border-top: 1px solid var(--color-border);
    padding-block: 7rem;

    @include max-md { padding-block: 5rem; }

    &__container {
      max-width: 80rem;
      margin-inline: auto;
      padding-inline: 2rem;

      @include max-lg { padding-inline: 1.5rem; }
      @include max-sm { padding-inline: 1rem; }
    }

    &__header {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 0.75rem;
      margin-bottom: 3.5rem;
    }

    &__headline {
      color: var(--color-text);
    }

    &__subheadline {
      max-width: 40rem;
    }

    &__context {
      color: var(--color-muted);
    }

    &__grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;

      @include max-lg { grid-template-columns: repeat(2, 1fr); }
      @include max-sm { grid-template-columns: 1fr; }
    }

    &__card {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      padding: 1.5rem;
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: 12px;

      @include max-sm { padding: 1.25rem; }
    }

    &__tag {
      color: var(--color-tertiary);
    }

    &__card-title {
      color: var(--color-text);
    }

    &__stage {
      color: var(--color-muted);
    }

    &__comp {
      color: var(--color-muted);
    }

    &__stack {
      display: flex;
      flex-wrap: wrap;
      gap: 0.375rem;
      margin-top: auto;
    }

    &__skill {
      font-size: 0.75rem;
      font-weight: 500;
      color: var(--color-muted);
      background: var(--color-bg);
      border: 1px solid var(--color-border);
      border-radius: 6px;
      padding: 2px 8px;
    }

    &__btn {
      align-self: flex-start;
      padding: 8px 18px;
      margin-top: 0.5rem;
    }

    &__footer {
      text-align: center;
      margin-top: 3rem;
      color: var(--color-muted);
    }

    &__footer-link {
      color: var(--color-text);
      text-decoration: underline;
      text-underline-offset: 3px;
      text-decoration-color: var(--color-border);
      transition: color 0.15s ease;

      &:hover {
        color: var(--color-accent);
      }
    }
  }
</style>
