---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import HeroSection from '../../components/HeroSection.astro';
import AudienceSplit from '../../components/AudienceSplit.astro';
import EngineSection from '../../components/EngineSection.astro';
import Footer from '../../components/Footer.astro';
import CompanyCarousel from '../../components/CompanyCarousel.astro';
import CultureSection from '../../components/CultureSection.astro';
import TestimonialsSection from '../../components/TestimonialsSection.astro';
import CTASection from '../../components/CTASection.astro';
import { getContent, type Lang } from '../../content/index';
import RolesSection from '../../components/RolesSection.astro';

const lang = (Astro.currentLocale ?? 'es') as Lang;
const c = getContent(lang);
---

<Layout
  title="Purrfect Hire — El motor de contratación de ciclo cerrado para startups"
  description="Extraemos señales reales de contratación, entrenamos talento contra esas señales y colocamos ingenieros que ya conocen tu stack."
  lang={lang}
>
  <Nav content={c.nav} lang={lang} />
  <main>
    <HeroSection content={c.hero} />
    <CompanyCarousel label="De confianza para los mejores equipos de ingeniería" />
    <AudienceSplit content={c.audienceSplit} />
    <EngineSection content={c.engine} />
    <CultureSection content={c.culture} />
    <RolesSection>
    <TestimonialsSection content={c.testimonials} clientLabel="Cliente" candidateLabel="Candidato" />
    <CTASection content={c.cta} />
  </main>
  <Footer content={c.footer} />
</Layout>
