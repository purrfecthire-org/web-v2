---
import Layout from '../layouts/Layout.astro';
import V2Nav from '../components/v2/V2Nav.astro';
import V2Hero from '../components/v2/V2Hero.astro';
import V2Why2026 from '../components/v2/V2Why2026.astro';
import V2AudienceSplit from '../components/v2/V2AudienceSplit.astro';
import V2OfferAcceleration from '../components/v2/V2OfferAcceleration.astro';
import V2Engine from '../components/v2/V2Engine.astro';
import V2Culture from '../components/v2/V2Culture.astro';
import V2Testimonials from '../components/v2/V2Testimonials.astro';
import V2Roles from '../components/v2/V2Roles.astro';
import V2CTASection from '../components/v2/V2CTASection.astro';
import V2Footer from '../components/v2/V2Footer.astro';
import { getContent } from '../content/index';

const c = getContent('en');
---

<Layout title={c.meta.title} description={c.meta.description} lang="en">
  <style is:global>
    @import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&display=swap');

    /* ── V2 Design Tokens — Linen & Terra ─────────────────── */
    :root {
      --v2-bg:           #FDFAF6;
      --v2-surface:      #FFFFFF;
      --v2-warm:         #F5EFE6;
      --v2-navy:         #0F172A;
      --v2-text:         #1C1917;
      --v2-muted:        #78716C;
      --v2-subtle:       #A8A29E;
      --v2-accent:       #C2410C;
      --v2-accent-light: #FED7AA;
      --v2-accent-warm:  #EA580C;
      --v2-border:       #E7E0D4;
      --v2-border-dark:  #D4C5B0;
    }

    body {
      background-color: #FDFAF6;
      font-family: 'Inter', system-ui, -apple-system, sans-serif;
    }
  </style>

  <V2Nav content={c.nav} lang="en" />
  <main>
    <V2Hero content={c.hero} />
    <V2Why2026 content={c.why2026} />
    <V2AudienceSplit content={c.audienceSplit} />
    <V2OfferAcceleration content={c.offerAcceleration} />
    <V2Engine content={c.engine} />
    <V2Culture content={c.culture} />
    <V2Testimonials content={c.testimonials} />
    <V2Roles content={c.roles} />
    <V2CTASection content={c.cta} />
  </main>
  <V2Footer content={c.footer} />
</Layout>
