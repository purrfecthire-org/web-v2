---
import Layout from '../layouts/Layout.astro';
import V3Nav from '../components/v3/V3Nav.astro';
import V3Hero from '../components/v3/V3Hero.astro';
import V3Why2026 from '../components/v3/V3Why2026.astro';
import V3AudienceSplit from '../components/v3/V3AudienceSplit.astro';
import V3OfferAcceleration from '../components/v3/V3OfferAcceleration.astro';
import V3Engine from '../components/v3/V3Engine.astro';
import V3Culture from '../components/v3/V3Culture.astro';
import V3Testimonials from '../components/v3/V3Testimonials.astro';
import V3Roles from '../components/v3/V3Roles.astro';
import V3CTASection from '../components/v3/V3CTASection.astro';
import V3Footer from '../components/v3/V3Footer.astro';
import { getContent } from '../content/index';

const c = getContent('en');
---

<Layout title={c.meta.title} description={c.meta.description} lang="en">
  <style is:global>
    body {
      background-color: #F8F7FF;
    }
  </style>

  <!-- Fixed background canvas -->
  <div class="v3-canvas" aria-hidden="true">
    <div class="v3-canvas__blob v3-canvas__blob--1"></div>
    <div class="v3-canvas__blob v3-canvas__blob--2"></div>
    <div class="v3-canvas__blob v3-canvas__blob--3"></div>
  </div>

  <V3Nav content={c.nav} lang="en" />

  <main style="position: relative; z-index: 1;">
    <V3Hero content={c.hero} />
    <V3Why2026 content={c.why2026} />
    <V3AudienceSplit content={c.audienceSplit} />
    <V3OfferAcceleration content={c.offerAcceleration} />
    <V3Engine content={c.engine} />
    <V3Culture content={c.culture} />
    <V3Testimonials content={c.testimonials} />
    <V3Roles content={c.roles} />
    <V3CTASection content={c.cta} />
  </main>

  <V3Footer content={c.footer} />
</Layout>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');

  /* Aurora canvas — fixed gradient blobs behind everything */
  .v3-canvas {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .v3-canvas__blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(120px);
  }

  .v3-canvas__blob--1 {
    width: 700px;
    height: 700px;
    top: -200px;
    right: -200px;
    background: radial-gradient(circle, rgba(139, 92, 246, 0.25) 0%, transparent 70%);
    animation: v3-canvas-drift-1 20s ease-in-out infinite alternate;
  }

  .v3-canvas__blob--2 {
    width: 600px;
    height: 600px;
    bottom: 20%;
    left: -200px;
    background: radial-gradient(circle, rgba(20, 184, 166, 0.18) 0%, transparent 70%);
    animation: v3-canvas-drift-2 25s ease-in-out infinite alternate;
  }

  .v3-canvas__blob--3 {
    width: 500px;
    height: 500px;
    top: 50%;
    right: 10%;
    background: radial-gradient(circle, rgba(59, 130, 246, 0.15) 0%, transparent 70%);
    animation: v3-canvas-drift-3 18s ease-in-out infinite alternate;
  }

  @keyframes v3-canvas-drift-1 {
    from { transform: translate(0, 0) scale(1); }
    to   { transform: translate(-60px, 80px) scale(1.1); }
  }

  @keyframes v3-canvas-drift-2 {
    from { transform: translate(0, 0) scale(1); }
    to   { transform: translate(80px, -60px) scale(1.08); }
  }

  @keyframes v3-canvas-drift-3 {
    from { transform: translate(0, 0) scale(1); }
    to   { transform: translate(-40px, 60px) scale(0.92); }
  }

  /* Smooth scroll */
  html {
    scroll-behavior: smooth;
  }
</style>
