---
import Layout from '../layouts/Layout.astro';
import V4Nav from '../components/v4/V4Nav.astro';
import V4Hero from '../components/v4/V4Hero.astro';
import V4Why2026 from '../components/v4/V4Why2026.astro';
import V4AudienceSplit from '../components/v4/V4AudienceSplit.astro';
import V4OfferAcceleration from '../components/v4/V4OfferAcceleration.astro';
import V4Engine from '../components/v4/V4Engine.astro';
import V4Culture from '../components/v4/V4Culture.astro';
import V4Testimonials from '../components/v4/V4Testimonials.astro';
import V4Roles from '../components/v4/V4Roles.astro';
import V4CTASection from '../components/v4/V4CTASection.astro';
import V4Footer from '../components/v4/V4Footer.astro';
import { getContent } from '../content/index';

const c = getContent('en');
---

<Layout title={c.meta.title} description={c.meta.description} lang="en">
  <style is:global>
    body {
      background-color: #F5F3FF;
    }
  </style>

  <!-- Fixed background canvas — brand purple aurora -->
  <div class="v4-canvas" aria-hidden="true">
    <div class="v4-canvas__blob v4-canvas__blob--1"></div>
    <div class="v4-canvas__blob v4-canvas__blob--2"></div>
    <div class="v4-canvas__blob v4-canvas__blob--3"></div>
  </div>

  <V4Nav content={c.nav} lang="en" />

  <main style="position: relative; z-index: 1;">
    <V4Hero content={c.hero} />
    <V4Why2026 content={c.why2026} />
    <V4AudienceSplit content={c.audienceSplit} />
    <V4OfferAcceleration content={c.offerAcceleration} />
    <V4Engine content={c.engine} />
    <V4Culture content={c.culture} />
    <V4Testimonials content={c.testimonials} />
    <V4Roles content={c.roles} />
    <V4CTASection content={c.cta} />
  </main>

  <V4Footer content={c.footer} />
</Layout>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');

  /* Aurora canvas — fixed brand-purple gradient blobs behind everything */
  .v4-canvas {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .v4-canvas__blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(120px);
  }

  .v4-canvas__blob--1 {
    width: 700px;
    height: 700px;
    top: -200px;
    right: -200px;
    background: radial-gradient(circle, rgba(60, 43, 220, 0.26) 0%, transparent 70%);
    animation: v4-canvas-drift-1 20s ease-in-out infinite alternate;
  }

  .v4-canvas__blob--2 {
    width: 600px;
    height: 600px;
    bottom: 20%;
    left: -200px;
    background: radial-gradient(circle, rgba(124, 58, 237, 0.20) 0%, transparent 70%);
    animation: v4-canvas-drift-2 25s ease-in-out infinite alternate;
  }

  .v4-canvas__blob--3 {
    width: 500px;
    height: 500px;
    top: 50%;
    right: 10%;
    background: radial-gradient(circle, rgba(13, 8, 87, 0.12) 0%, transparent 70%);
    animation: v4-canvas-drift-3 18s ease-in-out infinite alternate;
  }

  @keyframes v4-canvas-drift-1 {
    from { transform: translate(0, 0) scale(1); }
    to   { transform: translate(-60px, 80px) scale(1.1); }
  }

  @keyframes v4-canvas-drift-2 {
    from { transform: translate(0, 0) scale(1); }
    to   { transform: translate(80px, -60px) scale(1.08); }
  }

  @keyframes v4-canvas-drift-3 {
    from { transform: translate(0, 0) scale(1); }
    to   { transform: translate(-40px, 60px) scale(0.92); }
  }

  html {
    scroll-behavior: smooth;
  }
</style>
