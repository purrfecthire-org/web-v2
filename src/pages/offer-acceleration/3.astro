---
// ── Offer Acceleration — Design test v3 ──────────────────────────────────
// Direction: frontend-design / editorial. Warm paper canvas, Fraunces
// serif display, asymmetric magazine layout, thin rules, pull quotes.
// Desktop-first (design test). DELETE when a final version is chosen.
import Layout from '../../layouts/Layout.astro';
import { oaContent as c } from '../../content/offerAcceleration';
---

<Layout title={c.meta.title} description={c.meta.description} lang="es" noindex>
  <link
    slot="head"
    href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;1,9..144,300;1,9..144,400&display=swap"
    rel="stylesheet"
  />

  <main class="oa3">

    <!-- Masthead -->
    <header class="oa3-masthead">
      <img src="/logos/logo-desktop.png" alt="Purrfect Hire" class="oa3-masthead__logo" />
      <span class="oa3-masthead__label">Offer Acceleration · Programa 1:1</span>
      <a href={c.apply.url} class="oa3-masthead__cta">
        Aplicar →
      </a>
    </header>

    <!-- ── Hero ─────────────────────────────────────────────────────── -->
    <section class="oa3-hero">
      <div class="oa3-hero__inner">
        <p class="oa3-kicker oa3-fade" style="--d: 0.1s">{c.hero.eyebrow}</p>
        <h1 class="oa3-hero__headline">
          <span class="oa3-fade" style="--d: 0.25s">Tu perfil tiene techo</span>
          <span class="oa3-fade" style="--d: 0.4s">más alto que tu</span>
          <span class="oa3-fade oa3-hero__italic" style="--d: 0.55s">salario actual.</span>
        </h1>
        <div class="oa3-hero__deck oa3-fade" style="--d: 0.75s">
          <p>{c.hero.subhead}</p>
          <a href={c.apply.url} class="oa3-link-btn">
            {c.apply.label} →
          </a>
        </div>
      </div>

      <aside class="oa3-hero__facts oa3-fade" style="--d: 0.9s">
        {c.hero.stats.map((s) => (
          <div class="oa3-hero__fact">
            <span class="oa3-hero__fact-value">{s.value}</span>
            <span class="oa3-hero__fact-label">{s.label}</span>
          </div>
        ))}
      </aside>
    </section>

    <hr class="oa3-rule oa3-rule--heavy" />

    <!-- ── Cost ─────────────────────────────────────────────────────── -->
    <section class="oa3-spread">
      <div class="oa3-spread__label oa3-reveal">
        <span class="oa3-folio">I</span>
        <h2>{c.cost.title}</h2>
      </div>
      <div class="oa3-spread__body oa3-reveal">
        <p class="oa3-lede">{c.cost.body}</p>
        <p class="oa3-cost-line">{c.cost.highlight}</p>
        <p class="oa3-smallcaps">{c.cost.note}</p>
      </div>
      <blockquote class="oa3-pull oa3-reveal">
        “{c.cost.quote}”
      </blockquote>
    </section>

    <hr class="oa3-rule" />

    <!-- ── Cases ────────────────────────────────────────────────────── -->
    <section class="oa3-spread" id="casos">
      <div class="oa3-spread__label oa3-reveal">
        <span class="oa3-folio">II</span>
        <h2>{c.cases.title}</h2>
      </div>
      <div class="oa3-cases">
        {c.cases.items.map((item, i) => (
          <article class={`oa3-case oa3-reveal ${i % 2 === 1 ? 'oa3-case--right' : ''}`}>
            <div class="oa3-case__head">
              <span class="oa3-case__metric">{item.metric}</span>
              <span class="oa3-case__unit">{item.unit}</span>
            </div>
            <h3>{item.role}</h3>
            <p>{item.story}</p>
            <p class="oa3-case__result">{item.result}</p>
          </article>
        ))}
      </div>
    </section>

    <hr class="oa3-rule" />

    <!-- ── Investment ───────────────────────────────────────────────── -->
    <section class="oa3-spread">
      <div class="oa3-spread__label oa3-reveal">
        <span class="oa3-folio">III</span>
        <h2>{c.investment.title}</h2>
      </div>
      <div class="oa3-spread__body oa3-reveal">
        <p class="oa3-price">{c.investment.price}<span class="oa3-price__note"> · pago único</span></p>
        <p class="oa3-lede">{c.investment.priceNote}</p>
      </div>

      <div class="oa3-table-block oa3-reveal">
        <p class="oa3-smallcaps">{c.investment.tableTitle}</p>
        <table class="oa3-table">
          <thead>
            <tr>
              <th>Seniority</th>
              <th>Salario actual</th>
              <th>Salto realista</th>
              <th>Adicional / año</th>
              <th>Recuperas en</th>
            </tr>
          </thead>
          <tbody>
            {c.investment.tiers.map((t) => (
              <tr>
                <td>{t.seniority}</td>
                <td>{t.current}</td>
                <td class="oa3-table__jump">{t.jump}</td>
                <td>{t.annual}</td>
                <td>{t.payback}</td>
              </tr>
            ))}
          </tbody>
        </table>
        <p class="oa3-table__note">{c.investment.tableNote} · {c.investment.payments}</p>
      </div>

      <blockquote class="oa3-pull oa3-reveal">“{c.investment.proof}”</blockquote>
    </section>

    <hr class="oa3-rule" />

    <!-- ── Deliverables ─────────────────────────────────────────────── -->
    <section class="oa3-spread">
      <div class="oa3-spread__label oa3-reveal">
        <span class="oa3-folio">IV</span>
        <h2>{c.deliverables.title}</h2>
        <p class="oa3-spread__note">{c.deliverables.subhead}</p>
      </div>
      <ol class="oa3-index">
        {c.deliverables.items.map((d, i) => (
          <li class="oa3-index__item oa3-reveal">
            <span class="oa3-index__num">{String(i + 1).padStart(2, '0')}</span>
            <div>
              <h3>{d.title}</h3>
              <p>{d.body}</p>
            </div>
          </li>
        ))}
      </ol>
    </section>

    <hr class="oa3-rule" />

    <!-- ── How + Who ────────────────────────────────────────────────── -->
    <section class="oa3-spread">
      <div class="oa3-spread__label oa3-reveal">
        <span class="oa3-folio">V</span>
        <h2>{c.how.title}</h2>
      </div>

      <div class="oa3-how oa3-reveal">
        {c.how.facts.map((f) => (
          <div class="oa3-how__item">
            <span class="oa3-smallcaps">{f.label}</span>
            <span class="oa3-how__value">{f.value}</span>
            <p>{f.detail}</p>
          </div>
        ))}
      </div>

      <blockquote class="oa3-pull oa3-reveal">“{c.how.quote}”</blockquote>

      <div class="oa3-who oa3-reveal">
        <article class="oa3-who__card">
          <h3>{c.who.kate.name}</h3>
          <span class="oa3-smallcaps">{c.who.kate.role}</span>
          <p>{c.who.kate.bio}</p>
          <p class="oa3-who__motto">“{c.who.kate.quote}”</p>
        </article>
        <article class="oa3-who__card">
          <h3>{c.who.team.name}</h3>
          <p>{c.who.team.bio}</p>
        </article>
      </div>
    </section>

    <hr class="oa3-rule" />

    <!-- ── FAQ ──────────────────────────────────────────────────────── -->
    <section class="oa3-spread">
      <div class="oa3-spread__label oa3-reveal">
        <span class="oa3-folio">VI</span>
        <h2>{c.faq.title}</h2>
      </div>
      <div class="oa3-faq oa3-reveal">
        {c.faq.items.map((f) => (
          <details class="oa3-faq__item">
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </section>

    <hr class="oa3-rule oa3-rule--heavy" />

    <!-- ── Colophon / final CTA ─────────────────────────────────────── -->
    <section class="oa3-colophon">
      <h2 class="oa3-colophon__title oa3-reveal">
        La diferencia entre quien cruza y quien se queda<br />
        no es talento. <em>Es velocidad de decisión.</em>
      </h2>
      <div class="oa3-colophon__steps oa3-reveal">
        {c.start.steps.map((s, i) => (
          <div class="oa3-colophon__step">
            <span class="oa3-folio">{i + 1}.</span>
            <div>
              <h3>{s.title}</h3>
              <p>{s.body}</p>
            </div>
          </div>
        ))}
      </div>
      <p class="oa3-smallcaps oa3-reveal">{c.start.note}</p>
      <div class="oa3-colophon__ctas oa3-reveal">
        <a href={c.apply.url} class="oa3-link-btn oa3-link-btn--solid">
          {c.apply.labelFinal}
        </a>
      </div>
      <footer class="oa3-colophon__footer">
        © {new Date().getFullYear()} Purrfect Hire · Offer Acceleration
      </footer>
    </section>
  </main>
</Layout>

<style lang="scss">
  $ease-expo: cubic-bezier(0.16, 1, 0.3, 1);

  .oa3 {
    --oa3-paper: #f6f2ea;
    --oa3-ink: #1c1a17;
    --oa3-muted: #5e5950;
    --oa3-faint: #98917f;
    --oa3-rule: #d8d1c2;
    --oa3-accent: #3c2bdc;

    background: var(--oa3-paper);
    color: var(--oa3-ink);
    font-family: 'Inter', Arial, sans-serif;
    overflow-x: hidden;

    // subtle paper grain
    background-image: radial-gradient(rgba(28, 26, 23, 0.022) 1px, transparent 1px);
    background-size: 4px 4px;

    ::selection {
      background: var(--oa3-accent);
      color: #fff;
    }

    h1, h2, h3 {
      font-family: 'Fraunces', Georgia, serif;
      font-weight: 400;
      margin: 0;
    }
  }

  .oa3-kicker {
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--oa3-accent);
  }

  .oa3-smallcaps {
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--oa3-faint);
  }

  .oa3-folio {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1.125rem;
    font-style: italic;
    color: var(--oa3-accent);
  }

  // ── Masthead ──────────────────────────────────────────────
  .oa3-masthead {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 1.25rem 4vw;
    border-bottom: 1px solid var(--oa3-rule);

    &__logo { width: 9rem; }

    &__label {
      font-size: 0.6875rem;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--oa3-muted);
      text-align: center;
    }

    &__cta {
      justify-self: end;
      font-size: 0.875rem;
      font-weight: 500;
      color: var(--oa3-ink);
      text-decoration: none;
      border-bottom: 1px solid var(--oa3-ink);
      padding-bottom: 2px;
      transition: color 0.2s ease, border-color 0.2s ease;

      &:hover { color: var(--oa3-accent); border-color: var(--oa3-accent); }
    }
  }

  // ── Hero ──────────────────────────────────────────────────
  .oa3-hero {
    display: grid;
    grid-template-columns: 1fr 16rem;
    gap: 5rem;
    padding: 7rem 7vw 6rem;
    align-items: end;

    &__headline {
      font-size: clamp(3.5rem, 7vw, 7rem);
      line-height: 1.02;
      letter-spacing: -0.02em;
      margin-top: 1.75rem;

      span { display: block; }
    }

    &__italic {
      font-style: italic;
      color: var(--oa3-accent);
    }

    &__deck {
      display: flex;
      align-items: baseline;
      gap: 3rem;
      margin-top: 3rem;
      max-width: 44rem;

      p {
        font-size: 1.125rem;
        line-height: 1.65;
        color: var(--oa3-muted);
        margin: 0;
      }
    }

    &__facts {
      display: flex;
      flex-direction: column;
      border-left: 1px solid var(--oa3-rule);
      padding-left: 2rem;
    }

    &__fact {
      padding: 1.125rem 0;
      display: flex;
      flex-direction: column;
      gap: 0.25rem;

      & + & { border-top: 1px solid var(--oa3-rule); }
    }

    &__fact-value {
      font-family: 'Fraunces', Georgia, serif;
      font-size: 2.125rem;
      line-height: 1;
    }

    &__fact-label {
      font-size: 0.8125rem;
      color: var(--oa3-muted);
    }
  }

  .oa3-link-btn {
    flex-shrink: 0;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--oa3-ink);
    text-decoration: none;
    border-bottom: 1px solid var(--oa3-ink);
    padding-bottom: 3px;
    transition: color 0.2s ease, border-color 0.2s ease;

    &:hover { color: var(--oa3-accent); border-color: var(--oa3-accent); }

    &--solid {
      border: 1px solid var(--oa3-ink);
      border-radius: 999px;
      padding: 14px 30px;
      transition: background 0.25s ease, color 0.25s ease, border-color 0.25s ease;

      &:hover {
        background: var(--oa3-accent);
        border-color: var(--oa3-accent);
        color: #fff;
      }
    }
  }

  // ── Rules ─────────────────────────────────────────────────
  .oa3-rule {
    border: none;
    border-top: 1px solid var(--oa3-rule);
    margin: 0 4vw;

    &--heavy { border-top-width: 3px; border-color: var(--oa3-ink); }
  }

  // ── Spreads (sections) ────────────────────────────────────
  .oa3-spread {
    padding: 6rem 7vw;

    &__label {
      display: flex;
      align-items: baseline;
      gap: 1.5rem;
      margin-bottom: 3.5rem;

      h2 {
        font-size: clamp(2rem, 3.4vw, 3rem);
        letter-spacing: -0.01em;
      }
    }

    &__note {
      max-width: 24rem;
      margin-left: auto;
      font-size: 0.9375rem;
      line-height: 1.6;
      color: var(--oa3-muted);
      align-self: center;
    }

    &__body { max-width: 44rem; }
  }

  .oa3-lede {
    font-size: 1.25rem;
    line-height: 1.65;
    color: var(--oa3-muted);
    margin: 0;
  }

  .oa3-cost-line {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(2.25rem, 4.5vw, 4rem);
    font-style: italic;
    line-height: 1.15;
    color: var(--oa3-accent);
    margin: 2.5rem 0 1.5rem;
    max-width: 56rem;
  }

  .oa3-pull {
    margin: 5rem auto 0;
    max-width: 50rem;
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(1.5rem, 2.4vw, 2.125rem);
    font-style: italic;
    line-height: 1.4;
    text-align: center;
    color: var(--oa3-ink);
    position: relative;
    padding-top: 2.5rem;

    &::before {
      content: '';
      position: absolute;
      top: 0;
      left: 50%;
      transform: translateX(-50%);
      width: 3.5rem;
      height: 2px;
      background: var(--oa3-accent);
    }
  }

  // ── Cases ─────────────────────────────────────────────────
  .oa3-cases {
    display: flex;
    flex-direction: column;
    gap: 3.5rem;
  }

  .oa3-case {
    max-width: 38rem;
    border-top: 1px solid var(--oa3-rule);
    padding-top: 1.75rem;

    &--right { align-self: flex-end; }

    &__head {
      display: flex;
      align-items: baseline;
      gap: 1rem;
    }

    &__metric {
      font-family: 'Fraunces', Georgia, serif;
      font-size: 2.75rem;
      line-height: 1;
      color: var(--oa3-accent);
      font-variant-numeric: tabular-nums;
    }

    &__unit {
      font-size: 0.8125rem;
      color: var(--oa3-faint);
      letter-spacing: 0.04em;
    }

    h3 {
      font-size: 1.375rem;
      margin: 1rem 0 0.625rem;
    }

    p {
      font-size: 0.9375rem;
      line-height: 1.7;
      color: var(--oa3-muted);
      margin: 0;
    }

    &__result {
      margin-top: 0.75rem !important;
      font-weight: 500;
      color: var(--oa3-ink) !important;
    }
  }

  // ── Investment ────────────────────────────────────────────
  .oa3-price {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(2.75rem, 5vw, 4.5rem);
    line-height: 1;
    margin: 0 0 1.25rem;

    &__note {
      font-size: 1.25rem;
      font-style: italic;
      color: var(--oa3-faint);
    }
  }

  .oa3-table-block { margin-top: 3.5rem; }

  .oa3-table {
    width: 100%;
    margin-top: 1.25rem;
    border-collapse: collapse;
    font-size: 0.9375rem;

    th {
      font-family: 'Fraunces', Georgia, serif;
      font-weight: 400;
      font-style: italic;
      font-size: 1.0625rem;
      text-align: left;
      color: var(--oa3-ink);
      padding: 0.875rem 1.25rem 0.875rem 0;
      border-bottom: 2px solid var(--oa3-ink);
    }

    td {
      padding: 1.125rem 1.25rem 1.125rem 0;
      border-bottom: 1px solid var(--oa3-rule);
      color: var(--oa3-muted);
      font-variant-numeric: tabular-nums;

      &:first-child {
        font-weight: 500;
        color: var(--oa3-ink);
      }
    }

    &__jump { color: var(--oa3-accent) !important; font-weight: 500; }
  }

  .oa3-table__note {
    margin-top: 1rem;
    font-size: 0.8125rem;
    color: var(--oa3-faint);
  }

  // ── Deliverables index ────────────────────────────────────
  .oa3-index {
    list-style: none;
    margin: 0;
    padding: 0;
    columns: 2;
    column-gap: 5rem;

    &__item {
      display: flex;
      gap: 1.5rem;
      break-inside: avoid;
      padding: 1.75rem 0;
      border-top: 1px solid var(--oa3-rule);

      h3 { font-size: 1.25rem; margin-bottom: 0.5rem; }

      p {
        font-size: 0.9375rem;
        line-height: 1.65;
        color: var(--oa3-muted);
        margin: 0;
      }
    }

    &__num {
      font-family: 'Fraunces', Georgia, serif;
      font-style: italic;
      font-size: 1.125rem;
      color: var(--oa3-accent);
      flex-shrink: 0;
    }
  }

  // ── How / Who ─────────────────────────────────────────────
  .oa3-how {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3rem;

    &__item {
      display: flex;
      flex-direction: column;
      gap: 0.625rem;
      border-top: 1px solid var(--oa3-rule);
      padding-top: 1.25rem;

      p {
        font-size: 0.9375rem;
        line-height: 1.65;
        color: var(--oa3-muted);
        margin: 0;
      }
    }

    &__value {
      font-family: 'Fraunces', Georgia, serif;
      font-size: 1.625rem;
    }
  }

  .oa3-who {
    margin-top: 5rem;
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: 3rem;

    &__card {
      border-top: 2px solid var(--oa3-ink);
      padding-top: 1.5rem;

      h3 { font-size: 1.625rem; margin-bottom: 0.375rem; }

      p {
        margin: 1rem 0 0;
        font-size: 0.9375rem;
        line-height: 1.7;
        color: var(--oa3-muted);
      }
    }

    &__motto {
      font-family: 'Fraunces', Georgia, serif;
      font-style: italic;
      font-size: 1.125rem !important;
      color: var(--oa3-accent) !important;
    }
  }

  // ── FAQ ───────────────────────────────────────────────────
  .oa3-faq {
    max-width: 46rem;

    &__item {
      border-top: 1px solid var(--oa3-rule);

      &:last-child { border-bottom: 1px solid var(--oa3-rule); }

      summary {
        font-family: 'Fraunces', Georgia, serif;
        font-size: 1.1875rem;
        padding: 1.375rem 2.5rem 1.375rem 0;
        cursor: pointer;
        list-style: none;
        position: relative;

        &::-webkit-details-marker { display: none; }

        &::after {
          content: '+';
          position: absolute;
          right: 0.25rem;
          top: 50%;
          transform: translateY(-50%);
          font-family: 'Inter', sans-serif;
          font-weight: 300;
          font-size: 1.375rem;
          color: var(--oa3-accent);
          transition: transform 0.25s $ease-expo;
        }
      }

      &[open] summary::after { transform: translateY(-50%) rotate(45deg); }

      p {
        margin: 0 0 1.5rem;
        font-size: 0.9375rem;
        line-height: 1.7;
        color: var(--oa3-muted);
        max-width: 40rem;
      }
    }
  }

  // ── Colophon ──────────────────────────────────────────────
  .oa3-colophon {
    padding: 7rem 7vw 3rem;
    text-align: center;

    &__title {
      font-size: clamp(2.25rem, 4.2vw, 3.75rem);
      line-height: 1.15;
      letter-spacing: -0.01em;

      em { color: var(--oa3-accent); }
    }

    &__steps {
      display: flex;
      justify-content: center;
      gap: 4rem;
      margin: 4rem 0 2.5rem;
      text-align: left;
    }

    &__step {
      display: flex;
      gap: 1rem;
      max-width: 16rem;

      h3 { font-size: 1.125rem; margin-bottom: 0.375rem; }

      p {
        font-size: 0.875rem;
        color: var(--oa3-muted);
        margin: 0;
        line-height: 1.6;
      }
    }

    &__ctas {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 2.5rem;
      margin-top: 2.5rem;
    }

    &__footer {
      margin-top: 6rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--oa3-rule);
      font-size: 0.8125rem;
      color: var(--oa3-faint);
    }
  }

  // ── Motion ────────────────────────────────────────────────
  .oa3-fade {
    opacity: 0;
    transform: translateY(22px);
    animation: oa3-up 1s $ease-expo var(--d, 0s) forwards;
  }

  .oa3-reveal {
    opacity: 0;
    transform: translateY(26px);
    transition: opacity 0.95s $ease-expo, transform 0.95s $ease-expo;

    &.is-visible {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes oa3-up {
    to { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .oa3-fade { animation: none; opacity: 1; transform: none; }
    .oa3-reveal { transition: none; opacity: 1; transform: none; }
  }
</style>

<script>
  const reveals = document.querySelectorAll('.oa3-reveal');
  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add('is-visible');
          io.unobserve(e.target);
        }
      });
    },
    { threshold: 0.12 }
  );
  reveals.forEach((el) => io.observe(el));
</script>
