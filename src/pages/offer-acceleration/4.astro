---
// ── Offer Acceleration — Design test v4 ──────────────────────────────────
// Direction: ui-ux-pro-max / bento grid. Conversion-focused layout on the
// existing brand design system: cream bg, white 12px-radius cards, pill
// buttons, purple accent. Desktop-first (design test). DELETE when a
// final version is chosen.
import Layout from '../../layouts/Layout.astro';
import { oaContent as c } from '../../content/offerAcceleration';
---

<Layout title={c.meta.title} description={c.meta.description} lang="es" noindex>
  <main class="oa4">

    <header class="oa4-nav">
      <img src="/logos/logo-desktop.png" alt="Purrfect Hire" class="oa4-nav__logo" />
      <nav class="oa4-nav__links">
        <a href="#casos">Casos</a>
        <a href="#inversion">Inversión</a>
        <a href="#entregables">Lo que te llevas</a>
        <a href="#faq">Preguntas</a>
      </nav>
      <a href={c.apply.url} class="btn">{c.apply.label}</a>
    </header>

    <!-- ── Hero bento ───────────────────────────────────────────────── -->
    <section class="oa4-hero">
      <div class="oa4-bento">

        <div class="oa4-tile oa4-tile--headline oa4-pop" style="--d: 0.05s">
          <p class="label-uppercase oa4-tile__eyebrow">{c.hero.eyebrow}</p>
          <h1 class="oa4-hero__headline">
            Tu perfil tiene techo más alto que <em>tu salario actual.</em>
          </h1>
          <p class="oa4-hero__subhead">{c.hero.subhead}</p>
          <div class="oa4-hero__ctas">
            <a href={c.apply.url} class="btn">{c.apply.label}</a>
            <a href="#casos" class="btn-secondary">{c.hero.ctaSecondary}</a>
          </div>
        </div>

        <div class="oa4-tile oa4-tile--accent oa4-pop" style="--d: 0.15s">
          <span class="oa4-tile__big">7/10</span>
          <p>personas cierran en mejores condiciones</p>
        </div>

        <div class="oa4-tile oa4-pop" style="--d: 0.22s">
          <span class="oa4-tile__big oa4-text-accent">1.5–3x</span>
          <p>salto salarial típico del programa</p>
        </div>

        <div class="oa4-tile oa4-pop" style="--d: 0.29s">
          <span class="oa4-tile__big oa4-text-accent">4 meses</span>
          <p>máximo para cerrar tu oferta</p>
        </div>

        <div class="oa4-tile oa4-tile--dark oa4-pop" style="--d: 0.36s">
          <span class="oa4-tile__big">150+</span>
          <p>placements en startups de US, Europa y LATAM — founders de YC, Sequoia y a16z</p>
        </div>

      </div>
    </section>

    <!-- ── Cost ─────────────────────────────────────────────────────── -->
    <section class="oa4-section">
      <div class="oa4-cost oa4-reveal">
        <div class="oa4-cost__text">
          <h2 class="headline2">{c.cost.title}</h2>
          <p class="body1">{c.cost.body}</p>
          <p class="label-uppercase oa4-cost__note">{c.cost.note}</p>
        </div>
        <div class="oa4-cost__math">
          <div class="oa4-cost__row">
            <span>Salto realista</span>
            <strong>+$4,000 / mes</strong>
          </div>
          <div class="oa4-cost__row">
            <span>Decisión postergada</span>
            <strong>3 meses</strong>
          </div>
          <div class="oa4-cost__row oa4-cost__row--total">
            <span>Dinero que no recuperas</span>
            <strong>−$12,000 USD</strong>
          </div>
        </div>
      </div>
      <blockquote class="oa4-quote oa4-reveal">{c.cost.quote}</blockquote>
    </section>

    <!-- ── Cases ────────────────────────────────────────────────────── -->
    <section class="oa4-section" id="casos">
      <h2 class="headline2 oa4-section__title oa4-reveal">{c.cases.title}</h2>
      <div class="oa4-cases">
        {c.cases.items.map((item) => (
          <article class="oa4-card oa4-reveal">
            <div class="oa4-card__metric">{item.metric}</div>
            <div class="oa4-card__unit">{item.unit}</div>
            <h3 class="headline3">{item.role}</h3>
            <p class="body2">{item.story}</p>
            <p class="oa4-card__result">{item.result}</p>
          </article>
        ))}
      </div>
    </section>

    <!-- ── Investment ───────────────────────────────────────────────── -->
    <section class="oa4-section" id="inversion">
      <div class="oa4-invest oa4-reveal">
        <div class="oa4-invest__card">
          <p class="label-uppercase">{c.investment.title}</p>
          <div class="oa4-invest__price">{c.investment.price}</div>
          <p class="body2">{c.investment.priceNote}</p>
          <p class="oa4-invest__payments label-uppercase">{c.investment.payments}</p>
          <a href={c.apply.url} class="btn oa4-invest__cta">
            {c.apply.label}
          </a>
        </div>

        <div class="oa4-invest__table">
          <p class="label-uppercase oa4-invest__table-title">{c.investment.tableTitle}</p>
          <table class="oa4-table">
            <thead>
              <tr>
                <th>Seniority</th>
                <th>Hoy (USD/mes)</th>
                <th>Salto realista</th>
                <th>Adicional / año</th>
                <th>Recuperas en</th>
              </tr>
            </thead>
            <tbody>
              {c.investment.tiers.map((t) => (
                <tr>
                  <td>{t.seniority}</td>
                  <td>{t.current}</td>
                  <td class="oa4-table__jump">{t.jump}</td>
                  <td>{t.annual}</td>
                  <td>{t.payback}</td>
                </tr>
              ))}
            </tbody>
          </table>
          <p class="oa4-table__note body2">{c.investment.tableNote}</p>
        </div>
      </div>
      <blockquote class="oa4-quote oa4-reveal">{c.investment.proof}</blockquote>
    </section>

    <!-- ── Deliverables bento ───────────────────────────────────────── -->
    <section class="oa4-section" id="entregables">
      <div class="oa4-reveal">
        <h2 class="headline2 oa4-section__title">{c.deliverables.title}</h2>
        <p class="subhead subhead-section oa4-section__subhead">{c.deliverables.subhead}</p>
      </div>
      <div class="oa4-deliverables">
        {c.deliverables.items.map((d, i) => (
          <article class={`oa4-card oa4-card--deliverable oa4-reveal ${i === 4 ? 'oa4-card--feature' : ''}`}>
            <span class="oa4-card__num">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="headline3">{d.title}</h3>
            <p class="body2">{d.body}</p>
          </article>
        ))}
      </div>
    </section>

    <!-- ── How ──────────────────────────────────────────────────────── -->
    <section class="oa4-section">
      <h2 class="headline2 oa4-section__title oa4-reveal">{c.how.title}</h2>
      <div class="oa4-how oa4-reveal">
        {c.how.facts.map((f) => (
          <div class="oa4-card oa4-how__fact">
            <p class="label-uppercase">{f.label}</p>
            <div class="oa4-how__value">{f.value}</div>
            <p class="body2">{f.detail}</p>
          </div>
        ))}
      </div>
      <div class="oa4-how__bottom oa4-reveal">
        <div class="oa4-card oa4-how__rhythm">
          <h3 class="headline3">{c.how.rhythm.title}</h3>
          <p class="body2">{c.how.rhythm.body}</p>
        </div>
        <div class="oa4-card oa4-card--accent-soft oa4-how__goal">
          <p>{c.how.quote}</p>
        </div>
      </div>
    </section>

    <!-- ── Who ──────────────────────────────────────────────────────── -->
    <section class="oa4-section">
      <h2 class="headline2 oa4-section__title oa4-reveal">{c.who.title}</h2>
      <div class="oa4-who oa4-reveal">
        <article class="oa4-card">
          <h3 class="headline3">{c.who.kate.name}</h3>
          <p class="label-uppercase oa4-who__role">{c.who.kate.role}</p>
          <p class="body2">{c.who.kate.bio}</p>
          <p class="oa4-who__quote">“{c.who.kate.quote}”</p>
        </article>
        <article class="oa4-card">
          <h3 class="headline3">{c.who.team.name}</h3>
          <p class="body2 oa4-who__bio">{c.who.team.bio}</p>
        </article>
      </div>
    </section>

    <!-- ── FAQ ──────────────────────────────────────────────────────── -->
    <section class="oa4-section oa4-section--narrow" id="faq">
      <h2 class="headline2 oa4-section__title oa4-reveal">{c.faq.title}</h2>
      <div class="oa4-faq oa4-reveal">
        {c.faq.items.map((f) => (
          <details class="oa4-faq__item">
            <summary>{f.q}</summary>
            <p class="body1">{f.a}</p>
          </details>
        ))}
      </div>
    </section>

    <!-- ── Start / final CTA ────────────────────────────────────────── -->
    <section class="oa4-section">
      <div class="oa4-start oa4-reveal">
        <h2 class="headline2">{c.start.title}</h2>
        <p class="subhead">{c.start.note}</p>
        <div class="oa4-start__steps">
          {c.start.steps.map((s, i) => (
            <div class="oa4-start__step">
              <span class="oa4-start__num">{i + 1}</span>
              <h3 class="headline3">{s.title}</h3>
              <p class="body2">{s.body}</p>
            </div>
          ))}
        </div>
        <p class="oa4-start__quote">{c.start.quote}</p>
        <div class="oa4-start__ctas">
          <a href={c.apply.url} class="btn oa4-btn-invert">{c.apply.labelFinal}</a>
        </div>
      </div>
    </section>

    <footer class="oa4-footer">
      <p class="body2">© {new Date().getFullYear()} Purrfect Hire · Offer Acceleration</p>
    </footer>
  </main>
</Layout>

<style lang="scss">
  $ease-expo: cubic-bezier(0.16, 1, 0.3, 1);

  .oa4 {
    background: var(--color-bg);
    overflow-x: hidden;
  }

  .oa4-text-accent { color: var(--color-accent); }

  // ── Nav ───────────────────────────────────────────────────
  .oa4-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding: 0.875rem 2.5rem;
    background: rgba(250, 249, 247, 0.88);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);

    &__logo { width: 10rem; }

    &__links {
      display: flex;
      gap: 2rem;

      a {
        font-size: 0.9375rem;
        font-weight: 500;
        color: var(--color-muted);
        text-decoration: none;
        transition: color 0.15s ease;

        &:hover { color: var(--color-text); }
      }
    }
  }

  // ── Bento hero ────────────────────────────────────────────
  .oa4-hero { padding: 3rem 2.5rem 0; }

  .oa4-bento {
    max-width: 76rem;
    margin-inline: auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: auto auto;
    gap: 1rem;
  }

  .oa4-tile {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    justify-content: flex-end;
    transition: transform 0.35s $ease-expo, box-shadow 0.35s $ease-expo;

    &:hover {
      transform: translateY(-3px);
      box-shadow: 0 14px 36px rgba(15, 15, 15, 0.06);
    }

    p {
      font-size: 0.875rem;
      line-height: 1.5;
      color: var(--color-muted);
      margin: 0;
    }

    &__big {
      font-size: 2.75rem;
      font-weight: 500;
      line-height: 1;
      letter-spacing: -0.5px;
      font-variant-numeric: tabular-nums;
    }

    &__eyebrow { margin-bottom: 0.75rem; }

    &--headline {
      grid-column: span 3;
      grid-row: 1;
      justify-content: center;
      padding: 3.5rem 3.5rem 3rem;
    }

    &--accent {
      grid-column: 4;
      grid-row: 1;
      background: var(--color-accent);
      border-color: var(--color-accent);
      color: #fff;

      p { color: rgba(255, 255, 255, 0.75); }
      .oa4-tile__big { color: #fff; }
    }

    &--dark {
      grid-column: span 2;
      background: #0f0f0f;
      border-color: #0f0f0f;
      flex-direction: row;
      align-items: baseline;
      gap: 1.5rem;

      .oa4-tile__big { color: #fff; flex-shrink: 0; }
      p { color: rgba(255, 255, 255, 0.65); }
    }
  }

  .oa4-hero__headline {
    font-size: 3rem;
    font-weight: 500;
    line-height: 1.08;
    letter-spacing: -0.5px;
    margin: 0;

    em {
      font-style: normal;
      color: var(--color-accent);
    }
  }

  .oa4-hero__subhead {
    font-size: 1.0625rem !important;
    max-width: 36rem;
    margin-top: 1rem !important;
  }

  .oa4-hero__ctas {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
  }

  // ── Sections ──────────────────────────────────────────────
  .oa4-section {
    max-width: 76rem;
    margin-inline: auto;
    padding: 5.5rem 2.5rem 0;

    &--narrow { max-width: 52rem; }

    &__title {
      text-align: center;
      margin-bottom: 1rem;
    }

    &__subhead {
      text-align: center;
      margin-bottom: 2.5rem;
    }
  }

  // ── Cost ──────────────────────────────────────────────────
  .oa4-cost {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 1rem;
    align-items: stretch;

    &__text {
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: 12px;
      padding: 2.5rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    &__note { margin-top: auto; }

    &__math {
      background: #0f0f0f;
      border-radius: 12px;
      padding: 2.5rem;
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 1.25rem;
    }

    &__row {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      padding-bottom: 1.25rem;
      border-bottom: 1px solid rgba(255, 255, 255, 0.12);

      span { font-size: 0.875rem; color: rgba(255, 255, 255, 0.6); }

      strong {
        font-size: 1.25rem;
        font-weight: 500;
        color: #fff;
        font-variant-numeric: tabular-nums;
      }

      &--total {
        border-bottom: none;
        padding-bottom: 0;

        strong {
          font-size: 2rem;
          color: #ff8d7a;
        }
      }
    }
  }

  .oa4-quote {
    max-width: 44rem;
    margin: 3rem auto 0;
    padding: 1.75rem 2rem;
    background: var(--color-accent-light);
    border-radius: 12px;
    font-size: 1.125rem;
    line-height: 1.55;
    font-weight: 500;
    color: var(--color-text);
    text-align: center;
  }

  // ── Cards ─────────────────────────────────────────────────
  .oa4-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: transform 0.35s $ease-expo, box-shadow 0.35s $ease-expo;

    &:hover {
      transform: translateY(-3px);
      box-shadow: 0 14px 36px rgba(15, 15, 15, 0.06);
    }

    &__metric {
      font-size: 2rem;
      font-weight: 500;
      line-height: 1;
      color: var(--color-accent);
      font-variant-numeric: tabular-nums;
    }

    &__unit { font-size: 0.8125rem; color: var(--color-tertiary); }

    &__result {
      margin-top: auto;
      font-size: 0.9375rem;
      font-weight: 500;
      color: var(--color-text);
    }

    &__num {
      font-size: 0.8125rem;
      font-weight: 500;
      letter-spacing: 0.06em;
      color: var(--color-accent);
    }

    &--accent-soft {
      background: var(--color-accent-light);
      border-color: transparent;
      justify-content: center;

      p {
        font-size: 1.25rem;
        font-weight: 500;
        line-height: 1.45;
        color: var(--color-navy);
        margin: 0;
      }
    }

    &--feature {
      background: var(--color-accent);
      border-color: var(--color-accent);

      .oa4-card__num { color: rgba(255, 255, 255, 0.7); }
      h3 { color: #fff; }
      p { color: rgba(255, 255, 255, 0.8); }
    }
  }

  .oa4-cases {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .oa4-deliverables {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;

    .oa4-card--feature { grid-column: span 2; }
  }

  // ── Investment ────────────────────────────────────────────
  .oa4-invest {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 1rem;
    align-items: stretch;

    &__card {
      background: #0f0f0f;
      border-radius: 12px;
      padding: 2.5rem;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;

      .label-uppercase { color: rgba(255, 255, 255, 0.5); }

      :global(p.body2) { color: rgba(255, 255, 255, 0.65); }
    }

    &__price {
      font-size: 2.5rem;
      font-weight: 500;
      letter-spacing: -0.5px;
      color: #fff;
      line-height: 1.1;
    }

    &__payments {
      margin-top: auto;
      color: rgba(255, 255, 255, 0.5) !important;
    }

    &__cta {
      margin-top: 1rem;
      background-color: var(--color-accent) !important;
      justify-content: center;

      &:hover { background-color: #5847e8 !important; }
    }

    &__table {
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: 12px;
      padding: 2.5rem;
    }

    &__table-title { margin-bottom: 1.25rem; }
  }

  .oa4-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9375rem;

    th {
      text-align: left;
      font-size: 0.6875rem;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--color-tertiary);
      padding: 0.75rem 1rem 0.75rem 0;
      border-bottom: 1px solid var(--color-border);
    }

    td {
      padding: 1rem 1rem 1rem 0;
      border-bottom: 1px solid var(--color-border);
      color: var(--color-muted);
      font-variant-numeric: tabular-nums;

      &:first-child {
        font-weight: 500;
        color: var(--color-text);
      }
    }

    tr:last-child td { border-bottom: none; }

    &__jump { color: var(--color-accent) !important; font-weight: 500; }
  }

  .oa4-table__note {
    margin-top: 1rem;
    color: var(--color-tertiary);
  }

  // ── How ───────────────────────────────────────────────────
  .oa4-how {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;

    &__value {
      font-size: 1.5rem;
      font-weight: 500;
      color: var(--color-text);
    }

    &__bottom {
      display: grid;
      grid-template-columns: 3fr 2fr;
      gap: 1rem;
      margin-top: 1rem;
    }
  }

  // ── Who ───────────────────────────────────────────────────
  .oa4-who {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: 1rem;

    &__role { margin-bottom: 0.25rem; }

    &__quote {
      margin-top: auto;
      font-size: 1.0625rem;
      font-weight: 500;
      color: var(--color-accent);
    }

    &__bio { margin-top: 0.25rem; }
  }

  // ── FAQ ───────────────────────────────────────────────────
  .oa4-faq__item {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 0 1.75rem;
    margin-bottom: 0.75rem;
    transition: border-color 0.2s ease;

    &[open] { border-color: var(--color-accent); }

    summary {
      padding: 1.25rem 2rem 1.25rem 0;
      font-size: 1rem;
      font-weight: 500;
      color: var(--color-text);
      cursor: pointer;
      list-style: none;
      position: relative;

      &::-webkit-details-marker { display: none; }

      &::after {
        content: '+';
        position: absolute;
        right: 0;
        top: 50%;
        transform: translateY(-50%);
        font-size: 1.25rem;
        font-weight: 300;
        color: var(--color-accent);
        transition: transform 0.25s $ease-expo;
      }
    }

    &[open] summary::after { transform: translateY(-50%) rotate(45deg); }

    p { padding-bottom: 1.5rem; margin: 0; }
  }

  // ── Start ─────────────────────────────────────────────────
  .oa4-start {
    background: #0f0f0f;
    border-radius: 12px;
    padding: 4.5rem 4rem;
    text-align: center;

    .headline2 { color: #fff; }
    .subhead { margin-top: 0.75rem; color: rgba(255, 255, 255, 0.55); }

    &__steps {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
      margin: 3rem 0;
    }

    &__step {
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 12px;
      padding: 2rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.625rem;

      .headline3 { color: #fff; }
      .body2 { color: rgba(255, 255, 255, 0.6); }
    }

    &__num {
      width: 2.25rem;
      height: 2.25rem;
      display: grid;
      place-items: center;
      border-radius: 999px;
      background: var(--color-accent);
      color: #fff;
      font-weight: 500;
      margin-bottom: 0.5rem;
    }

    &__quote {
      max-width: 34rem;
      margin: 0 auto 2.5rem;
      font-size: 1.125rem;
      font-weight: 500;
      line-height: 1.5;
      color: rgba(255, 255, 255, 0.85);
    }

    &__ctas {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 2rem;
    }

    &__email {
      font-size: 0.9375rem;
      font-weight: 500;
      color: rgba(255, 255, 255, 0.7);
      text-decoration: none;
      border-bottom: 1px solid rgba(255, 255, 255, 0.3);
      padding-bottom: 2px;
      transition: color 0.2s ease, border-color 0.2s ease;

      &:hover { color: #fff; border-color: #fff; }
    }
  }

  .oa4-btn-invert {
    background-color: var(--color-accent) !important;

    &:hover { background-color: #5847e8 !important; }
  }

  .oa4-footer {
    padding: 3rem 2.5rem;
    text-align: center;
  }

  // ── Motion ────────────────────────────────────────────────
  .oa4-pop {
    opacity: 0;
    transform: translateY(18px) scale(0.985);
    animation: oa4-pop 0.8s $ease-expo var(--d, 0s) forwards;
  }

  .oa4-reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.85s $ease-expo, transform 0.85s $ease-expo;

    &.is-visible {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes oa4-pop {
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  @media (prefers-reduced-motion: reduce) {
    .oa4-pop { animation: none; opacity: 1; transform: none; }
    .oa4-reveal { transition: none; opacity: 1; transform: none; }
  }
</style>

<script>
  const reveals = document.querySelectorAll('.oa4-reveal');
  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add('is-visible');
          io.unobserve(e.target);
        }
      });
    },
    { threshold: 0.12 }
  );
  reveals.forEach((el) => io.observe(el));
</script>
