---
// ── Offer Acceleration — application form ────────────────────────────────
// Multi-step application: contact info → situación → perfil → salario →
// visión. On submit, a 5–8s two-phase loading overlay runs while the
// application POSTs to {PUBLIC_API_ENDPOINT}/public/oa/applications; the
// result card branches on the backend's data.status (accepted / rejected /
// pending). When PUBLIC_API_ENDPOINT is unset (the default until the ATS
// backend is publicly deployed) the form stays fully client-side with the
// original salary branch and makes zero network calls.
//
// Loading overlay design: 8 selectable variants via ?loader=1..8 (default 1).
// Preview gallery: /oa/loading-designs.
import Layout from '../../layouts/Layout.astro';
import OALoader from '../../components/oa/OALoader.astro';
import { oaContent as c } from '../../content/offerAcceleration';

const f = c.form;
const TOTAL = f.steps.length;

// This page ships Kate's Spanish copy and passes lang="es" to Layout; the
// submission locale mirrors that. (New copy in offerAcceleration.ts is
// EN + ES, keyed by lang, ready for a future EN route.)
const PAGE_LANG = 'es' as const;
const loading = f.loading[PAGE_LANG];
const pending = f.pending[PAGE_LANG];
const errorCopy = f.error[PAGE_LANG];

// Config handed to the client script (replaces the old define:vars pattern —
// the script is now a processed module so it can import the shared loader
// controller and read import.meta.env.PUBLIC_*).
const clientConfig = {
  stepTitles: f.steps.map((s) => s.title),
  errors: f.errors,
  submitLabel: f.submit,
  nextLabel: f.next,
  locale: PAGE_LANG,
};
---

<Layout title={`${f.title} · Purrfect Hire`} description={c.meta.description} lang="es" noindex>
  <main class="apl">
    <div class="apl-glow" aria-hidden="true"></div>

    <header class="apl-header">
      <a href="/offer-acceleration"><img src="/logos/logo-desktop.png" alt="Purrfect Hire" class="apl-header__logo" /></a>
    </header>

    <!-- ── Form card ────────────────────────────────────────────────── -->
    <section class="apl-card" id="apl-card">
      <div class="apl-intro">
        <p class="label-uppercase">{c.hero.eyebrow}</p>
        <h1 class="apl-title">{f.title}</h1>
        <p class="apl-subtitle">{f.subtitle}</p>
      </div>

      <!-- Progress -->
      <div class="apl-progress" aria-hidden="false">
        <div class="apl-progress__meta">
          <span class="apl-progress__step">
            {f.stepLabel} <span id="apl-step-now">1</span> {f.of} {TOTAL}
          </span>
          <span class="apl-progress__name" id="apl-step-name">{f.steps[0].title}</span>
        </div>
        <div class="apl-progress__track">
          <div class="apl-progress__fill" id="apl-progress-fill" style={`width: ${100 / TOTAL}%`}></div>
        </div>
      </div>

      <form id="apl-form" novalidate>

        <!-- Step 1 — Sobre ti -->
        <fieldset class="apl-step is-active" data-step="0">
          <p class="apl-step__desc">{f.steps[0].desc}</p>

          <div class="apl-grid">
            <div class="apl-field">
              <label for="apl-name">{f.fields.name.label} *</label>
              <input type="text" id="apl-name" name="name" placeholder={f.fields.name.placeholder} autocomplete="name" required />
              <span class="apl-error"></span>
            </div>
            <div class="apl-field">
              <label for="apl-email">{f.fields.email.label} *</label>
              <input type="email" id="apl-email" name="email" placeholder={f.fields.email.placeholder} autocomplete="email" required />
              <span class="apl-error"></span>
            </div>
            <div class="apl-field">
              <label for="apl-phone">{f.fields.phone.label} *</label>
              <input type="tel" id="apl-phone" name="phone" placeholder={f.fields.phone.placeholder} autocomplete="tel" required />
              <span class="apl-error"></span>
            </div>
            <div class="apl-field">
              <label for="apl-linkedin">{f.fields.linkedin.label} *</label>
              <input type="text" id="apl-linkedin" name="linkedin" placeholder={f.fields.linkedin.placeholder} required />
              <span class="apl-error"></span>
            </div>
          </div>
        </fieldset>

        <!-- Step 2 — Tu situación -->
        <fieldset class="apl-step" data-step="1">
          <p class="apl-step__desc">{f.steps[1].desc}</p>
          <div class="apl-field">
            <label for="apl-blockers">{f.fields.blockers.label} *</label>
            <textarea id="apl-blockers" name="blockers" rows="6" placeholder={f.fields.blockers.placeholder} data-min="10" data-max="600" required></textarea>
            <div class="apl-field__foot">
              <span class="apl-error"></span>
              <span class="apl-hint" data-count-for="apl-blockers">{f.minCharsHint}</span>
            </div>
          </div>
        </fieldset>

        <!-- Step 3 — Tu perfil -->
        <fieldset class="apl-step" data-step="2">
          <p class="apl-step__desc">{f.steps[2].desc}</p>
          <div class="apl-grid">
            <div class="apl-field">
              <label for="apl-role">{f.fields.role.label} *</label>
              <input type="text" id="apl-role" name="role" placeholder={f.fields.role.placeholder} required />
              <span class="apl-error"></span>
            </div>
            <div class="apl-field">
              <label for="apl-english">{f.fields.english.label} *</label>
              <select id="apl-english" name="english" required>
                <option value="" disabled selected>{f.fields.english.placeholder}</option>
                {f.fields.english.options.map((o) => <option value={o}>{o}</option>)}
              </select>
              <span class="apl-error"></span>
            </div>
          </div>
        </fieldset>

        <!-- Step 4 — Tu salario -->
        <fieldset class="apl-step" data-step="3">
          <p class="apl-step__desc">{f.steps[3].desc}</p>
          <div class="apl-grid">
            <div class="apl-field">
              <label for="apl-salary-now">{f.fields.currentSalary.label} *</label>
              <div class="apl-money">
                <span>$</span>
                <input type="number" id="apl-salary-now" name="currentSalary" min="0" step="50" placeholder={f.fields.currentSalary.placeholder} inputmode="numeric" required />
                <span class="apl-money__unit">USD/mes</span>
              </div>
              <span class="apl-error"></span>
            </div>
            <div class="apl-field">
              <label for="apl-salary-want">{f.fields.expectedSalary.label} *</label>
              <div class="apl-money">
                <span>$</span>
                <input type="number" id="apl-salary-want" name="expectedSalary" min="0" step="50" placeholder={f.fields.expectedSalary.placeholder} inputmode="numeric" required />
                <span class="apl-money__unit">USD/mes</span>
              </div>
              <span class="apl-error"></span>
            </div>
          </div>
        </fieldset>

        <!-- Step 5 — Tu visión -->
        <fieldset class="apl-step" data-step="4">
          <p class="apl-step__desc">{f.steps[4].desc}</p>
          <div class="apl-field">
            <label for="apl-vision">{f.fields.vision.label} *</label>
            <textarea id="apl-vision" name="vision" rows="7" placeholder={f.fields.vision.placeholder} data-min="10" data-max="600" required></textarea>
            <div class="apl-field__foot">
              <span class="apl-error"></span>
              <span class="apl-hint" data-count-for="apl-vision">{f.minCharsHint}</span>
            </div>
          </div>
        </fieldset>

        <!-- Honeypot — visually hidden (off-screen, NOT display:none so bots
             still fill it). Humans never see or tab into it; its value is
             sent as `website` and must arrive empty. -->
        <div class="apl-hp" aria-hidden="true">
          <label for="apl-website">Website</label>
          <input type="text" id="apl-website" name="website" tabindex="-1" autocomplete="off" />
        </div>

        <!-- Controls -->
        <div class="apl-controls">
          <button type="button" class="apl-back" id="apl-back" disabled>{f.back}</button>
          <button type="button" class="btn apl-next" id="apl-next">{f.next}</button>
        </div>
      </form>
    </section>

    <!-- ── Loading overlay (2 phases · 8 designs, ?loader=1..8) ─────── -->
    <div class="apl-analyzing" id="apl-analyzing" aria-hidden="true">
      {[1, 2, 3, 4, 5, 6, 7, 8].map((n) => (
        <OALoader variant={n} phrases={loading} />
      ))}
    </div>

    <!-- ── Result: accepted ─────────────────────────────────────────── -->
    <section class="apl-result" id="apl-accepted" hidden>
      <p class="label-uppercase apl-result__eyebrow">{f.accepted.eyebrow}</p>
      <h2 class="apl-result__title">{f.accepted.title}</h2>
      <p class="apl-result__body">{f.accepted.body}</p>

      <div class="apl-person-card">
        <div class="apl-person-card__avatar" aria-hidden="true">PH</div>
        <div class="apl-person-card__info">
          <strong>{f.accepted.calendlyName}</strong>
          <span>{f.accepted.calendlyRole}</span>
        </div>
        <a href={c.contact.calendly} class="btn apl-person-card__cta" target="_blank" rel="noopener">
          {f.accepted.calendlyCta}
        </a>
      </div>
      <!-- Payment link intentionally removed: the payment flow is never
           surfaced from the application funnel (business decision). -->
    </section>

    <!-- ── Result: pending (backend is reviewing) ───────────────────── -->
    <section class="apl-result" id="apl-pending" hidden>
      <p class="label-uppercase apl-result__eyebrow">{pending.eyebrow}</p>
      <h2 class="apl-result__title">{pending.title}</h2>
      <p class="apl-result__body">{pending.body}</p>
    </section>

    <!-- ── Error: submission failed (network / HTTP) ────────────────── -->
    <section class="apl-result" id="apl-error-card" hidden>
      <p class="label-uppercase apl-result__eyebrow">{errorCopy.eyebrow}</p>
      <h2 class="apl-result__title">{errorCopy.title}</h2>
      <p class="apl-result__body">{errorCopy.body}</p>
      <button type="button" class="btn" id="apl-retry">{errorCopy.retry}</button>
    </section>

    <!-- ── Result: not a fit ────────────────────────────────────────── -->
    <section class="apl-result" id="apl-rejected" hidden>
      <p class="label-uppercase apl-result__eyebrow">{f.rejected.eyebrow}</p>
      <h2 class="apl-result__title">{f.rejected.title}</h2>
      <p class="apl-result__body">{f.rejected.body}</p>

      <div class="apl-person-card">
        <div class="apl-person-card__avatar" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
            <polyline points="15 3 21 3 21 9"></polyline>
            <line x1="10" y1="14" x2="21" y2="3"></line>
          </svg>
        </div>
        <div class="apl-person-card__info">
          <strong>{f.rejected.linkedinName}</strong>
          <span>{f.rejected.linkedinRole}</span>
        </div>
        <a href={c.contact.kateLinkedIn} class="btn apl-person-card__cta" target="_blank" rel="noopener">
          {f.rejected.linkedinCta}
        </a>
      </div>
    </section>

  </main>
</Layout>

<script type="application/json" id="apl-config" set:html={JSON.stringify(clientConfig)} />

<script>
  import { createOALoader, pickTimings } from '../../scripts/oaLoader';

  const cfg = JSON.parse(document.getElementById('apl-config')!.textContent!) as {
    stepTitles: string[];
    errors: { required: string; email: string; minChars: string; maxChars: string; number: string };
    submitLabel: string;
    nextLabel: string;
    locale: 'en' | 'es';
  };
  const { stepTitles, errors, submitLabel, nextLabel } = cfg;
  const TOTAL = stepTitles.length;

  // Backend base URLs — PUBLIC_* vars are inlined at build time. Unset/empty
  // means "no backend": the site stays fully static with zero network calls.
  const API_ENDPOINT = String(import.meta.env.PUBLIC_API_ENDPOINT ?? '').replace(/\/+$/, '');
  const LOG_ENDPOINT = String(import.meta.env.PUBLIC_LOG_ENDPOINT ?? '').replace(/\/+$/, '');

  // FALLBACK ONLY — the pre-existing client-side branch, kept solely so the
  // site still works with no backend configured. This constant dies once the
  // ATS backend is live; the real submission path never reads it.
  const FALLBACK_SALARY_THRESHOLD = 3000;

  // First render of step 1 → fill_time_ms in the submission payload.
  const renderStart = Date.now();

  const card = document.getElementById('apl-card')!;
  const steps = [...document.querySelectorAll('.apl-step')] as HTMLElement[];
  const backBtn = document.getElementById('apl-back') as HTMLButtonElement;
  const nextBtn = document.getElementById('apl-next') as HTMLButtonElement;
  const fill = document.getElementById('apl-progress-fill')!;
  const stepNow = document.getElementById('apl-step-now')!;
  const stepName = document.getElementById('apl-step-name')!;
  const analyzing = document.getElementById('apl-analyzing')!;

  // ── Loading overlay: pick 1 of the 8 designs via ?loader=1..8 ─────────
  const requested = parseInt(new URLSearchParams(location.search).get('loader') ?? '1', 10);
  const variant = requested >= 1 && requested <= 8 ? requested : 1;
  const loaderRoot = analyzing.querySelector<HTMLElement>(`.oal[data-variant="${variant}"]`)!;
  loaderRoot.hidden = false;
  const loader = createOALoader(loaderRoot);

  let current = 0;

  function setError(field: HTMLElement, msg: string) {
    const wrap = field.closest('.apl-field');
    if (!wrap) return; // honeypot lives outside .apl-field on purpose
    wrap.querySelector('.apl-error')!.textContent = msg || '';
    field.classList.toggle('is-invalid', !!msg);
  }

  function validateField(el) {
    const v = el.value.trim();
    if (!v) return errors.required;
    if (el.type === 'email' && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v)) return errors.email;
    if (el.type === 'number' && (isNaN(parseFloat(v)) || parseFloat(v) < 0)) return errors.number;
    const min = parseInt(el.dataset.min || '0', 10);
    if (min && v.length < min) return errors.minChars;
    const max = parseInt(el.dataset.max || '0', 10);
    if (max && v.length > max) return errors.maxChars;
    return '';
  }

  function validateStep(i) {
    let ok = true;
    let firstBad = null;
    steps[i].querySelectorAll('input, textarea, select').forEach((el) => {
      const msg = validateField(el);
      setError(el, msg);
      if (msg && !firstBad) firstBad = el;
      if (msg) ok = false;
    });
    if (firstBad) firstBad.focus();
    return ok;
  }

  function show(i) {
    steps.forEach((s, idx) => s.classList.toggle('is-active', idx === i));
    current = i;
    stepNow.textContent = String(i + 1);
    stepName.textContent = stepTitles[i];
    fill.style.width = ((i + 1) / TOTAL) * 100 + '%';
    backBtn.disabled = i === 0;
    nextBtn.textContent = i === TOTAL - 1 ? submitLabel : nextLabel;
    nextBtn.classList.toggle('apl-next--submit', i === TOTAL - 1);
    card.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  backBtn.addEventListener('click', () => { if (current > 0) show(current - 1); });

  nextBtn.addEventListener('click', () => {
    if (!validateStep(current)) return;
    if (current < TOTAL - 1) {
      show(current + 1);
    } else {
      submit();
    }
  });

  // Clear errors while typing + live char hint on textareas
  document.querySelectorAll('#apl-form input, #apl-form textarea, #apl-form select').forEach((el) => {
    el.addEventListener('input', () => setError(el, ''));
  });
  // Live char counter: neutral while below the minimum, green once it's
  // met, yellow near the maximum, red past it. Thresholds come from each
  // textarea's own data-min/data-max, so this works for any field.
  document.querySelectorAll('.apl-hint[data-count-for]').forEach((hint) => {
    const ta = document.getElementById(hint.dataset.countFor);
    const min = parseInt(ta.dataset.min || '0', 10);
    const max = parseInt(ta.dataset.max || '0', 10);
    const warnAt = max ? Math.round(max * 0.85) : Infinity; // last ~15% before the max
    const base = hint.textContent; // friendly "Entre X y Y caracteres" from SSR

    const update = () => {
      const n = ta.value.trim().length;
      hint.classList.remove('is-ok', 'is-warning', 'is-over');

      if (n === 0) {
        hint.textContent = base;
        return;
      }
      if (min && n < min) {
        hint.textContent = base + ' · ' + n + '/' + min;
        return;
      }
      hint.textContent = max ? n + '/' + max + ' caracteres' : n + ' caracteres';
      if (max && n > max) hint.classList.add('is-over');
      else if (n >= warnAt) hint.classList.add('is-warning');
      else hint.classList.add('is-ok');
    };

    ta.addEventListener('input', update);
  });

  // ── Submission ─────────────────────────────────────────────────────────

  const inputValue = (id: string) => (document.getElementById(id) as HTMLInputElement).value;
  const numValue = (id: string) => parseFloat(inputValue(id)) || 0;

  type SubmitStatus = 'accepted' | 'rejected' | 'pending';

  function collectPayload() {
    return {
      name: inputValue('apl-name').trim(),
      email: inputValue('apl-email').trim(),
      phone: inputValue('apl-phone').trim(),
      linkedin: inputValue('apl-linkedin').trim(),
      blockers: inputValue('apl-blockers').trim(),
      role: inputValue('apl-role').trim(),
      english_level: inputValue('apl-english'),
      current_salary: numValue('apl-salary-now'),
      expected_salary: numValue('apl-salary-want'),
      vision: inputValue('apl-vision').trim(),
      locale: cfg.locale,
      fill_time_ms: Date.now() - renderStart,
      website: inputValue('apl-website'), // honeypot — must arrive empty
    };
  }

  async function postApplication(requestId: string): Promise<SubmitStatus> {
    const res = await fetch(`${API_ENDPOINT}/public/oa/applications`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-Request-Id': requestId, // site convention: correlate every network call
      },
      body: JSON.stringify(collectPayload()),
    });
    if (!res.ok) {
      const err = new Error(`HTTP ${res.status}`) as Error & { status?: number };
      err.status = res.status;
      throw err;
    }
    // Envelope contract: { data: { id, status: 'accepted'|'rejected'|'pending' } }
    const json = await res.json();
    const status = json?.data?.status;
    if (status !== 'accepted' && status !== 'rejected' && status !== 'pending') {
      throw new Error('Malformed response envelope');
    }
    return status;
  }

  // Report submit failures through the shared /logs/client contract.
  // NEVER include form PII — only status code + request id.
  function reportFailure(err: unknown, requestId: string) {
    if (!LOG_ENDPOINT) return;
    try {
      const status = (err as { status?: number })?.status ?? null;
      fetch(`${LOG_ENDPOINT}/logs/client`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        keepalive: true,
        body: JSON.stringify({
          entries: [
            {
              level: 'error',
              message: `OA application submit failed (${status ? `HTTP ${status}` : 'network error'})`,
              source: 'portal',
              url: location.origin + location.pathname,
              occurred_at: new Date().toISOString(),
              context: { status, request_id: requestId },
            },
          ],
        }),
      }).catch(() => {});
    } catch {
      /* reporter must never break the page */
    }
  }

  function fallbackStatus(): SubmitStatus {
    // Pre-existing client-side branch (no backend configured): current
    // salary >= threshold → accepted card, otherwise → rejected card.
    return numValue('apl-salary-now') >= FALLBACK_SALARY_THRESHOLD ? 'accepted' : 'rejected';
  }

  function showResult(id: string) {
    const el = document.getElementById(id)!;
    el.hidden = false;
    el.classList.add('is-on');
    el.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }

  function hideResult(id: string) {
    const el = document.getElementById(id)!;
    el.hidden = true;
    el.classList.remove('is-on');
  }

  function submit() {
    card.style.display = 'none';
    hideResult('apl-error-card'); // retry path

    // Overlay on + phase schedule (phase 1: 0.5–1.1s, phase 2: 4–6s,
    // total clamped to 5–8s — see pickTimings()).
    loader.reset();
    loader.setPhase(0);
    analyzing.classList.add('is-on');
    analyzing.setAttribute('aria-hidden', 'false');
    const { phase1Ms, totalMs } = pickTimings();
    const phaseTimer = setTimeout(() => loader.setPhase(1), phase1Ms);
    const minDone = new Promise((r) => setTimeout(r, totalMs));

    // The POST fires NOW, in parallel with the animation. The result shows
    // only when BOTH the animation minimum has elapsed AND the response
    // arrived; if the server is slower, phase 2 simply keeps looping.
    const requestId = crypto.randomUUID();
    const outcome: Promise<{ ok: true; status: SubmitStatus } | { ok: false; error: unknown }> =
      API_ENDPOINT
        ? postApplication(requestId)
            .then((status) => ({ ok: true as const, status }))
            .catch((error) => ({ ok: false as const, error }))
        : Promise.resolve({ ok: true as const, status: fallbackStatus() }); // zero network calls

    Promise.all([minDone, outcome]).then(([, result]) => {
      clearTimeout(phaseTimer);
      loader.destroy();
      analyzing.classList.remove('is-on');
      analyzing.setAttribute('aria-hidden', 'true');
      if (result.ok) {
        showResult(
          result.status === 'accepted'
            ? 'apl-accepted'
            : result.status === 'pending'
              ? 'apl-pending'
              : 'apl-rejected'
        );
      } else {
        reportFailure(result.error, requestId);
        showResult('apl-error-card');
      }
    });
  }

  document.getElementById('apl-retry')!.addEventListener('click', submit);
</script>

<style lang="scss">
  $ease-expo: cubic-bezier(0.16, 1, 0.3, 1);

  .apl {
    position: relative;
    min-height: 100svh;
    background: var(--color-bg);
    overflow-x: hidden;
    padding-bottom: 6rem;
  }

  .apl-glow {
    position: absolute;
    width: 60vw;
    height: 60vw;
    top: -32vw;
    right: -18vw;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(60, 43, 220, 0.12) 0%, rgba(60, 43, 220, 0) 65%);
    pointer-events: none;
  }

  .apl-header {
    position: relative;
    padding: 1.25rem 2.5rem;

    &__logo { width: 10rem; }
  }

  // ── Card ──────────────────────────────────────────────────
  .apl-card {
    position: relative;
    max-width: 44rem;
    margin: 2.5rem auto 0;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 3rem 3.25rem 2.5rem;
    box-shadow: 0 24px 70px rgba(15, 15, 15, 0.06);
    animation: apl-in 0.8s $ease-expo both;
  }

  .apl-intro { margin-bottom: 2rem; }

  .apl-title {
    font-size: 2rem;
    font-weight: 500;
    letter-spacing: -0.3px;
    line-height: 1.15;
    margin: 0.625rem 0 0.5rem;
  }

  .apl-subtitle {
    font-size: 1rem;
    color: var(--color-muted);
    margin: 0;
  }

  // ── Progress ──────────────────────────────────────────────
  .apl-progress {
    margin-bottom: 2.25rem;

    &__meta {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      margin-bottom: 0.625rem;
    }

    &__step {
      font-size: 0.75rem;
