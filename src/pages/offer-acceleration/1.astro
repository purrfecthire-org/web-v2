---
// ── Offer Acceleration — Design test v1 ──────────────────────────────────
// Direction: V6 lineage. Light cream, animated salary-trajectory SVG
// background, letter-stagger headline, count-up metrics, scroll reveals.
// Desktop-first (design test). DELETE when a final version is chosen.
import Layout from '../../layouts/Layout.astro';
import { oaContent as c } from '../../content/offerAcceleration';

// Salary-trajectory chart geometry (viewBox 1440×800)
const LEFT = 80;
const RIGHT = 1360;
const BASE = 700;

// "Te quedas" bundle: gray, flat, slowly decaying
const stayPaths = Array.from({ length: 7 }, (_, i) => ({
  d: `M ${LEFT} ${BASE - 180 - i * 6}
      C 420 ${BASE - 175 - i * 6}, 800 ${BASE - 150 - i * 4}, 1020 ${BASE - 135 - i * 3}
      C 1180 ${BASE - 125 - i * 2}, 1290 ${BASE - 118 - i}, ${RIGHT} ${BASE - 112 - i}`,
  width: 0.7 + i * 0.12,
  opacity: 0.10 + i * 0.04,
  dur: 15 + i * 1.3,
  delay: 2.4 + i * 0.3,
}));

// "Saltas" bundle: purple, fanning sharply upward
const jumpPaths = Array.from({ length: 10 }, (_, i) => ({
  d: `M ${LEFT} ${BASE - 190 - i * 3}
      C 380 ${BASE - 200 - i * 5}, 660 ${BASE - 290 - i * 8}, 880 ${BASE - 380 - i * 10}
      C 1080 ${BASE - 465 - i * 12}, 1250 ${BASE - 530 - i * 13}, ${RIGHT} ${BASE - 575 - i * 14}`,
  width: 0.6 + i * 0.16,
  opacity: 0.08 + i * 0.05,
  dur: 16 + i * 1.2,
  delay: 2.4 + i * 0.25,
}));

const splitWords = (phrase: string) => phrase.split(' ').map((w) => w.split(''));
const headWords = splitWords(c.hero.headline);
const accentWords = splitWords(c.hero.headlineAccent);
const LETTER = 0.04;
const WORD = 0.11;
const P1 = 0.3;
const P2 = 1.5;
const delayFor = (base: number, wi: number, li: number) => base + wi * WORD + li * LETTER;
---

<Layout title={c.meta.title} description={c.meta.description} lang="es" noindex>
  <main class="oa1">

    <!-- Minimal nav -->
    <header class="oa1-nav">
      <img src="/logos/logo-desktop.png" alt="Purrfect Hire" class="oa1-nav__logo" />
      <a href={c.apply.url} class="btn oa1-nav__cta">
        {c.apply.label}
      </a>
    </header>

    <!-- ── Hero ─────────────────────────────────────────────────────── -->
    <section class="oa1-hero">
      <div class="oa1-hero__chart" aria-hidden="true">
        <svg viewBox="0 0 1440 800" preserveAspectRatio="none" fill="none" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <linearGradient id="oa1-area" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#3C2BDC" stop-opacity="0.10" />
              <stop offset="100%" stop-color="#3C2BDC" stop-opacity="0" />
            </linearGradient>
          </defs>

          <g class="oa1-chart__axis">
            <line x1={LEFT} y1={BASE} x2={RIGHT} y2={BASE} stroke="#0F0F0F" stroke-opacity="0.12" />
            <line x1={LEFT} y1={BASE} x2={LEFT} y2={BASE + 8} stroke="#0F0F0F" stroke-opacity="0.14" />
            <line x1={RIGHT} y1={BASE} x2={RIGHT} y2={BASE + 8} stroke="#0F0F0F" stroke-opacity="0.14" />
            <text class="oa1-chart__month" x={LEFT} y={BASE + 32} text-anchor="middle">hoy</text>
            <text class="oa1-chart__month" x={RIGHT} y={BASE + 32} text-anchor="middle">mes 4</text>
          </g>

          <g class="oa1-chart__area-wrap">
            <path
              d={`M ${LEFT} ${BASE - 190}
                  C 380 ${BASE - 200}, 660 ${BASE - 290}, 880 ${BASE - 380}
                  C 1080 ${BASE - 465}, 1250 ${BASE - 530}, ${RIGHT} ${BASE - 575}
                  L ${RIGHT} ${BASE} L ${LEFT} ${BASE} Z`}
              fill="url(#oa1-area)"
            />
          </g>

          <g class="oa1-chart__reveal oa1-chart__reveal--stay">
            {stayPaths.map((p) => (
              <path
                class="oa1-chart__flow"
                d={p.d}
                pathLength="100"
                stroke="#5C5C5C"
                stroke-width={p.width}
                stroke-opacity={p.opacity}
                stroke-linecap="round"
                style={`animation-duration: ${p.dur}s; animation-delay: ${p.delay}s;`}
              />
            ))}
          </g>
          <g class="oa1-chart__reveal oa1-chart__reveal--jump">
            {jumpPaths.map((p) => (
              <path
                class="oa1-chart__flow"
                d={p.d}
                pathLength="100"
                stroke="#3C2BDC"
                stroke-width={p.width}
                stroke-opacity={p.opacity}
                stroke-linecap="round"
                style={`animation-duration: ${p.dur}s; animation-delay: ${p.delay}s;`}
              />
            ))}
          </g>

          <g class="oa1-chart__labels">
            <text class="oa1-chart__label oa1-chart__label--stay" x="1240" y={BASE - 90} text-anchor="end">
              si esperas
            </text>
            <text class="oa1-chart__label oa1-chart__label--jump" x="1240" y={BASE - 600} text-anchor="end">
              si ejecutas
            </text>
          </g>
        </svg>
        <div class="oa1-hero__vignette"></div>
      </div>

      <div class="oa1-hero__content">
        <p class="label-uppercase oa1-phase-1">{c.hero.eyebrow}</p>

        <h1 class="oa1-hero__headline headline1" aria-label={`${c.hero.headline} ${c.hero.headlineAccent}`}>
          <span class="oa1-hero__phrase oa1-hero__phrase--main" aria-hidden="true">
            {headWords.map((word, wi) => (
              <span class="oa1-hero__word">
                {word.map((letter, li) => (
                  <span class="oa1-hero__letter" style={`animation-delay: ${delayFor(P1, wi, li)}s;`}>{letter}</span>
                ))}
              </span>
            ))}
          </span>
          <span class="oa1-hero__phrase oa1-hero__phrase--accent" aria-hidden="true">
            {accentWords.map((word, wi) => (
              <span class="oa1-hero__word">
                {word.map((letter, li) => (
                  <span class="oa1-hero__letter" style={`animation-delay: ${delayFor(P2, wi, li)}s;`}>{letter}</span>
                ))}
              </span>
            ))}
          </span>
        </h1>

        <p class="subhead oa1-hero__subhead oa1-phase-3">{c.hero.subhead}</p>

        <div class="oa1-hero__metrics oa1-phase-3">
          {c.hero.stats.map((s, i) => (
            <>
              {i > 0 && <div class="oa1-hero__divider" />}
              <div class="oa1-hero__metric">
                <div class="oa1-hero__metric-value">{s.value}</div>
                <p class="oa1-hero__metric-label">{s.label}</p>
              </div>
            </>
          ))}
        </div>

        <div class="oa1-hero__ctas oa1-phase-4">
          <a href={c.apply.url} class="btn">{c.apply.label}</a>
          <a href="#casos" class="btn-secondary">{c.hero.ctaSecondary}</a>
        </div>
      </div>
    </section>

    <!-- ── Cost of waiting ─────────────────────────────────────────── -->
    <section class="oa1-section oa1-cost">
      <div class="oa1-container oa1-reveal">
        <h2 class="headline2">{c.cost.title}</h2>
        <p class="oa1-cost__body body1">{c.cost.body}</p>
        <p class="oa1-cost__highlight">{c.cost.highlight}</p>
        <p class="oa1-cost__note label-uppercase">{c.cost.note}</p>
        <blockquote class="oa1-quote">{c.cost.quote}</blockquote>
      </div>
    </section>

    <!-- ── Cases ────────────────────────────────────────────────────── -->
    <section class="oa1-section" id="casos">
      <div class="oa1-container">
        <h2 class="headline2 oa1-section__title oa1-reveal">{c.cases.title}</h2>
        <div class="oa1-cases">
          {c.cases.items.map((item) => (
            <article class="oa1-card oa1-reveal">
              <div class="oa1-card__metric">{item.metric}</div>
              <div class="oa1-card__unit">{item.unit}</div>
              <h3 class="headline3 oa1-card__role">{item.role}</h3>
              <p class="body2 oa1-card__story">{item.story}</p>
              <p class="oa1-card__result">{item.result}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ── Investment ───────────────────────────────────────────────── -->
    <section class="oa1-section oa1-invest">
      <div class="oa1-container">
        <div class="oa1-invest__head oa1-reveal">
          <h2 class="headline2">{c.investment.title}</h2>
          <div class="oa1-invest__price">{c.investment.price}</div>
          <p class="body1">{c.investment.priceNote}</p>
        </div>

        <div class="oa1-table-wrap oa1-reveal">
          <p class="label-uppercase oa1-table__title">{c.investment.tableTitle}</p>
          <table class="oa1-table">
            <thead>
              <tr>
                <th>Seniority</th>
                <th>Salario actual</th>
                <th>Salto realista</th>
                <th>Ingreso adicional anual</th>
                <th>Recuperas la inversión en</th>
              </tr>
            </thead>
            <tbody>
              {c.investment.tiers.map((t) => (
                <tr>
                  <td class="oa1-table__seniority">{t.seniority}</td>
                  <td>{t.current}</td>
                  <td class="oa1-table__jump">{t.jump}</td>
                  <td>{t.annual}</td>
                  <td>{t.payback}</td>
                </tr>
              ))}
            </tbody>
          </table>
          <p class="oa1-table__note body2">{c.investment.tableNote}</p>
        </div>

        <blockquote class="oa1-quote oa1-reveal">{c.investment.proof}</blockquote>
        <p class="oa1-invest__payments label-uppercase oa1-reveal">{c.investment.payments}</p>
      </div>
    </section>

    <!-- ── Deliverables ─────────────────────────────────────────────── -->
    <section class="oa1-section">
      <div class="oa1-container">
        <div class="oa1-reveal">
          <h2 class="headline2 oa1-section__title">{c.deliverables.title}</h2>
          <p class="subhead subhead-section oa1-section__subhead">{c.deliverables.subhead}</p>
        </div>
        <div class="oa1-deliverables">
          {c.deliverables.items.map((d, i) => (
            <article class="oa1-card oa1-card--deliverable oa1-reveal">
              <span class="oa1-card__index">{String(i + 1).padStart(2, '0')}</span>
              <h3 class="headline3">{d.title}</h3>
              <p class="body2">{d.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ── How we work ──────────────────────────────────────────────── -->
    <section class="oa1-section oa1-how">
      <div class="oa1-container">
        <h2 class="headline2 oa1-section__title oa1-reveal">{c.how.title}</h2>
        <div class="oa1-how__facts">
          {c.how.facts.map((f) => (
            <article class="oa1-card oa1-reveal">
              <p class="label-uppercase">{f.label}</p>
              <div class="oa1-how__value">{f.value}</div>
              <p class="body2">{f.detail}</p>
            </article>
          ))}
        </div>
        <div class="oa1-how__rhythm oa1-reveal">
          <h3 class="headline3">{c.how.rhythm.title}</h3>
          <p class="body1">{c.how.rhythm.body}</p>
        </div>
        <blockquote class="oa1-quote oa1-reveal">{c.how.quote}</blockquote>
      </div>
    </section>

    <!-- ── Who ──────────────────────────────────────────────────────── -->
    <section class="oa1-section">
      <div class="oa1-container">
        <h2 class="headline2 oa1-section__title oa1-reveal">{c.who.title}</h2>
        <div class="oa1-who">
          <article class="oa1-card oa1-card--kate oa1-reveal">
            <h3 class="headline3">{c.who.kate.name}</h3>
            <p class="label-uppercase oa1-who__role">{c.who.kate.role}</p>
            <p class="body2">{c.who.kate.bio}</p>
            <p class="oa1-who__quote">“{c.who.kate.quote}”</p>
          </article>
          <article class="oa1-card oa1-reveal">
            <h3 class="headline3">{c.who.team.name}</h3>
            <p class="body2 oa1-who__team-bio">{c.who.team.bio}</p>
          </article>
        </div>
      </div>
    </section>

    <!-- ── FAQ ──────────────────────────────────────────────────────── -->
    <section class="oa1-section oa1-faq">
      <div class="oa1-container oa1-container--narrow">
        <h2 class="headline2 oa1-section__title oa1-reveal">{c.faq.title}</h2>
        <div class="oa1-reveal">
          {c.faq.items.map((f) => (
            <details class="oa1-faq__item">
              <summary class="oa1-faq__q">{f.q}</summary>
              <p class="body1 oa1-faq__a">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- ── Start / final CTA ────────────────────────────────────────── -->
    <section class="oa1-section oa1-start">
      <div class="oa1-container oa1-container--narrow oa1-reveal">
        <h2 class="headline2 oa1-section__title">{c.start.title}</h2>
        <p class="subhead oa1-start__note">{c.start.note}</p>
        <ol class="oa1-start__steps">
          {c.start.steps.map((s, i) => (
            <li class="oa1-start__step">
              <span class="oa1-start__num">{i + 1}</span>
              <div>
                <h3 class="headline3">{s.title}</h3>
                <p class="body2">{s.body}</p>
              </div>
            </li>
          ))}
        </ol>
        <blockquote class="oa1-quote">{c.start.quote}</blockquote>
        <div class="oa1-start__ctas">
          <a href={c.apply.url} class="btn">{c.apply.labelFinal}</a>
        </div>
      </div>
    </section>

    <footer class="oa1-footer">
      <p class="body2">© {new Date().getFullYear()} Purrfect Hire · Offer Acceleration</p>
    </footer>
  </main>
</Layout>

<style lang="scss">
  @use '../../styles/breakpoints' as *;

  $ease-expo: cubic-bezier(0.16, 1, 0.3, 1);
  $ease-quart: cubic-bezier(0.25, 1, 0.5, 1);
  $ease-spring: cubic-bezier(0.34, 1.3, 0.64, 1);

  $t1: 0.3s;   // headline 1 + axis + stay bundle
  $t2: 1.5s;   // accent phrase + jump bundle
  $t3: 2.6s;   // subhead + metrics
  $t4: 3.2s;   // CTAs

  .oa1 {
    background: var(--color-bg);
    overflow-x: hidden;
  }

  // ── Nav ───────────────────────────────────────────────────
  .oa1-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.875rem 2rem;
    opacity: 0;
    animation: oa1-fade 0.9s $ease-expo ($t4 + 0.4s) forwards;

    &__logo { width: 10rem; }
  }

  // ── Hero ──────────────────────────────────────────────────
  .oa1-hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    overflow: hidden;

    &__chart {
      position: absolute;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      animation: oa1-float 16s ease-in-out 4s infinite alternate;

      svg { width: 100%; height: 100%; display: block; }
    }

    &__vignette {
      position: absolute;
      inset: 0;
      background: radial-gradient(
        ellipse 62% 55% at 42% 48%,
        rgba(250, 249, 247, 0.94) 0%,
        rgba(250, 249, 247, 0.55) 55%,
        rgba(250, 249, 247, 0) 100%
      );
    }

    &__content {
      position: relative;
      z-index: 1;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 2rem;
      padding-left: 8vw;
      padding-right: 2rem;
      max-width: 72rem;
    }

    &__headline {
      display: flex;
      flex-direction: column;
      gap: 10px;
      max-width: 56rem;
    }

    &__phrase { display: block; }

    &__word {
      display: inline-block;
      white-space: nowrap;
      margin-right: 0.28em;
      &:last-child { margin-right: 0; }
    }

    &__letter {
      display: inline-block;
      opacity: 0;
      transform: translateY(0.7em);
      animation: oa1-letter 0.8s $ease-spring forwards;
      background-clip: text;
      -webkit-background-clip: text;
      color: transparent;
    }

    &__phrase--main .oa1-hero__letter {
      background-image: linear-gradient(90deg, var(--color-text) 0%, rgba(15, 15, 15, 0.72) 100%);
    }

    &__phrase--accent .oa1-hero__letter {
      background-image: linear-gradient(90deg, var(--color-accent) 0%, rgba(60, 43, 220, 0.65) 100%);
    }

    &__subhead { max-width: 34rem; }

    &__metrics {
      display: flex;
      align-items: center;
      gap: 2.25rem;
    }

    &__metric {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }

    &__metric-value {
      font-size: 2rem;
      font-weight: 500;
      line-height: 1;
      color: var(--color-text);
    }

    &__metric-label {
      font-size: 0.8125rem;
      color: var(--color-muted);
      max-width: 140px;
    }

    &__divider {
      width: 1px;
      height: 40px;
      background: var(--color-border);
    }

    &__ctas {
      display: flex;
      gap: 1rem;
    }
  }

  .oa1-phase-1 {
    opacity: 0;
    animation: oa1-up 0.9s $ease-expo $t1 forwards;
  }

  .oa1-phase-3 {
    opacity: 0;
    transform: translateY(20px);
    animation: oa1-up 0.9s $ease-expo $t3 forwards;
  }

  .oa1-phase-4 {
    opacity: 0;
    transform: translateY(20px);
    animation: oa1-up 0.9s $ease-expo $t4 forwards;
  }

  // ── Chart internals ───────────────────────────────────────
  .oa1-chart__month {
    font-size: 13px;
    fill: var(--color-muted);
    fill-opacity: 0.75;
    letter-spacing: 0.04em;
  }

  .oa1-chart__label {
    font-size: 14px;
    letter-spacing: 0.02em;
    &--stay { fill: var(--color-muted); }
    &--jump { fill: var(--color-accent); font-weight: 500; }
  }

  .oa1-chart__axis {
    opacity: 0;
    animation: oa1-fade 0.8s $ease-quart $t1 forwards;
  }

  .oa1-chart__labels {
    opacity: 0;
    animation: oa1-fade 0.8s $ease-quart ($t2 + 1s) forwards;
  }

  .oa1-chart__reveal {
    clip-path: inset(-5% 105% -5% -2%);
    &--stay { animation: oa1-draw 1.7s $ease-quart $t1 forwards; }
    &--jump { animation: oa1-draw 1.8s $ease-expo $t2 forwards; }
  }

  .oa1-chart__flow {
    animation-name: oa1-flow;
    animation-timing-function: linear;
    animation-iteration-count: infinite;
  }

  .oa1-chart__area-wrap {
    opacity: 0;
    animation: oa1-fade 1.2s $ease-expo ($t2 + 0.4s) forwards;
  }

  // ── Sections ──────────────────────────────────────────────
  .oa1-section {
    padding: 6.5rem 2rem;

    &__title { margin-bottom: 1rem; }
    &__subhead { margin-bottom: 3rem; text-align: center; }
  }

  .oa1-container {
    max-width: 72rem;
    margin-inline: auto;

    &--narrow { max-width: 46rem; }
  }

  .oa1-section .oa1-section__title { text-align: center; }

  // ── Cost ──────────────────────────────────────────────────
  .oa1-cost {
    text-align: center;

    &__body {
      max-width: 40rem;
      margin: 1.5rem auto 0;
    }

    &__highlight {
      font-size: 2.25rem;
      font-weight: 500;
      letter-spacing: -0.3px;
      color: var(--color-accent);
      margin-top: 1.5rem;
      line-height: 1.15;
    }

    &__note { margin-top: 1rem; }
  }

  .oa1-quote {
    max-width: 42rem;
    margin: 3rem auto 0;
    padding-left: 1.5rem;
    border-left: 3px solid var(--color-accent);
    font-size: 1.25rem;
    line-height: 1.5;
    font-weight: 500;
    color: var(--color-text);
    text-align: left;
  }

  // ── Cards ─────────────────────────────────────────────────
  .oa1-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: transform 0.35s $ease-expo, box-shadow 0.35s $ease-expo;

    &:hover {
      transform: translateY(-4px);
      box-shadow: 0 16px 40px rgba(15, 15, 15, 0.07);
    }

    &__metric {
      font-size: 2rem;
      font-weight: 500;
      line-height: 1;
      color: var(--color-accent);
    }

    &__unit {
      font-size: 0.8125rem;
      color: var(--color-tertiary);
    }

    &__role { margin-top: 0.5rem; }

    &__result {
      font-size: 0.9375rem;
      font-weight: 500;
      color: var(--color-text);
      margin-top: auto;
    }

    &__index {
      font-size: 0.8125rem;
      font-weight: 500;
      color: var(--color-accent);
      letter-spacing: 0.06em;
    }
  }

  .oa1-cases {
    margin-top: 3rem;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  .oa1-deliverables {
    margin-top: 1rem;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;

    // last item spans wider for a deliberate asymmetric finish
    .oa1-card--deliverable:last-child {
      grid-column: span 3;
      flex-direction: row;
      align-items: baseline;
      gap: 1.5rem;

      p { max-width: 44rem; }
    }
  }

  // ── Investment ────────────────────────────────────────────
  .oa1-invest {
    &__head {
      text-align: center;
      margin-bottom: 3rem;
    }

    &__price {
      font-size: 3.25rem;
      font-weight: 500;
      letter-spacing: -0.5px;
      color: var(--color-accent);
      margin: 1rem 0 0.5rem;
    }

    &__payments {
      text-align: center;
      margin-top: 2rem;
    }
  }

  .oa1-table-wrap {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 2rem;
    overflow-x: auto;
  }

  .oa1-table__title {
    margin-bottom: 1.25rem;
  }

  .oa1-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9375rem;

    th {
      text-align: left;
      font-size: 0.6875rem;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--color-tertiary);
      padding: 0.75rem 1rem 0.75rem 0;
      border-bottom: 1px solid var(--color-border);
    }

    td {
      padding: 1rem 1rem 1rem 0;
      border-bottom: 1px solid var(--color-border);
      color: var(--color-muted);
      font-variant-numeric: tabular-nums;
    }

    tr:last-child td { border-bottom: none; }

    &__seniority {
      font-weight: 500;
      color: var(--color-text) !important;
    }

    &__jump {
      color: var(--color-accent) !important;
      font-weight: 500;
    }
  }

  .oa1-table__note {
    margin-top: 1rem;
    color: var(--color-tertiary);
  }

  // ── How ───────────────────────────────────────────────────
  .oa1-how {
    &__facts {
      margin-top: 3rem;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }

    &__value {
      font-size: 1.5rem;
      font-weight: 500;
      color: var(--color-text);
    }

    &__rhythm {
      margin-top: 2rem;
      background: var(--color-accent-light);
      border-radius: 12px;
      padding: 2rem;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
  }

  // ── Who ───────────────────────────────────────────────────
  .oa1-who {
    margin-top: 3rem;
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: 1.25rem;

    &__role { margin-bottom: 0.5rem; }

    &__quote {
      margin-top: auto;
      font-size: 1.0625rem;
      font-weight: 500;
      color: var(--color-accent);
    }

    &__team-bio { margin-top: 0.5rem; }
  }

  // ── FAQ ───────────────────────────────────────────────────
  .oa1-faq__item {
    border-bottom: 1px solid var(--color-border);
    padding: 1.25rem 0;

    &:first-of-type { border-top: 1px solid var(--color-border); }
  }

  .oa1-faq__q {
    font-size: 1.0625rem;
    font-weight: 500;
    color: var(--color-text);
    cursor: pointer;
    list-style: none;
    position: relative;
    padding-right: 2rem;

    &::-webkit-details-marker { display: none; }

    &::after {
      content: '+';
      position: absolute;
      right: 0;
      top: 50%;
      transform: translateY(-50%);
      font-size: 1.25rem;
      color: var(--color-accent);
      transition: transform 0.25s $ease-expo;
    }
  }

  .oa1-faq__item[open] .oa1-faq__q::after {
    transform: translateY(-50%) rotate(45deg);
  }

  .oa1-faq__a {
    margin-top: 0.75rem;
    max-width: 42rem;
  }

  // ── Start ─────────────────────────────────────────────────
  .oa1-start {
    text-align: center;

    &__note { margin-bottom: 2.5rem; }

    &__steps {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
      text-align: left;
    }

    &__step {
      display: flex;
      align-items: flex-start;
      gap: 1.25rem;
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: 12px;
      padding: 1.5rem 2rem;
    }

    &__num {
      flex-shrink: 0;
      width: 2.25rem;
      height: 2.25rem;
      display: grid;
      place-items: center;
      border-radius: 999px;
      background: var(--color-accent);
      color: #fff;
      font-weight: 500;
    }

    &__ctas {
      margin-top: 3rem;
      display: flex;
      justify-content: center;
      gap: 1rem;
    }
  }

  .oa1-footer {
    padding: 2.5rem 2rem;
    text-align: center;
    border-top: 1px solid var(--color-border);
  }

  // ── Scroll reveals ────────────────────────────────────────
  .oa1-reveal {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.9s $ease-expo, transform 0.9s $ease-expo;

    &.is-visible {
      opacity: 1;
      transform: translateY(0);
    }
  }

  // ── Keyframes ─────────────────────────────────────────────
  @keyframes oa1-letter {
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes oa1-up {
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes oa1-fade {
    to { opacity: 1; }
  }
  @keyframes oa1-draw {
    to { clip-path: inset(-5% -2% -5% -2%); }
  }
  @keyframes oa1-flow {
    from { stroke-dasharray: 80 20; stroke-dashoffset: 0; }
    to { stroke-dasharray: 80 20; stroke-dashoffset: -100; }
  }
  @keyframes oa1-float {
    from { transform: translateY(0); }
    to { transform: translateY(-12px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .oa1-hero__chart { animation: none; }
    .oa1-hero__letter,
    .oa1-phase-1,
    .oa1-phase-3,
    .oa1-phase-4,
    .oa1-nav,
    .oa1-chart__axis,
    .oa1-chart__labels,
    .oa1-chart__area-wrap {
      animation: none;
      opacity: 1;
      transform: none;
    }
    .oa1-chart__reveal { animation: none; clip-path: none; }
    .oa1-chart__flow { animation: none !important; }
    .oa1-reveal { transition: none; opacity: 1; transform: none; }
  }
</style>

<script>
  const reveals = document.querySelectorAll('.oa1-reveal');
  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add('is-visible');
          io.unobserve(e.target);
        }
      });
    },
    { threshold: 0.12 }
  );
  reveals.forEach((el) => io.observe(el));
</script>
