---
import Layout from '../layouts/Layout.astro';
import V6Nav from '../components/v6/V6Nav.astro';
import V6HeroSection from '../components/v6/V6HeroSection.astro';
import CompanyCarousel from '../components/CompanyCarousel.astro';
import Why2026Section from '../components/Why2026Section.astro';
import AudienceSplit from '../components/AudienceSplit.astro';
import OfferAccelerationSection from '../components/OfferAccelerationSection.astro';
import EngineSection from '../components/EngineSection.astro';
import CultureSection from '../components/CultureSection.astro';
import TestimonialsSection from '../components/TestimonialsSection.astro';
import RolesSection from '../components/RolesSection.astro';
import CTASection from '../components/CTASection.astro';
import Footer from '../components/Footer.astro';
import { getContent } from '../content/index';

const c = getContent('en');
---

<Layout
  title={c.meta.title}
  description={c.meta.description}
  lang="en"
>
  <V6Nav content={c.nav} lang="en" />
  <main>
    <V6HeroSection content={c.hero} />
    <CompanyCarousel />
    <Why2026Section content={c.why2026} />
    <AudienceSplit content={c.audienceSplit} />
    <OfferAccelerationSection content={c.offerAcceleration} />
    <EngineSection content={c.engine} />
    <CultureSection content={c.culture} />
    <TestimonialsSection content={c.testimonials} />
    <RolesSection content={c.roles} />
    <CTASection content={c.cta} />
  </main>
  <Footer content={c.footer} />
</Layout>

<style is:global>
  html {
    scroll-behavior: smooth;
  }

  /* Intro choreography: nav joins in phase 4, with the rest of the page chrome */
  .v6-nav {
    opacity: 0;
    animation: v6-nav-in 0.9s cubic-bezier(0.16, 1, 0.3, 1) 4.5s forwards;
  }

  @keyframes v6-nav-in {
    to { opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .v6-nav {
      animation: none;
      opacity: 1;
    }
  }
</style>
