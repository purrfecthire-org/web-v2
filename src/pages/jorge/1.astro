---
// ── Jorge Donado — Roadmap MVP v1: "Ruta Ejecutiva" ──────────────────────
// Standalone test page: NO shared Layout, NO global styles, fully isolated.
// Desktop-only by design (MVP). Light theme. DELETE when a version is chosen.
// Route: /jorge/1

const sessions = [
  {
    n: '0',
    phase: 1,
    tag: 'Completada',
    done: true,
    title: 'Diagnóstico & Presentación',
    goal: 'Entender tu historia, tus cicatrices y tus medallas. De aquí salió todo lo que sigue.',
    why: 'Sin diagnóstico no hay ruta: cada sesión de este plan existe porque algo concreto apareció en esta conversación.',
    deliver: 'Lectura completa de tu perfil',
  },
  {
    n: '1',
    phase: 1,
    tag: 'Fase 1 · El activo',
    title: 'Tesis Ejecutiva & Narrativa',
    goal: 'Tu tesis a 3 años y tu historia contada con números que aguantan repreguntas.',
    why: 'Tu próximo rol lo decide un CEO o un founder en una conversación de 45 minutos. La conversación es el filtro: arreglamos la fuente antes que cualquier perfil.',
    deliver: 'Tesis + 3 NOs · 3 historias CIAR · las 2 respuestas clave',
  },
  {
    n: '2',
    phase: 1,
    tag: 'Fase 1 · El activo',
    title: 'Posicionamiento Público',
    goal: 'LinkedIn como dossier ejecutivo y un CV de una página.',
    why: 'A tu nivel el perfil no es donde te descubren: es lo que el CEO revisa después de oír de ti. Tiene que confirmar en 8 segundos lo que la referencia le prometió.',
    deliver: 'LinkedIn publicado · CV ejecutivo de 1 página',
  },
  {
    n: '3',
    phase: 2,
    tag: 'Fase 2 · El mercado te conoce',
    title: 'Autoridad & Evidencia Pública',
    goal: 'Evidencia pública de tu criterio: IA en producción contada por quien la hizo.',
    why: 'Antes de invertir una hora en ti, un founder te googlea. Hablas del trabajo, no de ti mismo: la jugada hecha a tu medida.',
    deliver: '4 piezas · cadencia semanal · 10 cuentas objetivo',
  },
  {
    n: '4',
    phase: 2,
    tag: 'Fase 2 · El mercado te conoce',
    title: 'Mapa de Acceso & Red Ejecutiva',
    goal: 'Las 50 personas que pueden contratarte, con camino tibio hacia cada una.',
    why: 'Los roles de tu nivel se llenan por referencia, casi nunca por aplicación. Tu red ex-Rappi es una ventaja injusta que hoy duerme.',
    deliver: 'Mapa de 50 · 5 referencias activadas · sistema semanal',
  },
  {
    n: '5',
    phase: 3,
    tag: 'Fase 3 · La decisión',
    title: 'La Conversación Ejecutiva',
    goal: 'Jugar la entrevista como conversación entre pares, con tu instinto y sin guion.',
    why: 'Tu único punto de falla probado. Se corrige con reps de lo que ya haces a diario, no con más libreto.',
    deliver: '3 simulacros en vivo · números bajo fuego · las 4 respuestas',
  },
  {
    n: '6',
    phase: 3,
    tag: 'Fase 3 · La decisión',
    title: 'Negociación & Cierre Ejecutivo',
    goal: 'Cerrar la estructura completa (base, bono, equity) y salir de Rappi sin quemar nada.',
    why: 'A tu nivel la compensación es una estructura, no un número. Y tu salida define cómo te recomienda tu red los próximos 10 años.',
    deliver: 'Piso, objetivo y techo · plan de salida elegante',
  },
];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=1280" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Jorge · Ruta Ejecutiva — Offer Accelerator</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="jr1">
      <!-- Top bar -->
      <header class="jr1-bar">
        <span class="jr1-bar__brand">Offer Accelerator</span>
        <span class="jr1-bar__pill">Propuesta de ruta · 1 de 2</span>
      </header>

      <!-- Hero -->
      <section class="jr1-hero">
        <p class="jr1-hero__eyebrow jr1-in" style="--d: 0s">Jorge Mario Donado · Cohorte 3</p>
        <h1 class="jr1-hero__title">
          <span class="jr1-in" style="--d: .08s">La Ruta</span>
          <span class="jr1-hero__accent jr1-in" style="--d: .2s">Ejecutiva</span>
        </h1>
        <p class="jr1-hero__sub jr1-in" style="--d: .34s">
          Tu próximo rol no lo decide un recruiter: lo decide un CEO, un founder o un board.
          Esta ruta construye, en orden, lo que esa mesa evalúa: tu historia, tu evidencia
          pública, tu acceso y tu manera de jugar la conversación.
        </p>
        <div class="jr1-hero__meta jr1-in" style="--d: .48s">
          <div class="jr1-meta"><strong>7</strong><span>sesiones</span></div>
          <div class="jr1-meta"><strong>3</strong><span>fases</span></div>
          <div class="jr1-meta"><strong>Aprox. 12</strong><span>semanas</span></div>
        </div>
        <div class="jr1-hero__scroll jr1-in" style="--d: .62s">
          <span>Recorre la ruta</span>
          <svg width="16" height="22" viewBox="0 0 16 22" fill="none" aria-hidden="true">
            <path d="M8 2v16M2 12l6 7 6-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
      </section>

      <!-- Road -->
      <section class="jr1-road" id="road">
        <svg class="jr1-road__path" viewBox="0 0 1200 4900" preserveAspectRatio="none" fill="none" aria-hidden="true">
          <path
            id="jr1-route-bg"
            d="M 600 0
               C 600 220, 230 260, 230 480
               C 230 700, 970 740, 970 960
               C 970 1180, 230 1220, 230 1440
               C 230 1660, 970 1700, 970 1920
               C 970 2140, 230 2180, 230 2400
               C 230 2620, 970 2660, 970 2880
               C 970 3100, 230 3140, 230 3360
               C 230 3580, 970 3620, 970 3840
               C 970 4060, 600 4150, 600 4400
               L 600 4900"
            stroke="#E5E5E1" stroke-width="3" stroke-dasharray="1 14" stroke-linecap="round"
          />
          <path
            id="jr1-route"
            d="M 600 0
               C 600 220, 230 260, 230 480
               C 230 700, 970 740, 970 960
               C 970 1180, 230 1220, 230 1440
               C 230 1660, 970 1700, 970 1920
               C 970 2140, 230 2180, 230 2400
               C 230 2620, 970 2660, 970 2880
               C 970 3100, 230 3140, 230 3360
               C 230 3580, 970 3620, 970 3840
               C 970 4060, 600 4150, 600 4400
               L 600 4900"
            stroke="#3C2BDC" stroke-width="4" stroke-linecap="round"
          />
        </svg>

        {sessions.map((s, i) => (
          <article class={`jr1-stop ${i % 2 === 0 ? 'jr1-stop--left' : 'jr1-stop--right'} ${s.done ? 'jr1-stop--done' : ''}`}>
            <div class="jr1-stop__node" aria-hidden="true">
              {s.done ? (
                <svg width="22" height="22" viewBox="0 0 22 22" fill="none"><path d="M4 11.5l5 5L18 6" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/></svg>
              ) : (
                <span>{s.n}</span>
              )}
            </div>
            <div class="jr1-stop__card">
              <p class="jr1-stop__tag">{s.tag}</p>
              <h2 class="jr1-stop__title">Sesión {s.n} · {s.title}</h2>
              <p class="jr1-stop__goal">{s.goal}</p>
              <p class="jr1-stop__why"><strong>Por qué aquí:</strong> {s.why}</p>
              <p class="jr1-stop__deliver">{s.deliver}</p>
            </div>
          </article>
        ))}
      </section>

      <!-- North star -->
      <section class="jr1-end">
        <div class="jr1-end__card jr1-reveal">
          <p class="jr1-end__eyebrow">El destino</p>
          <h2 class="jr1-end__title">En 90 días</h2>
          <p class="jr1-end__text">
            Founders y C-levels de empresas globales de tecnología saben quién eres antes de
            que abras la boca: tu narrativa, tus referencias y tu evidencia pública hablan por
            ti. Las conversaciones te llegan tibias, y tú eliges en cuáles sentarte.
          </p>
          <p class="jr1-end__note">
            Este programa no existe para conseguirte un trabajo. Existe para que nunca más
            dependas de que alguien te encuentre.
          </p>
        </div>
        <footer class="jr1-foot">
          <span>Purrfect Hire · Offer Accelerator</span>
          <span>MVP de visualización · versión 1 · solo escritorio</span>
        </footer>
      </section>
    </div>

    <style>
      /* ── Reset (page-local) ─────────────────────────────────────────── */
      :global(html), :global(body) {
        margin: 0;
        padding: 0;
      }
      :where(.jr1, .jr1 *) { box-sizing: border-box; margin: 0; padding: 0; }
      .jr1 {
        --bg: #FAF9F7;
        --ink: #0F0F0F;
        --muted: #5C5C5C;
        --accent: #3C2BDC;
        --accent-soft: #E8E6F8;
        --navy: #0D0857;
        --card: #FFFFFF;
        --line: #E5E5E1;
        font-family: 'Inter', system-ui, sans-serif;
        background:
          radial-gradient(1200px 600px at 85% -5%, #EFEDF8 0%, transparent 60%),
          radial-gradient(900px 500px at -10% 30%, #F0EEF9 0%, transparent 55%),
          var(--bg);
        color: var(--ink);
        min-width: 1100px;
        overflow-x: hidden;
      }

      /* ── Top bar ────────────────────────────────────────────────────── */
      .jr1-bar {
        position: fixed;
        top: 0; left: 0; right: 0;
        display: flex; align-items: center; justify-content: space-between;
        padding: 18px 48px;
        z-index: 50;
        backdrop-filter: blur(8px);
        background: color-mix(in srgb, var(--bg) 78%, transparent);
        border-bottom: 1px solid color-mix(in srgb, var(--line) 60%, transparent);
      }
      .jr1-bar__brand { font-weight: 700; letter-spacing: .02em; font-size: 15px; }
      .jr1-bar__pill {
        font-size: 12.5px; font-weight: 600; color: var(--accent);
        background: var(--accent-soft);
        border: 1px solid color-mix(in srgb, var(--accent) 25%, transparent);
        padding: 6px 14px; border-radius: 999px;
      }

      /* ── Hero ───────────────────────────────────────────────────────── */
      .jr1-hero {
        min-height: 92vh;
        display: flex; flex-direction: column; justify-content: center; align-items: center;
        text-align: center;
        padding: 140px 60px 60px;
      }
      .jr1-hero__eyebrow {
        font-size: 13px; font-weight: 600; letter-spacing: .14em; text-transform: uppercase;
        color: var(--navy);
        margin-bottom: 22px;
      }
      .jr1-hero__title {
        font-family: 'Inter', sans-serif;
        font-size: 92px; line-height: 1.02; font-weight: 800;
        display: flex; gap: 26px; align-items: baseline;
      }
      .jr1-hero__accent {
        color: var(--accent);
        font-style: italic;
        position: relative;
      }
      .jr1-hero__accent::after {
        content: '';
        position: absolute; left: 2%; right: 2%; bottom: 6px;
        height: 12px;
        background: color-mix(in srgb, var(--accent) 20%, transparent);
        z-index: -1;
        border-radius: 3px;
        transform: scaleX(0);
        transform-origin: left;
        animation: jr1-underline .7s cubic-bezier(.2,.7,.2,1) 1s forwards;
      }
      @keyframes jr1-underline { to { transform: scaleX(1); } }
      .jr1-hero__sub {
        max-width: 680px;
        margin-top: 30px;
        font-size: 18.5px; line-height: 1.65; color: var(--muted);
      }
      .jr1-hero__meta { display: flex; gap: 56px; margin-top: 44px; }
      .jr1-meta { display: flex; flex-direction: column; align-items: center; gap: 2px; }
      .jr1-meta strong { font-family: 'Inter', sans-serif; font-size: 30px; font-weight: 800; color: var(--accent); }
      .jr1-meta span { font-size: 13px; color: var(--muted); letter-spacing: .06em; text-transform: uppercase; }
      .jr1-hero__scroll {
        margin-top: 64px;
        display: flex; flex-direction: column; align-items: center; gap: 8px;
        font-size: 13px; color: var(--muted); letter-spacing: .08em; text-transform: uppercase;
      }
      .jr1-hero__scroll svg { animation: jr1-bob 1.8s ease-in-out infinite; color: var(--accent); }
      @keyframes jr1-bob { 0%,100% { transform: translateY(0) } 50% { transform: translateY(7px) } }

      /* intro stagger */
      .jr1-in { opacity: 0; transform: translateY(22px); animation: jr1-rise .8s cubic-bezier(.2,.7,.2,1) var(--d, 0s) forwards; }
      @keyframes jr1-rise { to { opacity: 1; transform: translateY(0); } }

      /* ── Road ───────────────────────────────────────────────────────── */
      .jr1-road {
        position: relative;
        max-width: 1200px;
        margin: 0 auto;
        padding: 60px 0 40px;
      }
      .jr1-road__path {
        position: absolute; inset: 0;
        width: 100%; height: 100%;
        pointer-events: none;
      }

      .jr1-stop {
        position: relative;
        width: 520px;
        margin-bottom: 170px;
        opacity: 0;
        transform: translateY(46px);
        transition: opacity .8s cubic-bezier(.2,.7,.2,1), transform .8s cubic-bezier(.2,.7,.2,1);
      }
      .jr1-stop.jr1-visible { opacity: 1; transform: translateY(0); }
      .jr1-stop--left  { margin-left: 70px; }
      .jr1-stop--right { margin-left: 640px; }

      .jr1-stop__node {
        position: absolute;
        top: -26px;
        width: 58px; height: 58px;
        border-radius: 50%;
        background: var(--accent);
        color: #fff;
        display: flex; align-items: center; justify-content: center;
        font-family: 'Inter', sans-serif;
        font-size: 25px; font-weight: 700;
        box-shadow:
          0 0 0 7px var(--bg),
          0 0 0 9px color-mix(in srgb, var(--accent) 35%, transparent),
          0 10px 24px -8px color-mix(in srgb, var(--accent) 55%, transparent);
        z-index: 2;
        transition: transform .5s cubic-bezier(.34,1.56,.64,1);
      }
      .jr1-stop--left  .jr1-stop__node { left: -22px; }
      .jr1-stop--right .jr1-stop__node { right: -22px; }
      .jr1-stop--done  .jr1-stop__node { background: var(--navy); }
      .jr1-stop:hover  .jr1-stop__node { transform: scale(1.14) rotate(6deg); }

      .jr1-stop__card {
        background: var(--card);
        border: 1px solid var(--line);
        border-radius: 18px;
        padding: 30px 32px 26px;
        box-shadow: 0 18px 44px -22px rgba(15, 15, 15, .15);
        transition: transform .45s cubic-bezier(.2,.7,.2,1), box-shadow .45s;
      }
      .jr1-stop:hover .jr1-stop__card {
        transform: translateY(-5px);
        box-shadow: 0 28px 60px -24px rgba(60, 43, 220, .25);
      }
      .jr1-stop__tag {
        display: inline-block;
        font-size: 11.5px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase;
        color: var(--accent);
        background: var(--accent-soft);
        padding: 4px 11px; border-radius: 999px;
        margin-bottom: 14px;
      }
      .jr1-stop--done .jr1-stop__tag { color: var(--navy); background: #E6E4F0; }
      .jr1-stop__title {
        font-family: 'Inter', sans-serif;
        font-size: 26px; font-weight: 700; line-height: 1.2;
        margin-bottom: 10px;
      }
      .jr1-stop__goal { font-size: 15.5px; line-height: 1.6; margin-bottom: 12px; }
      .jr1-stop__why {
        font-size: 14px; line-height: 1.62; color: var(--muted);
        border-left: 3px solid var(--accent-soft);
        padding-left: 14px;
        margin-bottom: 16px;
      }
      .jr1-stop__why strong { color: var(--accent); font-weight: 600; }
      .jr1-stop__deliver {
        font-size: 13px; font-weight: 600; color: var(--navy);
        letter-spacing: .015em;
      }
      .jr1-stop__deliver::before { content: '⟶ '; }

      /* ── End / North star ───────────────────────────────────────────── */
      .jr1-end { padding: 0 60px 70px; display: flex; flex-direction: column; align-items: center; }
      .jr1-end__card {
        max-width: 760px;
        text-align: center;
        background: linear-gradient(160deg, #3C2BDC, #2A1FA8);
        color: #f3f5ff;
        border-radius: 26px;
        padding: 64px 70px;
        box-shadow: 0 36px 80px -30px rgba(60, 43, 220, .45);
      }
      .jr1-end__eyebrow {
        font-size: 12.5px; font-weight: 700; letter-spacing: .16em; text-transform: uppercase;
        color: #B8B0FF;
        margin-bottom: 14px;
      }
      .jr1-end__title { font-family: 'Inter', sans-serif; font-size: 46px; font-weight: 800; margin-bottom: 20px; }
      .jr1-end__text { font-size: 17.5px; line-height: 1.7; margin-bottom: 26px; }
      .jr1-end__note {
        font-size: 15px; font-style: italic; color: #C4BFFF;
        border-top: 1px solid rgba(255,255,255,.18);
        padding-top: 22px;
      }
      .jr1-reveal { opacity: 0; transform: translateY(40px) scale(.97); transition: all .9s cubic-bezier(.2,.7,.2,1); }
      .jr1-reveal.jr1-visible { opacity: 1; transform: none; }

      .jr1-foot {
        width: 100%; max-width: 760px;
        display: flex; justify-content: space-between;
        margin-top: 48px;
        font-size: 12.5px; color: var(--muted);
      }
    </style>

    <script>
      // Reveal stops + end card
      const io = new IntersectionObserver(
        (entries) => entries.forEach((e) => e.isIntersecting && e.target.classList.add('jr1-visible')),
        { threshold: 0.25 }
      );
      document.querySelectorAll('.jr1-stop, .jr1-reveal').forEach((el) => io.observe(el));

      // Draw the route as you scroll
      const route = document.getElementById('jr1-route') as SVGPathElement | null;
      const road = document.getElementById('road');
      if (route && road) {
        const len = route.getTotalLength();
        route.style.strokeDasharray = `${len}`;
        route.style.strokeDashoffset = `${len}`;
        const onScroll = () => {
          const r = road.getBoundingClientRect();
          const vh = window.innerHeight;
          const progress = Math.min(1, Math.max(0, (vh * 0.75 - r.top) / r.height));
          route.style.strokeDashoffset = `${len * (1 - progress)}`;
        };
        onScroll();
        window.addEventListener('scroll', onScroll, { passive: true });
      }
    </script>
  </body>
</html>
