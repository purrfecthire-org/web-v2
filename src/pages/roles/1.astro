---
import Layout from '../../layouts/Layout.astro';
import RoleDetailV1 from '../../components/roles-v1/RoleDetailV1.astro';
import { roleSample } from '../../content/roleSample';

const role = roleSample;
---

<Layout title={`${role.title} — Purrfect Hire`} description={role.company.description} lang="en">
  <style is:global>
    body {
      background-color: #F8F7FF;
    }
  </style>

  <!-- Fixed aurora canvas -->
  <div class="rv1-canvas" aria-hidden="true">
    <div class="rv1-canvas__blob rv1-canvas__blob--1"></div>
    <div class="rv1-canvas__blob rv1-canvas__blob--2"></div>
    <div class="rv1-canvas__blob rv1-canvas__blob--3"></div>
  </div>

  <RoleDetailV1 role={role} />
</Layout>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');

  html {
    scroll-behavior: smooth;
  }

  .rv1-canvas {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .rv1-canvas__blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(120px);
  }

  .rv1-canvas__blob--1 {
    width: 700px;
    height: 700px;
    top: -200px;
    right: -200px;
    background: radial-gradient(circle, rgba(79, 70, 229, 0.22) 0%, transparent 70%);
    animation: rv1-drift-1 22s ease-in-out infinite alternate;
  }

  .rv1-canvas__blob--2 {
    width: 600px;
    height: 600px;
    bottom: 10%;
    left: -200px;
    background: radial-gradient(circle, rgba(8, 145, 178, 0.18) 0%, transparent 70%);
    animation: rv1-drift-2 26s ease-in-out infinite alternate;
  }

  .rv1-canvas__blob--3 {
    width: 520px;
    height: 520px;
    top: 45%;
    right: 8%;
    background: radial-gradient(circle, rgba(5, 150, 105, 0.14) 0%, transparent 70%);
    animation: rv1-drift-3 19s ease-in-out infinite alternate;
  }

  @keyframes rv1-drift-1 {
    from { transform: translate(0, 0) scale(1); }
    to   { transform: translate(-60px, 80px) scale(1.1); }
  }
  @keyframes rv1-drift-2 {
    from { transform: translate(0, 0) scale(1); }
    to   { transform: translate(80px, -60px) scale(1.08); }
  }
  @keyframes rv1-drift-3 {
    from { transform: translate(0, 0) scale(1); }
    to   { transform: translate(-40px, 60px) scale(0.92); }
  }
</style>
