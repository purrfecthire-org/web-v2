---
import Layout from '../../layouts/Layout.astro';
import V6Nav from '../../components/v6/V6Nav.astro';
import Footer from '../../components/Footer.astro';
import { getContent } from '../../content/index';
import { fetchRoles, roleCardHTML, type PublicRoleListItem } from '../../lib/roles';

// ─────────────────────────────────────────────────────────────────────────────
// Roles index — list of open positions (hybrid delivery).
//
// BUILD TIME: fetch GET {PUBLIC_API_ENDPOINT}/public/roles and prerender the
// cards for SEO. If the backend is unreachable (e.g. in CI), we catch the error
// and render an empty state rather than failing the build.
//
// CLIENT TIME: a small inline script re-fetches the list after load so
// mid-week publishes appear without a rebuild. If it fails, the prerendered
// snapshot stays untouched.
//
// Same no-company-identity rule as the detail pages: only a generic label is
// ever shown, never a real company name or website.
//
// Chrome is the GLOBAL v6 nav + footer (same as for-founders / for-talent); the
// page hero/cards use the shared brand tokens (navy ink, white canvas).
// ─────────────────────────────────────────────────────────────────────────────

const c = getContent('en');
const siteUrl = 'https://purrfecthire.com';
const pageUrl = `${siteUrl}/roles`;

let roles: PublicRoleListItem[] = [];
try {
  roles = await fetchRoles();
} catch (err) {
  // Resilience: never fail the build on a backend outage — render empty state.
  console.warn(
    `[roles/index] build-time fetch failed, rendering empty state: ${(err as Error)?.message ?? err}`
  );
}

const cardsHtml = roles.map(roleCardHTML).join('');

const stats = [
  { value: String(roles.length), label: 'Open roles', id: 'rl-count' },
  { value: '100%', label: 'Remote-friendly' },
  { value: '< 4 wks', label: 'Avg. placement' },
];
---

<Layout
  title="Open roles | Purrfect Hire"
  description="Browse open roles at vetted YC, a16z and Sequoia startups hiring senior LatAm talent."
  lang="en"
  canonicalUrl={pageUrl}
>
  <style is:global>
    body { background-color: var(--bg); }
    html { scroll-behavior: smooth; }
    /* Nav is visible from the start on this page (no hero choreography). */
    .v6-nav { opacity: 1; }
  </style>

  <V6Nav content={c.nav} lang="en" />

  <main class="rl">
    <div class="rl__wrap">
      <!-- Branded page header -->
      <section class="rl__header">
        <span class="rl__eyebrow">
          <span class="rl__eyebrow-dot" aria-hidden="true"></span>
          Active searches · LatAm → YC, a16z &amp; Sequoia
        </span>
        <h1 class="rl__title">Open roles</h1>
        <p class="rl__sub">
          Curated, senior roles at vetted US startups. Companies stay confidential until your
          intro call. Apply once and we match you where you fit best.
        </p>

        <div class="rl__stats">
          {stats.map((s) => (
            <div class="rl__stat">
              <span class="rl__stat-value" id={s.id}>{s.value}</span>
              <span class="rl__stat-label">{s.label}</span>
            </div>
          ))}
        </div>
      </section>

      <!-- Loading skeleton — hidden by default (no-JS fallback shows the
           prerendered grid/empty state below immediately). The client
           refresh script un-hides this the instant it starts fetching, and
           hides the prerendered grid/empty state underneath it, so visitors
           always see a fresh loading state rather than briefly stale data. -->
      <section class="rl__skeleton" id="rl-skeleton" hidden aria-hidden="true">
        {Array.from({ length: 6 }).map(() => (
          <div class="rl__skel-card">
            <div class="rl-sk" style="width:40%;height:10px;"></div>
            <div class="rl-sk" style="width:80%;height:20px;margin-top:10px;"></div>
            <div class="rl-sk" style="width:60%;height:13px;margin-top:14px;"></div>
            <div class="rl-sk" style="width:45%;height:22px;border-radius:999px;margin-top:18px;"></div>
          </div>
        ))}
      </section>

      <!-- Roles grid — rendered from the single-source-of-truth card renderer
           (shared build-time + client-refresh). -->
      <section class="rl__grid" id="rl-grid" hidden={roles.length === 0} set:html={cardsHtml}></section>

      <!-- Empty state — shown when no open roles (or the build-time fetch
           failed). The client refresh hides this once it loads roles. -->
      <section class="rl__empty" id="rl-empty" hidden={roles.length > 0}>
        <h2 class="rl__empty-title">No open roles right now</h2>
        <p class="rl__empty-sub">
          New searches go live every week. Send us your profile and we'll reach out
          the moment something fits.
        </p>
        <a href="#apply" class="rl__empty-cta">Submit your profile</a>
      </section>

      <!-- Closing CTA -->
      <section class="rl__cta" id="apply">
        <h2 class="rl__cta-title">Don't see your role?</h2>
        <p class="rl__cta-sub">Send us your profile. We surface new searches every week.</p>
        <a href="mailto:talent@purrfecthire.com" class="rl__cta-btn">
          Submit your profile
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </section>
    </div>
  </main>

  <Footer content={c.footer} />
</Layout>

<script>
  // ── Client refresh (primary data path) ───────────────────────────────────
  // Fetch-on-load: show a visible skeleton immediately, re-fetch
  // /public/roles, then render fresh cards — so mid-week publishes (or any
  // ATS edit) appear without a rebuild. Defensive: on ANY failure, restore
  // whatever was already showing (prerendered grid or empty state) rather
  // than leaving a blank page. Uses the same card renderer as build time, so
  // markup never drifts.
  import { roleCardHTML, initRolesRefresh } from '../../lib/roles';

  initRolesRefresh({
    containerId: 'rl-grid',
    emptyId: 'rl-empty',
    skeletonId: 'rl-skeleton',
    countId: 'rl-count',
    render: roleCardHTML,
    stage: 'roles_list_refresh',
  });
</script>

<style is:global>
  /* ── Roles list — shared v6 brand tokens (navy ink, white canvas) ──────────
     Card classes (.rl__card*) are styled GLOBALLY because the markup is
     injected via set:html (build) / innerHTML (client refresh) and never
     receives Astro's scoped attribute. Keep them in sync with roleCardHTML(). */

  .rl {
    position: relative;
    z-index: 1;
    font-family: 'Schibsted Grotesk', system-ui, sans-serif;
    color: var(--text);
  }

  .rl__wrap {
    max-width: 72rem;
    margin-inline: auto;
    padding: clamp(7rem, 10vw, 9rem) clamp(1.25rem, 4vw, 2rem) 5rem;
  }

  /* Header */
  .rl__header { text-align: center; max-width: 44rem; margin: 0 auto 3rem; }
  .rl__eyebrow {
    display: inline-flex; align-items: center; gap: 8px;
    background: var(--bg);
    border: 1px solid var(--line); color: var(--muted);
    border-radius: var(--radius); padding: 7px 18px;
    font-size: 0.8125rem; font-weight: 500;
  }
  .rl__eyebrow-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--ink); }
  .rl__title {
    font-size: clamp(2.4rem, 5vw, 3.5rem); font-weight: 600; line-height: 1.08;
    letter-spacing: -0.03em; margin: 1.25rem 0 1rem; color: var(--ink);
  }
  .rl__sub {
    font-size: 1.0625rem; line-height: 1.65; color: var(--muted);
    margin: 0 auto; max-width: 38rem;
  }

  .rl__stats { display: flex; justify-content: center; flex-wrap: wrap; gap: 14px; margin-top: 2rem; }
  .rl__stat {
    background: var(--bg); border: 1px solid var(--line);
    border-radius: var(--radius); padding: 16px 28px; text-align: center;
  }
  .rl__stat-value { display: block; font-size: 1.6rem; font-weight: 600; color: var(--ink); line-height: 1; letter-spacing: -0.02em; }
  .rl__stat-label { display: block; margin-top: 6px; font-size: 0.6875rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.06em; color: var(--color-tertiary); }

  /* Grid */
  .rl__grid {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 18px; margin-bottom: 3rem;
  }
  @media (max-width: 768px) { .rl__grid { grid-template-columns: 1fr; } }
  .rl__grid[hidden] { display: none; }

  /* Loading skeleton — same grid as .rl__grid, shimmer placeholder cards
     sized to roughly match .rl__card so there's no layout jump on swap. */
  .rl__skeleton {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 18px; margin-bottom: 3rem;
  }
  @media (max-width: 768px) { .rl__skeleton { grid-template-columns: 1fr; } }
  .rl__skeleton[hidden] { display: none; }

  .rl__skel-card {
    background: var(--bg); border: 1px solid var(--line);
    border-radius: var(--radius); padding: 28px 26px 24px;
  }

  .rl-sk {
    border-radius: 6px;
    background: linear-gradient(90deg, var(--bg-soft) 25%, var(--line) 37%, var(--bg-soft) 63%);
    background-size: 400% 100%;
    animation: rl-shimmer 1.4s ease infinite;
  }

  @keyframes rl-shimmer {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .rl-sk { animation: none; background: var(--bg-soft); }
  }

  /* Card */
  .rl__card {
    position: relative; display: flex; flex-direction: column;
    background: var(--bg); border: 1px solid var(--line);
    border-radius: var(--radius); padding: 28px 26px 24px; overflow: hidden; text-decoration: none;
    transition: transform .2s ease, border-color .2s ease;
  }
  .rl__card:hover { transform: translateY(-4px); border-color: var(--ink); }
  .rl__card:focus-visible { outline: 2px solid var(--ink); outline-offset: 3px; }
  /* Single, subtle top accent — navy on hover */
  .rl__card-accent { position: absolute; top: 0; left: 0; right: 0; height: 3px; background: var(--line); transition: background .2s ease; }
  .rl__card:hover .rl__card-accent { background: var(--ink); }

  .rl__card-top { display: flex; align-items: center; justify-content: space-between; gap: 1rem; margin-bottom: 0.75rem; }
  .rl__card-company { font-size: 0.6875rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-tertiary); }
  .rl__card-posted {
    font-size: 0.6875rem; font-weight: 600; color: var(--muted);
    background: var(--bg-soft); border: 1px solid var(--line); border-radius: 999px; padding: 3px 11px;
  }

  .rl__card-title { font-size: 1.3rem; font-weight: 600; color: var(--ink); margin: 0 0 0.75rem; letter-spacing: -0.02em; line-height: 1.25; }

  .rl__card-meta { display: flex; align-items: center; flex-wrap: wrap; gap: 0.5rem; font-size: 0.875rem; color: var(--muted); margin-bottom: 1.1rem; }
  .rl__meta { display: inline-flex; align-items: center; gap: 6px; }
  .rl__meta svg { color: var(--color-tertiary); }
  .rl__meta--salary { font-weight: 600; color: var(--ink); }
  .rl__meta-dot { width: 3px; height: 3px; border-radius: 50%; background: var(--color-tertiary); }

  .rl__tags { display: flex; flex-wrap: wrap; gap: 7px; margin-bottom: 1.4rem; }
  .rl__tag {
    background: var(--color-accent-light); color: var(--ink); border: 1px solid transparent;
    border-radius: 999px; padding: 4px 12px; font-size: 0.75rem; font-weight: 500;
  }

  .rl__card-foot { display: flex; align-items: center; justify-content: space-between; gap: 1rem; margin-top: auto; }
  .rl__badges { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }
  .rl__yc {
    display: inline-flex; align-items: center; gap: 5px; background: #FF6B00; color: #fff;
    border-radius: 999px; padding: 3px 11px 3px 4px; font-size: 0.75rem; font-weight: 700;
  }
  .rl__yc-mark {
    display: inline-flex; align-items: center; justify-content: center; width: 17px; height: 17px;
    border-radius: 4px; background: #fff; color: #FF6B00; font-weight: 800; font-size: 0.75rem;
  }
  .rl__english {
    background: var(--bg-soft); border: 1px solid var(--line); color: var(--muted);
    border-radius: 999px; padding: 3px 12px; font-size: 0.75rem; font-weight: 500;
  }
  .rl__view {
    display: inline-flex; align-items: center; gap: 5px; font-size: 0.875rem; font-weight: 600;
    color: var(--ink);
  }
  .rl__view svg { color: var(--ink); transition: transform .2s; }
  .rl__card:hover .rl__view svg { transform: translateX(3px); }

  /* Empty state */
  .rl__empty {
    text-align: center; padding: clamp(3rem, 8vw, 5rem) 1.5rem;
    background: var(--bg-soft); border: 1px solid var(--line);
    border-radius: var(--radius); margin-bottom: 3rem;
    display: flex; flex-direction: column; align-items: center; gap: 0.7rem;
  }
  .rl__empty[hidden] { display: none; }
  .rl__empty-title { font-size: clamp(1.4rem, 3vw, 1.9rem); font-weight: 600; letter-spacing: -0.02em; margin: 0; color: var(--ink); }
  .rl__empty-sub { font-size: 1rem; color: var(--muted); margin: 0 0 0.6rem; max-width: 34rem; line-height: 1.6; }
  .rl__empty-cta {
    display: inline-flex; align-items: center; gap: 8px;
    background: var(--ink); color: #fff;
    border-radius: var(--radius); padding: 12px 24px; font-size: 0.9375rem; font-weight: 500; text-decoration: none;
    transition: background-color .2s ease;
  }
  .rl__empty-cta:hover { background: #1E1D47; }

  /* Closing CTA */
  .rl__cta {
    text-align: center; padding: clamp(2.5rem, 6vw, 3.5rem) 1.5rem;
    background: var(--dark);
    border-radius: var(--radius);
    display: flex; flex-direction: column; align-items: center; gap: 0.7rem;
  }
  .rl__cta-title { font-size: clamp(1.4rem, 3vw, 1.9rem); font-weight: 600; letter-spacing: -0.02em; margin: 0; color: var(--on-dark); }
  .rl__cta-sub { font-size: 1rem; color: rgba(243, 239, 230, 0.8); margin: 0 0 0.6rem; }
  .rl__cta-btn {
    display: inline-flex; align-items: center; gap: 8px;
    background: var(--on-dark); color: var(--dark);
    border-radius: var(--radius); padding: 14px 28px; font-size: 0.9375rem; font-weight: 600; text-decoration: none;
    transition: opacity .2s ease;
  }
  .rl__cta-btn:hover { opacity: 0.9; }
  .rl__cta-btn svg { transition: transform .2s; }
  .rl__cta-btn:hover svg { transform: translateX(3px); }
</style>
