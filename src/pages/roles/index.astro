---
import Layout from '../../layouts/Layout.astro';

// ─────────────────────────────────────────────────────────────────────────────
// Roles index — list of open positions (FAKE sample data).
// Same no-company-identity rule as the detail pages: only a generic label is
// ever shown, never a real company name or website.
// Each card links to a detail page (/roles/1 is the live sample).
// ─────────────────────────────────────────────────────────────────────────────

interface RoleListItem {
  href: string;
  title: string;
  companyLabel: string;
  location: string;
  modality: string;
  employmentType: string;
  skills: string[];
  englishLevel?: string;
  yc?: boolean;
  posted: string;
}

const roles: RoleListItem[] = [
  {
    href: '/roles/1',
    title: 'Senior AI / Backend Engineer',
    companyLabel: 'Confidential Company',
    location: 'Colombia · LatAm',
    modality: 'Remote',
    employmentType: 'Full-time',
    skills: ['Python', 'TypeScript', 'LLMs', 'AWS'],
    englishLevel: 'C1',
    yc: true,
    posted: 'New',
  },
  {
    href: '/roles/1',
    title: 'Founding Frontend Engineer',
    companyLabel: 'Confidential Company',
    location: 'LatAm',
    modality: 'Remote',
    employmentType: 'Full-time',
    skills: ['React', 'TypeScript', 'Tailwind', 'Next.js'],
    englishLevel: 'C1',
    yc: true,
    posted: 'New',
  },
  {
    href: '/roles/1',
    title: 'Product Designer (Senior)',
    companyLabel: 'Confidential Company',
    location: 'Mexico · Colombia',
    modality: 'Hybrid',
    employmentType: 'Full-time',
    skills: ['Figma', 'Design Systems', 'Prototyping'],
    englishLevel: 'B2',
    posted: '3d ago',
  },
  {
    href: '/roles/1',
    title: 'DevOps / Platform Engineer',
    companyLabel: 'Confidential Company',
    location: 'Argentina · LatAm',
    modality: 'Remote',
    employmentType: 'Full-time',
    skills: ['Kubernetes', 'Terraform', 'AWS', 'Go'],
    englishLevel: 'C1',
    yc: true,
    posted: '5d ago',
  },
  {
    href: '/roles/1',
    title: 'Data Engineer',
    companyLabel: 'Confidential Company',
    location: 'Colombia · Brazil',
    modality: 'Remote',
    employmentType: 'Full-time',
    skills: ['Python', 'dbt', 'Snowflake', 'Airflow'],
    englishLevel: 'B2',
    posted: '1w ago',
  },
  {
    href: '/roles/1',
    title: 'Founding Account Executive',
    companyLabel: 'Confidential Company',
    location: 'LatAm · US time zones',
    modality: 'Remote',
    employmentType: 'Full-time',
    skills: ['B2B SaaS', 'Outbound', 'Pipeline'],
    englishLevel: 'C1',
    yc: true,
    posted: '1w ago',
  },
];

const stats = [
  { value: String(roles.length), label: 'Open roles' },
  { value: '100%', label: 'Remote-friendly' },
  { value: '< 4 wks', label: 'Avg. placement' },
];
---

<Layout title="Open roles — Purrfect Hire" description="Browse open roles at vetted YC & a16z startups hiring senior LatAm talent." lang="en">
  <style is:global>
    body { background-color: #F8F7FF; }
    html { scroll-behavior: smooth; }
  </style>

  <!-- Aurora canvas -->
  <div class="rl-canvas" aria-hidden="true">
    <span class="rl-canvas__blob rl-canvas__blob--1"></span>
    <span class="rl-canvas__blob rl-canvas__blob--2"></span>
  </div>

  <div class="rl">
    <!-- Slim top bar -->
    <header class="rl__bar">
      <a href="/" class="rl__brand">Purrfect&nbsp;Hire</a>
      <nav class="rl__bar-nav">
        <a href="/" class="rl__bar-link">Home</a>
        <a href="#apply" class="rl__bar-cta">Get placed</a>
      </nav>
    </header>

    <main class="rl__main">
      <!-- Header -->
      <section class="rl__header">
        <span class="rl__eyebrow">
          <span class="rl__eyebrow-dot" aria-hidden="true"></span>
          Active searches · LatAm → YC &amp; a16z
        </span>
        <h1 class="rl__title">Open roles</h1>
        <p class="rl__sub">
          Curated, senior roles at vetted US startups. Companies stay confidential until your
          intro call — apply once and we match you where you fit best.
        </p>

        <div class="rl__stats">
          {stats.map((s) => (
            <div class="rl__stat">
              <span class="rl__stat-value">{s.value}</span>
              <span class="rl__stat-label">{s.label}</span>
            </div>
          ))}
        </div>
      </section>

      <!-- Roles grid -->
      <section class="rl__grid">
        {roles.map((r) => (
          <a href={r.href} class="rl__card">
            <div class="rl__card-accent" aria-hidden="true"></div>

            <div class="rl__card-top">
              <span class="rl__card-company">{r.companyLabel}</span>
              <span class="rl__card-posted">{r.posted}</span>
            </div>

            <h2 class="rl__card-title">{r.title}</h2>

            <div class="rl__card-meta">
              <span class="rl__meta">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                  <path d="M7 1.5C4.51 1.5 2.5 3.51 2.5 6c0 3.75 4.5 6.5 4.5 6.5S11.5 9.75 11.5 6c0-2.49-2.01-4.5-4.5-4.5Zm0 6.5a2 2 0 1 1 0-4 2 2 0 0 1 0 4Z" fill="currentColor"/>
                </svg>
                {r.location}
              </span>
              <span class="rl__meta-dot" aria-hidden="true"></span>
              <span class="rl__meta">{r.modality} · {r.employmentType}</span>
            </div>

            <div class="rl__tags">
              {r.skills.map((s) => <span class="rl__tag">{s}</span>)}
            </div>

            <div class="rl__card-foot">
              <div class="rl__badges">
                {r.yc && (
                  <span class="rl__yc">
                    <span class="rl__yc-mark" aria-hidden="true">Y</span>
                    YC
                  </span>
                )}
                {r.englishLevel && <span class="rl__english">English {r.englishLevel}</span>}
              </div>
              <span class="rl__view">
                View role
                <svg width="15" height="15" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </div>
          </a>
        ))}
      </section>

      <!-- Closing CTA -->
      <section class="rl__cta" id="apply">
        <h2 class="rl__cta-title">Don't see your role?</h2>
        <p class="rl__cta-sub">Send us your profile — we surface new searches every week.</p>
        <a href="mailto:talent@purrfecthire.com" class="rl__cta-btn">
          Submit your profile
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </section>
    </main>

    <footer class="rl__footer">
      <span>Purrfect Hire</span>
      <span class="rl__footer-note">Company details are shared after your intro call.</span>
    </footer>
  </div>
</Layout>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');

  :root {
    --rl-indigo: #4F46E5;
    --rl-cyan: #0891B2;
    --rl-emerald: #059669;
    --rl-ink: #111827;
    --rl-muted: #6B7280;
    --rl-subtle: #9CA3AF;
  }

  /* Aurora canvas */
  .rl-canvas { position: fixed; inset: 0; z-index: 0; pointer-events: none; overflow: hidden; }
  .rl-canvas__blob { position: absolute; border-radius: 50%; filter: blur(130px); }
  .rl-canvas__blob--1 {
    width: 660px; height: 660px; top: -180px; right: -160px;
    background: radial-gradient(circle, rgba(79, 70, 229, 0.20) 0%, transparent 70%);
  }
  .rl-canvas__blob--2 {
    width: 560px; height: 560px; bottom: 6%; left: -180px;
    background: radial-gradient(circle, rgba(8, 145, 178, 0.15) 0%, transparent 70%);
  }

  .rl {
    position: relative;
    z-index: 1;
    font-family: 'Plus Jakarta Sans', Inter, sans-serif;
    color: var(--rl-ink);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  /* Top bar */
  .rl__bar {
    position: sticky; top: 0; z-index: 30;
    display: flex; align-items: center; justify-content: space-between;
    padding: 14px clamp(1.25rem, 4vw, 2.5rem);
    background: rgba(248, 247, 255, 0.78);
    backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid rgba(79, 70, 229, 0.08);
  }
  .rl__brand { font-weight: 800; font-size: 1.05rem; letter-spacing: -0.02em; color: var(--rl-ink); text-decoration: none; }
  .rl__bar-nav { display: flex; align-items: center; gap: 1.25rem; }
  .rl__bar-link { font-size: 14px; font-weight: 500; color: var(--rl-muted); text-decoration: none; transition: color .15s; }
  .rl__bar-link:hover { color: var(--rl-indigo); }
  .rl__bar-cta {
    display: inline-flex; align-items: center;
    background: linear-gradient(135deg, #4F46E5 0%, #0891B2 100%);
    color: #fff; border-radius: 999px; padding: 9px 20px; font-size: 14px; font-weight: 600;
    text-decoration: none; box-shadow: 0 4px 16px rgba(79, 70, 229, 0.3); transition: transform .15s;
  }
  .rl__bar-cta:hover { transform: translateY(-1px); }

  /* Main */
  .rl__main {
    flex: 1; width: 100%; max-width: 72rem; margin-inline: auto;
    padding: clamp(2.5rem, 6vw, 4rem) clamp(1.25rem, 4vw, 2rem) 4rem;
  }

  /* Header */
  .rl__header { text-align: center; max-width: 42rem; margin: 0 auto 3rem; }
  .rl__eyebrow {
    display: inline-flex; align-items: center; gap: 8px;
    background: linear-gradient(135deg, rgba(79, 70, 229, 0.1) 0%, rgba(8, 145, 178, 0.1) 100%);
    border: 1px solid rgba(79, 70, 229, 0.22); color: #4F46E5;
    border-radius: 999px; padding: 7px 18px; font-size: 13px; font-weight: 600;
  }
  .rl__eyebrow-dot { width: 6px; height: 6px; border-radius: 50%; background: linear-gradient(135deg, #4F46E5, #0891B2); }
  .rl__title {
    font-size: clamp(2.2rem, 5vw, 3.5rem); font-weight: 800; line-height: 1.08;
    letter-spacing: -0.03em; margin: 1.25rem 0 1rem;
    background: linear-gradient(135deg, #4F46E5 0%, #0891B2 50%, #059669 100%);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  }
  .rl__sub { font-size: 1.0625rem; line-height: 1.65; color: var(--rl-muted); margin: 0 auto; max-width: 36rem; }

  .rl__stats { display: flex; justify-content: center; flex-wrap: wrap; gap: 14px; margin-top: 2rem; }
  .rl__stat {
    background: rgba(255, 255, 255, 0.82); border: 1px solid rgba(79, 70, 229, 0.15);
    border-radius: 16px; padding: 16px 28px; text-align: center;
    backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
  }
  .rl__stat-value { display: block; font-size: 1.6rem; font-weight: 700; color: var(--rl-indigo); line-height: 1; letter-spacing: -0.02em; }
  .rl__stat-label { display: block; margin-top: 6px; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--rl-subtle); }

  /* Grid */
  .rl__grid {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; margin-bottom: 3rem;
  }
  @media (max-width: 768px) { .rl__grid { grid-template-columns: 1fr; } }

  .rl__card {
    position: relative; display: flex; flex-direction: column;
    background: rgba(255, 255, 255, 0.85); border: 1.5px solid rgba(229, 231, 235, 0.9);
    border-radius: 20px; padding: 26px 24px 22px; overflow: hidden; text-decoration: none;
    backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
    transition: transform .25s ease, box-shadow .25s ease, border-color .25s ease;
  }
  .rl__card:hover { transform: translateY(-4px); box-shadow: 0 16px 48px rgba(79, 70, 229, 0.12); border-color: rgba(79, 70, 229, 0.25); }
  .rl__card-accent { position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, #4F46E5 0%, #0891B2 100%); }
  .rl__card:nth-child(3n+2) .rl__card-accent { background: linear-gradient(90deg, #0891B2 0%, #06B6D4 100%); }
  .rl__card:nth-child(3n) .rl__card-accent { background: linear-gradient(90deg, #059669 0%, #0891B2 100%); }

  .rl__card-top { display: flex; align-items: center; justify-content: space-between; gap: 1rem; margin-bottom: 0.75rem; }
  .rl__card-company { font-size: 11.5px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--rl-subtle); }
  .rl__card-posted {
    font-size: 11px; font-weight: 700; color: var(--rl-indigo);
    background: rgba(79, 70, 229, 0.08); border-radius: 999px; padding: 3px 10px;
  }

  .rl__card-title { font-size: 1.3rem; font-weight: 700; color: var(--rl-ink); margin: 0 0 0.75rem; letter-spacing: -0.02em; line-height: 1.25; }

  .rl__card-meta { display: flex; align-items: center; flex-wrap: wrap; gap: 0.5rem; font-size: 13.5px; color: var(--rl-muted); margin-bottom: 1.1rem; }
  .rl__meta { display: inline-flex; align-items: center; gap: 6px; }
  .rl__meta svg { color: var(--rl-indigo); opacity: 0.8; }
  .rl__meta-dot { width: 3px; height: 3px; border-radius: 50%; background: var(--rl-subtle); }

  .rl__tags { display: flex; flex-wrap: wrap; gap: 7px; margin-bottom: 1.4rem; }
  .rl__tag {
    background: rgba(79, 70, 229, 0.08); color: var(--rl-indigo); border: 1px solid rgba(79, 70, 229, 0.15);
    border-radius: 6px; padding: 3px 10px; font-size: 12px; font-weight: 600;
  }

  .rl__card-foot { display: flex; align-items: center; justify-content: space-between; gap: 1rem; margin-top: auto; }
  .rl__badges { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }
  .rl__yc {
    display: inline-flex; align-items: center; gap: 5px; background: #FF6B00; color: #fff;
    border-radius: 999px; padding: 3px 11px 3px 4px; font-size: 12px; font-weight: 700;
  }
  .rl__yc-mark {
    display: inline-flex; align-items: center; justify-content: center; width: 17px; height: 17px;
    border-radius: 4px; background: #fff; color: #FF6B00; font-weight: 800; font-size: 12px;
  }
  .rl__english {
    background: rgba(79, 70, 229, 0.06); border: 1px solid rgba(79, 70, 229, 0.16); color: var(--rl-indigo);
    border-radius: 999px; padding: 3px 11px; font-size: 12px; font-weight: 600;
  }
  .rl__view {
    display: inline-flex; align-items: center; gap: 5px; font-size: 14px; font-weight: 600;
    background: linear-gradient(135deg, #4F46E5 0%, #0891B2 100%);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  }
  .rl__view svg { color: #4F46E5; transition: transform .2s; }
  .rl__card:hover .rl__view svg { transform: translateX(3px); }

  /* Closing CTA */
  .rl__cta {
    text-align: center; padding: clamp(2.5rem, 6vw, 3.5rem) 1.5rem;
    background: linear-gradient(135deg, rgba(79, 70, 229, 0.08) 0%, rgba(8, 145, 178, 0.08) 100%);
    border: 1.5px solid rgba(79, 70, 229, 0.16); border-radius: 24px;
    display: flex; flex-direction: column; align-items: center; gap: 0.7rem;
  }
  .rl__cta-title { font-size: clamp(1.4rem, 3vw, 1.9rem); font-weight: 800; letter-spacing: -0.02em; margin: 0; }
  .rl__cta-sub { font-size: 1rem; color: var(--rl-muted); margin: 0 0 0.6rem; }
  .rl__cta-btn {
    display: inline-flex; align-items: center; gap: 8px;
    background: linear-gradient(135deg, #4F46E5 0%, #0891B2 100%); color: #fff;
    border-radius: 999px; padding: 14px 28px; font-size: 15px; font-weight: 600; text-decoration: none;
    box-shadow: 0 4px 20px rgba(79, 70, 229, 0.35); transition: transform .15s, box-shadow .2s;
  }
  .rl__cta-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(79, 70, 229, 0.45); }
  .rl__cta-btn svg { transition: transform .2s; }
  .rl__cta-btn:hover svg { transform: translateX(3px); }

  /* Footer */
  .rl__footer {
    display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem;
    max-width: 72rem; margin-inline: auto; width: 100%;
    padding: 2rem clamp(1.25rem, 4vw, 2rem); border-top: 1px solid rgba(79, 70, 229, 0.08);
    font-size: 13px; font-weight: 600; color: var(--rl-muted);
  }
  .rl__footer-note { font-weight: 400; color: var(--rl-subtle); }
</style>
