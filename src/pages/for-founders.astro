---
// ── /for-founders ────────────────────────────────────────────────────────
// Dedicated landing destination for founders/hiring decision-makers who click
// "For founders" from the main site. Single-audience: leads with real
// placement proof, then metrics, clients, why-culture, the engine, founder
// testimonials, and an FAQ — no talent-side content to dilute the message.
//
// Design is an ISOLATED replica of the V6 visual language (aurora background,
// V6 nav, warm-cream canvas, purple accent). It does NOT share the final
// design system — kept self-contained until a direction is approved.
import Layout from '../layouts/Layout.astro';
import V6Nav from '../components/v6/V6Nav.astro';
import FoundersHero from '../components/founders/FoundersHero.astro';
import FoundersBody from '../components/founders/FoundersBody.astro';
import V6FaqAccordion from '../components/v6/V6FaqAccordion.astro';
import Footer from '../components/Footer.astro';
import { getContent } from '../content/index';

const c = getContent('en');
const siteUrl = 'https://purrfecthire.com';
const pageUrl = `${siteUrl}/for-founders`;

const meta = {
  title: 'For Founders. Senior hires who clear your bar and stay | Purrfect Hire',
  description:
    'Purrfect Hire places senior LATAM talent at YC, a16z and Sequoia startups. 160+ placements, 80% still in seat at 2+ years, first hire in under 4 weeks. Real proof, not promises.',
};

// Founder-facing FAQ — facts already stated on the site (no fabrication).
const faqs = [
  {
    q: 'How fast can Purrfect Hire make a hire?',
    a: 'Typically under four weeks to a first placement. Because we map how your team actually evaluates before opening the pipeline, candidates arrive already calibrated to your bar, so you spend less time screening and more time deciding.',
  },
  {
    q: 'Why hire for culture fit instead of just skills?',
    a: '46% of new hires fail within 18 months, and 89% of those failures come from culture and attitude misalignment, not a skills gap. Starting with fit, rather than treating it as a final check, is what keeps 80% of our placements in seat past two years.',
  },
  {
    q: 'What kind of companies do you place talent at?',
    a: 'Seed to Series A startups backed by Y Combinator, Andreessen Horowitz (a16z), and Sequoia, where a wrong hire costs months of runway. We have completed 160+ placements across engineering, AI/ML, and go-to-market roles.',
  },
  {
    q: 'How is this different from a sourcing tool or an agency?',
    a: 'Tools surface profiles; agencies forward résumés. We have been inside 160+ startups learning where hires actually break, and we train the talent we place against that signal before they ever meet you. It is a conversation, not a keyword filter.',
  },
];

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Purrfect Hire',
  url: siteUrl,
  logo: `${siteUrl}/logos/ph_imagotipo.png`,
  description: meta.description,
  sameAs: ['https://www.linkedin.com/company/purrfect-hire'],
  areaServed: 'Latin America',
  knowsAbout: ['Technical recruiting', 'Startup hiring', 'Culture-fit assessment', 'YC, a16z and Sequoia startups'],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<Layout title={meta.title} description={meta.description} lang="en" canonicalUrl={pageUrl}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <V6Nav content={c.nav} lang="en" />
  <main style="position: relative; z-index: 1;">
    <FoundersHero />
    <FoundersBody content={c} />
    <section id="faq" class="ff-faq">
      <div class="ff-faq__container">
        <V6FaqAccordion faqs={faqs} heading="Common questions" accent="founders" />
      </div>
    </section>
  </main>
  <Footer content={c.footer} />
</Layout>

<style is:global>
  html { scroll-behavior: smooth; }

  /* Nav is visible from the start on this page (no 5s hero choreography). */
  .v6-nav { opacity: 1; }

  /* Flat white page background */
  body { background: var(--bg); }

  /* FAQ section wrapper around the shared accordion */
  .ff-faq { position: relative; z-index: 1; padding-block: 6rem; }
  .ff-faq__container { max-width: 52rem; margin-inline: auto; padding-inline: 2rem; }
  @media (max-width: 640px) { .ff-faq { padding-block: 4rem; } .ff-faq__container { padding-inline: 1rem; } }
</style>
